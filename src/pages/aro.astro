---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const features = [
  { title: 'Zero Backend', desc: 'One HTML file. No server. No database. No cloud. Open it in any browser and start building. Your data never leaves your machine.' },
  { title: 'Investor-Ready', desc: 'Built for pitch decks, board presentations, and funding rounds. Clean typography, transitions, and layouts.' },
  { title: 'Fully Offline', desc: 'Works on a plane. Works in a cafe with no wifi. Works in a bunker. The file IS the application — save it to a USB drive and present anywhere.' },
  { title: 'No Subscription', desc: 'Pay once (or download free). No monthly fees. No "your trial expired." No upsell. No account required. Ever.' },
  { title: 'Secure by Default', desc: 'No telemetry. No analytics. No tracking. Your pitch deck content stays on your hard drive. Good for stealth-mode founders.' },
  { title: 'Export Anywhere', desc: 'Present directly from the file, export to PDF, or screenshot slides. Works in Chrome, Firefox, Safari, Edge. Any device, any OS.' },
];

const versions = [
  {
    name: 'Aro Pro — The Pitch Engine',
    version: '2026',
    size: '227 KB',
    price: '$29 CAD',
    desc: 'The flagship version. Neon Brutalism design system. Presenter mode. Slide transitions. Full-featured pitch deck builder for founders and operators.',
    file: '/downloads/aro-pitch-engine.html',
    accent: '#EC4899',
    paid: true,
  },
  {
    name: 'Deck Builder Classic',
    version: 'Free',
    size: '95 KB',
    price: 'Free',
    desc: 'The original deck builder. Simpler interface, lighter weight. Still fully functional for quick presentations and internal decks.',
    file: '/downloads/deck-builder-classic.html',
    accent: '#8B5CF6',
    paid: false,
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Aro — The Pitch Engine',
  alternateName: 'DeckForge',
  description: 'Zero-backend pitch deck builder. One HTML file, no server, no cloud. Build investor-ready presentations offline. Your data never leaves your machine.',
  url: 'https://3d3d.ca/aro',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any (browser-based)',
  fileSize: '227 KB',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CAD', description: 'Free download. Donations welcome.' },
  author: { '@type': 'Organization', name: '3D3D Atlantic Cooperative', url: 'https://3d3d.ca' },
  keywords: 'pitch deck builder, presentation software, offline, zero-backend, investor presentation, startup pitch, no cloud',
};
---

<BaseLayout title="Aro — The Pitch Engine | Zero-Backend Deck Builder | 3D3D" description="Build investor-ready pitch decks in one HTML file. No server, no cloud, no subscription. 227 KB. Fully offline. Your data never leaves your machine." activePath="/aro" schema={schema}>

  <main class="hp-home">

    <!-- Hero -->
    <section class="hp-section" style="--section-accent: #40C4C4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim" style="background: linear-gradient(135deg, rgba(15,12,41,0.9), rgba(40,10,35,0.7));"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Software', href: '/software'}, {label: 'Aro'}]} />
            <p class="hp-card__eyebrow mt-4" style="color: #EC4899;">Zero-Backend Pitch Deck Builder</p>
            <h1 class="hp-card__title mt-2 mb-4">Aro — The Pitch Engine</h1>
            <p class="hp-card__copy hp-card__copy--lead" style="max-width: 38rem;">
              One HTML file. No server. No cloud. No subscription. Build investor-ready pitch decks that never leave your machine. 227 KB is all it takes.
            </p>

            <div class="aro-stats mt-6">
              <div class="aro-stat"><span class="aro-stat__val">227 KB</span><span class="aro-stat__label">Total Size</span></div>
              <div class="aro-stat"><span class="aro-stat__val">1</span><span class="aro-stat__label">File</span></div>
              <div class="aro-stat"><span class="aro-stat__val">0</span><span class="aro-stat__label">Dependencies</span></div>
              <div class="aro-stat"><span class="aro-stat__val">$0</span><span class="aro-stat__label">Monthly Fee</span></div>
            </div>

            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="/downloads/aro-pitch-engine.html" download class="hp-cta hp-cta--accent" style="background: #EC4899; border-color: #EC4899;">Download Aro (Free)</a>
              <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer" class="hp-cta hp-cta--glass">Donate (Ko-fi)</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Features -->
    <section class="hp-section" style="--section-accent: #E84A8A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow" style="color: #8B5CF6;">Why Aro</p>
            <h2 class="hp-card__title mt-2 mb-6">No Account. No Cloud. No Tricks.</h2>

            <div class="aro-features">
              {features.map((f) => (
                <div class="aro-feature">
                  <h3 class="aro-feature__title">{f.title}</h3>
                  <p class="aro-feature__desc">{f.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Downloads -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow" style="color: #EC4899;">Download</p>
            <h2 class="hp-card__title mt-2 mb-6">Get Aro</h2>

            <div class="aro-downloads">
              {versions.map((v) => (
                <div class="aro-download" style={`border-color: ${v.accent}30;`}>
                  <div class="aro-download__header">
                    <h3 class="aro-download__name" style={`color: ${v.accent};`}>{v.name}</h3>
                    <div class="aro-download__meta">
                      <span class="aro-download__version">{v.version}</span>
                      <span class="aro-download__size">{v.size}</span>
                      <span class="aro-download__price" style={v.paid ? `color: ${v.accent};` : 'color: #4ADE80;'}>{v.price}</span>
                    </div>
                  </div>
                  <p class="aro-download__desc">{v.desc}</p>
                  {v.paid ? (
                    <div class="aro-download__actions">
                      <a href={v.file} download class="hp-cta hp-cta--accent aro-dl-btn" style={`background: ${v.accent}; border-color: ${v.accent};`}>Download Free</a>
                      <span class="aro-download__or">Free download — support on <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer" style="color: var(--section-accent); text-decoration: underline;">Ko-fi</a></span>
                    </div>
                  ) : (
                    <a href={v.file} download class="hp-cta hp-cta--glass aro-dl-btn">Download Free ({v.size})</a>
                  )}
                </div>
              ))}
            </div>

            <div class="aro-donate mt-6">
              <p class="hp-card__eyebrow" style="color: #F59E0B;">Support the Work</p>
              <p class="hp-card__copy mt-2 mb-4">
                Aro is free. If it helped you raise money, close a deal, or win a meeting — consider donating. Every dollar goes directly to keeping these tools open source and free.
              </p>
              <div class="aro-donate-options">
                <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer" class="hp-cta hp-cta--accent" style="background: #F59E0B; border-color: #F59E0B; color: #0F0D24;">Ko-fi (Card/PayPal/Stripe)</a>
                <a href="mailto:info@3d3d.ca?subject=Donation%20-%20Aro%20Pitch%20Engine&body=I%27d%20like%20to%20donate%20via%20e-Transfer.%20Amount:%20" class="hp-cta hp-cta--glass">E-Transfer (info@3d3d.ca)</a>
                <a href="/pricing" class="hp-cta hp-cta--glass">All Payment Options</a>
              </div>
            </div>

            <div class="mt-8">
              <PageNextActions actions={[
                {label: 'All Software', href: '/software', description: 'Everything built by 3D3D.', accent: 'teal'},
                {label: 'ORA Runtime', href: '/ora', description: 'The AI runtime behind the 3D3D ecosystem.', accent: 'magenta'},
              ]} />
            </div>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .aro-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.6rem;
  }
  @media (max-width: 480px) { .aro-stats { grid-template-columns: repeat(2, 1fr); } }
  .aro-stat {
    text-align: center;
    padding: 0.8rem 0.5rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(236, 72, 153, 0.15);
    border-radius: 2px;
  }
  .aro-stat__val {
    display: block;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: #EC4899;
  }
  .aro-stat__label {
    font-family: var(--font-tech);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.35);
  }

  .aro-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(240px, 100%), 1fr));
    gap: 0.7rem;
  }
  .aro-feature {
    padding: 1.1rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(139, 92, 246, 0.12);
    border-radius: 2px;
  }
  .aro-feature__title {
    margin: 0 0 0.4rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.9);
  }
  .aro-feature__desc { margin: 0; font-size: 0.78rem; line-height: 1.6; color: rgba(246, 247, 250, 0.42); }

  .aro-downloads { display: grid; gap: 0.8rem; }
  .aro-download {
    padding: 1.4rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid;
    border-radius: 2px;
  }
  .aro-download__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .aro-download__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
  }
  .aro-download__meta { display: flex; gap: 0.6rem; }
  .aro-download__version, .aro-download__size {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    color: rgba(246, 247, 250, 0.35);
    padding: 0.15rem 0.4rem;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 2px;
  }
  .aro-download__desc { margin: 0 0 1rem; font-size: 0.8rem; line-height: 1.6; color: rgba(246, 247, 250, 0.45); }
  .aro-download__price {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
  }
  .aro-download__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem; }
  .aro-download__or { font-size: 0.68rem; color: rgba(246, 247, 250, 0.3); font-style: italic; }
  .aro-dl-btn { width: fit-content; }

  .aro-donate {
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: 2px;
  }
  .aro-donate-options { display: flex; flex-wrap: wrap; gap: 0.6rem; }
</style>
