---
const FORM_ENDPOINT = 'https://formspree.io/f/mldlydbl';
---

<dialog id="dlg-subscribe" class="subscribe-dialog">
  <div class="subscribe-dialog__shell">
    <button type="button" class="subscribe-dialog__close" data-subscribe-close aria-label="Close subscribe dialog">&#x2715;</button>
    <div class="subscribe-dialog__content">
      <p class="subscribe-dialog__eyebrow">Stay in the Loop</p>
      <h3 class="subscribe-dialog__title">Build updates. Material guides. First access.</h3>
      <p class="subscribe-dialog__copy">
        Real workshop notes, new product drops, and field deployment stories — delivered when there's something worth reading.
      </p>
      <form action={FORM_ENDPOINT} method="POST" class="subscribe-dialog__form" data-subscribe-form>
        <input type="hidden" name="_subject" value="New Subscriber | 3D3D" />
        <input type="hidden" name="source" value="subscribe-modal" />
        <div class="subscribe-dialog__input-row">
          <input
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            aria-label="Email address"
            class="subscribe-dialog__input"
          />
          <button type="submit" class="subscribe-dialog__submit">Subscribe</button>
        </div>
        <p class="subscribe-dialog__note">No spam. Unsubscribe anytime. CASL compliant.</p>
      </form>
      <div class="subscribe-dialog__success" data-subscribe-success hidden>
        <p class="subscribe-dialog__success-text">You're in. Watch your inbox.</p>
      </div>
    </div>
  </div>
</dialog>

<style>
  .subscribe-dialog {
    border: none;
    background: transparent;
    padding: 0;
    max-width: min(480px, calc(100vw - 2rem));
    width: 100%;
    border-radius: 2px;
    overflow: visible;
  }

  .subscribe-dialog::backdrop {
    background: rgba(10, 11, 12, 0.7);
    backdrop-filter: blur(6px);
  }

  .subscribe-dialog__shell {
    position: relative;
    background: rgba(10, 11, 12, 0.88);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 3px solid rgba(64, 196, 196, 0.35);
    border-radius: 2px;
    padding: 2.5rem;
    color: #F6F7FA;
  }

  .subscribe-dialog__close {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: rgba(246, 247, 250, 0.4);
    font-size: 0.9rem;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .subscribe-dialog__close:hover {
    color: #F6F7FA;
  }

  .subscribe-dialog__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-tech);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #40C4C4;
  }

  .subscribe-dialog__title {
    margin: 0 0 0.6rem;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1rem + 1vw, 1.6rem);
    line-height: 1.15;
  }

  .subscribe-dialog__copy {
    margin: 0 0 1.25rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(246, 247, 250, 0.6);
  }

  .subscribe-dialog__input-row {
    display: flex;
    gap: 0.5rem;
  }

  .subscribe-dialog__input {
    flex: 1;
    padding: 0.7rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 2px solid rgba(255, 255, 255, 0.12);
    border-radius: 2px;
    color: #F6F7FA;
    font-family: var(--font-body);
    font-size: 0.88rem;
    transition: border-color 0.2s ease;
  }

  .subscribe-dialog__input:focus {
    outline: none;
    border-color: #40C4C4;
  }

  .subscribe-dialog__input::placeholder {
    color: rgba(246, 247, 250, 0.25);
  }

  .subscribe-dialog__submit {
    padding: 0.7rem 1.5rem;
    background: #40C4C4;
    border: 3px solid #40C4C4;
    border-radius: 2px;
    color: #0A0B0C;
    font-family: var(--font-tech);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .subscribe-dialog__submit:hover {
    background: #53D3D3;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(64, 196, 196, 0.3);
  }

  .subscribe-dialog__note {
    margin: 0.6rem 0 0;
    font-family: var(--font-tech);
    font-size: 0.62rem;
    color: rgba(246, 247, 250, 0.3);
    letter-spacing: 0.04em;
  }

  .subscribe-dialog__success-text {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.92rem;
    font-weight: 600;
    color: #40C4C4;
  }

  @media (max-width: 480px) {
    .subscribe-dialog__shell {
      padding: 1.8rem 1.2rem;
    }

    .subscribe-dialog__input-row {
      flex-direction: column;
    }
  }
</style>

<script>
  (() => {
    const dialog = document.getElementById('dlg-subscribe');
    if (!(dialog instanceof HTMLDialogElement)) return;

    const closeBtn = dialog.querySelector('[data-subscribe-close]');
    const form = dialog.querySelector('[data-subscribe-form]');
    const success = dialog.querySelector('[data-subscribe-success]');
    const STORAGE_KEY = '3d3d_subscribed';

    const isSubscribed = () => {
      try { return localStorage.getItem(STORAGE_KEY) === 'true'; } catch { return false; }
    };

    const markSubscribed = () => {
      try { localStorage.setItem(STORAGE_KEY, 'true'); } catch { /* noop */ }
    };

    const closeDialog = () => {
      if (typeof dialog.close === 'function') dialog.close();
    };

    // Auto-trigger on homepage after 8s
    if (window.location.pathname === '/' && !isSubscribed()) {
      setTimeout(() => {
        if (!document.querySelector('.hp-dialog[open]') && typeof dialog.showModal === 'function') {
          dialog.showModal();
        }
      }, 8000);
    }

    // Manual trigger from any page
    document.querySelectorAll('[data-open-subscribe]').forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        if (typeof dialog.showModal === 'function') dialog.showModal();
      });
    });

    if (closeBtn) closeBtn.addEventListener('click', closeDialog);
    dialog.addEventListener('click', (e) => { if (e.target === dialog) closeDialog(); });

    if (form instanceof HTMLFormElement) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        try {
          await fetch(form.action, { method: 'POST', body: formData, headers: { Accept: 'application/json' } });
          markSubscribed();
          form.hidden = true;
          if (success instanceof HTMLElement) success.hidden = false;
          setTimeout(closeDialog, 2500);
        } catch {
          form.submit();
        }
      });
    }
  })();
</script>
