---
interface Props {
  title: string;
  description: string;
  author?: string;
  datePublished: string;
  dateModified?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  author = 'Ken',
  datePublished,
  dateModified = datePublished,
  image,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished,
  dateModified,
  publisher: {
    '@type': 'Organization',
    name: '3D3D Atlantic Cooperative',
    url: 'https://3d3d.ca',
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
  ...(image ? { image: { '@type': 'ImageObject', url: image } } : {}),
};
---

<article itemscope itemtype="https://schema.org/Article">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <header class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <time
        datetime={datePublished}
        class="font-tech text-[10px] uppercase tracking-[0.15em]"
        style="color: var(--color-text-secondary);"
        itemprop="datePublished"
      >
        {new Date(datePublished).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <span class="font-tech text-[10px] uppercase tracking-[0.15em]" style="color: var(--color-charcoal-muted);">
        &middot;
      </span>
      <span
        class="font-tech text-[10px] uppercase tracking-[0.15em]"
        style="color: var(--color-text-secondary);"
        itemprop="author"
      >
        {author}
      </span>
    </div>

    <h1
      class="font-display text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight"
      style="color: var(--color-text-primary);"
      itemprop="headline"
    >
      {title}
    </h1>

    <p
      class="mt-4 text-lg leading-relaxed max-w-3xl"
      style="color: var(--color-text-secondary);"
      itemprop="description"
    >
      {description}
    </p>
  </header>

  <div
    class="prose prose-invert max-w-3xl"
    style="color: var(--color-text-primary);"
    itemprop="articleBody"
  >
    <slot />
  </div>
</article>
