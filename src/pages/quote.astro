---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteCalculator from '../components/QuoteCalculator.tsx';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '3D3D Quote Calculator',
  description: 'Get instant pricing for custom 3D printed parts. Adjust material, quality, infill, supports, and more.',
  url: 'https://3d3d.ca/quote',
  applicationCategory: 'BusinessApplication',
};
---

<BaseLayout title="Quote Calculator — 3D3D" description="Instant pricing for custom 3D prints. Configure material, quality, infill, supports, scale, and quantity." schema={schema} activePath="/quote">

  <div class="pt-8 pb-12">
    <section class="max-w-7xl mx-auto">
      <p class="font-display text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">Pricing Tool</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold mt-2 mb-2" style="color: var(--color-text-primary);">Quote Calculator</h1>
      <p class="text-sm max-w-lg mb-10" style="color: var(--color-text-secondary);">
        Configure your print parameters below. Prices include material, machine time, surcharges, and the 75/25 maker split.
      </p>

      <QuoteCalculator client:load />
    </section>
  </div>
</BaseLayout>

<style>
  :global(.lg\:\!grid-cols-\[1fr_340px\]) {
    @media (min-width: 1024px) {
      grid-template-columns: 1fr 340px !important;
    }
  }
</style>
