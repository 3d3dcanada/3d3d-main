---
import BaseLayout from '../layouts/BaseLayout.astro';
import SplashOrbit from '../components/SplashOrbit';
---

<BaseLayout
  title="3D3D"
  description="3D3D splash orbit. Explore the market, services, network, learning, and the story behind the platform."
  noFooter
  noSidebar
  noMobileCTA
  noFeedbackBlip
  bodyClass="splash-page"
>
  <script is:inline>
    (() => {
      const storageKey = '3d3d:splash-theme';
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

      try {
        const storedTheme = window.localStorage.getItem(storageKey);
        const theme =
          storedTheme === 'light' || storedTheme === 'dark'
            ? storedTheme
            : prefersDark
              ? 'dark'
              : 'light';

        document.body.dataset.splashTheme = theme;
      } catch {
        document.body.dataset.splashTheme = prefersDark ? 'dark' : 'light';
      }
    })();
  </script>

  <section id="home" class="splash-home" data-section>
    <SplashOrbit client:load />
  </section>
</BaseLayout>
