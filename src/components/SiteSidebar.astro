---

<button
  type="button"
  class="sidebar-toggle"
  data-sidebar-toggle
  data-open="false"
  aria-expanded="false"
  aria-controls="site-sidebar"
  aria-label="Open navigation menu"
>
  <span class="sidebar-toggle__bar"></span>
  <span class="sidebar-toggle__bar"></span>
  <span class="sidebar-toggle__bar"></span>
</button>

<div class="sidebar-backdrop" data-sidebar-backdrop hidden></div>

<aside id="site-sidebar" class="site-sidebar" data-sidebar-open="false">
  <div class="site-sidebar__content">
    <a href="/" class="site-sidebar__brand" aria-label="3D3D home">
      <span class="site-sidebar__brand-pill">3D3D</span>
      <span class="site-sidebar__tagline">Precision Fabrication · Marine · Automotive</span>
    </a>

    <nav class="site-sidebar__nav" aria-label="Primary navigation">
      {navGroups.map((group) => (
        <section class="site-sidebar__group">
          <p class="site-sidebar__group-label">{group.label}</p>
          <div class="site-sidebar__group-links">
            {group.items.map((item) => {
              const isActive = isActiveLink(item);

              return (
                <a
                  href={item.href || `#${item.id}`}
                  class:list={['site-sidebar__link', isActive && 'site-sidebar__link--active']}
                  aria-current={isActive ? 'page' : undefined}
                  data-sidebar-link
                >
                  {item.label}
                </a>
              );
            })}
          </div>
        </section>
      ))}
    </nav>
  </div>

  <div class="site-sidebar__bottom">
    <a
      href="/contact"
      class="btn btn-primary site-sidebar__cta"
      data-analytics-event="contact_started"
      data-analytics-source="sidebar-cta"
      data-sidebar-link
    >
      Request Service
    </a>

    <div class="site-sidebar__socials" aria-label="3D3D social links">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          class="site-sidebar__social-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
          title={link.label}
        >
          <svg viewBox={link.viewBox} aria-hidden="true" focusable="false">
            <path d={link.path} fill="currentColor"></path>
          </svg>
        </a>
      ))}
    </div>
  </div>
</aside>

<script>
  (() => {
    const sidebar = document.querySelector('.site-sidebar');
    const toggle = document.querySelector('[data-sidebar-toggle]');
    const backdrop = document.querySelector('[data-sidebar-backdrop]');

    if (!(sidebar instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement) || !(backdrop instanceof HTMLElement)) {
      return;
    }

    const mobileQuery = window.matchMedia('(max-width: 1023px)');
    const closeTargets = sidebar.querySelectorAll('[data-sidebar-link]');

    const setOpen = (open) => {
      const nextOpen = mobileQuery.matches ? open : false;

      sidebar.dataset.sidebarOpen = nextOpen ? 'true' : 'false';
      toggle.dataset.open = nextOpen ? 'true' : 'false';
      toggle.setAttribute('aria-expanded', String(nextOpen));
      toggle.setAttribute('aria-label', nextOpen ? 'Close navigation menu' : 'Open navigation menu');
      backdrop.hidden = !nextOpen;
      document.body.classList.toggle('menu-open', nextOpen);
    };

    const close = () => setOpen(false);

    toggle.addEventListener('click', () => {
      if (!mobileQuery.matches) return;

      setOpen(sidebar.dataset.sidebarOpen !== 'true');
    });

    backdrop.addEventListener('click', close);

    closeTargets.forEach((target) => {
      target.addEventListener('click', () => {
        if (mobileQuery.matches) close();
      });
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') close();
    });

    const handleViewportChange = () => {
      if (!mobileQuery.matches) close();
    };

    if (typeof mobileQuery.addEventListener === 'function') {
      mobileQuery.addEventListener('change', handleViewportChange);
    } else if (typeof mobileQuery.addListener === 'function') {
      mobileQuery.addListener(handleViewportChange);
    }

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) close();
    });
  })();
</script>
