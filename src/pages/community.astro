---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const stats = [
  { value: '100%', label: 'Open Source' },
  { value: 'Growing', label: 'Maker Network' },
  { value: 'Worldwide', label: 'Shipping' },
];

const repos = [
  {
    name: '3d3d-platform',
    desc: 'This website. Built with Astro 6 and deployed on Cloudflare.',
    url: 'https://github.com/3d3dcanada/3d3d-main',
    lang: 'Astro',
  },
  {
    name: 'revolution-is-law',
    desc: 'The Revolution brand site. Next.js, live on Vercel.',
    url: 'https://github.com/3d3dcanada/revolution-is-law',
    lang: 'Next.js',
  },
  {
    name: '3d3d-printfiles',
    desc: 'Public print files, jigs, and fixtures shared from the shop.',
    url: 'https://github.com/3d3dcanada/3d3d-printfiles',
    lang: 'STL / 3MF',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Community & Open Source — 3D3D',
  description: '3D3D is an open source manufacturing cooperative based in Fredericton. Access our code, join the network, or find us at events.',
  url: 'https://3d3d.ca/community',
};
---

<BaseLayout title="Community & Open Source | 3D3D" description="3D3D is an open source manufacturing cooperative. Access our code, join the network, or find us at events." activePath="/community" schema={schema}>

  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Community'}]} />
            <p class="hp-card__eyebrow mt-4">The Network</p>
            <h1 class="hp-card__title mt-2 mb-4">Community & Open Source</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              We operate transparently. If we build a tool to make the cooperative run better, we open source it.
              If we design a part that can help someone fix a broken machine, we publish the model.
              The 3D3D network is small and early-stage — but everything we build is shared.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="https://github.com/3d3dcanada" target="_blank" class="hp-cta hp-cta--accent">GitHub Organization</a>
              <a href="https://www.printables.com/@KTK3D_3050116" target="_blank" class="hp-cta hp-cta--glass">Printables Catalog</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Active Repositories -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Open Source</p>
            <h2 class="hp-card__title mt-2 mb-2">Public Repositories</h2>
            <p class="hp-card__copy mb-6">These are the repos we actively maintain. Other projects are in progress but not yet public.</p>

            <div class="community-repo-grid">
              {repos.map(repo => (
                <a href={repo.url} target="_blank" rel="noopener noreferrer" class="community-repo-card">
                  <div class="community-repo-card__header">
                    <span class="community-repo-card__name">{repo.name}</span>
                    <span class="community-repo-card__lang">{repo.lang}</span>
                  </div>
                  <p class="community-repo-card__desc">{repo.desc}</p>
                </a>
              ))}
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: Stats -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Where We Stand</p>
            <h2 class="hp-card__title mt-2 mb-6">The Network Today</h2>

            <div class="community-stats">
              {stats.map((stat) => (
                <div class="community-stat">
                  <span class="community-stat__value">{stat.value}</span>
                  <span class="community-stat__label">{stat.label}</span>
                </div>
              ))}
            </div>

            <p class="hp-card__copy mb-6">We are a Fredericton-based cooperative that is still building out. No inflated numbers — just real work, real code, and real parts shipping from the shop.</p>

            <PageNextActions actions={[
              {label: 'Sponsor an Event', href: '/sponsors', description: 'Help fund workshops in your community.', accent: 'teal'},
              {label: 'Book a Call', href: '/book', description: 'Talk to us about joining or collaborating.', accent: 'magenta'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .community-repo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .community-repo-card {
    display: block;
    padding: 1rem 1.2rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .community-repo-card:hover {
    border-color: rgba(64, 196, 196, 0.5);
    transform: translateY(-2px);
  }
  .community-repo-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .community-repo-card__name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(246, 247, 250, 0.9);
  }
  .community-repo-card__lang {
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(246, 247, 250, 0.5);
    border-radius: 2px;
  }
  .community-repo-card__desc {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgba(246, 247, 250, 0.45);
  }

  .community-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .community-stat {
    text-align: center;
    padding: 1.2rem 0.8rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }
  .community-stat__value {
    display: block;
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-teal-primary);
  }
  .community-stat__label {
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.45);
  }
</style>
