---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { 
  PRUSA_PRINTERS, 
  PRUSA_FILAMENTS, 
  PRUSA_PARTS,
  PRINTER_CATEGORIES,
  FILAMENT_CATEGORIES,
  PART_CATEGORIES,
  getInStockPrinters,
  formatPriceCAD,
  calculateOurPrice,
  DEFAULT_MARKUP_PERCENT
} from '../data/prusa';

const inStockPrinters = getInStockPrinters();

const printerSeries = [
  { id: 'CORE', name: 'CORE Series', desc: 'Professional enclosed printers', icon: '🔧' },
  { id: 'XL', name: 'Original XL', desc: 'Large format CoreXY', icon: '📐' },
  { id: 'MK4S', name: 'MK4S Series', desc: 'Latest MK generation', icon: '⚡' },
  { id: 'MINI', name: 'MINI+', desc: 'Compact & affordable', icon: '🎯' },
  { id: 'SL1S', name: 'SL1S', desc: 'High-res resin printing', icon: '✨' },
];

const valueProps = [
  {
    icon: '⚡',
    title: 'Priority Shipping',
    body: 'We order directly from Prusa with priority handling. Your printer ships to us first for inspection, then to you with full documentation.'
  },
  {
    icon: '🔧',
    title: 'Pre-Configuration',
    body: 'Every machine is unboxed, inspected, and pre-configured for Atlantic Canada humidity conditions. No surprises on first boot.'
  },
  {
    icon: '📋',
    title: 'Full Documentation',
    body: 'Complete inspection report with photos, test prints, and calibration data. Know exactly what you are getting from day one.'
  },
  {
    icon: '🏪',
    title: 'Local Support',
    body: 'Parts, repairs, and upgrades available locally. No waiting for international shipping when you need a nozzle at 11 PM on a Sunday.'
  },
  {
    icon: '💰',
    title: 'Bulk Filament Savings',
    body: 'Prusament at competitive prices. Order 10+ spools for 10% off, 50+ for 20% off. Same quality as direct, better price.'
  },
  {
    icon: '🛡️',
    title: 'Quality Guarantee',
    body: 'We check every machine before it reaches you. If something is wrong, we fix it here. No RMAs to Prague required.'
  }
];

const whyNotOfficial = [
  'We are not an authorized Prusa reseller.',
  'We are a point of trust between you and the manufacturer.',
  'You get Prusa quality with local Canadian support.',
  'Priority shipping, inspection, and pre-configuration included.',
  'Parts and service available without international delays.',
  'Pricing is competitive - we make our margin on volume, not markup.'
];

const comparisonPoints = [
  { prusa: 'Steel frame construction', other: 'Plastic frame, warps over time' },
  { prusa: 'Open-source firmware', other: 'Locked down, no customization' },
  { prusa: '10+ year track record', other: '2-3 years, disasters documented' },
  { prusa: 'Repairable for life', other: 'Disposable when it breaks' },
  { prusa: 'Community support', other: 'Corporate silencing' },
  { prusa: 'Made in EU', other: 'Made where QA is optional' },
];

const formatPrice = (price: number) => {
  if (price === 0) return 'Contact for pricing';
  return `CA$ ${price.toLocaleString('en-CA', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
};

const getStockBadge = (status: string) => {
  switch (status) {
    case 'in_stock': return { text: 'In Stock', class: 'prusa-badge--stock' };
    case 'lead_time': return { text: 'Lead Time', class: 'prusa-badge--lead' };
    case 'high_demand': return { text: 'High Demand', class: 'prusa-badge--demand' };
    default: return { text: 'Order', class: 'prusa-badge--default' };
  }
};
---

<BaseLayout 
  title="Prusa by 3D3D | 3D Printers, Filament & Parts in Canada"
  description="Prusa 3D printers, Prusament filament, and genuine parts - available in Canada through 3D3D. Priority shipping, local support, bulk pricing. Not an official reseller. A point of trust."
  activePath="/prusa"
>
  <section class="prusa-page">
    
    <!-- ═══ HERO ═══ -->
    <div class="prusa-hero">
      <div class="prusa-hero__bg">
        <img src="/media/workshop/printer-action-cf.jpg" alt="3D printing workshop" class="prusa-hero__bg-img" />
      </div>
      <div class="prusa-shell">
        <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Prusa'}]} />

        <div class="prusa-hero__grid">
          <div class="prusa-hero__content">
            <p class="prusa-eyebrow">Prusa in Canada</p>
            <h1 class="prusa-title">
              The Right Way.
              <span class="prusa-title__sub">Without the Wait.</span>
            </h1>
            <p class="prusa-intro">
              Prusa Research builds the Bugatti of 3D printers. We bridge the gap between
              their EU factory and your Canadian workshop. Priority shipping, full inspection,
              local support.
            </p>
            <p class="prusa-notice">
              <strong>Not an official reseller.</strong> We are a point of trust.
              You get Prusa quality with hands-on Canadian support.
            </p>
            <div class="prusa-hero__actions">
              <a href="#printers" class="prusa-cta">Browse Printers</a>
              <a href="#filaments" class="prusa-cta prusa-cta--ghost">Filament & Parts</a>
            </div>
          </div>

          <div class="prusa-hero__image">
            <img
              src="/images/hp_convert_prusa_1774867155451.png"
              alt="Prusa 3D Printer"
              class="prusa-hero__printer-img"
            />
            <div class="prusa-hero__stats">
              <div class="prusa-stat">
                <span class="prusa-stat__num">14</span>
                <span class="prusa-stat__label">Printer Models</span>
              </div>
              <div class="prusa-stat">
                <span class="prusa-stat__num">{inStockPrinters.length}</span>
                <span class="prusa-stat__label">In Stock Now</span>
              </div>
              <div class="prusa-stat">
                <span class="prusa-stat__num">17.5%</span>
                <span class="prusa-stat__label">Our Markup</span>
              </div>
              <div class="prusa-stat">
                <span class="prusa-stat__num">🇨🇦</span>
                <span class="prusa-stat__label">Local Support</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ DISCLOSURE BANNER ═══ -->
    <div class="prusa-disclosure">
      <div class="prusa-shell">
        <p>
          <strong>Important:</strong> 3D3D is not an authorized Prusa reseller. 
          We purchase Prusa products through standard channels and provide value through 
          inspection, local support, and faster fulfillment. All products are genuine 
          Prusa Research equipment with full manufacturer warranty.
        </p>
      </div>
    </div>

    <!-- ═══ WHY 3D3D ═══ -->
    <div class="prusa-value" id="why-3d3d">
      <div class="prusa-shell">
        <p class="prusa-section-eyebrow">Why Buy Through 3D3D</p>
        <h2 class="prusa-section-title">Prusa quality.<br/>Canadian support.</h2>
        
        <div class="prusa-value__grid">
          {valueProps.map(prop => (
            <div class="prusa-value__card">
              <span class="prusa-value__icon">{prop.icon}</span>
              <h3 class="prusa-value__title">{prop.title}</h3>
              <p class="prusa-value__body">{prop.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ═══ PRINTER SHOWCASE ═══ -->
    <div class="prusa-printers" id="printers">
      <div class="prusa-shell">
        <p class="prusa-section-eyebrow">3D Printers</p>
        <h2 class="prusa-section-title">Built like a Bugatti.<br/>Not a Bambu Lab.</h2>
        
        <!-- Series tabs -->
        <div class="prusa-series">
          {printerSeries.map(series => (
            <a href={`#series-${series.id}`} class="prusa-series__tab">
              <span class="prusa-series__icon">{series.icon}</span>
              <span class="prusa-series__name">{series.name}</span>
              <span class="prusa-series__desc">{series.desc}</span>
            </a>
          ))}
        </div>

        <!-- Printer Cards -->
        <div class="prusa-printer-grid">
          {PRUSA_PRINTERS.map(printer => {
            const stockBadge = getStockBadge(printer.stockStatus);
            const seriesImages = {
              CORE: '/media/workshop/printer-frame-shot.jpg',
              XL: '/media/workshop/printer-action-cf.jpg',
              MK4S: '/images/hp_convert_prusa_1774867155451.png',
              MINI: '/media/workshop/printer-bed-benchy.jpg',
              SL1S: '/media/workshop/printer-frame-shot.jpg',
            };
            const cardImage = printer.featuredImage || seriesImages[printer.series] || '/images/hp_convert_prusa_1774867155451.png';
            return (
              <article class="prusa-printer-card" id={`series-${printer.series}`}>
                <div class="prusa-printer-card__header">
                  <span class={`prusa-badge ${stockBadge.class}`}>{stockBadge.text}</span>
                  {printer.isSpecialEdition && (
                    <span class="prusa-badge prusa-badge--special">{printer.specialEditionType}</span>
                  )}
                </div>

                <div class="prusa-printer-card__image">
                  <img
                    src={cardImage}
                    alt={printer.name}
                    class="prusa-printer-card__img"
                    loading="lazy"
                  />
                </div>
                
                <h3 class="prusa-printer-card__name">{printer.name}</h3>
                
                <p class="prusa-printer-card__desc">{printer.shortDescription}</p>
                
                {printer.stockStatus === 'lead_time' && printer.leadTimeWeeks && (
                  <p class="prusa-printer-card__lead">
                    ⏱️ Lead time: {printer.leadTimeWeeks} weeks
                  </p>
                )}
                
                <div class="prusa-printer-card__specs">
                  <span>📐 {printer.specs.buildVolume.x}×{printer.specs.buildVolume.y}×{printer.specs.buildVolume.z}mm</span>
                  <span>🔥 {printer.specs.materials.slice(0, 3).join(', ')}{printer.specs.materials.length > 3 ? '...' : ''}</span>
                </div>
                
                <div class="prusa-printer-card__pricing">
                  <div class="prusa-printer-card__price-row">
                    <span class="prusa-printer-card__label">Prusa Price:</span>
                    <span class="prusa-printer-card__base">{formatPrice(printer.basePriceCAD)}</span>
                  </div>
                  <div class="prusa-printer-card__price-row prusa-printer-card__price-row--our">
                    <span class="prusa-printer-card__label">Your Price:</span>
                    <span class="prusa-printer-card__our">{formatPrice(printer.ourPriceCAD)}</span>
                  </div>
                  <span class="prusa-printer-card__markup">+{printer.markupPercent}% includes inspection & support</span>
                </div>
                
                <a 
                  href={`/quote?product=prusa-printer-${printer.id}`}
                  class="prusa-printer-card__cta"
                >
                  Request Quote →
                </a>
              </article>
            );
          })}
        </div>
      </div>
    </div>

    <!-- ═══ FILAMENT STORE ═══ -->
    <div class="prusa-filaments" id="filaments">
      <div class="prusa-shell">
        <p class="prusa-section-eyebrow">Filament</p>
        <h2 class="prusa-section-title">Prusament.<br/>Competitive pricing.</h2>
        
        <div class="prusa-filament__intro">
          <p>Prusament is Prusa's premium filament. Engineered for their printers, 
          tested to exacting standards. Now available at prices competitive with 
          generic Amazon filament - with bulk pricing that makes it cheaper.</p>
          
          <div class="prusa-bulk-banner">
            <span class="prusa-bulk-banner__title">💰 Bulk Pricing Available</span>
            <span class="prusa-bulk-banner__tier">10+ spools = 10% off</span>
            <span class="prusa-bulk-banner__tier">50+ spools = 20% off</span>
            <span class="prusa-bulk-banner__note">Community orders welcome - combine with others to maximize savings</span>
          </div>
        </div>

        <!-- Filament Categories -->
        <div class="prusa-filament-categories">
          {FILAMENT_CATEGORIES.map(cat => {
            const catFilaments = PRUSA_FILAMENTS.filter(f => f.material === cat.id);
            return (
              <div class="prusa-filament-cat">
                <div class="prusa-filament-cat__header">
                  <h3 class="prusa-filament-cat__name">{cat.name}</h3>
                  <span class={`prusa-filament-cat__difficulty prusa-filament-cat__difficulty--${cat.difficulty}`}>
                    {cat.difficulty}
                  </span>
                </div>
                <p class="prusa-filament-cat__desc">{cat.description}</p>
                
                {catFilaments.length > 0 ? (
                  <div class="prusa-filament-list">
                    {catFilaments.map(fil => (
                      <div class="prusa-filament-item">
                        <div class="prusa-filament-item__color" style={`background: ${fil.colors[0]?.hex || '#ccc'}`}></div>
                        <span class="prusa-filament-item__name">{fil.name}</span>
                        <span class="prusa-filament-item__price">{formatPrice(fil.ourPriceCAD)}</span>
                        <span class="prusa-filament-item__size">1kg</span>
                      </div>
                    ))}
                  </div>
                ) : (
                  <p class="prusa-filament-cat__empty">Coming soon - inquire for availability</p>
                )}
                
                <div class="prusa-filament-cat__uses">
                  <strong>Best for:</strong> {cat.typicalUseCases.slice(0, 3).join(', ')}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <!-- ═══ PARTS & SERVICE ═══ -->
    <div class="prusa-parts" id="parts">
      <div class="prusa-shell">
        <p class="prusa-section-eyebrow">Parts & Support</p>
        <h2 class="prusa-section-title">Local spares.<br/>No waiting.</h2>
        
        <div class="prusa-parts__grid">
          <div class="prusa-parts__content">
            <p class="prusa-parts__intro">
              Why wait 2 weeks for a nozzle from Prague when you can get it tomorrow 
              from Fredericton? We stock essential Prusa parts and can source anything 
              in their catalog.
            </p>
            
            <div class="prusa-parts__categories">
              {PART_CATEGORIES.map(cat => (
                <div class="prusa-parts__cat">
                  <h4>{cat.name}</h4>
                  <p>{cat.description}</p>
                </div>
              ))}
            </div>
            
            <div class="prusa-service__features">
              <h4>Our Services:</h4>
              <ul>
                <li>✓ Emergency part supply (same-day local)</li>
                <li>✓ Nozzle swapping & hotend maintenance</li>
                <li>✓ Belt replacement & calibration</li>
                <li>✓ Board-level repairs</li>
                <li>✓ MMU3 installation & troubleshooting</li>
                <li>✓ Full printer refurbishment</li>
              </ul>
            </div>
          </div>
          
          <div class="prusa-parts__featured">
            <h4>Popular Parts</h4>
            {PRUSA_PARTS.slice(0, 6).map(part => (
              <div class="prusa-part-item">
                <span class="prusa-part-item__name">{part.name}</span>
                <span class="prusa-part-item__price">{formatPrice(part.ourPriceCAD)}</span>
              </div>
            ))}
            <a href="/contact?subject=prusa-parts" class="prusa-cta--small">
              Request Part Quote
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ QUALITY COMPARISON ═══ -->
    <div class="prusa-comparison">
      <div class="prusa-shell">
        <p class="prusa-section-eyebrow">Why Prusa</p>
        <h2 class="prusa-section-title">The Bugatti.<br/>Not the disposable.</h2>
        
        <div class="prusa-comparison__grid">
          <div class="prusa-comparison__prusa">
            <h3>✅ Prusa Research</h3>
            <ul>
              {comparisonPoints.map(pt => (
                <li>{pt.prusa}</li>
              ))}
            </ul>
          </div>
          
          <div class="prusa-comparison__vs">
            <span>VS</span>
          </div>
          
          <div class="prusa-comparison__other">
            <h3>❌ Consumer Competition</h3>
            <ul>
              {comparisonPoints.map(pt => (
                <li>{pt.other}</li>
              ))}
            </ul>
          </div>
        </div>
        
        <p class="prusa-comparison__note">
          We have seen too many "Bambu Labs disasters" - warped frames, failed boards, 
          customer service nightmares. Prusa machines run for 10+ years. 
          That is why we only support Prusa.
        </p>
      </div>
    </div>

    <!-- ═══ OUR PROCESS ═══ -->
    <div class="prusa-process">
      <div class="prusa-shell">
        <p class="prusa-section-eyebrow">Our Process</p>
        <h2 class="prusa-section-title">What you get<br/>when you order.</h2>
        
        <div class="prusa-process__steps">
          <div class="prusa-process__step">
            <span class="prusa-process__num">1</span>
            <h3>Priority Order</h3>
            <p>We place your order with Prusa Research using priority shipping channels. Your printer is reserved.</p>
          </div>
          
          <div class="prusa-process__step">
            <span class="prusa-process__num">2</span>
            <h3>Factory to 3D3D</h3>
            <p>Machine ships to our workshop first. We unbox and begin inspection before it ever touches your hands.</p>
          </div>
          
          <div class="prusa-process__step">
            <span class="prusa-process__num">3</span>
            <h3>Full Inspection</h3>
            <p>Every component checked against factory spec. Photos taken. Test prints run. Calibration verified.</p>
          </div>
          
          <div class="prusa-process__step">
            <span class="prusa-process__num">4</span>
            <h3>Canadian Prep</h3>
            <p>Pre-configured for Atlantic Canada humidity. Settings adjusted. Documentation prepared.</p>
          </div>
          
          <div class="prusa-process__step">
            <span class="prusa-process__num">5</span>
            <h3>Delivery & Support</h3>
            <p>Ships to you with full report. Local support available. Parts in stock. We have your back.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ CTA ═══ -->
    <div class="prusa-cta-block">
      <div class="prusa-shell">
        <p class="prusa-cta-block__eyebrow">Ready to order?</p>
        <h2 class="prusa-cta-block__title">Get the best printer.<br/>With local support.</h2>
        
        <div class="prusa-cta-block__actions">
          <a href="/quote?category=prusa" class="prusa-cta prusa-cta--large">
            Request Prusa Quote →
          </a>
          <a href="/contact" class="prusa-cta prusa-cta--ghost prusa-cta--large">
            Ask Questions →
          </a>
        </div>
        
        <p class="prusa-cta-block__note">
          Not sure which printer? Tell us your use case and we will spec the right machine. 
          We have used them all and know exactly what works for what.
        </p>
      </div>
    </div>

  </section>
</BaseLayout>

<style>
  /* Prusa Page Styles */
  .prusa-page {
    --prusa-orange: #FA6831;
    --prusa-dark: #1A1A1A;
    background: #FFFFFF;
    color: #1A1A1A;
  }

  .prusa-shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 1200px);
    margin: 0 auto;
  }

  /* ── Typography ── */
  .prusa-eyebrow {
    margin: 0 0 0.8rem;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--prusa-orange);
  }

  .prusa-section-eyebrow {
    margin: 0 0 0.8rem;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--prusa-orange);
  }

  .prusa-section-title {
    margin: 0 0 2rem;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 1.5rem + 3vw, 3.8rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: #1A1A1A;
    text-transform: uppercase;
  }

  /* ── Hero ── */
  .prusa-hero {
    position: relative;
    padding-block: clamp(5rem, 8vw, 8rem) clamp(3rem, 5vw, 5rem);
    color: #FFFFFF;
    overflow: hidden;
  }

  .prusa-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .prusa-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.25);
  }

  .prusa-hero .prusa-shell {
    position: relative;
    z-index: 1;
  }

  .prusa-hero__grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: center;
  }

  .prusa-hero__image {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .prusa-hero__printer-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 4px;
    border: 2px solid rgba(250, 104, 49, 0.4);
  }

  .prusa-title {
    margin: 1rem 0 1.2rem;
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 4vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: #FFFFFF;
    text-transform: uppercase;
  }

  .prusa-title__sub {
    display: block;
    font-size: 0.6em;
    color: var(--prusa-orange);
    margin-top: 0.3rem;
  }

  .prusa-intro {
    margin: 0 0 1.5rem;
    max-width: 44rem;
    font-size: 1.1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.8);
  }

  .prusa-notice {
    margin: 0 0 2rem;
    padding: 1rem 1.2rem;
    background: rgba(250, 104, 49, 0.15);
    border-left: 3px solid var(--prusa-orange);
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .prusa-notice strong {
    color: var(--prusa-orange);
  }

  .prusa-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .prusa-hero__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }

  .prusa-stat {
    text-align: center;
  }

  .prusa-stat__num {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--prusa-orange);
  }

  .prusa-stat__label {
    font-family: var(--font-tech);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ── Disclosure ── */
  .prusa-disclosure {
    background: #FFF3ED;
    border-bottom: 1px solid #FA683120;
    padding: 1rem 0;
  }

  .prusa-disclosure p {
    margin: 0;
    font-size: 0.85rem;
    color: #8B4513;
    text-align: center;
  }

  .prusa-disclosure strong {
    color: var(--prusa-orange);
  }

  /* ── Value Props ── */
  .prusa-value {
    padding-block: clamp(5rem, 8vw, 7rem);
    background: #F8F8F8;
  }

  .prusa-value__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
