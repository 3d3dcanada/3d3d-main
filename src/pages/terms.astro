---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandSidebar from '../components/BrandSidebar.tsx';

const sidebarTheme = {
  accent: '#00C4CC', accentDark: '#0891B2', bg: '#0D0E1A', bgAlt: '#141525',
  border: 'rgba(255,255,255,0.07)', text: '#E8E8F2', muted: '#7878A0', dimmed: '#4A4A6A', glow: 'rgba(0,196,204,0.3)',
};

const sidebarNav = [{
  label: '3D3D',
  items: [
    { id: 'shop', label: 'Shop', href: '/shop' },
    { id: 'about', label: 'About', href: '/about' },
    { id: 'contact', label: 'Contact', href: '/contact' },
  ],
}];
---

<BaseLayout title="Terms of Service — 3D3D" description="Terms and conditions for using the 3D3D platform and ordering custom 3D prints.">
  <BrandSidebar slot="sidebar" client:load navGroups={sidebarNav} theme={sidebarTheme} activePath="/terms" />

  <div class="pt-16 pl-0 lg:pl-4">
    <section class="px-6 lg:px-12 py-12">
      <div class="max-w-3xl mx-auto">
        <p class="font-tech text-[10px] uppercase tracking-[0.25em] text-[#7878A0] mb-2">Legal</p>
        <h1 class="font-display text-3xl font-bold text-[#E8E8F2] mb-2">Terms of Service</h1>
        <p class="font-tech text-xs text-[#4A4A6A] mb-8">Last updated: March 2026</p>

        <div class="space-y-6 text-sm leading-relaxed text-[#7878A0]">
          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">1. Overview</h2>
            <p>3D3D Atlantic Cooperative ("3D3D", "we") operates a distributed 3D printing marketplace. By using our platform, you agree to these terms.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">2. Orders and Pricing</h2>
            <p>All prices are in Canadian dollars (CAD) and include applicable surcharges. Tax is calculated based on the shipping province. Prices are subject to change without notice. Orders are confirmed upon payment processing.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">3. Fulfillment</h2>
            <p>Orders are fulfilled by independent makers in our cooperative network. Standard turnaround is 24-48 hours for printing, plus shipping time. We do not guarantee exact delivery dates but make reasonable efforts to meet estimated timelines.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">4. Returns and Refunds</h2>
            <p>Custom 3D printed items are made to order and are non-refundable unless defective. If your order has a quality issue, contact us within 7 days of receipt with photos. We will reprint or refund at our discretion.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">5. Intellectual Property</h2>
            <p>Catalog products use open-source designs (Creative Commons licensed) from platforms like Printables, Thingiverse, and MakerWorld, as well as original 3D3D designs. By ordering a custom print, you warrant that you have the right to reproduce the design.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">6. Maker Terms</h2>
            <p>Makers in the cooperative operate as independent contractors. 3D3D does not control the means or methods of production. Makers agree to meet quality standards and turnaround commitments as outlined in the Maker Agreement.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">7. Limitation of Liability</h2>
            <p>3D3D is not liable for indirect, incidental, or consequential damages arising from use of our platform or products. Our total liability is limited to the amount paid for the specific order in question.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">8. Governing Law</h2>
            <p>These terms are governed by the laws of the Province of New Brunswick, Canada. Disputes shall be resolved in the courts of the Province of New Brunswick.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">8A. Consumer Protection</h2>
            <p>These terms are subject to the New Brunswick Consumer Product Warranty and Liability Act (SNB 1978, c. C-18.1) and other applicable federal and provincial consumer protection legislation. Nothing in these terms limits your rights under provincial consumer protection law, including rights related to product quality, fitness for purpose, and remedies for defective goods.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">9. Contact</h2>
            <p>Questions about these terms: <a href="mailto:info@3d3d.ca" class="text-[#00C4CC] hover:underline">info@3d3d.ca</a> · 506-953-2678</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
