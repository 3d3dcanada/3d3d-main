---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Thing',
  name: 'The Old Girl',
  description: 'Community 3D printer — Prusa i3 MK2.5S with MMU2S. Print queue, donations, livestream. Run by 3D3D Atlantic Cooperative.',
  url: 'https://oldgirl.3d3d.ca',
};

const restorationLog = [
  { date: '2026-02-14', status: 'done', entry: 'Acquired the printer — broken MMU2S, bent frame, dead extruder motor. $0 cost.' },
  { date: '2026-02-28', status: 'done', entry: 'Full teardown. Replaced extruder motor, straightened frame, rebuilt heatblock.' },
  { date: '2026-03-10', status: 'done', entry: 'MMU2S rebuilt with new idler and selector motor. First successful 5-colour test print.' },
  { date: '2026-03-12', status: 'done', entry: 'Loaded Lime Green Galaxy ABS. Stage One preview launched.' },
  { date: 'TBD', status: 'pending', entry: 'Stage Two — live queue, realtime monitoring, Ko-fi filament fund, community voting.' },
];

const fundingTiers = [
  { name: 'Filament Backer', amount: '$5+', desc: 'Goes directly to filament. Every $5 buys ~30m of material.', color: '#8B5CF6' },
  { name: 'Queue Jumper', amount: '$15+', desc: 'Your print moves to the top of the community queue.', color: '#F97316' },
  { name: 'Patron', amount: '$25+', desc: 'Donor wall, priority queue, and a print of your choice each month.', color: '#84CC16' },
];
---

<BaseLayout
  title="The Old Girl — Community 3D Printer"
  description="A Prusa i3 MK2.5S with MMU2S, restored and given to the community. Print queue, Ko-fi donations, livestream."
  schema={schema}
  accent="#8B5CF6"
  showFooter={false}
  bodyClass="og-page"
>
  {/* ── Dark hero ── */}
  <section class="og-hero">
    <div class="og-hero__bg"></div>
    <div class="og-hero__scrim"></div>
    <div class="og-hero__content">
      <a href="https://3d3d.ca" class="og-hero__back" aria-label="Back to 3D3D">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 3L4 7l5 4"/></svg>
      </a>
      <div>
        <p class="og-hero__kicker">Community Printer</p>
        <h1 class="og-hero__title">The Old <span class="og-hero__accent">Girl</span></h1>
        <p class="og-hero__sub">A Prusa i3 MK2.5S with MMU2S. Acquired broken, rebuilt from scratch. This printer belongs to the internet.</p>
      </div>
    </div>
  </section>

  {/* ── Status strip (dark bridge) ── */}
  <div class="og-status-strip">
    <div class="og-status-strip__inner">
      <div class="og-status-item">
        <span class="og-status-dot og-status-dot--orange"></span>
        <span class="og-status-label">Idle — Preview Mode</span>
      </div>
      <div class="og-status-meta">
        <span>Prusa i3 MK2.5S</span>
        <span>MMU2S</span>
        <span>Lime Green Galaxy ABS</span>
        <span>Stage One</span>
      </div>
    </div>
  </div>

  {/* ── Light content ── */}
  <div class="og-shell">

    {/* ── Print Queue ── */}
    <section class="og-section">
      <span class="og-eyebrow">Queue</span>
      <h2 class="og-heading">Print Queue</h2>
      <div class="og-queue">
        {[
          { name: 'Replacement MMU2S latch prototype', status: 'Preview' },
          { name: 'First community calibration print', status: 'Waitlist' },
          { name: 'Filament swatch set for launch day', status: 'Waitlist' },
        ].map((item, i) => (
          <div class="og-queue__item">
            <span class="og-queue__num">#{String(i + 1).padStart(2, '0')}</span>
            <span class="og-queue__name">{item.name}</span>
            <span class="og-queue__status">{item.status}</span>
          </div>
        ))}
      </div>
      <p class="og-note">Queue submissions open in Stage Two. <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer">Ko-fi queue jump</a> available at launch.</p>
    </section>

    {/* ── Restoration Log ── */}
    <section class="og-section">
      <span class="og-eyebrow">Build log</span>
      <h2 class="og-heading">Restoration Log</h2>
      <div class="og-log">
        {restorationLog.map((entry) => (
          <div class="og-log__entry">
            <span class={`og-log__dot ${entry.status === 'done' ? 'og-log__dot--done' : ''}`}></span>
            <div>
              <span class="og-log__date">{entry.date}</span>
              <p class="og-log__text">{entry.entry}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* ── Community Funding ── */}
    <section class="og-section">
      <span class="og-eyebrow">Support</span>
      <h2 class="og-heading">Community Funding</h2>
      <p class="og-prose">Every donation goes directly to filament, parts, and uptime.</p>
      <div class="og-tiers">
        {fundingTiers.map((tier) => (
          <div class="og-tier">
            <span class="og-tier__amount" style={`color: ${tier.color};`}>{tier.amount}</span>
            <span class="og-tier__name">{tier.name}</span>
            <p class="og-tier__desc">{tier.desc}</p>
          </div>
        ))}
      </div>
      <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer" class="og-cta">
        Support on Ko-fi
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 5h6m-2-2 2 2-2 2"/></svg>
      </a>
    </section>
  </div>

  {/* ── Footer ── */}
  <footer class="og-footer">
    <a href="mailto:info@3d3d.ca">info@3d3d.ca</a>
    <a href="https://3d3d.ca">3d3d.ca</a>
    <span>Moncton, NB</span>
  </footer>
</BaseLayout>

<style>
  /* ── Page override ── */
  .og-page {
    background: var(--color-surface-primary);
    background-image: none;
  }

  /* ══════════════════════════════════════════
     DARK HERO — purple brand
     ══════════════════════════════════════════ */
  .og-hero {
    position: relative;
    overflow: hidden;
    min-height: 240px;
    display: flex;
    align-items: flex-end;
  }

  .og-hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(139, 92, 246, 0.25) 0%, transparent 55%),
      radial-gradient(ellipse at 70% 80%, rgba(132, 204, 22, 0.12) 0%, transparent 50%),
      #0e0a16;
  }

  .og-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(14, 10, 22, 0.6) 100%);
  }

  .og-hero__content {
    position: relative;
    z-index: 1;
    width: min(100%, 760px);
    margin: 0 auto;
    padding: 3rem 1.25rem 1.5rem;
    display: flex;
    gap: 0.75rem;
  }

  .og-hero__back {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-sm);
    background: rgba(139, 92, 246, 0.12);
    border: 1px solid rgba(139, 92, 246, 0.2);
    color: rgba(200, 190, 220, 0.7);
    flex-shrink: 0;
    margin-top: 0.15rem;
    transition: background 150ms ease;
  }

  .og-hero__back:hover {
    background: rgba(139, 92, 246, 0.25);
    color: #f0ebf5;
  }

  .og-hero__kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(200, 190, 220, 0.6);
  }

  .og-hero__title {
    margin: 0.25rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.5rem + 2vw, 3rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: #f0ebf5;
  }

  .og-hero__accent {
    color: #8B5CF6;
  }

  .og-hero__sub {
    margin: 0.4rem 0 0;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: rgba(200, 190, 220, 0.6);
    line-height: 1.5;
    max-width: 28rem;
  }

  /* ══════════════════════════════════════════
     STATUS STRIP — dark bridge
     ══════════════════════════════════════════ */
  .og-status-strip {
    background: #0a0712;
    border-bottom: 1px solid rgba(139, 92, 246, 0.1);
  }

  .og-status-strip__inner {
    width: min(100%, 760px);
    margin: 0 auto;
    padding: 0.6rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .og-status-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .og-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-muted);
  }

  .og-status-dot--orange {
    background: #F97316;
    box-shadow: 0 0 6px rgba(249, 115, 22, 0.5);
  }

  .og-status-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F97316;
  }

  .og-status-meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-left: auto;
  }

  .og-status-meta span {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.06em;
    color: rgba(200, 190, 220, 0.35);
  }

  /* ══════════════════════════════════════════
     LIGHT CONTENT
     ══════════════════════════════════════════ */
  .og-shell {
    width: min(100%, 760px);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .og-section {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .og-section:last-child { border-bottom: none; }

  .og-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-purple-dark);
  }

  .og-eyebrow::before {
    content: '';
    width: 1.25rem;
    height: 2px;
    background: var(--color-purple-primary);
    flex-shrink: 0;
  }

  .og-heading {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 0.9rem + 0.8vw, 1.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0.25rem 0 0.5rem;
  }

  .og-prose {
    font-family: var(--font-body);
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0 0 0.6rem;
  }

  .og-note {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .og-note a {
    color: var(--color-purple-primary);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  /* ── Queue ── */
  .og-queue {
    display: grid;
    gap: 0.3rem;
  }

  .og-queue__item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.65rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-subtle);
  }

  .og-queue__num {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--color-text-muted);
  }

  .og-queue__name {
    flex: 1;
    font-size: 0.78rem;
    color: var(--color-text-primary);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .og-queue__status {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F97316;
    flex-shrink: 0;
  }

  /* ── Restoration Log ── */
  .og-log {
    display: grid;
    gap: 0.5rem;
  }

  .og-log__entry {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .og-log__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-muted);
    flex-shrink: 0;
    margin-top: 0.45rem;
  }

  .og-log__dot--done {
    background: #84CC16;
  }

  .og-log__date {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .og-log__text {
    margin: 0.1rem 0 0;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-text-secondary);
  }

  /* ── Funding Tiers ── */
  .og-tiers {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .og-tier {
    padding: 0.65rem 0.75rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-subtle);
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    gap: 0.1rem 0.6rem;
  }

  .og-tier__amount {
    grid-row: 1 / 3;
    align-self: center;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
  }

  .og-tier__name {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
  }

  .og-tier__desc {
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ── CTA ── */
  .og-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.85rem;
    border-radius: var(--radius-sm);
    background: var(--color-purple-primary);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 150ms ease;
    box-shadow: 0 3px 10px rgba(139, 92, 246, 0.2);
  }

  .og-cta:hover {
    background: var(--color-purple-dark);
    color: #fff;
  }

  /* ── Footer ── */
  .og-footer {
    width: min(100%, 760px);
    margin: 0 auto;
    padding: 0.65rem 1.25rem 1.5rem;
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-border-subtle);
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .og-footer a {
    color: var(--color-purple-primary);
    text-decoration: none;
  }

  .og-footer a:hover { color: var(--color-purple-dark); }

  /* ── Responsive ── */
  @media (min-width: 500px) {
    .og-tiers { grid-template-columns: 1fr 1fr 1fr; }
  }

  @media (min-width: 700px) {
    .og-hero__content,
    .og-status-strip__inner,
    .og-shell,
    .og-footer { padding-inline: 2rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .og-hero__back, .og-cta { transition: none !important; }
  }
</style>
