---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  author?: string;
  datePublished: string;
  dateModified?: string;
  image?: string;
  accent?: string;
}

const {
  title,
  description,
  author = 'Ken',
  datePublished,
  dateModified = datePublished,
  image,
  accent = '#00C4CC',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished,
  dateModified,
  publisher: {
    '@type': 'Organization',
    name: '3D3D Atlantic Cooperative',
    url: 'https://3d3d.ca',
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
  ...(image ? { image: { '@type': 'ImageObject', url: image } } : {}),
};
---

<BaseLayout
  title={`${title} — Blog`}
  description={description}
  canonicalURL={canonicalURL}
  ogType="article"
  ogImage={image}
  schema={articleSchema}
  accent={accent}
>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-20 lg:px-8" itemscope itemtype="https://schema.org/Article">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <time
          datetime={datePublished}
          class="font-tech text-[10px] uppercase tracking-[0.15em]"
          style="color: var(--color-text-secondary);"
          itemprop="datePublished"
        >
          {new Date(datePublished).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="font-tech text-[10px]" style="color: var(--color-charcoal-muted);">&middot;</span>
        <span class="font-tech text-[10px] uppercase tracking-[0.15em]" style="color: var(--color-text-secondary);" itemprop="author">
          {author}
        </span>
      </div>

      <h1
        class="font-display text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight"
        style="color: var(--color-text-primary);"
        itemprop="headline"
      >
        {title}
      </h1>

      <p class="mt-4 text-lg leading-relaxed" style="color: var(--color-text-secondary);" itemprop="description">
        {description}
      </p>
    </header>

    <div class="blog-content" itemprop="articleBody">
      <slot />
    </div>
  </article>

  <style>
    .blog-content :global(h2) {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      color: var(--color-text-primary);
    }
    .blog-content :global(h3) {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 600;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      color: var(--color-text-primary);
    }
    .blog-content :global(p) {
      margin-bottom: 1.25rem;
      line-height: 1.75;
      color: var(--color-text-secondary);
    }
    .blog-content :global(a) {
      color: var(--color-accent-teal);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .blog-content :global(ul), .blog-content :global(ol) {
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;
      color: var(--color-text-secondary);
    }
    .blog-content :global(li) {
      margin-bottom: 0.5rem;
      line-height: 1.65;
    }
    .blog-content :global(blockquote) {
      border-left: 3px solid var(--color-accent-teal);
      padding-left: 1rem;
      margin: 1.5rem 0;
      font-style: italic;
      color: var(--color-charcoal-muted);
    }
    .blog-content :global(code) {
      font-family: var(--font-tech);
      background: var(--color-charcoal);
      padding: 0.15em 0.4em;
      border-radius: 3px;
      font-size: 0.875em;
    }
    .blog-content :global(pre) {
      background: var(--color-charcoal);
      border: 1px solid var(--color-charcoal-border);
      border-radius: 6px;
      padding: 1rem;
      overflow-x: auto;
      margin-bottom: 1.5rem;
    }
  </style>
</BaseLayout>
