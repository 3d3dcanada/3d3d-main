---
import { SITE_NAV, SOCIAL_LINKS } from '../data/siteNav';

interface Props {
  activePath?: string;
}

const { activePath = '' } = Astro.props;

const normalizePath = (value?: string) => {
  if (!value) return '';
  if (value === '/') return '/';
  return value.replace(/\/+$/, '');
};

const currentPath = normalizePath(activePath);
---

<button
  type="button"
  class="sidebar-toggle"
  data-sidebar-toggle
  data-open="false"
  aria-expanded="false"
  aria-controls="site-sidebar"
  aria-label="Open navigation menu"
>
  <span class="sidebar-toggle__bar"></span>
  <span class="sidebar-toggle__bar"></span>
  <span class="sidebar-toggle__bar"></span>
</button>

<div class="sidebar-backdrop" data-sidebar-backdrop hidden></div>

<aside id="site-sidebar" class="site-sidebar" data-sidebar-open="false">
  <div class="site-sidebar__header">
    <a href="/" class="site-sidebar__brand" aria-label="3D3D home">
      <span class="site-sidebar__brand-pill">3D3D</span>
      <span class="site-sidebar__tagline">Specialty Fabrication · Marine · Motorsport</span>
    </a>
  </div>

  <div class="site-sidebar__content">
    <nav class="site-sidebar__nav" aria-label="Primary navigation">
      {SITE_NAV.map((group) => {
        const hasActiveChild = group.items.some((item) => {
          if (item.external) return false;
          return normalizePath(item.href) === currentPath;
        });

        return (
          <section class="site-sidebar__group" data-nav-group data-group-open={hasActiveChild ? 'true' : 'false'} style={`--group-accent: ${group.accent};`}>
            <button
              type="button"
              class:list={['site-sidebar__group-toggle', hasActiveChild && 'site-sidebar__group-toggle--active']}
              data-group-toggle
              aria-expanded={hasActiveChild ? 'true' : 'false'}
            >
              <span class="site-sidebar__group-pip"></span>
              <span>{group.label}</span>
              <svg class="site-sidebar__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="site-sidebar__group-links" data-group-content>
              <div class="site-sidebar__node-line"></div>
              {group.items.map((item) => {
                const isActive = !item.external && normalizePath(item.href) === currentPath;
                return (
                  <a
                    href={item.href}
                    class:list={['site-sidebar__link', isActive && 'site-sidebar__link--active']}
                    aria-current={isActive ? 'page' : undefined}
                    target={item.external ? '_blank' : undefined}
                    rel={item.external ? 'noopener noreferrer' : undefined}
                    data-sidebar-link
                  >
                    <span class="site-sidebar__node-dot"></span>
                    {item.label}
                    {item.external && (
                      <svg width="10" height="10" viewBox="0 0 12 12" aria-hidden="true" class="site-sidebar__ext-icon">
                        <path d="M3.5 2H10V8.5M10 2L2 10" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </a>
                );
              })}
            </div>
          </section>
        );
      })}
    </nav>
  </div>

  <div class="site-sidebar__bottom">
    <a
      href="/quote"
      class="site-sidebar__cta"
      data-sidebar-link
    >
      Get a Quote
    </a>
    <button type="button" class="site-sidebar__subscribe" data-open-subscribe>
      Stay in the Loop
    </button>

    <div class="site-sidebar__socials" aria-label="3D3D social links">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.href}
          class="site-sidebar__social-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
          title={link.label}
        >
          <svg viewBox={link.viewBox} aria-hidden="true" focusable="false">
            <path d={link.path} fill="currentColor"></path>
          </svg>
        </a>
      ))}
    </div>
  </div>
</aside>

<style>
  .site-sidebar {
    position: fixed;
    left: 0;
    top: 0;
    height: 100dvh;
    width: var(--sidebar-width);
    z-index: 60;
    display: flex;
    flex-direction: column;
    padding: 0;
    background: #111214;
    border-right: 2px solid #1A1A1A;
    overflow-y: auto;
    transform: translateX(-100%);
    box-shadow: 12px 0 48px rgba(0, 0, 0, 0.4);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .site-sidebar[data-sidebar-open='true'] {
    transform: translateX(0);
  }

  .site-sidebar__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.25rem 1rem 0.75rem;
    border-bottom: 1px solid rgba(64, 196, 196, 0.15);
  }

  .site-sidebar__brand {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    color: #F6F7FA;
  }

  .site-sidebar__brand:hover {
    color: #40C4C4;
  }

  .site-sidebar__brand-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    min-width: 4.25rem;
    min-height: 2.4rem;
    padding: 0.5rem 0.9rem;
    border-radius: 2px;
    border: 2px solid #40C4C4;
    background: #40C4C4;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 400;
    color: #111214;
    letter-spacing: -0.01em;
  }

  .site-sidebar__tagline {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: rgba(246, 247, 250, 0.78);
    line-height: 1.4;
  }

  .site-sidebar__content {
    flex: 1;
    padding: 0.75rem 0.5rem;
    overflow-y: auto;
  }

  .site-sidebar__nav {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  /* ── Collapsible Group ────────────────── */
  .site-sidebar__group {
    display: flex;
    flex-direction: column;
  }

  .site-sidebar__group-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    min-height: 2.2rem;
    padding: 0.45rem 0.75rem;
    border: none;
    border-radius: 2px;
    background: transparent;
    color: rgba(246, 247, 250, 0.6);
    font-family: var(--font-tech);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .site-sidebar__group-toggle .site-sidebar__chevron {
    margin-left: auto;
  }

  .site-sidebar__group-toggle:hover {
    color: var(--group-accent);
    background: rgba(255, 255, 255, 0.03);
  }

  .site-sidebar__group-toggle--active {
    color: var(--group-accent);
  }

  /* Node pip — colored dot per group */
  .site-sidebar__group-pip {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 1px;
    border: 2px solid var(--group-accent);
    background: transparent;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .site-sidebar__group[data-group-open='true'] .site-sidebar__group-pip {
    background: var(--group-accent);
  }

  .site-sidebar__group-toggle--active .site-sidebar__group-pip {
    background: var(--group-accent);
  }

  .site-sidebar__chevron {
    width: 12px;
    height: 12px;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .site-sidebar__group[data-group-open='true'] .site-sidebar__chevron {
    transform: rotate(180deg);
  }

  .site-sidebar__group-links {
    position: relative;
    display: grid;
    gap: 0.05rem;
    overflow: hidden;
    max-height: 0;
    padding-left: 0.5rem;
    transition: max-height 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-sidebar__group[data-group-open='true'] .site-sidebar__group-links {
    max-height: 24rem;
  }

  /* Vertical connecting line from parent node */
  .site-sidebar__node-line {
    position: absolute;
    left: 1.15rem;
    top: 0;
    bottom: 0.8rem;
    width: 2px;
    background: color-mix(in srgb, var(--group-accent) 20%, transparent);
    pointer-events: none;
  }

  .site-sidebar__link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.2rem;
    padding: 0.4rem 0.75rem 0.4rem 1.8rem;
    border-left: 3px solid transparent;
    border-radius: 0 2px 2px 0;
    background: transparent;
    color: rgba(246, 247, 250, 0.68);
    font-family: var(--font-tech);
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }

  /* Node dot on each child link */
  .site-sidebar__node-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 1px;
    border: 1.5px solid color-mix(in srgb, var(--group-accent) 50%, transparent);
    background: transparent;
    flex-shrink: 0;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .site-sidebar__link:hover {
    background: color-mix(in srgb, var(--group-accent) 8%, transparent);
    color: #F6F7FA;
    border-left-color: color-mix(in srgb, var(--group-accent) 40%, transparent);
  }

  .site-sidebar__link:hover .site-sidebar__node-dot {
    border-color: var(--group-accent);
    background: color-mix(in srgb, var(--group-accent) 40%, transparent);
  }

  .site-sidebar__link--active {
    border-left-color: var(--group-accent);
    background: color-mix(in srgb, var(--group-accent) 12%, transparent);
    color: var(--group-accent);
  }

  .site-sidebar__link--active .site-sidebar__node-dot {
    background: var(--group-accent);
    border-color: var(--group-accent);
  }

  .site-sidebar__ext-icon {
    opacity: 0.4;
    flex-shrink: 0;
  }

  /* ── Bottom ────────────────── */
  .site-sidebar__bottom {
    position: sticky;
    bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1rem 0.75rem;
    border-top: 1px solid rgba(64, 196, 196, 0.15);
    background: linear-gradient(180deg, rgba(17, 18, 20, 0) 0%, #111214 30%);
  }

  .site-sidebar__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 2.8rem;
    padding-inline: 1rem;
    border: 2px solid #40C4C4;
    background: #40C4C4;
    color: #111214;
    font-family: var(--font-tech);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  .site-sidebar__cta:hover {
    background: #53D3D3;
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(64, 196, 196, 0.3);
  }

  .site-sidebar__subscribe {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 2.4rem;
    padding-inline: 1rem;
    border: 2px solid rgba(232, 74, 138, 0.4);
    background: transparent;
    color: #E84A8A;
    font-family: var(--font-tech);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .site-sidebar__subscribe:hover {
    background: rgba(232, 74, 138, 0.1);
    border-color: #E84A8A;
    transform: translateY(-1px);
  }

  .site-sidebar__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .site-sidebar__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 2px;
    border: 1px solid rgba(246, 247, 250, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(246, 247, 250, 0.78);
    transition: all 0.15s ease;
  }

  .site-sidebar__social-link:hover {
    border-color: #40C4C4;
    background: rgba(64, 196, 196, 0.12);
    color: #40C4C4;
  }

  .site-sidebar__social-link svg {
    width: 0.88rem;
    height: 0.88rem;
  }

  /* ── Toggle (always visible) ────────────────── */
  .sidebar-toggle {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 70;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.28rem;
    width: 44px;
    height: 44px;
    border: 2px solid #1A1A1A;
    border-radius: 2px;
    background: #111214;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    cursor: pointer;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .sidebar-toggle:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  }

  .sidebar-toggle__bar {
    display: block;
    width: 18px;
    height: 2px;
    border-radius: 2px;
    background: #F6F7FA;
    transition: transform 0.3s ease, opacity 0.2s ease;
  }

  .sidebar-toggle[data-open='true'] .sidebar-toggle__bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .sidebar-toggle[data-open='true'] .sidebar-toggle__bar:nth-child(2) {
    opacity: 0;
  }

  .sidebar-toggle[data-open='true'] .sidebar-toggle__bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .sidebar-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(17, 18, 20, 0.5);
    z-index: 55;
    backdrop-filter: blur(4px);
  }

  .sidebar-backdrop[hidden] {
    display: none;
  }
</style>

<script>
  (() => {
    const sidebar = document.querySelector('.site-sidebar');
    const toggle = document.querySelector('[data-sidebar-toggle]');
    const backdrop = document.querySelector('[data-sidebar-backdrop]');
    if (!(sidebar instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement) || !(backdrop instanceof HTMLElement)) {
      return;
    }

    const closeTargets = sidebar.querySelectorAll('[data-sidebar-link]');

    const setOpen = (open: boolean) => {
      sidebar.dataset.sidebarOpen = open ? 'true' : 'false';
      toggle.dataset.open = open ? 'true' : 'false';
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
      backdrop.hidden = !open;
      document.body.classList.toggle('menu-open', open);
    };

    const close = () => setOpen(false);
    const isOpen = () => sidebar.dataset.sidebarOpen === 'true';

    toggle.addEventListener('click', () => setOpen(!isOpen()));
    backdrop.addEventListener('click', close);

    closeTargets.forEach((target) => {
      target.addEventListener('click', close);
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isOpen()) close();
    });

    // Group accordion toggles
    const groupToggles = sidebar.querySelectorAll('[data-group-toggle]');
    groupToggles.forEach((btn) => {
      btn.addEventListener('click', () => {
        const group = btn.closest('[data-nav-group]');
        if (!(group instanceof HTMLElement)) return;
        const isGroupOpen = group.dataset.groupOpen === 'true';
        group.dataset.groupOpen = isGroupOpen ? 'false' : 'true';
        btn.setAttribute('aria-expanded', isGroupOpen ? 'false' : 'true');
      });
    });
  })();
</script>
