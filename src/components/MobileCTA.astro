---
/**
 * Sticky mobile CTA bar. Visible only on touch devices below 768px.
 * Sits in the thumb zone at the bottom of the screen.
 */
---

<div class="mobile-cta" role="navigation" aria-label="Quick actions">
  <a href="/contact" class="mobile-cta__btn mobile-cta__btn--primary">Contact Ken</a>
  <a href="https://wa.me/15069532678" class="mobile-cta__btn mobile-cta__btn--wa" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
  <a href="/book" class="mobile-cta__btn mobile-cta__btn--book">Book a Call</a>
</div>

<style>
  .mobile-cta {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-cta {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 900;
      display: flex;
      gap: 0.5rem;
      padding: 0.6rem 0.75rem;
      padding-bottom: calc(0.6rem + env(safe-area-inset-bottom, 0px));
      background: rgba(17, 18, 20, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1px solid rgba(64, 196, 196, 0.2);
    }

    .mobile-cta__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      border-radius: 8px;
      font-family: var(--font-tech);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.2s ease, transform 0.15s ease;
      -webkit-tap-highlight-color: transparent;
    }

    .mobile-cta__btn:active {
      transform: scale(0.97);
    }

    .mobile-cta__btn--primary {
      flex: 1;
      background: #40C4C4;
      color: #0F1112;
      padding: 0 1rem;
    }

    .mobile-cta__btn--wa {
      width: 44px;
      flex-shrink: 0;
      background: #25D366;
      color: #FFFFFF;
    }

    .mobile-cta__btn--book {
      flex: 1;
      background: rgba(255, 255, 255, 0.1);
      color: #F6F7FA;
      border: 1px solid rgba(246, 247, 250, 0.15);
      padding: 0 1rem;
    }

    /* Push page content above the bar */
    :global(body) {
      padding-bottom: calc(60px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>
