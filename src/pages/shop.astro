---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
import { CATALOG } from '../lib/catalog';
import { CATEGORY_LABELS } from '../lib/types';
import type { CatalogCategory } from '../lib/types';

const categories = [...new Set(CATALOG.map((p) => p.category))] as CatalogCategory[];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'The Market — 3D3D',
  description: 'Ready-made 3D printed products. Gifts, functional parts, and engineering-grade fabrication. Browse the catalog and order.',
  url: 'https://3d3d.ca/shop',
};
---

<BaseLayout title="The Market | 3D3D" description="Ready-made 3D printed products. Gifts, functional parts, flex prints, and marine hardware. Browse the catalog and order." activePath="/shop" schema={schema}>

  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/images/splash-bg-market.png'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Shop'}]} />
            <p class="hp-card__eyebrow mt-4" style="color: #FF6B2B;">Shop / Store</p>
            <h1 class="hp-card__title mt-2 mb-4">The Market</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Ready-to-order parts and prints. Everything here has been printed, tested, and used before it went on sale. {CATALOG.length} products and growing.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <button type="button" class="hp-cta hp-cta--accent" style="background: #FF6B2B; border-color: #FF6B2B;" data-dialog-open="dlg-quote">Request a Quote</button>
              <a href="/merch" class="hp-cta hp-cta--glass">Merch Store</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Product Catalog -->
    {categories.map((cat, idx) => {
      const products = CATALOG.filter((p) => p.category === cat);
      const label = CATEGORY_LABELS[cat] ?? cat;
      const accents = ['#E84A8A', '#FF6B2B', '#AAFF2A', '#40C4C4'];
      const accent = accents[idx % accents.length];
      const bgIdx = (idx % 3) + 1;
      return (
        <section class="hp-section" style={`--section-accent: ${accent};`}>
          <div class="hp-section__bg">
            <div class="hp-section__bg-img hp-section__bg-img--active" style={`background-image: url('/media/generated/fab-0${bgIdx}.jpg'); background-position: center;`}></div>
          </div>
          <div class="hp-section__vignette"></div>
          <div class="hp-section__scrim"></div>
          <div class="hp-section__grain"></div>

          <div class="hp-section__shell hp-section__shell--start">
            <article class="hp-card">
              <div class="hp-card__inner">
                <p class="hp-card__eyebrow">{label}</p>
                <h2 class="hp-card__title mt-2 mb-6">{products.length} Products</h2>

                <div class="shop-grid">
                  {products.map((product) => (
                    <article class="shop-product">
                      <div class="shop-product__img-wrap">
                        {product.images?.[0] ? (
                          <img src={product.images[0]} alt={product.name} class="shop-product__img" loading="lazy" />
                        ) : (
                          <div class="shop-product__img-placeholder">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                          </div>
                        )}
                      </div>
                      <div class="shop-product__info">
                        <h3 class="shop-product__name">{product.name}</h3>
                        <p class="shop-product__desc">{product.description.slice(0, 80)}...</p>
                        <div class="shop-product__meta">
                          <span class="shop-product__price">
                            From ${product.basePrice.toFixed(2)}
                          </span>
                          <span class="shop-product__materials">
                            {product.material}
                          </span>
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            </article>
          </div>
        </section>
      );
    })}

    <!-- CTA Section -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner" style="text-align: center; align-items: center;">
            <p class="hp-card__eyebrow">Custom Work</p>
            <h2 class="hp-card__title mt-2 mb-4">Don't see what you need?</h2>
            <p class="hp-card__copy" style="max-width: 36rem; text-align: center;">
              The catalog is just the starting point. We fabricate custom parts for marine, automotive, motorsport, and industrial applications. Upload your file or describe your project.
            </p>
            <div class="hp-card__cta-row mt-6">
              <button type="button" class="hp-cta hp-cta--accent" data-dialog-open="dlg-quote">Get a Custom Quote</button>
            </div>

            <div class="mt-8" style="text-align: left; width: 100%;">
              <PageNextActions actions={[
                {label: 'Materials Guide', href: '/materials', description: 'Choose the right material for your part.', accent: 'teal'},
                {label: 'The Fleet', href: '/fleet', description: 'See the machines behind the catalog.', accent: 'magenta'},
              ]} />
            </div>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(220px, 100%), 1fr));
    gap: 0.8rem;
  }
  .shop-product {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .shop-product:hover {
    border-color: rgba(64, 196, 196, 0.4);
    transform: translateY(-2px);
  }
  .shop-product__img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.4);
  }
  .shop-product__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .shop-product__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: rgba(246, 247, 250, 0.2);
  }
  .shop-product__info {
    padding: 1rem;
    display: grid;
    gap: 0.35rem;
  }
  .shop-product__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.15;
    color: rgba(246, 247, 250, 0.9);
  }
  .shop-product__desc {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.5;
    color: rgba(246, 247, 250, 0.4);
  }
  .shop-product__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.3rem;
  }
  .shop-product__price {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-teal-primary);
  }
  .shop-product__materials {
    font-family: var(--font-tech);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.3);
  }
</style>
