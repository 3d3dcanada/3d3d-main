---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const agencySchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "3D3D Media Studio",
  "description": "Content production studio using AI tools and automation for businesses in Atlantic Canada.",
  "keywords": "AI content production, video production, social media automation, content creation, AI tools",
  "url": "https://3d3d.ca/media"
};

const jobPostingSchema = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": "Content Pipeline Lead",
  "description": "3D3D Media is a content production studio in Fredericton, NB. We are hiring someone to run our AI-powered content pipeline.",
  "datePosted": "2026-03-29",
  "validThrough": "2026-12-31",
  "employmentType": "CONTRACTOR",
  "hiringOrganization": { "@type": "Organization", "name": "3D3D Media", "sameAs": "https://3d3d.ca", "logo": "https://3d3d.ca/og-image.png" },
  "jobLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "Fredericton", "addressRegion": "NB", "addressCountry": "CA" } },
  "baseSalary": { "@type": "MonetaryAmount", "currency": "CAD", "value": { "@type": "QuantitativeValue", "value": 100, "unitText": "WEEK" } },
  "qualifications": "Strong visual sense and hands-on experience with AI content tools.",
  "skills": "AI content tools, social media production, video editing, prompt writing, workflow automation.",
  "jobBenefits": "Seated Anthropic Claude subscription, Google Workspace, cooperative profit sharing, complete process autonomy."
};

const services = [
  { title: 'Brand Training', copy: 'We teach AI tools your brand voice, your past work, and your technical language. The result: generated content that sounds like you wrote it.', use: 'Ready in 14 days.', icon: 'M22 12h-4l-3 9L9 3l-3 9H2' },
  { title: 'Short-Form Video', copy: 'High-volume short-form video and macro photography. We shoot the raw footage, AI handles the clipping, transcription, and formatting for TikTok, Reels, and Shorts.', use: 'Starting at $250/mo.', icon: 'M3 3h18v18H3z M8.5 8.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z' },
  { title: 'Automation Setup', copy: 'We connect your content tools to your CMS and scheduling platforms using Make and n8n. Write once, publish everywhere, automatically.', use: 'Full setup included.', icon: 'M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6' },
  { title: 'AI Prompt Systems', copy: 'We build multi-step prompt chains that turn rough ideas into publishable content. Tuned for Claude and GPT-4.', use: 'Custom prompt libraries.', icon: 'M12 12m-3 0a3 3 0 106 0a3 3 0 10-6 0' },
  { title: 'AI Image Generation', copy: 'Midjourney, ComfyUI, and Stable Diffusion set up for your brand. Photorealistic backgrounds, concept art, and product shots without stock photography.', use: 'No stock photos needed.', icon: 'M21 16V8l-7-4a2 2 0 00-2 0l-7 4v8l7 4a2 2 0 002 0l7-4z' },
  { title: 'Open Source Docs', copy: 'We help companies open-source their internal tools and write technical documentation formatted properly for GitHub.', use: 'Documentation that scales.', icon: 'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77' },
];
---

<BaseLayout
  title="3D3D Media — Content Production Studio | Fredericton, NB"
  description="3D3D Media makes content for businesses using AI tools and automation. Video, social media, brand assets. Fredericton-based, serving Atlantic Canada and beyond."
  activePath="/media"
  schema={[jobPostingSchema, agencySchema]}
>

  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/images/media_agency_hero.png'); background-position: center 30%;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Media Studio'}]} />
            <p class="hp-card__eyebrow mt-4">3D3D Media Studio</p>
            <h1 class="hp-card__title mt-2 mb-4">We make your content. AI does the heavy lifting.</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              You tell us what you need. We build automated pipelines that produce video, social posts, and brand assets at scale — using AI tools and real editorial oversight.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="#services" class="hp-cta hp-cta--accent">Our Services</a>
              <a href="#role" class="hp-cta hp-cta--glass">Open Positions</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Philosophy -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in" style="text-align: center;">
          <div class="hp-card__inner" style="align-items: center;">
            <p class="hp-card__eyebrow">Philosophy</p>
            <h2 class="hp-card__title mt-2 mb-4" style="max-width: 48rem;">You decide the direction. AI handles the production.</h2>
            <p class="hp-card__copy" style="max-width: 48rem; text-align: center;">
              AI can generate content fast, but it still needs a human with taste to steer it. We set up your brand in AI tools, automate the repetitive production work, and keep a real person in charge of the final cut.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: Services -->
    <section class="hp-section" id="services" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Services</p>
            <h2 class="hp-card__title mt-2 mb-2">What We Offer</h2>
            <p class="hp-card__copy mb-6">We build content systems for your business. Not one-off posts — repeatable pipelines you can run every week.</p>

            <div class="media-services-grid">
              {services.map((s) => (
                <div class="media-service-card">
                  <h3 class="media-service-card__title">{s.title}</h3>
                  <p class="media-service-card__copy">{s.copy}</p>
                  <span class="media-service-card__use">{s.use}</span>
                </div>
              ))}
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 4: Community Pool -->
    <section class="hp-section" style="--section-accent: #AAFF2A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow" style="color: var(--color-magenta-primary);">Community Production</p>
            <h2 class="hp-card__title mt-2 mb-4">Pool resources. Share the output.</h2>
            <p class="hp-card__copy">Small businesses chip in together to fund shared content production. Everyone in the pool gets access to the videos, templates, and automation we build.</p>
            <p class="hp-card__copy mt-3">Starting at $100/month — that gets you 3 hours of dedicated content production per week on your projects.</p>

            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="https://ko-fi.com/3d3dcanada" target="_blank" rel="noreferrer" class="hp-cta hp-cta--accent" style="background: var(--color-magenta-primary); border-color: var(--color-magenta-primary);">Join the Pool</a>
              <a href="/contact?subject=media-pool" class="hp-cta hp-cta--glass">Ask About Pricing</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 5: Sponsorship -->
    <section class="hp-section" style="--section-accent: #40C4C4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/images/media_community_sponsors.png'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow" style="color: #FF6B2B;">Sponsorship & Outreach</p>
            <h2 class="hp-card__title mt-2 mb-4">Have us document your build.</h2>
            <p class="hp-card__copy">Brands and companies can hire us to film and document community projects, makerspaces, and open-source hardware builds.</p>
            <ul class="media-sponsor-list mt-4">
              <li><strong>Open Source Hardware Projects:</strong> We shoot, edit, and document your repository.</li>
              <li><strong>Community Events:</strong> Professional b-roll and macro-production for local maker events.</li>
              <li><strong>Corporate Sponsorship:</strong> Fund free content tools and templates for small creators.</li>
            </ul>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="/contact?subject=sponsorship" class="hp-cta hp-cta--accent" style="background: #FF6B2B; border-color: #FF6B2B;">Sponsor a Project</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 6: The Role -->
    <section class="hp-section" id="role" style="--section-accent: #E84A8A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/images/media_asset_production.png'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Hiring</p>
            <h2 class="hp-card__title mt-2 mb-4">The first hire runs the whole thing.</h2>
            <p class="hp-card__copy mb-6">We are not looking for someone to grind out posts. We need someone who can set up the tools and systems that produce them.</p>

            <div class="media-role-grid">
              <div class="media-role-block">
                <h3 class="media-role-block__title">The Setup</h3>
                <ul class="media-role-block__list">
                  <li>You manage the art direction and the business context.</li>
                  <li>Your seated Anthropic Claude subscription manages the production overhead.</li>
                  <li>You dictate the workflows. You don't have to write the repetitive code; you build the system that writes it.</li>
                </ul>
              </div>
              <div class="media-role-block">
                <h3 class="media-role-block__title">What you get</h3>
                <ul class="media-role-block__list">
                  <li>$100/week guaranteed baseline <span class="media-role-note">(grows as the Ko-fi pool grows)</span></li>
                  <li><strong style="color: var(--color-teal-primary);">Seated Anthropic Claude subscription</strong> — funded and yours to command</li>
                  <li>Google Workspace subscription</li>
                  <li>Cooperative node ownership — what you put into the system, you own</li>
                </ul>
              </div>
            </div>

            <div class="media-role-highlight mt-4">
              <h3 class="media-role-block__title">The Person We Need</h3>
              <p class="hp-card__copy">You need a good eye and zero patience for doing things the slow way.</p>
              <p class="hp-card__copy mt-2">If you are someone who works best when you can skip the tedious parts and stay in the creative zone — this is the role for you.</p>
              <p class="hp-card__copy mt-2">If you are tired of people telling you how to be creative — come build the system instead.</p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 7: Apply CTA -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in" style="text-align: center;">
          <div class="hp-card__inner" style="align-items: center;">
            <p class="hp-card__eyebrow">Apply</p>
            <h2 class="hp-card__title mt-2 mb-4">Build the System.</h2>
            <p class="hp-card__copy" style="max-width: 36rem; text-align: center;">
              Send a message. Show us something you built with AI — a prompt, a workflow, a system. No cover letter. No resume padding. Just show your work.
            </p>
            <div class="hp-card__cta-row mt-6">
              <a href="/contact?subject=agency" class="hp-cta hp-cta--accent">Contact 3D3D Media</a>
            </div>

            <div class="mt-8" style="text-align: left; width: 100%;">
              <PageNextActions actions={[
                {label: 'About the Cooperative', href: '/about', description: 'Read about our decentralized structure.', accent: 'teal'},
                {label: 'Get a Quote', href: '/', description: 'Commission physical fabrication.', accent: 'magenta'},
              ]} />
            </div>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .media-services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: 0.8rem;
  }
  .media-service-card {
    display: grid;
    gap: 0.6rem;
    padding: clamp(1.2rem, 2.5vw, 1.6rem);
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .media-service-card:hover {
    border-color: rgba(64, 196, 196, 0.4);
    transform: translateY(-3px);
  }
  .media-service-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.9);
  }
  .media-service-card__copy {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.65;
    color: rgba(246, 247, 250, 0.45);
  }
  .media-service-card__use {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--color-teal-primary);
    margin-top: auto;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .media-pool-meter {
    max-width: 32rem;
  }
  .media-pool-meter__labels {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.45);
    margin-bottom: 0.5rem;
  }
  .media-pool-meter__labels strong {
    color: rgba(246, 247, 250, 0.9);
  }
  .media-pool-meter__bar {
    height: 8px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    overflow: hidden;
  }
  .media-pool-meter__fill {
    height: 100%;
    width: var(--pool-pct);
    background: var(--color-magenta-primary);
    box-shadow: 0 0 10px rgba(232, 74, 138, 0.4);
  }

  .media-sponsor-list {
    margin: 0;
    padding-left: 1.25rem;
    color: rgba(246, 247, 250, 0.5);
    line-height: 1.6;
    font-size: 0.88rem;
  }
  .media-sponsor-list li {
    margin-bottom: 0.6rem;
  }
  .media-sponsor-list li strong {
    color: rgba(246, 247, 250, 0.85);
  }

  .media-role-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: 1rem;
  }
  .media-role-block {
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }
  .media-role-block__title {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.9);
  }
  .media-role-block__list {
    margin: 0;
    padding-left: 1.25rem;
    color: rgba(246, 247, 250, 0.5);
    line-height: 1.6;
    font-size: 0.85rem;
  }
  .media-role-block__list li {
    margin-bottom: 0.6rem;
  }
  .media-role-note {
    display: block;
    font-size: 0.82em;
    color: rgba(246, 247, 250, 0.35);
    font-style: italic;
  }
  .media-role-highlight {
    padding: 1.5rem;
    background: linear-gradient(145deg, rgba(0, 0, 0, 0.3), rgba(64, 196, 196, 0.05));
    border: 1px solid rgba(64, 196, 196, 0.25);
    border-radius: 2px;
  }
</style>
