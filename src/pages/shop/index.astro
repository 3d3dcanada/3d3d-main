---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageNextActions from '../../components/PageNextActions.astro';
import { CATALOG, SHOP_CATEGORIES, SOURCE_LABELS, getCatalogItemStartingPrice, getCatalogItemHasPriceRange } from '../../lib/catalog';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: '3D3D Print Shop',
  description: 'Custom 3D printing. 27 products, 5 materials. Tested designs, fast turnaround.',
  url: 'https://3d3d.ca/shop',
  areaServed: 'Worldwide',
};

---

<BaseLayout title="Shop | 3D3D" description="Custom 3D printed products. PLA, PETG, TPU, ABS, ASA. Tested designs, fast turnaround." schema={schema} activePath="/shop">
  <div class="pt-8">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Shop'}]} />
    </div>
    {/* Hero strip */}
    <section class="px-6 lg:px-12 py-10 relative overflow-hidden bg-surface-secondary">
      <div class="max-w-7xl mx-auto">
        <p class="font-body text-xs uppercase tracking-widest text-teal-dark mb-2">3D3D Shop</p>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary leading-tight">
          Print Shop
        </h1>
        <p class="mt-3 text-text-secondary max-w-xl text-sm sm:text-base">
              Tested products, organizers, gifts, and display pieces.
            </p>
        <div class="flex flex-wrap gap-4 mt-6">
          <a href="/quote?source=shop-hero" class="btn-primary" data-analytics-event="quote_started" data-analytics-source="shop-hero">
            Get a Quote
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 7h8m-3-3 3 3-3 3"/></svg>
          </a>
          <a href="/opportunities" class="btn-secondary">
                  Opportunities
                </a>
        </div>
      </div>
    </section>

    {/* Category filter tabs */}
    <section class="px-6 lg:px-12 py-4 overflow-x-auto bg-surface-primary">
      <div class="max-w-7xl mx-auto flex gap-2 flex-nowrap" id="category-tabs">
        <button class="category-tab active font-body text-xs uppercase tracking-wider px-4 py-2 rounded-full whitespace-nowrap transition-all" data-cat="all">
          All
        </button>
        {SHOP_CATEGORIES.map((cat) => (
          <button
            class="category-tab font-body text-xs uppercase tracking-wider px-4 py-2 rounded-full whitespace-nowrap transition-all"
            data-cat={cat.id}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </section>

    {/* Product grid */}
    <section class="px-6 lg:px-12 py-8 bg-surface-primary">
      <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="product-grid">
        {CATALOG.map((item) => {
          const startPrice = getCatalogItemStartingPrice(item);
          const hasRange = getCatalogItemHasPriceRange(item);
          const sourceInfo = item.source ? SOURCE_LABELS[item.source] : null;

          return (
            <a
              href={`/shop/${item.id}`}
              class="product-card group relative rounded-2xl overflow-hidden transition-all duration-300"
              data-category={item.category}
              data-analytics-event="featured_product_clicked"
              data-analytics-source="shop-grid"
            >
              {/* Image */}
              <div class="aspect-[4/3] overflow-hidden relative bg-surface-tertiary">
                {item.images[0] ? (
                  <img
                    src={item.images[0]}
                    alt={item.name}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="font-body text-xs uppercase tracking-widest text-text-muted">No image</span>
                  </div>
                )}

                {/* Badges */}
                <div class="absolute top-2 left-2 flex gap-1.5 flex-wrap">
                  {sourceInfo && (
                    <span class="badge" style={`background: ${sourceInfo.color};`}>
                      {sourceInfo.label}
                    </span>
                  )}
                  {item.isNew && (
                    <span class="badge badge-magenta">
                      New
                    </span>
                  )}
                  {item.isPopular && (
                    <span class="badge badge-teal">
                      Popular
                    </span>
                  )}
                </div>
              </div>

              {/* Info */}
              <div class="p-4 bg-surface-card">
                <p class="font-body text-[10px] uppercase tracking-widest text-text-muted mb-1">{item.material}</p>
                <h3 class="font-display text-sm font-semibold text-text-primary leading-snug group-hover:text-teal-primary transition-colors">
                  {item.name}
                </h3>
                <div class="flex items-baseline justify-between mt-2">
                  <span class="font-display text-lg font-bold text-teal-primary">
                    {hasRange ? 'From ' : ''}${startPrice.toFixed(2)}
                  </span>
                  <svg class="w-4 h-4 text-text-muted group-hover:text-teal-primary transition-all duration-200 group-hover:translate-x-0.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    <path d="M3 7h8m-3-3 3 3-3 3" />
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-6 lg:px-12 pb-8">
      <PageNextActions actions={[
        {label: 'Get a Quote', href: '/quote', description: 'Need something custom? Upload your files and describe the project.', accent: 'teal'},
        {label: 'Materials Guide', href: '/materials', description: 'Compare engineering compounds by environment and performance.', accent: 'orange'},
        {label: 'Contact', href: '/contact', description: 'Questions about a product or custom order? Reach out.', accent: 'magenta'},
      ]} />
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.category-tab');
    const cards = document.querySelectorAll<HTMLElement>('.product-card');

    function setActiveTab(activeTab: HTMLButtonElement) {
      tabs.forEach((t) => {
        if (t === activeTab) {
          t.classList.add('active');
        } else {
          t.classList.remove('active');
        }
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const cat = tab.dataset.cat;
        setActiveTab(tab);

        cards.forEach((card) => {
          if (cat === 'all' || card.dataset.category === cat) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>

<style>
  .category-tab {
    background: var(--color-surface-card);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-light);
  }
  
  .category-tab:hover {
    background: var(--color-surface-secondary);
    border-color: var(--color-teal-light);
  }
  
  .category-tab.active {
    background: var(--color-teal-primary);
    color: white;
    border-color: var(--color-teal-primary);
  }
  
  .product-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-light);
    box-shadow: 0 2px 8px oklch(0 0 0 / 0.04);
  }
  
  .product-card:hover {
    border-color: var(--color-teal-light);
    box-shadow: 0 4px 20px oklch(from var(--color-teal-primary) l c h / 0.15);
    transform: translateY(-2px);
  }
  
  .badge {
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: white;
  }
  
  .badge-magenta {
    background: var(--color-magenta-primary);
  }
  
  .badge-teal {
    background: var(--color-teal-primary);
    color: white;
  }
</style>
