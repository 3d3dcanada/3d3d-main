---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EventSeries',
  name: '3D3D Events & Projects',
  description: 'The logbook of offshore fabrication work. Races, deployments, and jobs where having a specialist aboard changes the outcome.',
  organizer: {
    '@type': 'Organization',
    name: '3D3D',
    url: 'https://3d3d.ca',
  },
  location: {
    '@type': 'Place',
    name: 'Coastal and international routes',
  },
};

const timeline = [
  {
    date: 'March 2025',
    title: '3D3D Founded',
    body: 'Operations begin from an RV. Three printers running off a generator — $30 a day in gas, 35-degree heat. Daily printing, daily failing, daily rebuilding.',
    status: 'completed',
  },
  {
    date: 'March 2025 — March 2026',
    title: 'One Year of Daily Commitment',
    body: 'A full year of daily production. Every material tested. Every failure documented. Marine hardware, automotive restoration, custom fabrication. Building the portfolio one job at a time.',
    status: 'completed',
  },
  {
    date: 'March 2026',
    title: 'Flagship Machine Acquired',
    body: 'After a year of documented daily fabrication work, 3D3D acquired its flagship enclosed CoreXY machine. Active chamber heating, automatic tool changing, and input shaping. Built for engineering-grade materials and offshore conditions.',
    status: 'active',
  },
  {
    date: 'June 2026',
    title: 'Newport-Bermuda Race — 120th Running',
    body: 'Aboard CSM the Mariner for the 120th running of one of offshore sailing\'s most demanding races. An enclosed CoreXY will be printing live — real parts, real problems, real conditions. Newport, Rhode Island to Bermuda. 635 nautical miles.',
    status: 'upcoming',
  },
];
---

<BaseLayout
  title="The Logbook | 3D3D"
  description="Offshore races, deployments, and on-location fabrication work. If you have a race, a refit, or a passage, get in touch."
  schema={schema}
  activePath="/events"
>
  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/afternoon-racing-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Events'}]} />
            <p class="hp-card__eyebrow mt-4">The Logbook</p>
            <h1 class="hp-card__title mt-2 mb-4">Races, Deployments<br />& Live Projects</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Offshore racing is an exercise in controlled degradation. Things break. Spinnaker pole end fittings crack during night peels. Electronics brackets shatter when the hull slams into a Gulf Stream trough. Having a fabricator aboard changes the tactical outcome.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Timeline -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/evening-fleet.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Timeline</p>
            <h2 class="hp-card__title mt-2 mb-6">The Campaign So Far.</h2>
            
            <div class="space-y-6">
              {timeline.map((item, i) => (
                <div class="border-l-2 pl-4 pb-2" style={`border-color: ${item.status === 'upcoming' ? 'rgba(232, 74, 138, 0.4)' : '#e84a8a'};`}>
                  <span class="font-tech text-xs font-bold uppercase tracking-widest" style={`color: ${item.status === 'upcoming' ? '#f07aa8' : '#e84a8a'};`}>{item.date}</span>
                  <h3 class="font-display text-xl text-white mt-1 mb-2">{item.title}</h3>
                  <p class="hp-card__copy text-sm">{item.body}</p>
                </div>
              ))}
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: Credentials & Actions -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/race-morning-crew.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Offshore Log</p>
            <h2 class="hp-card__title mt-2 mb-4">The ocean taught me everything I build for.</h2>
            <p class="hp-card__copy mb-6">
              My first time sailing was a duo passage with Christopher Stanmore-Major. Halifax, Nova Scotia to Antigua. No experience. We hit a cat-one storm — 70-knot sustained winds, 90-knot gusts. That trip taught me everything that matters about what breaks, why it breaks, and what you have to accept when there is no option to stop.
            </p>

            <div class="flex flex-col gap-2 mb-8 bg-black/30 border border-white/5 p-4 rounded text-sm text-gray-300">
              <span class="font-bold text-white mb-1">Credentials:</span>
              <span>• Halifax → Antigua (duo passage, cat-one storm)</span>
              <span>• Multiple transatlantic passages</span>
              <span>• Two-day solo sail — Saint John River</span>
              <span>• Newport-Bermuda 2026 (Upcoming)</span>
            </div>

            <PageNextActions actions={[
              {label: 'Get a Quote', href: '/quote', description: 'Custom prints for your event or project.', accent: 'teal'},
              {label: 'Join the Network', href: '/network', description: 'Collaborate with 3D3D on future events.', accent: 'magenta'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
</style>
