---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact 3D3D',
  description: 'Request service, send a file, or start a conversation about custom fabrication.',
  url: 'https://3d3d.ca/contact',
};
---

<BaseLayout title="Contact | 3D3D" description="Custom fabrication, worldwide. Tell us the problem and we will assess whether we can solve it, and exactly how. Marine hardware, discontinued parts, on-site deployment." activePath="/contact" schema={schema}>

  <main class="hp-home">
    
    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Contact'}]} />
            <p class="hp-card__eyebrow mt-4">Direct Line</p>
            <h1 class="hp-card__title mt-2 mb-4">Tell us the problem.</h1>
            <p class="hp-card__copy">
              We will assess whether we can solve it, and tell you exactly how we will do it. Marine hardware, discontinued parts, on-site deployment.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="#form" class="hp-cta hp-cta--accent">Send Us a Message</a>
              <a href="https://wa.me/15069532678" target="_blank" class="hp-cta hp-cta--glass">WhatsApp</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Intake Paths -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/golden-hour-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">The Process</p>
            <h2 class="hp-card__title mt-2 mb-6">How It Works</h2>

            <div class="flex flex-col gap-6">
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">01 / Remote Assessment</strong>
                <p class="hp-card__copy mt-1">Send high-resolution photos of the broken hardware, the surrounding mounting area, and a brief description of the failure. Include caliper measurements if you have them. We assess what can be rebuilt, what material it requires, and what it will cost.</p>
              </div>
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">02 / Reverse Engineering</strong>
                <p class="hp-card__copy mt-1">Box up the shattered part, the worn-out gear, or the broken bracket. Ship it to our workshop. We measure, model, and rebuild it in the correct material with the correct tolerances, then ship it back or bring it aboard.</p>
              </div>
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">03 / Direct Engagement</strong>
                <p class="hp-card__copy mt-1">For on-site deployment, extended refit support, race campaigns, or complex structural problems aboard a vessel, contact us directly. Tell us where the vessel is, what the job is, and when you need it done.</p>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: The Form -->
    <section id="form" class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Intake</p>
            <h2 class="hp-card__title mt-2 mb-6">Send Us the Details</h2>
            
            <form action="https://formspree.io/f/mldlydbl" method="POST" class="contact-page-form" data-analytics-submit="contact_submitted" data-analytics-source="contact-page">
              <input type="hidden" name="_subject" value="Contact Request | 3D3D" />
              <div aria-hidden="true" style="position: absolute; left: -100vw; width: 1px; height: 1px; overflow: hidden;">
                <label for="contact-website">Leave this field blank</label>
                <input type="text" id="contact-website" name="_gotcha" tabindex="-1" autocomplete="off" />
              </div>
              
              <div class="form-grid">
                <div class="form-field">
                  <label for="name">Name</label>
                  <input type="text" id="name" name="name" required placeholder="Your name" />
                </div>
                <div class="form-field">
                  <label for="email">Email</label>
                  <input type="email" id="email" name="email" required placeholder="you@example.com" />
                </div>
              </div>
              
              <div class="form-field mt-4">
                <label for="subject">What do you need?</label>
                <select id="subject" name="subject">
                  <option value="marine-hardware">Marine Hardware: Broken or Discontinued</option>
                  <option value="on-site">On-Site Deployment: Race, Refit, or Passage</option>
                  <option value="remote-assessment">Remote Assessment: Send Photos</option>
                  <option value="reverse-engineering">Reverse Engineering: Ship the Part</option>
                  <option value="automotive">Automotive Restoration</option>
                  <option value="other">Other</option>
                </select>
              </div>
              
              <div class="form-field mt-4">
                <label for="message">Describe your project or problem</label>
                <textarea id="message" name="message" rows="4" required placeholder="Where is the vessel? What broke? What do you need? We will take it from there."></textarea>
              </div>
              
              <div class="form-field mt-4">
                <label for="file">Attach a file (optional)</label>
                <input type="file" id="file" name="attachment" accept=".jpg,.jpeg,.png,.pdf,.stl,.step,.3mf" />
              </div>
              
              <div class="form-consent mt-6">
                <input type="checkbox" id="casl-consent" name="casl_consent" value="yes" required />
                <label for="casl-consent">
                  I consent to receiving commercial electronic messages from 3D3D. You may unsubscribe at any time. See our <a href="/casl">CASL policy</a> and <a href="/privacy">privacy policy</a>.
                </label>
              </div>
              
              <button type="submit" class="hp-cta hp-cta--accent mt-6">Send Message →</button>
            </form>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .form-field {
    display: grid;
    gap: 0.4rem;
  }
  .form-field label {
    font-family: var(--font-tech);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }
  .form-field input[type="text"],
  .form-field input[type="email"],
  .form-field select,
  .form-field textarea,
  .form-field input[type="file"] {
    width: 100%;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    padding: 0.75rem;
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.2s ease;
  }
  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-teal-primary);
  }
  .form-consent {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .form-consent input[type="checkbox"] {
    margin-top: 0.2rem;
  }
  .form-consent a {
    color: var(--color-teal-primary);
    text-decoration: underline;
  }
</style>
