---
interface Props {
  class?: string;
  tag?: string;
  variant?: 'default' | 'feature' | 'flat' | 'organic';
  hover?: boolean;
}

const {
  class: className = '',
  tag = 'div',
  variant = 'default',
  hover = true,
} = Astro.props;

const Tag = tag as any;

// Organic border radius variations
const variantStyles = {
  default: 'rounded-organic',
  feature: 'rounded-feature',
  flat: 'rounded-md',
  organic: 'rounded-lg rounded-br-sm',
};
---

<Tag
  class:list={[
    'card',
    variantStyles[variant],
    hover && 'hover:scale-[1.02]',
    'transition-all duration-300',
    'p-6',
    className,
  ]}
>
  <slot />
</Tag>
