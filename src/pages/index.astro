  <script is:inline>
    (() => {
      const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
      const sectionItems = Array.from(document.querySelectorAll('[data-reveal-section]'));
      const parallaxItems = Array.from(document.querySelectorAll('[data-parallax]'));

      const updateVisibleState = () => {
        const threshold = window.innerHeight + 300;

        revealItems.forEach((item) => {
          if (!(item instanceof HTMLElement)) return;
          if (item.getBoundingClientRect().top < threshold) {
            item.classList.add('revealed');
          }
        });

        sectionItems.forEach((item) => {
          if (!(item instanceof HTMLElement)) return;
          if (item.getBoundingClientRect().top < threshold) {
            item.classList.add('revealed-section');
          }
        });

        parallaxItems.forEach((item) => {
          if (!(item instanceof HTMLElement)) return;
          const host = item.parentElement instanceof HTMLElement ? item.parentElement : item;
          const rect = host.getBoundingClientRect();
          const speed = Number(item.dataset.parallax || '0.3');
          item.style.transform = `translate3d(0, ${rect.top * speed}px, 0)`;
        });
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(() => {
          updateVisibleState();
          ticking = false;
        });
      };

      updateVisibleState();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
    })();

    (() => {
      const drawer = document.getElementById('service-drawer');
      const content = document.getElementById('drawer-content');
      const triggers = Array.from(document.querySelectorAll('[data-drawer-trigger]'));

      if (!(drawer instanceof HTMLElement) || !(content instanceof HTMLElement) || triggers.length === 0) {
        return;
      }

      const closeTargets = () => Array.from(drawer.querySelectorAll('[data-drawer-close]'));
      let closeTimer = 0;

      const closeDrawer = () => {
        drawer.dataset.open = 'false';
        document.body.classList.remove('drawer-open');
        window.clearTimeout(closeTimer);
        closeTimer = window.setTimeout(() => {
          drawer.hidden = true;
          content.innerHTML = '';
        }, 320);
      };

      const openDrawer = (templateId) => {
        const template = document.getElementById(templateId);
        if (!(template instanceof HTMLTemplateElement)) return;

        window.clearTimeout(closeTimer);
        content.innerHTML = template.innerHTML;
        drawer.hidden = false;
        document.body.classList.add('drawer-open');

        window.requestAnimationFrame(() => {
          drawer.dataset.open = 'true';
        });
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          if (!(trigger instanceof HTMLElement)) return;
          const templateId = trigger.dataset.drawerId;
          if (!templateId) return;
          openDrawer(templateId);
        });
      });

      drawer.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-drawer-close]') : null;
        if (!target) return;
        closeDrawer();
      });

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && drawer.dataset.open === 'true') {
          closeDrawer();
        }
      });

      closeTargets().forEach((target) => {
        target.addEventListener('click', closeDrawer);
      });
    })();
  </script>
</BaseLayout>

