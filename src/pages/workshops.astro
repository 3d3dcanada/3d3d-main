---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
import { WORKSHOPS, PRICING_TIERS } from '../data/workshops';

const timeline = [
  { date: 'March 2025', title: '3D3D Founded', body: 'Operations began mobile. Three printers running production daily, testing materials and processes in demanding conditions from the start.', status: 'completed' },
  { date: 'March 2025 — March 2026', title: 'One Year of Daily Production', body: 'A full year of daily output. Every material tested, every failure documented. Marine hardware, automotive restoration, custom fabrication — building capability one job at a time.', status: 'completed' },
  { date: 'March 2026', title: 'Flagship Machine Acquired', body: 'After a year of documented daily fabrication work, 3D3D acquired its flagship enclosed CoreXY machine. Active chamber heating, automatic tool changing, and input shaping.', status: 'active' },
  { date: 'June 2026', title: 'Newport-Bermuda Race — 120th Running', body: 'Aboard CSM the Mariner for the 120th running. An enclosed CoreXY printing live — real parts, real problems, real conditions. Newport to Bermuda. 635 nautical miles.', status: 'upcoming' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Workshops & Events — 3D3D',
  description: 'Hands-on 3D printing workshops for beginners, youth, seniors, and advanced users. Book a workshop or suggest one for your community.',
  url: 'https://3d3d.ca/workshops',
};
---

<BaseLayout title="Workshops & Events | 3D3D" description="Hands-on 3D printing workshops for beginners, youth, seniors, and advanced users. STEM education, community events, and offshore deployments." activePath="/workshops" schema={schema}>

  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Workshops & Events'}]} />
            <p class="hp-card__eyebrow mt-4">Learn to Build</p>
            <h1 class="hp-card__title mt-2 mb-4">Workshops & Events</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Hands-on 3D printing workshops for beginners, youth, seniors, and experienced makers. We bring the printers, the materials, and the knowledge. You leave with something you built yourself.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="/contact?subject=workshop" class="hp-cta hp-cta--accent">Book a Workshop</a>
              <a href="#suggest" class="hp-cta hp-cta--glass">Suggest an Event</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Workshop Catalog -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Catalog</p>
            <h2 class="hp-card__title mt-2 mb-6">What We Offer</h2>

            <div class="ws-grid">
              {WORKSHOPS.map((ws) => (
                <article class="ws-card">
                  <div class="ws-card__header">
                    <span class={`ws-card__type ws-card__type--${ws.type}`}>{ws.type}</span>
                    <span class="ws-card__duration">{ws.duration}</span>
                  </div>
                  <h3 class="ws-card__title">{ws.title}</h3>
                  <p class="ws-card__audience">{ws.audience} · {ws.capacity}</p>
                  <p class="ws-card__desc">{ws.description}</p>
                  <div class="ws-card__pricing">
                    {ws.pricing.map((p) => (
                      <span class="ws-card__price">
                        <strong>{p.price}</strong> {p.label}
                        {p.note && <em> ({p.note})</em>}
                      </span>
                    ))}
                  </div>
                  <div class="ws-card__tags">
                    {ws.tags.map((t) => <span class="ws-tag">{t}</span>)}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: Pricing Overview -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Transparent Pricing</p>
            <h2 class="hp-card__title mt-2 mb-6">Workshop Pricing</h2>

            <div class="ws-pricing-grid">
              {PRICING_TIERS.map((tier) => (
                <div class="ws-pricing-row">
                  <span class="ws-pricing-row__label">{tier.label}</span>
                  <span class="ws-pricing-row__price">{tier.price}</span>
                  {tier.note && <span class="ws-pricing-row__note">{tier.note}</span>}
                </div>
              ))}
            </div>

            <p class="hp-card__copy mt-6">
              Custom pricing for schools, libraries, community centres, and sponsored events. We will work with your budget. The goal is access, not margin.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-4">
              <a href="/contact?subject=workshop-pricing" class="hp-cta hp-cta--accent">Discuss Custom Pricing</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 4: Suggest a Workshop -->
    <section class="hp-section" id="suggest" style="--section-accent: #AAFF2A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow" style="color: #FF6B2B;">Your Idea</p>
            <h2 class="hp-card__title mt-2 mb-4">Suggest a Workshop</h2>
            <p class="hp-card__copy mb-6">
              Have an idea for a workshop we should run? A school that needs STEM programming? A community centre looking for tech events? Tell us what you need and we will build the program around it.
            </p>

            <form action="https://formspree.io/f/mldlydbl" method="POST" class="ws-suggest-form">
              <input type="hidden" name="_subject" value="Workshop Suggestion — 3D3D" />
              <div class="ws-suggest-form__row">
                <label class="ws-suggest-form__label">
                  <span>Your Name</span>
                  <input type="text" name="name" required class="ws-suggest-form__input" />
                </label>
                <label class="ws-suggest-form__label">
                  <span>Email</span>
                  <input type="email" name="email" required class="ws-suggest-form__input" />
                </label>
              </div>
              <label class="ws-suggest-form__label">
                <span>Organization (optional)</span>
                <input type="text" name="organization" class="ws-suggest-form__input" />
              </label>
              <label class="ws-suggest-form__label">
                <span>Workshop Idea or Request</span>
                <textarea name="workshop_idea" rows="4" required class="ws-suggest-form__input" placeholder="What kind of workshop are you looking for? Who is the audience? Any specific topics?"></textarea>
              </label>
              <label class="ws-suggest-form__label">
                <span>Preferred Location / Region</span>
                <input type="text" name="location" class="ws-suggest-form__input" placeholder="City, province, or venue name" />
              </label>
              <button type="submit" class="hp-cta hp-cta--accent mt-4" style="background: #FF6B2B; border-color: #FF6B2B;">Submit Suggestion</button>
            </form>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 5: The Timeline -->
    <section class="hp-section" style="--section-accent: #40C4C4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/evening-fleet.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Timeline</p>
            <h2 class="hp-card__title mt-2 mb-6">The Campaign So Far</h2>

            <div class="ws-timeline">
              {timeline.map((item) => (
                <div class="ws-timeline__item" style={`border-color: ${item.status === 'upcoming' ? 'rgba(232, 74, 138, 0.4)' : '#e84a8a'};`}>
                  <span class="ws-timeline__date" style={`color: ${item.status === 'upcoming' ? '#f07aa8' : '#e84a8a'};`}>{item.date}</span>
                  <h3 class="ws-timeline__title">{item.title}</h3>
                  <p class="ws-timeline__body">{item.body}</p>
                </div>
              ))}
            </div>

            <div class="mt-8">
              <PageNextActions actions={[
                {label: 'Get a Quote', href: '/quote', description: 'Custom prints for your project.', accent: 'teal'},
                {label: 'Join the Network', href: '/network', description: 'Collaborate with 3D3D.', accent: 'magenta'},
              ]} />
            </div>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .ws-grid {
    display: grid;
    gap: 0.8rem;
  }
  .ws-card {
    padding: clamp(1.2rem, 2.5vw, 1.6rem);
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    display: grid;
    gap: 0.6rem;
  }
  .ws-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .ws-card__type {
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    border: 1px solid;
  }
  .ws-card__type--workshop { color: var(--color-teal-primary); border-color: var(--color-teal-primary); }
  .ws-card__type--event { color: var(--color-magenta-primary); border-color: var(--color-magenta-primary); }
  .ws-card__type--bootcamp { color: #FF6B2B; border-color: #FF6B2B; }
  .ws-card__duration {
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.4);
  }
  .ws-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 0.9rem + 0.5vw, 1.25rem);
    line-height: 1.15;
    color: rgba(246, 247, 250, 0.9);
  }
  .ws-card__audience {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.35);
  }
  .ws-card__desc {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgba(246, 247, 250, 0.45);
  }
  .ws-card__pricing {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .ws-card__price {
    font-size: 0.72rem;
    color: rgba(246, 247, 250, 0.45);
  }
  .ws-card__price strong {
    color: var(--color-teal-primary);
  }
  .ws-card__price em {
    color: rgba(246, 247, 250, 0.3);
    font-size: 0.65rem;
  }
  .ws-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .ws-tag {
    font-family: var(--font-tech);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.18rem 0.4rem;
    background: rgba(64, 196, 196, 0.12);
    color: var(--color-teal-primary);
    border-radius: 2px;
  }

  .ws-pricing-grid {
    display: grid;
    gap: 0.5rem;
    max-width: 32rem;
  }
  .ws-pricing-row {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .ws-pricing-row__label {
    font-size: 0.82rem;
    color: rgba(246, 247, 250, 0.7);
    flex: 1;
  }
  .ws-pricing-row__price {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-teal-primary);
    white-space: nowrap;
  }
  .ws-pricing-row__note {
    font-size: 0.68rem;
    color: rgba(246, 247, 250, 0.3);
    font-style: italic;
  }

  .ws-suggest-form {
    display: grid;
    gap: 1rem;
    max-width: 36rem;
  }
  .ws-suggest-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 560px) {
    .ws-suggest-form__row {
      grid-template-columns: 1fr;
    }
  }
  .ws-suggest-form__label {
    display: grid;
    gap: 0.3rem;
    font-family: var(--font-tech);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.5);
  }
  .ws-suggest-form__input {
    width: 100%;
    padding: 0.7rem 0.9rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 2px;
    color: rgba(246, 247, 250, 0.9);
    font-family: var(--font-body);
    font-size: 0.85rem;
    transition: border-color 0.2s ease;
  }
  .ws-suggest-form__input:focus {
    outline: none;
    border-color: #FF6B2B;
  }
  .ws-suggest-form__input::placeholder {
    color: rgba(246, 247, 250, 0.25);
  }

  .ws-timeline {
    display: grid;
    gap: 1.2rem;
  }
  .ws-timeline__item {
    border-left: 2px solid;
    padding-left: 1rem;
    padding-bottom: 0.5rem;
  }
  .ws-timeline__date {
    font-family: var(--font-tech);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .ws-timeline__title {
    margin: 0.3rem 0 0.4rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: rgba(246, 247, 250, 0.9);
  }
  .ws-timeline__body {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(246, 247, 250, 0.45);
  }
</style>
