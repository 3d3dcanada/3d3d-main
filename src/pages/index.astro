---
import BaseHead from '../components/BaseHead.astro';
import SiteFooterFull from '../components/SiteFooterFull.astro';
import SiteRightSidebar from '../components/SiteRightSidebar.astro';
import { ACCENT_HEX } from '../data/splashSections';
import {
  CATALOG,
  SHOP_CATEGORIES,
  getCatalogItemHasPriceRange,
  getCatalogItemStartingPrice,
  getCatalogItemUrl,
} from '../lib/catalog';
import '../styles/global.css';

const FORM_ENDPOINT = 'https://formspree.io/f/mldlydbl';
const featuredProducts = CATALOG.slice(0, 8);

const heroImages = [
  { src: '/media/real/open-ocean-01.jpg', position: 'center 40%' },
  { src: '/media/real/sunrise-offshore.jpg', position: 'center' },
  { src: '/media/real/sunset-sail-01.jpg', position: 'center' },
];

const fabricationImages = [
  { src: '/media/generated/fab-01.jpg', position: 'center' },
  { src: '/media/generated/fab-02.jpg', position: 'center' },
  { src: '/media/generated/fab-03.jpg', position: 'center' },
];

const storyImages = [
  { src: '/media/generated/story-01.jpg', position: 'center' },
  { src: '/media/generated/story-02.jpg', position: 'center' },
  { src: '/media/generated/story-03.jpg', position: 'center' },
];

const eventImages = [
  { src: '/media/real/fleet-start-press.jpg', position: 'center' },
  { src: '/media/real/fleet-aerial.jpg', position: 'center' },
  { src: '/media/real/race-morning-crew.jpg', position: 'center' },
];

const softwareImages = [
  { src: '/media/generated/software-01.jpg', position: 'center' },
  { src: '/media/generated/software-02.jpg', position: 'center' },
  { src: '/media/generated/software-03.jpg', position: 'center' },
];

const networkImages = [
  { src: '/media/generated/network-01.jpg', position: 'center' },
  { src: '/media/generated/network-02.jpg', position: 'center' },
  { src: '/media/generated/network-03.jpg', position: 'center' },
];

const oldGirlImages = [
  { src: '/media/workshop/printer-frame-shot.jpg', position: 'center' },
  { src: '/media/workshop/printer-action-cf.jpg', position: 'center' },
  { src: '/media/workshop/printer-bed-benchy.jpg', position: 'center' },
];

const galleryImages = [
  { src: '/media/real/dawn-approach.jpg', position: 'center' },
  { src: '/media/real/evening-passage.jpg', position: 'center' },
  { src: '/media/real/golden-hour-03.jpg', position: 'center' },
];

const sponsorImages = [
  { src: '/media/real/golden-hour-01.jpg', position: 'center' },
  { src: '/media/real/golden-hour-02.jpg', position: 'center' },
  { src: '/media/real/golden-hour-03.jpg', position: 'center' },
];

const softwareProjects = [
  {
    name: '3D3D Quote Desk',
    stack: ['Astro', 'React', 'Formspree'],
    note: 'Structured quote intake with uploads, material routing, and fewer dead-end leads.',
    href: '/quote',
  },
  {
    name: 'Co-op Shop Catalog',
    stack: ['Astro', 'Catalog data', 'Cloudflare'],
    note: 'Product catalog, pricing ranges, and direct pathways from discovery to purchase.',
    href: '/shop',
  },
  {
    name: 'Campaign & Race Logs',
    stack: ['Astro', 'Content ops', 'SEO'],
    note: 'Publishing workflow for offshore updates, build notes, and community documentation.',
    href: '/blog',
  },
  {
    name: 'Node Ops Toolkit',
    stack: ['Open source', 'Web apps', 'Automation'],
    note: 'The maker-first infrastructure layer for distributed production and local operator pages.',
    href: '/opportunities',
  },
];

const sponsorRates = {
  USD: 1,
  CAD: 1.37,
  EUR: 0.92,
};

const formatSponsorPrice = (amount: number, currency: keyof typeof sponsorRates) =>
  new Intl.NumberFormat(currency === 'EUR' ? 'de-DE' : 'en-CA', {
    style: 'currency',
    currency,
    maximumFractionDigits: 0,
  }).format(amount);

const sponsorDefaults = {
  currency: 'CAD' as const,
  billing: 'monthly' as const,
};

const initialSupporterPrice = formatSponsorPrice(
  Math.round(100 * sponsorRates[sponsorDefaults.currency]),
  sponsorDefaults.currency,
);

const initialPartnerPrice = formatSponsorPrice(
  Math.round(500 * sponsorRates[sponsorDefaults.currency]),
  sponsorDefaults.currency,
);
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="3D3D | Custom Fabrication, Software & Community — Fredericton, Canada"
    description="Custom fabrication, software builds, event deployment, and a maker-first network built in Fredericton and deployed wherever the job lands."
    keywords="3D printing Fredericton, custom fabrication Canada, marine parts 3D print, event hire 3D printer, open source cooperative, 3D printing New Brunswick"
  />
</head>
<body class="hp-page">
  <main class="hp-home">
    <SiteRightSidebar />

    <section class="hp-section hp-section--hero" style={`--section-accent: ${ACCENT_HEX.teal};`}>
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {heroImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--center">
        <article class="hp-card hp-card--hero">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Fredericton, NB · Canada · Deployed Worldwide</p>
            <h1 class="hp-card__hero-title">FOR THE ONES THAT GIVE A DAMN.</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Custom fabrication. Software. Community. Built from the ground up with grit, field
              hours, and a willingness to make the weird jobs work.
            </p>
            <div class="hp-card__cta-row">
              <button type="button" class="hp-cta hp-cta--accent" data-dialog-open="dlg-quote">Open the Quote Desk</button>
              <button type="button" class="hp-cta hp-cta--glass" data-dialog-open="dlg-events">Hire for Events</button>
              <button type="button" class="hp-cta hp-cta--ghost" data-dialog-open="dlg-network">Join the Network</button>
            </div>
            <div class="hp-card__stats">
              <div>
                <strong>6 printers</strong>
                <span>Field-ready fabrication stack</span>
              </div>
              <div>
                <strong>1 operator</strong>
                <span>Direct contact from intake to delivery</span>
              </div>
              <div>
                <strong>0 fluff</strong>
                <span>Just real work, routed fast</span>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section
      aria-label="Custom Fabrication Services"
      id="fabrication"
      data-observe-section
      class="hp-section"
      style={`--section-accent: ${ACCENT_HEX.teal};`}
    >
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {fabricationImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Custom Fabrication</p>
            <h2 class="hp-card__title">Need a part that doesn&apos;t exist?</h2>
            <p class="hp-card__subtitle">Six printers. Deployable anywhere. Same-day triage when the job calls for it.</p>
            <p class="hp-card__copy">
              Marine hardware, automotive restoration, prototypes, replacement components, and the
              ugly one-off problems that never fit a normal intake form.
            </p>
            <ul class="hp-card__highlights">
              <li>Marine-grade replacements</li>
              <li>Reverse engineering</li>
              <li>Automotive restoration</li>
              <li>Field deployment support</li>
            </ul>
            <div class="hp-card__tags">
              <span class="hp-card__tag">Prusa MK2.5</span>
              <span class="hp-card__tag">Bambu A1</span>
              <span class="hp-card__tag">Creality K1</span>
              <span class="hp-card__tag">Kobra 2 Max</span>
            </div>
            <div class="hp-card__cta-row hp-card__cta-row--start">
              <button type="button" class="hp-cta hp-cta--accent" data-dialog-open="dlg-quote">Get an Estimate</button>
              <a href="/quote" class="hp-cta hp-cta--glass">Open the Full Quote Page</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section
      aria-label="The Story and Mission"
      id="story"
      data-observe-section
      class="hp-section"
      style={`--section-accent: ${ACCENT_HEX.magenta};`}
    >
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {storyImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--end">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">The Story</p>
            <h2 class="hp-card__title">Made from nothing. Built for everyone.</h2>
            <p class="hp-card__copy">
              Ankylosing spondylitis ended a decade of trucking. Reinvention started in an RV with
              three printers, a workbench, and a refusal to disappear quietly.
            </p>
            <p class="hp-card__copy">
              Ten years sober. Still building. If you do not fit the normal job market, the maker
              economy should still have room for you.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start">
              <a href="/about" class="hp-cta hp-cta--accent">Read the Full Story</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section
      aria-label="Events and Live Deployment"
      id="events"
      data-observe-section
      class="hp-section"
      style={`--section-accent: ${ACCENT_HEX.magenta};`}
    >
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {eventImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Events & Deployment</p>
            <h2 class="hp-card__title">Bring 3D3D to your event.</h2>
            <p class="hp-card__subtitle">Regattas, car shows, expos, conventions, and community days.</p>
            <p class="hp-card__copy">
              Live printing, on-site troubleshooting, and video documentation from an operator who
              knows how to work around crowds, weather, and field constraints.
            </p>
            <ul class="hp-card__highlights">
              <li>Live fabrication on-site</li>
              <li>Video documentation</li>
              <li>Booth-ready setup</li>
              <li>Same-day problem solving</li>
            </ul>
            <div class="hp-card__cta-row hp-card__cta-row--start">
              <button type="button" class="hp-cta hp-cta--accent" data-dialog-open="dlg-events">Book the Deployment Desk</button>
              <a href="/book" class="hp-cta hp-cta--glass">Book a Call</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section
      aria-label="Software and AI Projects"
      id="software"
      data-observe-section
      class="hp-section"
      style={`--section-accent: ${ACCENT_HEX.teal};`}
    >
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {softwareImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--end">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Software & AI</p>
            <h2 class="hp-card__title">We build digital too.</h2>
            <p class="hp-card__subtitle">Websites, AI workflows, tools, and automations built fast and handed over cleanly.</p>
            <p class="hp-card__copy">
              The same mindset that solves a broken hardware workflow also ships better digital
              systems. Practical scopes. Tight feedback loops. No agency theatre.
            </p>
            <ul class="hp-card__highlights">
              <li>Custom websites & apps</li>
              <li>AI integrations</li>
              <li>Automation & tooling</li>
              <li>Open handoff</li>
            </ul>
            <div class="hp-card__cta-row hp-card__cta-row--start">
              <button type="button" class="hp-cta hp-cta--accent" data-dialog-open="dlg-software">Browse Live Work</button>
              <a href="/contact?subject=software-project" class="hp-cta hp-cta--glass">Start a Project</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section
      aria-label="The 3D3D Cooperative Network"
      id="network"
      data-observe-section
      class="hp-section"
      style={`--section-accent: ${ACCENT_HEX.magenta};`}
    >
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {networkImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">The Network</p>
            <h2 class="hp-card__title">3D3D connects Canada.</h2>
            <p class="hp-card__copy">
              First makers in get a free site at <strong>yourname.3d3d.ca</strong>, operator
              access, and a cooperative model designed to keep more value with the people doing the work.
            </p>
            <p class="hp-card__copy">
              Makers, coders, artists, robotics techs, sailors, and documentarians all belong here
              if they can carry their weight and share the road.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start">
              <button type="button" class="hp-cta hp-cta--accent" data-dialog-open="dlg-network">Apply to Join</button>
              <a href="/opportunities" class="hp-cta hp-cta--glass">Read the Opportunities</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section
      aria-label="The Old Girl Community Printer"
      id="oldgirl"
      data-observe-section
      class="hp-section"
      style={`--section-accent: ${ACCENT_HEX.orange};`}
    >
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {oldGirlImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--end">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Community Project</p>
            <h2 class="hp-card__title">The Old Girl.</h2>
            <p class="hp-card__copy">
              A rescued Prusa MK2 turned into the community printer. Pick the file. Pay for
              filament and shipping. No admin fee. No markup. No nonsense.
            </p>
            <div class="hp-card__tags">
              <span class="hp-card__tag">Running 24/7</span>
              <span class="hp-card__tag">Community-modded</span>
              <span class="hp-card__tag">Donations welcome</span>
            </div>
            <div class="hp-card__cta-row hp-card__cta-row--start">
              <a
                href="https://oldgirl.3d3d.ca"
                class="hp-cta hp-cta--accent"
                target="_blank"
                rel="noopener noreferrer"
              >
                Send a Print Job
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section
      aria-label="The 3D3D Media Archive"
      id="gallery"
      data-observe-section
      class="hp-section hp-section--gallery-cta"
      style={`--section-accent: ${ACCENT_HEX.teal};`}
    >
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {galleryImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--center">
        <article class="hp-card hp-card--gallery">
          <div class="hp-card__inner hp-card__inner--compact">
            <p class="hp-card__eyebrow">The Archive</p>
            <h2 class="hp-card__title">View the Journey.</h2>
            <p class="hp-card__copy">
              Sailing, workshop builds, race days, community printer runs, and the running log of
              how 3D3D got here.
            </p>
            <div class="hp-card__cta-row">
              <a href="/gallery" class="hp-cta hp-cta--accent">View the Journey</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section
      aria-label="Sponsorship Packages"
      id="sponsor"
      data-observe-section
      class="hp-section hp-section--sponsor"
      style={`--section-accent: ${ACCENT_HEX.magenta};`}
    >
      <div class="hp-section__bg" data-rotating-gallery data-rotate-interval="9000">
        {sponsorImages.map((image, index) => (
          <div
            class:list={['hp-section__bg-img', index === 0 && 'hp-section__bg-img--active']}
            style={`background-image: url('${image.src}'); background-position: ${image.position};`}
          ></div>
        ))}
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--stack">
        <article class="hp-card hp-card--wide">
          <div class="hp-card__inner">
            <div class="hp-sponsor-head">
              <div>
                <p class="hp-card__eyebrow">Sponsorships</p>
                <h2 class="hp-card__title">Sponsor the journey.</h2>
              </div>
              <p class="hp-card__copy">
                Monthly or yearly support. USD, CAD, or EUR. Real perks, real production help, and
                a path for brands or individuals to back the work without the page turning into fluff.
              </p>
            </div>

            <div class="hp-sponsor-controls">
              <div class="hp-switch" role="group" aria-label="Select sponsorship currency">
                <button type="button" class="hp-switch__button" data-currency-option="USD">USD</button>
                <button type="button" class="hp-switch__button hp-switch__button--active" data-currency-option="CAD">CAD</button>
                <button type="button" class="hp-switch__button" data-currency-option="EUR">EUR</button>
              </div>
              <div class="hp-switch" role="group" aria-label="Select sponsorship billing period">
                <button type="button" class="hp-switch__button hp-switch__button--active" data-billing-option="monthly">Monthly</button>
                <button type="button" class="hp-switch__button" data-billing-option="yearly">Yearly</button>
              </div>
            </div>
          </div>
        </article>

        <div class="hp-tier-grid">
          <article class="hp-tier">
            <p class="hp-tier__eyebrow">Supporter</p>
            <p class="hp-tier__price" data-tier-price="supporter">{initialSupporterPrice}</p>
            <p class="hp-tier__meta" data-tier-meta="supporter">per month</p>
            <ul class="hp-tier__list">
              <li>Custom high-spec filament keychain with their name or logo</li>
              <li>Name and site credits as a sponsor</li>
              <li>Hat or t-shirt of their choice</li>
              <li>Ko-fi thank-you post</li>
            </ul>
            <button
              type="button"
              class="hp-cta hp-cta--accent hp-cta--full"
              data-dialog-open="dlg-sponsor"
              data-sponsor-tier="supporter"
            >
              Start Supporter
            </button>
          </article>

          <article class="hp-tier hp-tier--featured">
            <span class="hp-tier__badge">Enhanced Package</span>
            <p class="hp-tier__eyebrow">Partner</p>
            <p class="hp-tier__price" data-tier-price="partner">{initialPartnerPrice}</p>
            <p class="hp-tier__meta" data-tier-meta="partner">per month</p>
            <ul class="hp-tier__list">
              <li>Everything in Supporter</li>
              <li>$100 in free prints per month</li>
              <li>2 t-shirts and 2 hats</li>
              <li>1-on-1 monthly consultation call</li>
              <li>One free software build per year</li>
              <li>Dedicated social feature and sponsor wall logo</li>
            </ul>
            <button
              type="button"
              class="hp-cta hp-cta--accent hp-cta--full"
              data-dialog-open="dlg-sponsor"
              data-sponsor-tier="partner"
            >
              Start Partner
            </button>
          </article>

          <article class="hp-tier">
            <p class="hp-tier__eyebrow">Investor</p>
            <div class="hp-tier__custom">
              <label class="hp-field hp-field--inline">
                <span>Custom amount</span>
                <div class="hp-field__inline-wrap">
                  <span class="hp-field__prefix" data-custom-currency-symbol>{sponsorDefaults.currency}</span>
                  <input
                    type="number"
                    min="250"
                    step="25"
                    value="1000"
                    data-custom-amount
                    aria-label="Custom sponsorship amount"
                  />
                </div>
              </label>
            </div>
            <ul class="hp-tier__list">
              <li>Event co-branding opportunities</li>
              <li>Equity conversation welcome</li>
              <li>Dedicated support channel</li>
              <li>Custom package negotiated around the work</li>
            </ul>
            <button
              type="button"
              class="hp-cta hp-cta--glass hp-cta--full"
              data-dialog-open="dlg-sponsor"
              data-sponsor-tier="custom"
            >
