---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — 3D3D" description="Get in touch. Custom print requests, maker applications, partnerships, or general inquiries." activePath="/contact">

  <div class="pt-8 pb-12">
    <section class="max-w-3xl mx-auto">
      <p class="font-display text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">Get in Touch</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold mt-2 mb-6" style="color: var(--color-text-primary);">Contact</h1>
      <p class="text-sm mb-8" style="color: var(--color-text-secondary);">Book 3D3D for your event, or get in touch about a custom print.</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="p-6 rounded-xl" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle); box-shadow: var(--shadow-sm);">
          <h2 class="font-display text-base font-semibold mb-4" style="color: var(--color-text-primary);">Direct</h2>
          <div class="space-y-3 text-sm">
            <div>
              <span class="block font-display text-[9px] uppercase tracking-widest mb-0.5" style="color: var(--color-text-muted);">Email</span>
              <a href="mailto:info@3d3d.ca" class="hover:underline" style="color: var(--color-teal-primary);">info@3d3d.ca</a>
            </div>
            <div>
              <span class="block font-display text-[9px] uppercase tracking-widest mb-0.5" style="color: var(--color-text-muted);">Phone / WhatsApp</span>
              <a
                href="https://wa.me/15069532678"
                class="transition-colors"
                target="_blank"
                rel="noopener noreferrer"
                style="color: var(--color-text-primary);"
              >
                506-953-2678 (WhatsApp)
              </a>
            </div>
            <div>
              <span class="block font-display text-[9px] uppercase tracking-widest mb-0.5" style="color: var(--color-text-muted);">Location</span>
              <span style="color: var(--color-text-secondary);">Fredericton, NB, Canada</span>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-xl" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle); box-shadow: var(--shadow-sm);">
          <h2 class="font-display text-base font-semibold mb-4" style="color: var(--color-text-primary);">Quick Links</h2>
          <div class="space-y-3 text-sm">
            <a href="/quote" class="block transition-colors" style="color: var(--color-text-secondary);">Get a custom quote →</a>
            <a href="/makers" class="block transition-colors" style="color: var(--color-text-secondary);">Apply as a maker →</a>
            <a href="/shop" class="block transition-colors" style="color: var(--color-text-secondary);">Browse the shop →</a>
            <a href="/blog" class="block transition-colors" style="color: var(--color-text-secondary);">Read the blog →</a>
          </div>
        </div>
      </div>

      {/* Contact form */}
      <div class="p-8 rounded-xl" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle); box-shadow: var(--shadow-sm);">
        <h2 class="font-display text-lg font-semibold mb-6" style="color: var(--color-text-primary);">Send a Message</h2>
        <form action="https://formspree.io/f/mldlydbl" method="POST" class="space-y-5" data-analytics-submit="contact_submitted" data-analytics-source="contact-page">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);" for="name">Name</label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-2.5 rounded-lg text-sm outline-none transition-colors"
                style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);"
              />
            </div>
            <div>
              <label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);" for="email">Email</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-2.5 rounded-lg text-sm outline-none transition-colors"
                style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);"
              />
            </div>
          </div>
          <div>
            <label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);" for="subject">Subject</label>
            <select id="subject" name="subject"
              class="w-full px-4 py-2.5 rounded-lg text-sm outline-none"
              style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);"
            >
              <option value="event-booking">Event Booking</option>
              <option value="custom-print">Custom Print Request</option>
              <option value="maker-application">Maker Application</option>
              <option value="partnership">Partnership Inquiry</option>
              <option value="support">Order Support</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);" for="message">Message</label>
            <textarea id="message" name="message" rows={5} required
              class="w-full px-4 py-2.5 rounded-lg text-sm outline-none resize-y"
              style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);"
            ></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="casl-consent" name="casl_consent" value="yes"
              class="mt-1 w-4 h-4 rounded flex-shrink-0"
              style="accent-color: var(--color-teal-primary);"
            />
            <label for="casl-consent" class="text-[11px] leading-relaxed" style="color: var(--color-text-muted);">
            I consent to receiving commercial electronic messages from 3D3D. You may unsubscribe at any time. See our <a href="/casl" class="underline" style="color: var(--color-teal-primary);">CASL policy</a> and <a href="/privacy" class="underline" style="color: var(--color-teal-primary);">privacy policy</a>.
            </label>
          </div>
          <button type="submit" class="btn btn-primary">
            Send Message
          </button>
        </form>
      </div>
    </section>
  </div>
</BaseLayout>
