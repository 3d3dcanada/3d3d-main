---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const materials = [
  // ── ENGINEERING TIER ────────────────────────────────────
  {
    tier: 'Engineering',
    id: 'asa',
    name: 'ASA',
    full: 'Acrylonitrile Styrene Acrylate',
    hdt: '93°C',
    tags: ['UV-stable', 'Outdoor', 'Marine'],
    body: 'The outdoor compound. UV-stable where ABS yellows and cracks, ASA holds colour and geometry through full seasons of sun, salt spray, and temperature cycling. Acetone-smoothable.',
  },
  {
    tier: 'Engineering',
    id: 'petg-cf',
    name: 'PETG-CF',
    full: 'PETG Carbon Fiber',
    hdt: '>68°C',
    tags: ['Structural', 'Stiff', 'Low-creep'],
    body: 'PETG with recycled carbon fibre reinforcement. Better dimensional stability, higher modulus, and lower creep than standard PETG. The right call for structural brackets.',
  },
  {
    tier: 'Engineering',
    id: 'pc-blend',
    name: 'PC Blend',
    full: 'Polycarbonate Blend',
    hdt: '113°C',
    tags: ['Tough', 'Impact-resistant', 'Heat-resistant'],
    body: 'Strong, tough, and heat-resistant. PC Blend maintains toughness at low temperatures and resists creep under mechanical stress.',
  },
  {
    tier: 'Engineering',
    id: 'pa11-cf',
    name: 'PA11 CF',
    full: 'Polyamide 11 Carbon Fiber',
    hdt: '192°C @ 0.45 MPa',
    tags: ['High-temp', 'Automotive', 'Structural'],
    body: 'The engine bay material. PA11 CF runs to 192°C under low load. Chemical resistance includes motor oils, fuels, benzene, ethanol, methanol, toluene, and acetone.',
  },
  {
    tier: 'Engineering',
    id: 'pp-gf',
    name: 'PP Glass Fiber',
    full: 'Polypropylene Glass Fiber',
    hdt: '138°C',
    tags: ['Chemical-resistant', 'Marine', 'Lab'],
    body: 'Polypropylene with glass fibre. 0.11% moisture absorption. No swelling, no delamination in saltwater or wet environments. The right material for through-hull fittings.',
  },
  // ── ELITE ────────────────────────────────────────────
  {
    tier: 'Elite',
    id: 'pei-1010',
    name: 'PEI 1010',
    full: 'Polyetherimide (Ultem-class)',
    hdt: '207°C @ 0.45 MPa',
    tags: ['Metal-replacement', 'Extreme-temp', 'Flame-retardant'],
    body: 'The ceiling. PEI runs to 207°C. Inherent UL94 VTM-0 flame retardancy. Autoclave sterilisable. Direct metal-alloy replacement for aerospace and medical instruments.',
  },
  // ── FLEXIBLE ────────────────────────────────────────────
  {
    tier: 'Flexible',
    id: 'tpu-95a',
    name: 'TPU 95A',
    full: 'Thermoplastic Polyurethane, Ether Type',
    hdt: '78°C @ 1.80 MPa',
    tags: ['Flexible', 'Seals', 'Impact-resistant'],
    body: 'Ether-type TPU. Resists hydrolysis where ester degrades in wet environments over time. Extreme wear resistance. Seals, gaskets, cable boots.',
  },
  // ── SPECIALTY ───────────────────────────────────────────
  {
    tier: 'Specialty',
    id: 'petg-tungsten',
    name: 'PETG Tungsten',
    full: 'PETG 75% Tungsten',
    hdt: '94°C',
    tags: ['Radiation-shielding', 'High-density', 'Lead-free'],
    body: '75% tungsten fill, the highest filler concentration in the catalogue and the densest printable material available. ~19 g/cm³, comparable to gold. Radiation shielding.',
  },
  // ── STANDARD ────────────────────────────────────────────
  {
    tier: 'Standard',
    id: 'petg',
    name: 'PETG',
    full: 'Polyethylene Terephthalate Glycol',
    hdt: '68°C',
    tags: ['General-purpose', 'Tough', 'Low-warp'],
    body: 'The general-purpose functional material. Tougher than PLA, lower warp than ABS, good chemical resistance. The baseline for parts that need to work.',
  },
  {
    tier: 'Standard',
    id: 'pla',
    name: 'PLA',
    full: 'Polylactic Acid',
    hdt: '55°C',
    tags: ['Prototyping', 'Detail', 'Easy-print'],
    body: 'The prototyping compound. Softens at 55–60°C. Not for functional parts exposed to heat, UV, or mechanical stress. Prototyping only.',
  },
];

const tiers = ['Engineering', 'Elite', 'Flexible', 'Specialty', 'Standard'];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Materials | 3D3D',
  description: 'Every material I run. Engineering-grade compounds for marine, automotive, and field fabrication — from ASA to PEI 1010.',
  url: 'https://3d3d.ca/materials',
};
---

<BaseLayout
  title="Materials | 3D3D"
  description="Every material I run. Engineering-grade compounds for marine, automotive, and field fabrication — from ASA to PEI 1010."
  activePath="/materials"
  schema={schema}
>
  <main class="hp-home">

    <!-- Section 1: Hero & The Rule -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/golden-hour-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Materials'}]} />
            <p class="hp-card__eyebrow mt-4">Material Stack</p>
            <h1 class="hp-card__title mt-2 mb-4">What it takes to survive the salt.</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Standard 3D printing plastics belong in a hobby shop. PLA softens at 55 degrees Celsius, absorbs moisture, and shatters under UV load. None of that is acceptable aboard a working vessel.
            </p>
            <p class="hp-card__copy mb-6">
              Every material I run is selected for the conditions it will face, not for ease of printing. Marine hardware sees salt spray, UV cycling, and sustained mechanical load. Automotive parts live near fuel, oil, and heat. The material has to be correct on the first print.
            </p>

            <h3 class="font-display text-xl text-teal-400 mb-2">The Verification Rule</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="bg-red-950/40 p-3 rounded border border-red-500/20">
                <strong class="text-red-400 block mb-1">PLA at sea (Fails)</strong>
                <span class="text-xs text-gray-400">Softens at 55°C. Absorbs moisture. Degrades under UV.</span>
              </div>
              <div class="bg-teal-950/40 p-3 rounded border border-teal-500/20">
                <strong class="text-teal-400 block mb-1">ASA above deck (Correct)</strong>
                <span class="text-xs text-gray-400">UV-stable. 93°C HDT. Holds geometry through sun and salt.</span>
              </div>
              <div class="bg-teal-950/40 p-3 rounded border border-teal-500/20">
                <strong class="text-teal-400 block mb-1">PP Glass Fiber submerged (Correct)</strong>
                <span class="text-xs text-gray-400">0.11% moisture absorption. Zero geometry shift in water.</span>
              </div>
              <div class="bg-teal-950/40 p-3 rounded border border-teal-500/20">
                <strong class="text-teal-400 block mb-1">PA11 CF in engine bay (Correct)</strong>
                <span class="text-xs text-gray-400">192°C HDT. Resists motor oils, fuels, benzene, ethanol.</span>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Material Roster -->
    <section class="hp-section" style="--section-accent: #e84a8a; min-height: 100svh;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/workshop/printer-action-cf.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim" style="background: rgba(17, 18, 20, 0.9);"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <div class="w-full max-w-5xl mx-auto py-12 relative z-10">
          <h2 class="font-display text-3xl text-white uppercase tracking-tighter mb-8">The Stack</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {materials.map(m => (
              <div class="bg-black/40 border border-white/10 p-5 rounded-sm hover:-translate-y-1 transition-transform">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-display text-2xl text-white tracking-tight">{m.name}</h3>
                  <span class="font-tech text-xs font-bold text-pink-400 uppercase">{m.hdt}</span>
                </div>
                <p class="font-tech text-xs text-gray-500 uppercase tracking-widest mb-3">{m.full} <span class="mx-2">•</span> {m.tier}</p>
                <div class="flex flex-wrap gap-2 mb-3">
                  {m.tags.map(t => (
                    <span class="text-[0.65rem] font-bold uppercase tracking-wider text-pink-300 border border-pink-500/30 px-2 py-0.5 rounded-sm">{t}</span>
                  ))}
                </div>
                <p class="text-sm text-gray-400 leading-relaxed">{m.body}</p>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- Section 3: When to Use What -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Selection Guide</p>
            <h2 class="hp-card__title mt-2 mb-4">Start with the environment. The material follows.</h2>
            <p class="hp-card__copy mb-6">
              Every material decision starts with the same question: what does this part have to survive? Pick the scenario below that matches your application. The recommendation is the compound we would use.
            </p>

            <div class="space-y-4">
              <div class="bg-black/20 p-4 border border-white/5 rounded">
                <h3 class="font-display text-lg text-white">Above deck, full sun</h3>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-2 font-tech font-bold">UV exposure, salt spray, temperature cycling</p>
                <p class="hp-card__copy"><strong class="text-teal-400">ASA:</strong> UV-stable. 93°C HDT. Holds colour and geometry through direct sun. The only correct choice for anything permanently exposed above deck.</p>
              </div>

              <div class="bg-black/20 p-4 border border-white/5 rounded">
                <h3 class="font-display text-lg text-white">Engine bay or exhaust proximity</h3>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-2 font-tech font-bold">Oil, fuel, high ambient heat</p>
                <p class="hp-card__copy"><strong class="text-teal-400">PA11 CF:</strong> 192°C HDT. Resists motor oils and fuels. The only FDM compound that survives a working engine compartment without outgassing.</p>
              </div>

              <div class="bg-black/20 p-4 border border-white/5 rounded">
                <h3 class="font-display text-lg text-white">Constant water contact</h3>
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-2 font-tech font-bold">Through-hull, bilge, saltwater immersion</p>
                <p class="hp-card__copy"><strong class="text-teal-400">PP Glass Fiber:</strong> 0.11% moisture absorption. Resists acids. Zero geometry shift in wet environments.</p>
              </div>
            </div>

            <div class="hp-card__cta-row hp-card__cta-row--start mt-8">
              <a href="/quote" class="hp-cta hp-cta--accent">Start a Project</a>
              <a href="/book" class="hp-cta hp-cta--glass">Book a Call</a>
            </div>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
</style>
