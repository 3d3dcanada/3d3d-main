---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Organization'],
  name: '3D3D',
  url: 'https://3d3d.ca',
  description: 'Precision 3D printing and fabrication — marine parts, automotive components, replacement parts, and retained fabrication support. Built from the ground up in New Brunswick, Canada.',
  telephone: '+1-506-953-2678',
  email: 'info@3d3d.ca',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Fredericton',
    addressRegion: 'NB',
    postalCode: 'E3B 0A1',
    addressCountry: 'CA',
  },
  founder: { '@type': 'Person', name: 'Ken' },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+1-506-953-2678',
    email: 'info@3d3d.ca',
    contactType: 'customer service',
  },
  sameAs: [
    'https://www.youtube.com/@3D3Dcanada',
    'https://www.tiktok.com/@3d3dcanada',
    'https://www.instagram.com/3d3dca/',
    'https://www.facebook.com/profile.php?id=61575548079847',
    'https://www.printables.com/@KTK3D_3050116',
    'https://github.com/3d3dcanada/3d3d-main',
    'https://wa.me/15069532678',
    'https://ko-fi.com/3d3dca',
  ],
  image: 'https://3d3d.ca/media/real/race-morning-crew.jpg',
  logo: 'https://3d3d.ca/media/brand/logo-badge.webp',
};

const homeNavGroups = [
  {
    label: 'On This Page',
    items: [
      { id: 'home', label: 'Home', href: '/' },
      { id: 'services', label: 'Services', href: '#services' },
      { id: 'story', label: 'Our Story', href: '#story' },
      { id: 'deployment', label: 'Deployment', href: '#deployment' },
      { id: 'tiers', label: 'Service Tiers', href: '#tiers' },
      { id: 'open-source', label: 'Open Source', href: '#open-source' },
      { id: 'partners', label: 'Partners', href: '#partners' },
      { id: 'contact', label: 'Contact', href: '#contact' },
    ],
  },
  {
    label: 'Site',
    items: [
      { id: 'blog', label: 'Updates', href: '/blog' },
      { id: 'shop', label: 'Shop', href: '/shop' },
      { id: 'about', label: 'About', href: '/about' },
    ],
  },
];

const heroStats = [
  { value: '3', label: 'Active print platforms' },
  { value: '120th', label: 'Newport Bermuda Race — June 2026' },
  { value: '1 yr', label: 'Built from nothing to here' },
];

const services = [
  {
    title: 'Marine & Offshore',
    body: 'Winch components, deck hardware, replacement fittings, and custom parts built to survive saltwater, UV, and open-ocean conditions. If it goes on a boat, we print it to last.',
    img: '/media/workshop/winch-cup-holder.jpg',
    alt: 'Custom winch-top cup holder — marine-grade 3D print',
  },
  {
    title: 'Automotive & Motorsport',
    body: 'Radio knob replacements, custom brackets, aftermarket accessories, and parts that no longer exist. Cars, trucks, rally rigs, drag cars — if it broke or never existed, we make it.',
    img: '/media/workshop/radio-button-replacement.jpg',
    alt: 'Replacement radio button for Pontiac Vibe — precision fit',
  },
  {
    title: 'Custom Fabrication',
    body: 'Carbon-fibre mouse bodies, spray-can adapters, TV mounts, desk organizers — whatever the problem, we design, scan, or source the file and print it in the right material for the job.',
    img: '/media/workshop/mouse-body-petgcf.jpg',
    alt: 'Custom gaming mouse body printed in PETG carbon fibre',
  },
  {
    title: 'Retained Support',
    body: 'Monthly retainer for clients who need a fabrication partner on call. Priority queue, direct line to the founder. No tickets, no wait, no guessing. You call, we build.',
    img: '/media/workshop/fan-reducers.jpg',
    alt: 'Precision-printed fan reducer brackets in black',
  },
];

const proofPoints = [
  'Started in an RV running on a generator — $30/day in gas, 35-degree heat, everything that could break, broke',
  'One year of daily printing, failing, learning, and building until the operation was stable and the work spoke for itself',
  'Prusa Research recognized that commitment and is sending a CORE One L — their flagship machine',
  'High-performance materials as standard: PETG-CF, ASA, annealed PLA, UV-stable compounds — not the cheapest filament, the right filament',
  'Every part reviewed, processed, and tested before it ships. Direct access to the founder on every engagement',
];

const racePhotos = [
  { src: '/media/real/sunrise-offshore.jpg', alt: 'Sunrise offshore during passage' },
  { src: '/media/real/race-morning-crew.jpg', alt: 'Crew preparing for race start' },
  { src: '/media/real/coastal-landmark.jpg', alt: 'Coastal approach at the end of a passage' },
  { src: '/media/real/golden-hour-01.jpg', alt: 'Golden-hour sailing conditions' },
];

const tiers = [
  {
    name: 'Standard',
    intro: 'One-off requests and production orders.',
    body: 'Standard fabrication queue. Full material and process review. Global shipping. You submit the request, we produce the part — reviewed, tested, and shipped. Not an estimate. A part.',
    cta: 'Request a build',
  },
  {
    name: 'Priority',
    intro: 'Faster turnaround. Direct access. Preferred scheduling.',
    body: 'Jump the queue. Accelerated fabrication, direct communication with the founder, and priority access when timing matters. Choosing Priority also directly funds the 3D3D mission and expansion.',
    cta: 'Get priority access',
  },
  {
    name: 'Patron',
    intro: 'Monthly retainer. On-call fabrication. Part of the campaign.',
    body: 'A recurring arrangement for clients and supporters who want 3D3D on call. Concierge fabrication priority, founder access, recognition on the race campaign, field updates, and the knowledge that you are one of the people making this possible.',
    cta: 'Become a patron',
    featured: true,
  },
];

const openSourceLinks = [
  {
    label: 'Printables',
    href: 'https://www.printables.com/@KTK3D_3050116',
    note: 'Open files, shared models, and fabrication-ready print releases.',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/3d3dcanada/3d3d-main',
    note: 'The open repository behind the 3D3D platform and this site.',
  },
  {
    label: 'Ko-fi',
    href: 'https://ko-fi.com/3d3dca',
    note: 'Support the project directly. Every contribution funds materials, travel, and deployment.',
  },
];

const partners = [
  {
    title: 'Prusa Research',
    body: 'Official platform partner. The Prusa CORE One L — enclosed CoreXY, 300 × 300 × 330 mm build volume — is arriving after one year of building 3D3D from the ground up. This machine is part of the arsenal now. It is here because a year of demonstrated commitment to open-source principles, quality manufacturing, and real-world deployment earned it.',
  },
  {
    title: 'Christopher Stanmore-Major · CSM The Mariner',
    body: 'Captain, mentor, and the reason 3D3D is going to sea. Chris is sponsoring Ken\'s place on the boat for the 2026 Newport Bermuda Race and partnering to bring a 3D printer onboard — live fabrication in a race environment. A lifelong sailor who has circumnavigated and raced at the highest levels, Chris saw what 3D3D was building and backed it.',
  },
  {
    title: 'Your brand here',
    body: 'This project runs on partnerships. If your brand, team, or organization is aligned with precision manufacturing, marine performance, motorsport, or open-source innovation — sponsor the campaign. Fund the deployment. Get 3D3D to your event, your boat, your track. Reach out.',
  },
];

const blogSubjects = [
  'The CORE One L arrives — what it means for 3D3D',
  'Printing for saltwater: material selection for marine parts',
  'Newport Bermuda 2026 — the deployment plan',
  'From an RV to a fabrication operation: the first year',
  'PETG-CF vs ASA: when carbon fibre composites matter',
  'Corporate team building with 3D printing — how to book a demo',
  'Why we anneal every structural part',
  'Open-source ethics in a paid fabrication service',
];
---

<BaseLayout
  title="3D3D — Precision fabrication for marine, automotive, and everything that breaks"
  description="3D3D produces precision 3D-printed parts for boats, cars, and anything else. Marine-grade fabrication, replacement parts, and retained support — built from the ground up in New Brunswick, Canada. Open-source. Field-tested. Obsessive about quality."
  schema={orgSchema}
  activePath="/"
  navGroups={homeNavGroups}
>
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section id="home" class="page-section home-hero">
    <div class="hero-grid">
      <div class="hero-copy reveal">
        <span class="eyebrow">Precision Fabrication · Marine · Automotive · Custom</span>
        <h1 class="hero-title">
          You have a problem.
          <br />
          We have a printer.
        </h1>
        <p class="hero-subheadline">
          3D3D builds precision parts for boats, cars, and anything else that needs to work under real conditions. Marine fittings, automotive replacements, custom components that don't exist yet. Open-source at the core. Built from nothing but stubbornness and a generator.
        </p>

        <div class="hero-actions">
          <a
            href="/contact"
            class="btn btn-primary"
            data-analytics-event="contact_started"
            data-analytics-source="home-hero"
          >
            Request Service
          </a>
          <a
            href="/blog"
            class="btn btn-secondary"
            data-analytics-event="blog_viewed"
            data-analytics-source="home-hero"
          >
            Follow the Project
          </a>
        </div>

        <div class="hero-trust" aria-label="Trust strip">
          <span>Prusa-backed</span>
          <span>Marine-grade materials</span>
          <span>Open-source</span>
          <span>Newport Bermuda 2026</span>
        </div>
      </div>

      <div class="hero-visual surface-panel reveal reveal-delay-1">
        <video
          class="hero-video"
          src="/media/hero-loop.mp4"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/media/real/race-morning-crew.jpg"
        ></video>
      </div>
    </div>

    <div class="hero-stats reveal reveal-delay-2">
      {heroStats.map((stat) => (
        <div class="hero-stat surface-panel">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════ SERVICES ═══════════════════ -->
  <section id="services" class="page-section home-section">
    <div class="section-heading reveal">
      <span class="eyebrow">Services</span>
      <h2 class="section-title">Whatever you need. We print it right.</h2>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <article class={`service-card surface-panel reveal reveal-delay-${i % 4}`}>
          <figure class="service-card__img">
            <img src={service.img} alt={service.alt} loading="lazy" />
          </figure>
          <div class="service-card__copy">
            <h3>{service.title}</h3>
            <p>{service.body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══════════════════ OUR STORY ═══════════════════ -->
  <section id="story" class="page-section home-section story-section">
    <div class="story-photos reveal">
      <figure class="story-photo story-photo--main surface-panel">
        <img
          src="/media/workshop/rv-lab-02.jpg"
          alt="The original 3D3D workshop — multiple printers running inside an RV"
          loading="lazy"
        />
      </figure>
      <figure class="story-photo story-photo--inset surface-panel reveal reveal-delay-1">
        <img
          src="/media/workshop/rv-lab-03.jpg"
          alt="The RV lab at night — printers, neon, and the work"
          loading="lazy"
        />
      </figure>
    </div>

    <div class="story-copy reveal reveal-delay-1">
      <span class="eyebrow">Where this started</span>
      <h2 class="section-title">
        An RV, a generator,
        <br />
        and every reason to quit.
      </h2>
      <p class="section-body">
        3D3D was not started in a workshop with a budget. It was started in a recreational vehicle, running three printers off a generator that cost $30 a day in gas. In 35-degree heat. With everything breaking — the printers, the power, the plans, all of it.
      </p>
      <p class="section-body">
        That was the sacrifice required to build this. A year of daily printing, failing, iterating, and producing parts that hold up — not because the setup was ideal, but because the standards were non-negotiable. The parts that leave 3D3D are reviewed, processed, annealed when required, and printed in materials chosen for the job, not the price.
      </p>
      <p class="section-body">
        Today the operation is stable, Prusa Research is sending a CORE One L, and the Newport Bermuda Race deployment is on the horizon. But the mentality hasn't changed: if it can break, it will. So it is built not to.
      </p>

      <ul class="proof-list">
        {proofPoints.map((point) => (
          <li>{point}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ═══════════════════ FABRICATION SHOWCASE ═══════════════════ -->
  <div class="fab-showcase reveal">
    <figure class="fab-showcase__item surface-panel">
      <img src="/media/workshop/spray-can-adapter.jpg" alt="Custom spray-can trigger adapter — functional print" loading="lazy" />
      <figcaption>Spray can adapter</figcaption>
    </figure>
    <figure class="fab-showcase__item surface-panel">
      <img src="/media/workshop/nomad-joe-holder.jpg" alt="Nomad Joe custom coffee drip holder — branded fabrication" loading="lazy" />
      <figcaption>Custom branded holder</figcaption>
    </figure>
    <figure class="fab-showcase__item surface-panel">
      <img src="/media/workshop/printer-action-cf.jpg" alt="Flashforge Adventurer 4 printing carbon fibre composite" loading="lazy" />
      <figcaption>Carbon fibre printing</figcaption>
    </figure>
    <figure class="fab-showcase__item surface-panel">
      <img src="/media/workshop/custom-tv-mount.jpg" alt="Custom 3D-printed TV mount bracket installed on stair railing" loading="lazy" />
      <figcaption>Custom TV mount</figcaption>
    </figure>
  </div>

  <!-- ═══════════════════ DEPLOYMENT ═══════════════════ -->
  <section
    id="deployment"
    class="home-race"
    style={`--race-bg: url('/media/real/fleet-running.jpg');`}
  >
    <div class="race-inner">
      <div class="race-copy reveal">
        <span class="eyebrow eyebrow-light">2026 Newport Bermuda Race — 120th Anniversary</span>
        <h2 class="race-title">
          A fabrication studio
          <br />
          in motion.
        </h2>
        <p class="race-body">
          Captain Christopher Stanmore-Major is sponsoring 3D3D's place aboard for the 2026 Newport Bermuda Race — the 120th running of one of offshore sailing's most demanding competitions. A Prusa CORE One L goes onboard. Parts get printed, tested, and used at sea. Weeks from any supply chain, far from any shop.
        </p>
        <p class="race-body">
          This is not a sponsorship logo on a hull. It is a live deployment — proof that additive manufacturing works where it matters most. And it is an invitation: if you want to bring 3D3D to your boat, your event, your corporate team build, your track day — we deploy.
        </p>
        <div class="race-actions">
          <a
            href="/contact"
            class="btn btn-primary"
            data-analytics-event="contact_started"
            data-analytics-source="home-deployment"
          >
            Book a deployment
          </a>
          <a
            href="/blog"
            class="btn btn-secondary home-cta-band__secondary"
            data-analytics-event="blog_viewed"
            data-analytics-source="home-deployment"
          >
            Follow the campaign
          </a>
        </div>
      </div>

      <div class="race-photo-grid reveal reveal-delay-1">
        {racePhotos.map((photo) => (
          <figure class="race-photo-card">
            <img src={photo.src} alt={photo.alt} loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ SERVICE TIERS ═══════════════════ -->
  <section id="tiers" class="page-section home-section">
    <div class="section-heading reveal">
      <span class="eyebrow">Service Tiers</span>
      <h2 class="section-title">How to work with 3D3D</h2>
    </div>

    <div class="tiers-grid">
      {tiers.map((tier, i) => (
        <article class={`tier-card surface-panel reveal reveal-delay-${i} ${tier.featured ? 'tier-card--featured' : ''}`}>
          <h3>{tier.name}</h3>
          <p class="tier-intro">{tier.intro}</p>
          <p class="tier-body">{tier.body}</p>
          <a
            href="/contact"
            class="btn btn-primary tier-cta"
            data-analytics-event="contact_started"
            data-analytics-source={`home-tier-${tier.name.toLowerCase()}`}
          >
            {tier.cta}
          </a>
        </article>
      ))}
    </div>

    <div class="tier-partnership surface-panel reveal">
      <figure class="tier-partnership__photo">
        <img
          src="/media/real/golden-hour-03.jpg"
          alt="Golden-hour wide shot on the water"
          loading="lazy"
        />
      </figure>
      <div class="tier-partnership__copy">
        <h3>Partnerships &amp; Sponsorships</h3>
        <p>Bring 3D3D to your event, your vessel, your track. Sponsor the campaign. Fund a deployment. Get your brand in front of the people who build and race and break things for a living.</p>
        <a
          href="/contact"
          class="btn btn-secondary"
          data-analytics-event="contact_started"
          data-analytics-source="home-partnerships"
        >
          Partner with 3D3D
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ OPEN SOURCE ═══════════════════ -->
  <section id="open-source" class="page-section home-section open-source-grid">
    <div class="open-source-copy reveal">
      <span class="eyebrow">Open-source at the core</span>
      <h2 class="section-title">The ecosystem matters more than the lock-in.</h2>
      <p class="section-body">
        3D3D runs on Prusa hardware, Printables files, and the open ecosystem that makes this kind of operation possible. The files are shared. The models are public. The knowledge is open. If you find something worth printing, 3D3D can build it, refine it, and ship it — and the community stays intact.
      </p>
    </div>

    <div class="open-source-media reveal reveal-delay-1">
      <figure class="open-source-photo surface-panel">
        <img
          src="/media/workshop/galaxy-vase.jpg"
          alt="Galaxy-effect vase — open-source model printed by 3D3D"
          loading="lazy"
        />
      </figure>

      <div class="open-source-links">
        {openSourceLinks.map((link) => (
          <a
            href={link.href}
            class="open-source-link surface-panel"
            target="_blank"
            rel="noopener noreferrer"
          >
            <strong>{link.label}</strong>
            <span>{link.note}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ PARTNERS ═══════════════════ -->
  <section id="partners" class="page-section home-section partners-section">
    <div class="section-heading reveal">
      <span class="eyebrow">Partners</span>
      <h2 class="section-title">The people behind this</h2>
    </div>

    <div class="partners-grid">
      {partners.map((partner, i) => (
        <article class={`partner-card surface-panel reveal reveal-delay-${i}`}>
          <h3>{partner.title}</h3>
          <p>{partner.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ═══════════════════ FINAL CTA ═══════════════════ -->
  <section
    id="contact"
    class="home-cta-band"
    style={`--cta-bg: url('/media/real/fleet-start-press.jpg');`}
  >
    <div class="home-cta-band__inner reveal">
      <div class="home-cta-band__copy">
        <h2>Whatever breaks, we build it back better.</h2>
        <p>One-off part, monthly retainer, race deployment, corporate demo — reach out. No sales deck. Just a direct conversation with the person who runs the printer.</p>
      </div>

      <div class="home-cta-band__actions">
        <a
          href="/contact"
          class="btn btn-primary home-cta-band__primary"
          data-analytics-event="contact_started"
          data-analytics-source="home-final-cta"
        >
          Request Service
        </a>
        <a
          href="https://ko-fi.com/3d3dca"
          class="btn btn-secondary home-cta-band__secondary"
          target="_blank"
          rel="noopener noreferrer"
          data-analytics-event="kofi_clicked"
          data-analytics-source="home-final-cta"
        >
          Support on Ko-fi
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ BLOG SUBJECTS (hidden, for future use) ═══════════════════ -->
  <template data-blog-subjects>
    {blogSubjects.map((subject) => (
      <span>{subject}</span>
    ))}
  </template>
</BaseLayout>

<style>
  /* ── Scroll Reveal System ─────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.12s; }
  .reveal-delay-2 { transition-delay: 0.24s; }
  .reveal-delay-3 { transition-delay: 0.36s; }

  /* ── Shared Section Styles ────────────────────────── */
  .home-section {
    display: grid;
    gap: 1.75rem;
  }

  .section-heading {
    display: grid;
    gap: 0.8rem;
  }

  .section-title,
  .race-title,
  .hero-title,
  .home-cta-band h2 {
    margin: 0;
    letter-spacing: -0.03em;
  }

  .hero-title {
    font-size: clamp(2.6rem, 1.8rem + 4vw, 5.2rem);
    line-height: 0.96;
    max-width: 16ch;
  }

  .section-title,
  .race-title,
  .home-cta-band h2 {
    font-size: clamp(2rem, 1.2rem + 2.4vw, 3.6rem);
    line-height: 1.02;
  }

  .hero-subheadline,
  .section-body,
  .race-body,
  .home-cta-band p {
    margin: 0;
    max-width: 64ch;
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  /* ── Hero ──────────────────────────────────────────── */
  .home-hero {
    padding-top: clamp(2.4rem, 4vw, 4rem);
    padding-bottom: clamp(3rem, 4vw, 4.6rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(1.75rem, 3vw, 3.5rem);
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: 1.35rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.25rem;
    font-family: var(--font-tech);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .hero-trust span {
    position: relative;
    padding-left: 0.85rem;
  }

  .hero-trust span::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-teal-primary);
    transform: translateY(-50%);
  }

  .hero-visual {
    min-height: clamp(22rem, 48vw, 38rem);
    overflow: hidden;
    border-radius: 20px;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .hero-stats {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .hero-stat {
    padding: 1.2rem 1.1rem;
    display: grid;
    gap: 0.35rem;
    background: linear-gradient(135deg, rgba(64, 196, 196, 0.1), rgba(255, 255, 255, 0.96));
  }

  .hero-stat strong {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.1rem + 0.8vw, 2.1rem);
