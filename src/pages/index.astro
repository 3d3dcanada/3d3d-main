<script>
  // Racing stripe scroll parallax — each stripe moves at a different rate
  (function () {
    const stripes = /** @type {HTMLElement[]} */ ([...document.querySelectorAll('.hero-stripe[data-speed]')]);
    if (!stripes.length) return;

    let ticking = false;

    function update() {
      const y = window.scrollY;
      stripes.forEach((stripe) => {
        const speed = parseFloat(stripe.dataset.speed ?? '0.1');
        stripe.style.transform = `translateY(${-(y * speed)}px)`;
      });
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (window.innerWidth < 768) return;
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();

  // Hero background parallax — bg image moves slower than scroll
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const bgImg = document.querySelector('.hero-bg img');
    if (!bgImg) return;
    let ticking = false;

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY;
          (bgImg as HTMLElement).style.transform = `translateY(${y * 0.3}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  })();

  // Stripe → Phone choreography timeline
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const heroMedia = document.querySelector('.hero-phones');
    if (!heroMedia) return;

    const timeline = [
      { delay: 1400, phone: 'marine',  scan: 'teal',    dir: 'h', stripe: '.hero-stripe--teal' },
      { delay: 2600, phone: 'print',   scan: 'orange',  dir: 'v', stripe: '.hero-stripe--orange' },
      { delay: 3400, phone: 'custom',  scan: 'magenta', dir: 'h', stripe: '.hero-stripe--magenta' },
    ];

    timeline.forEach(({ delay, phone, scan, dir, stripe }) => {
      setTimeout(() => {
        // Dispatch phone entrance event
        window.dispatchEvent(new CustomEvent('phone-enter', { detail: { phone } }));

        // Activate stripe glow pulse
        const stripeEl = document.querySelector(stripe);
        if (stripeEl) stripeEl.classList.add('stripe-alive');

        // Create scan line
        const line = document.createElement('div');
        line.className = `hero-scan-line hero-scan-line--${dir} hero-scan-line--${scan}`;
        line.style.cssText = dir === 'h'
          ? `top: 50%; left: 0;`
          : `left: 50%; top: 0;`;
        heroMedia.appendChild(line);

        // Trigger animation on next frame
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            line.classList.add('active');
          });
        });

        // Remove scan line after animation
        setTimeout(() => {
          line.classList.remove('active');
          setTimeout(() => line.remove(), 300);
        }, 800);
      }, delay);
    });
  })();
</script>

