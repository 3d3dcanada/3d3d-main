  <script is:inline>
    (() => {
      const html = document.documentElement;
      const dialogs = Array.from(document.querySelectorAll('.hp-dialog'));
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const sponsorState = {
        currency: 'CAD',
        billing: 'monthly',
      };

      const sponsorRates = {
        USD: 1,
        CAD: 1.37,
        EUR: 0.92,
      };

      const sponsorBase = {
        supporter: 100,
        partner: 500,
      };

      const getSponsorFormatter = (currency) =>
        new Intl.NumberFormat(currency === 'EUR' ? 'de-DE' : 'en-CA', {
          style: 'currency',
          currency,
          maximumFractionDigits: 0,
        });

      const detectCurrency = () => {
        const locale = navigator.language || '';
        const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
        const canadaZones = [
          'America/Halifax',
          'America/Moncton',
          'America/St_Johns',
          'America/Toronto',
          'America/Winnipeg',
          'America/Edmonton',
          'America/Vancouver',
        ];

        if (locale.includes('-CA') || canadaZones.includes(timeZone)) return 'CAD';
        if (timeZone.startsWith('Europe/')) return 'EUR';
        return 'USD';
      };

      sponsorState.currency = detectCurrency();

      const syncDialogState = () => {
        const hasOpenDialog = dialogs.some((dialog) => dialog.hasAttribute('open'));
        html.classList.toggle('hp-has-dialog', hasOpenDialog);
      };

      const openDialog = (dialog) => {
        if (!(dialog instanceof HTMLDialogElement)) return;
        if (typeof dialog.showModal === 'function') {
          dialog.showModal();
        } else {
          dialog.setAttribute('open', 'true');
        }
        syncDialogState();
      };

      const closeDialog = (dialog) => {
        if (!(dialog instanceof HTMLDialogElement)) return;
        if (typeof dialog.close === 'function') {
          dialog.close();
        } else {
          dialog.removeAttribute('open');
        }
        syncDialogState();
      };

      const updateSponsorUI = () => {
        document.querySelectorAll('[data-currency-option]').forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.classList.toggle('hp-switch__button--active', button.dataset.currencyOption === sponsorState.currency);
        });

        document.querySelectorAll('[data-billing-option]').forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.classList.toggle('hp-switch__button--active', button.dataset.billingOption === sponsorState.billing);
        });

        const billingMultiplier = sponsorState.billing === 'yearly' ? 10 : 1;
        const formatter = getSponsorFormatter(sponsorState.currency);

        Object.entries(sponsorBase).forEach(([tier, amount]) => {
          const priceNode = document.querySelector(`[data-tier-price="${tier}"]`);
          const metaNode = document.querySelector(`[data-tier-meta="${tier}"]`);
          if (!(priceNode instanceof HTMLElement) || !(metaNode instanceof HTMLElement)) return;

          const converted = Math.round(amount * sponsorRates[sponsorState.currency] * billingMultiplier);
          priceNode.textContent = formatter.format(converted);
          metaNode.textContent =
            sponsorState.billing === 'yearly' ? 'per year · 2 months free' : 'per month';
        });

        const customCurrencySymbol = document.querySelector('[data-custom-currency-symbol]');
        if (customCurrencySymbol instanceof HTMLElement) {
          customCurrencySymbol.textContent = sponsorState.currency;
        }

        const currencyField = document.querySelector('[data-sponsor-currency-field]');
        const billingField = document.querySelector('[data-sponsor-billing-field]');
        if (currencyField instanceof HTMLInputElement) currencyField.value = sponsorState.currency;
        if (billingField instanceof HTMLInputElement) billingField.value = sponsorState.billing;
      };

      updateSponsorUI();

      document.querySelectorAll('[data-currency-option]').forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener('click', () => {
          sponsorState.currency = button.dataset.currencyOption || 'CAD';
          updateSponsorUI();
        });
      });

      document.querySelectorAll('[data-billing-option]').forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener('click', () => {
          sponsorState.billing = button.dataset.billingOption || 'monthly';
          updateSponsorUI();
        });
      });

      const populateSponsorDialog = (trigger) => {
        const sponsorDialog = document.getElementById('dlg-sponsor');
        if (!(sponsorDialog instanceof HTMLDialogElement) || !(trigger instanceof HTMLElement)) return;

        const tier = trigger.dataset.sponsorTier || 'custom';
        const tierField = sponsorDialog.querySelector('[data-sponsor-tier-field]');
        const amountField = sponsorDialog.querySelector('[data-sponsor-amount-field]');
        const title = sponsorDialog.querySelector('[data-sponsor-dialog-title]');
        const copy = sponsorDialog.querySelector('[data-sponsor-dialog-copy]');
        const customInput = document.querySelector('[data-custom-amount]');
        const formatter = getSponsorFormatter(sponsorState.currency);
        const multiplier = sponsorState.billing === 'yearly' ? 10 : 1;

        let amountLabel = formatter.format(Math.round(100 * sponsorRates[sponsorState.currency] * multiplier));

        if (tier === 'partner') {
          amountLabel = formatter.format(Math.round(500 * sponsorRates[sponsorState.currency] * multiplier));
        }

        if (tier === 'custom') {
          const amountValue =
            customInput instanceof HTMLInputElement && customInput.value
              ? Number(customInput.value)
              : 1000;
          amountLabel = formatter.format(Math.round(amountValue));
        }

        if (tierField instanceof HTMLInputElement) tierField.value = tier;
        if (amountField instanceof HTMLInputElement) amountField.value = amountLabel;

        if (title instanceof HTMLElement) {
          if (tier === 'supporter') title.textContent = 'Start a Supporter sponsorship.';
          if (tier === 'partner') title.textContent = 'Start a Partner sponsorship.';
          if (tier === 'custom') title.textContent = 'Build a custom investor package.';
        }

        if (copy instanceof HTMLElement) {
          if (tier === 'supporter') {
            copy.textContent = `Supporter is ${amountLabel} ${sponsorState.billing === 'yearly' ? 'per year' : 'per month'} and includes the keychain plus hat or shirt package.`;
          }
          if (tier === 'partner') {
            copy.textContent = `Partner is ${amountLabel} ${sponsorState.billing === 'yearly' ? 'per year' : 'per month'} and includes the full enhanced package, prints, consult time, and software support.`;
          }
          if (tier === 'custom') {
            copy.textContent = `Custom investor support is set to ${amountLabel}. Use the notes field to outline event co-branding, equity, or a negotiated package.`;
          }
        }
      };

      document.querySelectorAll('[data-dialog-open]').forEach((trigger) => {
        if (!(trigger instanceof HTMLElement)) return;
        trigger.addEventListener('click', (event) => {
          event.preventDefault();
          const dialogId = trigger.dataset.dialogOpen;
          if (!dialogId) return;
          if (dialogId === 'dlg-sponsor') populateSponsorDialog(trigger);
          openDialog(document.getElementById(dialogId));
        });
      });

      document.querySelectorAll('[data-dialog-close]').forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        button.addEventListener('click', () => {
          closeDialog(button.closest('.hp-dialog'));
        });
      });

      dialogs.forEach((dialog) => {
        if (!(dialog instanceof HTMLDialogElement)) return;

        dialog.addEventListener('click', (event) => {
          if (event.target === dialog) {
            closeDialog(dialog);
          }
        });

        dialog.addEventListener('close', syncDialogState);
        dialog.addEventListener('cancel', syncDialogState);
      });

      document.querySelectorAll('[data-rotating-gallery]').forEach((gallery) => {
        if (!(gallery instanceof HTMLElement) || reducedMotion) return;
        const slides = Array.from(gallery.querySelectorAll('.hp-section__bg-img'));
        if (slides.length < 2) return;

        let activeIndex = 0;
        const interval = Number(gallery.dataset.rotateInterval || 9000);

        window.setInterval(() => {
          slides[activeIndex]?.classList.remove('hp-section__bg-img--active');
          activeIndex = (activeIndex + 1) % slides.length;
          slides[activeIndex]?.classList.add('hp-section__bg-img--active');
        }, interval);
      });

      const filterCards = () => {
        const activeFilter =
          document.querySelector('.hp-filter-pill--active')?.getAttribute('data-shop-filter') || 'all';

        document.querySelectorAll('[data-shop-card]').forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          const cardCategory = card.dataset.shopCategory || '';
          card.hidden = activeFilter !== 'all' && cardCategory !== activeFilter;
        });
      };

      document.querySelectorAll('[data-shop-filter]').forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener('click', () => {
          document.querySelectorAll('[data-shop-filter]').forEach((otherButton) => {
            otherButton.classList.remove('hp-filter-pill--active');
          });
          button.classList.add('hp-filter-pill--active');
          filterCards();
        });
      });

      filterCards();
    })();
  </script>
</body>
