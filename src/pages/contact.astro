---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — 3D3D" description="Get in touch with 3D3D. Custom fabrication requests, partnerships, printer setup, or anything else. Atlantic Canada based, serving the United States and Canada." activePath="/contact">

  <div class="contact-page">
    <div class="contact-hero">
      <div class="contact-shell">
        <p class="contact-eyebrow">Get in Touch</p>
        <h1 class="contact-title">Let's build something.</h1>
        <p class="contact-intro">
          3D3D builds functional parts for marine, automotive, motorsport, and field deployment. Whether you need a replacement part, a custom fabrication, printer setup help, or want to partner on the Newport Bermuda campaign — send us the details.
        </p>
      </div>
    </div>

    <div class="contact-shell contact-body">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="contact-card">
            <h2 class="contact-card__title">Direct Contact</h2>
            <div class="contact-card__row">
              <span class="contact-card__label">Email</span>
              <a href="mailto:3d3dcanada@gmail.com" class="contact-card__value contact-card__value--accent">3d3dcanada@gmail.com</a>
            </div>
            <div class="contact-card__row">
              <span class="contact-card__label">Phone / WhatsApp</span>
              <a href="https://wa.me/15069532678" class="contact-card__value" target="_blank" rel="noopener noreferrer">506-953-2678</a>
            </div>
            <div class="contact-card__row">
              <span class="contact-card__label">Location</span>
              <span class="contact-card__value">Atlantic Canada based. Serving the United States and Canada.</span>
            </div>
          </div>

          <div class="contact-card">
            <h2 class="contact-card__title">Quick Links</h2>
            <a href="/blog" class="contact-card__link">Follow the campaign →</a>
            <a href="https://ko-fi.com/3d3dca" class="contact-card__link" target="_blank" rel="noopener noreferrer">Support on Ko-fi →</a>
            <a href="https://www.printables.com/@KTK3D_3050116" class="contact-card__link" target="_blank" rel="noopener noreferrer">Free designs on Printables →</a>
            <a href="/shop" class="contact-card__link">Browse the shop →</a>
          </div>
        </div>

        <div class="contact-form-wrap">
          <h2 class="contact-form__title">Send a Message</h2>
          <form action="https://formspree.io/f/mldlydbl" method="POST" class="contact-form" data-analytics-submit="contact_submitted" data-analytics-source="contact-page">
            <div aria-hidden="true" style="position: absolute; left: -100vw; width: 1px; height: 1px; overflow: hidden;">
              <label for="contact-website">Leave this field blank</label>
              <input type="text" id="contact-website" name="_gotcha" tabindex="-1" autocomplete="off" />
            </div>
            <div class="contact-form__row">
              <div class="contact-form__field">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required placeholder="Your name" />
              </div>
              <div class="contact-form__field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="you@example.com" />
              </div>
            </div>
            <div class="contact-form__field">
              <label for="subject">What do you need?</label>
              <select id="subject" name="subject">
                <option value="custom-fabrication">Custom Fabrication Request</option>
                <option value="replacement-part">Replacement Part</option>
                <option value="printer-setup">Printer Setup Help</option>
                <option value="partnership">Partnership / Sponsorship</option>
                <option value="event-booking">Event Booking</option>
                <option value="support">Support the Campaign</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="contact-form__field">
              <label for="message">Describe your project or problem</label>
              <textarea id="message" name="message" rows={6} required placeholder="Tell us about the part, the problem, or the project. Include dimensions, materials, or photos if you have them."></textarea>
            </div>
            <div class="contact-form__field">
              <label for="file" class="contact-form__file-label">
                <span>Attach a file (optional)</span>
                <span class="contact-form__file-hint">Photos, drawings, STL files, or reference images</span>
              </label>
              <input type="file" id="file" name="attachment" accept=".jpg,.jpeg,.png,.pdf,.stl,.step,.3mf" />
            </div>
            <div class="contact-form__consent">
              <input type="checkbox" id="casl-consent" name="casl_consent" value="yes" />
              <label for="casl-consent">
                I consent to receiving commercial electronic messages from 3D3D. You may unsubscribe at any time. See our <a href="/casl">CASL policy</a> and <a href="/privacy">privacy policy</a>.
              </label>
            </div>
            <button type="submit" class="contact-form__submit">Send Message →</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    --page-accent: #40C4C4;
    --page-bg-dark: #111214;
    --page-bg-light: #F6F7FA;
    --page-border: 3px solid #1A1A1A;
  }

  .contact-hero {
    background: var(--page-bg-dark);
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
    color: #F6F7FA;
  }

  .contact-shell {
    width: min(calc(100% - 3rem), 1100px);
    margin: 0 auto;
  }

  .contact-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--page-accent);
  }

  .contact-title {
    margin: 0.75rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 4vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: #F6F7FA;
  }

  .contact-intro {
    margin: 1.25rem 0 0;
    max-width: 42rem;
    font-size: clamp(1rem, 0.94rem + 0.3vw, 1.15rem);
    line-height: 1.75;
    color: rgba(246, 247, 250, 0.78);
  }

  .contact-body {
    padding: clamp(3rem, 5vw, 4rem) 0 clamp(4rem, 6vw, 6rem);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: clamp(2rem, 4vw, 3rem);
    align-items: start;
  }

  .contact-info {
    display: grid;
    gap: 1.2rem;
  }

  .contact-card {
    padding: clamp(1.25rem, 2.5vw, 2rem);
    border: var(--page-border);
    border-radius: 1rem;
    background: var(--page-bg-light);
    display: grid;
    gap: 1rem;
  }

  .contact-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.1;
    color: #1A1A1A;
  }

  .contact-card__row {
    display: grid;
    gap: 0.2rem;
  }

  .contact-card__label {
    font-family: var(--font-tech);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #666666;
  }

  .contact-card__value {
    font-size: 0.96rem;
    line-height: 1.5;
    color: #1A1A1A;
  }

  .contact-card__value--accent {
    color: var(--page-accent);
    font-family: var(--font-mono);
  }

  .contact-card__link {
    font-size: 0.96rem;
    color: #1A1A1A;
    border-bottom: 1px solid rgba(26, 26, 26, 0.15);
    padding-bottom: 0.5rem;
    transition: color 0.15s ease;
  }

  .contact-card__link:hover {
    color: var(--page-accent);
  }

  .contact-form-wrap {
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border: var(--page-border);
    border-radius: 1rem;
    background: #FFFFFF;
  }

  .contact-form__title {
    margin: 0 0 1.5rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.1;
    color: #1A1A1A;
  }

  .contact-form {
    display: grid;
    gap: 1.25rem;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form__field {
    display: grid;
    gap: 0.4rem;
  }

  .contact-form__field label {
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666666;
  }

  .contact-form__field input,
  .contact-form__field select,
  .contact-form__field textarea {
    padding: 0.8rem 1rem;
    border: 2px solid #1A1A1A;
    border-radius: 0.5rem;
    background: #F6F7FA;
    color: #1A1A1A;
    font-family: var(--font-body);
    font-size: 0.96rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .contact-form__field input:focus,
  .contact-form__field select:focus,
  .contact-form__field textarea:focus {
    outline: none;
    border-color: var(--page-accent);
    box-shadow: 0 0 0 3px rgba(64, 196, 196, 0.2);
  }

  .contact-form__field input::placeholder,
  .contact-form__field textarea::placeholder {
    color: #999;
  }

  .contact-form__file-label {
    display: grid;
    gap: 0.15rem;
  }

  .contact-form__file-hint {
    font-size: 0.6rem !important;
    letter-spacing: 0.1em !important;
    color: #999 !important;
  }

  .contact-form__field input[type="file"] {
    padding: 0.6rem;
    font-size: 0.88rem;
    cursor: pointer;
  }

  .contact-form__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .contact-form__consent input[type="checkbox"] {
    margin-top: 0.2rem;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    accent-color: var(--page-accent);
  }

  .contact-form__consent label {
    font-size: 0.78rem;
    line-height: 1.5;
    color: #666666;
  }

  .contact-form__consent a {
    color: var(--page-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .contact-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.9rem 1.5rem;
    border: 3px solid #1A1A1A;
    background: var(--page-accent);
    color: #0F1112;
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.25s ease;
    width: 100%;
  }

  .contact-form__submit:hover {
    background: #53D3D3;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.3);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .contact-shell {
      width: min(calc(100% - 1.5rem), 1100px);
    }
  }
</style>
