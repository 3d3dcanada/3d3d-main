---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Community Projects',
  description: 'Open-source projects, community builds, and collaborative fabrication from the 3D3D cooperative network.',
  url: 'https://3d3d.ca/projects',
};

const projects = [
  {
    title: 'Old Girl — Community 3D Printer',
    status: 'Live',
    statusColor: '#40C4C4',
    description: 'A community CoreXY 3D printer built from scratch. Fully documented build process, BOM, and firmware config. Running and printing in Fredericton.',
    tags: ['Hardware', 'Open Source', 'CoreXY', 'Klipper'],
    link: 'https://oldgirl.3d3d.ca',
    linkLabel: 'oldgirl.3d3d.ca',
  },
  {
    title: 'ORA — Governed AI Runtime',
    status: 'Active Development',
    statusColor: '#E84A8A',
    description: 'An open-source governed AI runtime. Built in Rust. 8 MCP tools, evidence-based reasoning, durable memory, and the Odin Protocol. Self-hosted, provider-agnostic.',
    tags: ['Rust', 'TypeScript', 'AI', 'Open Source'],
    link: 'https://github.com/3d3dcanada',
    linkLabel: 'GitHub',
  },
  {
    title: 'Newport-Bermuda 2026 — Live Fabrication at Sea',
    status: 'Upcoming — June 2026',
    statusColor: '#FF6B2B',
    description: 'Deploying an enclosed CoreXY printer aboard a racing yacht for the 120th Newport Bermuda Race. Printing replacement parts live offshore — cleats, fairleads, instrument mounts — in ASA and PA-CF under ocean conditions.',
    tags: ['Marine', 'Event', 'ASA', 'PA-CF', 'Offshore'],
    link: '/events',
    linkLabel: 'Race Details',
  },
  {
    title: 'Distributed Print Network',
    status: 'Recruiting',
    statusColor: '#E84A8A',
    description: 'Building a network of vetted maker nodes across Canada. Each node gets a free website (yourname.3d3d.ca), access to enterprise contracts, bulk material pricing, and 75% revenue share.',
    tags: ['Network', 'Co-op', 'Manufacturing'],
    link: '/join',
    linkLabel: 'Join the Network',
  },
  {
    title: 'STEM Workshop Program',
    status: 'Active',
    statusColor: '#40C4C4',
    description: 'Hands-on 3D printing workshops for schools and community centers across Atlantic Canada. Students design, slice, and print functional parts. All workshop materials are open-source.',
    tags: ['Education', 'STEM', 'Youth', 'Community'],
    link: '/contact?subject=workshop',
    linkLabel: 'Book a Workshop',
  },
  {
    title: 'Parametric Parts Library',
    status: 'Growing',
    statusColor: '#40C4C4',
    description: 'Open-source parametric 3D models published on Printables. Marine hardware, automotive clips, household repairs — functional parts designed to be customized for exact dimensions.',
    tags: ['CAD', 'Printables', 'Open Source', 'Parametric'],
    link: 'https://www.printables.com/@KTK3D_3050116',
    linkLabel: 'Printables Catalog',
  },
  {
    title: 'CodeQuest — Interactive Coding Game',
    status: 'Active Development',
    statusColor: '#E84A8A',
    description: 'A gamified coding education platform built in C#. Teaches programming fundamentals through interactive challenges. Open-source, designed for community contribution.',
    tags: ['C#', 'Education', 'Game', 'Open Source'],
    link: 'https://github.com/3d3dcanada',
    linkLabel: 'GitHub',
  },
  {
    title: 'Marine Hardware Replacement Program',
    status: 'Active',
    statusColor: '#40C4C4',
    description: 'Reverse-engineering discontinued marine deck hardware. Scanning broken parts, modeling replacements in Fusion 360, and printing in ASA and PA-CF. Open catalog growing monthly.',
    tags: ['Marine', 'Reverse Engineering', 'ASA', 'Functional'],
    link: '/materials',
    linkLabel: 'Materials Guide',
  },
];
---

<BaseLayout title="Community Projects | 3D3D" description="Open-source builds, offshore deployments, STEM workshops, and maker network initiatives from the 3D3D cooperative." activePath="/projects" schema={schema}>

  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Community', href: '/community'}, {label: 'Projects'}]} />
            <p class="hp-card__eyebrow mt-4">Building in the Open</p>
            <h1 class="hp-card__title mt-2 mb-4">Community Projects</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Everything we build gets shared. Hardware designs, software tools, educational materials, and the infrastructure behind the cooperative itself. Here is what is active, what is coming, and how to get involved.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Project Cards -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Active & Upcoming</p>
            <h2 class="hp-card__title mt-2 mb-6">The Work</h2>

            <div class="proj-grid">
              {projects.map((p) => (
                <article class="proj-card">
                  <div class="proj-card__header">
                    <h3 class="proj-card__title">{p.title}</h3>
                    <span class="proj-card__status" style={`color: ${p.statusColor}; border-color: ${p.statusColor};`}>{p.status}</span>
                  </div>
                  <p class="proj-card__desc">{p.description}</p>
                  <div class="proj-card__tags">
                    {p.tags.map((t) => <span class="proj-tag">{t}</span>)}
                  </div>
                  <a href={p.link} class="proj-card__link" target={p.link.startsWith('http') ? '_blank' : undefined} rel={p.link.startsWith('http') ? 'noopener noreferrer' : undefined}>
                    {p.linkLabel} →
                  </a>
                </article>
              ))}
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: Contribute CTA -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Get Involved</p>
            <h2 class="hp-card__title mt-2 mb-4">Want to Contribute?</h2>
            <p class="hp-card__copy mb-6">
              Every project listed here accepts contributions — code, designs, documentation, testing, or just showing up to a workshop. Fork a repo, submit a model, or reach out to discuss how you can help.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start">
              <a href="https://github.com/3d3dcanada" target="_blank" rel="noopener noreferrer" class="hp-cta hp-cta--accent">GitHub Organization</a>
              <a href="/join" class="hp-cta hp-cta--glass">Join the Network</a>
              <a href="/contact?subject=project-contribution" class="hp-cta hp-cta--glass">Get in Touch</a>
            </div>

            <div class="mt-8">
              <PageNextActions actions={[
                {label: 'Sponsor a Project', href: '/sponsors', description: 'Fund workshops, printers, and event deployments.', accent: 'teal'},
                {label: 'Community Hub', href: '/community', description: 'Open-source repos and network information.', accent: 'magenta'},
              ]} />
            </div>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .proj-grid {
    display: grid;
    gap: 0.8rem;
  }
  .proj-card {
    padding: clamp(1.2rem, 2.5vw, 1.6rem);
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    display: grid;
    gap: 0.8rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .proj-card:hover {
    border-color: rgba(64, 196, 196, 0.4);
    transform: translateY(-2px);
  }
  .proj-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .proj-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.85rem + 0.6vw, 1.25rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: rgba(246, 247, 250, 0.9);
  }
  .proj-card__status {
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border: 1.5px solid;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .proj-card__desc {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.65;
    color: rgba(246, 247, 250, 0.45);
  }
  .proj-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .proj-tag {
    font-family: var(--font-tech);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.45rem;
    background: rgba(64, 196, 196, 0.12);
    color: var(--color-teal-primary);
    border-radius: 2px;
  }
  .proj-card__link {
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
    transition: color 0.2s ease;
  }
  .proj-card__link:hover { color: #53D3D3; }
</style>
