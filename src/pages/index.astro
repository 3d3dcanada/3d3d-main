---
import BaseLayout from '../layouts/BaseLayout.astro';
import CampaignStrip from '../components/CampaignStrip';
import DeviceShowcase from '../components/DeviceShowcase';
import BentoGrid from '../components/BentoGrid.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'Organization'],
  name: '3D3D',
  url: 'https://3d3d.ca',
  description: 'Specialty fabrication for marine, motorsport, replacement parts, and field deployment. Founder-operated and serving worldwide buyers.',
  telephone: '+1-506-953-2678',
  email: 'info@3d3d.ca',
  areaServed: ['Worldwide', 'Caribbean', 'Coastal United States', 'Europe'],
  founder: { '@type': 'Person', name: '3D3D' },
  sameAs: [
    'https://www.youtube.com/@3D3Dcanada',
    'https://www.tiktok.com/@3d3dcanada',
    'https://www.instagram.com/3d3dca/',
    'https://www.facebook.com/profile.php?id=61575548079847',
    'https://www.printables.com/@KTK3D_3050116',
    'https://github.com/3d3dcanada/3d3d-main',
    'https://wa.me/15069532678',
    'https://ko-fi.com/3d3dca',
  ],
  image: 'https://3d3d.ca/media/real/fleet-running.jpg',
  logo: 'https://3d3d.ca/media/brand/logo-badge.webp',
};

const homeNavGroups = [
  {
    label: 'On This Page',
    items: [
      { id: 'home', label: 'Home', href: '/' },
      { id: 'explore', label: 'Explore', href: '#explore' },
      { id: 'contact', label: 'Contact', href: '#contact' },
    ],
  },
  {
    label: 'Site',
    items: [
      { id: 'shop', label: 'Shop', href: '/shop' },
      { id: 'prusa', label: 'Prusa', href: '/prusa' },
      { id: 'blog', label: 'Blog', href: '/blog' },
      { id: 'about', label: 'About', href: '/about' },
    ],
  },
];

---

<BaseLayout
  title="3D3D | You Have a Problem. I Am Your Solution."
  description="Offshore marine fabrication and discontinued part replacement. Worldwide on-site deployment and remote engineering by a 20,000nm offshore specialist."
  schema={orgSchema}
  activePath="/"
  navGroups={homeNavGroups}
  bodyClass="home-editorial"
>
  <div class="home-page">

    <!-- ═══════════════════════════════════════════════════
         HERO — dark, full-height
         ═══════════════════════════════════════════════════ -->
    <section id="home" class="home-section home-section--dark home-hero" data-section>
      <div class="hero-bg" aria-hidden="true">
        <img src="/media/real/fleet-running.jpg" alt="" loading="eager" decoding="async" />
      </div>
      <div class="hero-stripes" aria-hidden="true">
        <div class="hero-stripe hero-stripe--magenta" data-speed="0.19"></div>
        <div class="hero-stripe hero-stripe--orange" data-speed="0.07"></div>
        <div class="hero-stripe hero-stripe--teal" data-speed="0.12"></div>
      </div>
      <div class="section-shell hero-shell">
        <div class="hero-copy">
          <p class="eyebrow hero-eyebrow" data-scramble>3D Printing · Fabrication · Marine Specialist</p>
          <h1 class="hero-title" aria-label="You have a problem. Let's find your solution.">
             <span class="hero-line" data-word-reveal>
               <span class="word-clip"><span class="word">You</span></span>
               <span class="word-clip"><span class="word">have</span></span>
               <span class="word-clip"><span class="word">a</span></span>
               <span class="word-clip"><span class="word">problem.</span></span>
             </span>
             <span class="hero-line hero-line--accent" data-word-reveal>
               <span class="word-clip"><span class="word">Let's</span></span>
               <span class="word-clip"><span class="word">find</span></span>
               <span class="word-clip"><span class="word">your</span></span>
               <span class="word-clip"><span class="word">solution.</span></span>
             </span>
           </h1>
        </div>

        <!-- Phones ARE the hero — the centerpiece -->
        <div class="hero-phones">
          <DeviceShowcase client:visible />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         CAMPAIGN STRIP (React + Motion)
         ═══════════════════════════════════════════════════ -->
    <CampaignStrip client:visible />

    <!-- ═══════════════════════════════════════════════════
         BENTO GRID — clickable exploration
         ═══════════════════════════════════════════════════ -->
    <BentoGrid />

    <!-- ═══════════════════════════════════════════════════
         CONTACT — teal/dark
         ═══════════════════════════════════════════════════ -->
    <section id="contact" class="home-section home-section--teal final-cta-section" data-section>
      <div class="section-shell final-cta-shell">
        <div class="final-cta-copy">
          <h2 class="section-title section-title--inverse scroll-in-float">
            One call. We'll assess it.<br />We'll sort it out.
          </h2>
          <p class="section-body section-body--inverse scroll-in-fade scroll-delay-1">
            Tell us the problem. Tell us where the vessel is. We'll tell you whether we can solve it, how we'll do it, and exactly what it takes. That is the whole process.
          </p>
          <div class="final-cta-actions">
            <a href="/contact" class="final-cta-button final-cta-button--light scroll-in-pop scroll-delay-2">Get in Touch →</a>
            <a href="/book" class="final-cta-button final-cta-button--ghost scroll-in-pop scroll-delay-3">Book a Call →</a>
          </div>
        </div>
      </div>
    </section>

  </div>

  <!-- ═══════════════════════════════════════════════════
       SCRIPTS
       ═══════════════════════════════════════════════════ -->
  <script is:inline>
    // Word-split masked reveal for hero title
    (() => {
      const lines = Array.from(document.querySelectorAll('[data-word-reveal]'));
      if (!lines.length || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        // Immediately reveal all words if reduced motion
        document.querySelectorAll('.word').forEach(w => w.classList.add('revealed'));
        return;
      }

      let wordIndex = 0;
      lines.forEach((line, lineIdx) => {
        const words = line.querySelectorAll('.word');
        words.forEach((word) => {
          const delay = wordIndex * 70 + lineIdx * 150;
          setTimeout(() => word.classList.add('revealed'), delay + 200);
          wordIndex++;
        });
      });
    })();

    // Eyebrow character scramble
    (() => {
      const el = document.querySelector('[data-scramble]');
      if (!el || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const finalText = el.textContent || '';
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789#@!%·';
      const duration = 900;
      const start = performance.now();

      function scramble(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const revealedCount = Math.floor(progress * finalText.length);

        let result = '';
        for (let i = 0; i < finalText.length; i++) {
          if (i < revealedCount) {
            result += finalText[i];
          } else if (finalText[i] === ' ' || finalText[i] === '·') {
            result += finalText[i];
          } else {
            result += chars[Math.floor(Math.random() * chars.length)];
          }
        }
        el.textContent = result;

        if (progress < 1) {
          requestAnimationFrame(scramble);
        } else {
          el.textContent = finalText;
        }
      }

      requestAnimationFrame(scramble);
    })();

  </script>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════
     PAGE TOKENS
     ═══════════════════════════════════════════════════ */
  :global(body.home-editorial) {
    background-color: #F6F7FA;
    background-image:
      radial-gradient(circle at 88% 8%, rgba(232, 74, 138, 0.07) 0%, transparent 28%),
      radial-gradient(circle at 10% 92%, rgba(64, 196, 196, 0.06) 0%, transparent 32%),
      radial-gradient(circle at 50% 50%, rgba(64, 196, 196, 0.03) 0%, transparent 60%),
      linear-gradient(180deg, rgba(246, 247, 250, 0.95), rgba(238, 242, 243, 1));
    background-attachment: fixed;
  }

  :global(body.home-editorial::after) {
    display: block;
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.025;
    background-image:
      repeating-linear-gradient(0deg, rgba(64, 196, 196, 0.15) 0px, transparent 1px, transparent 60px),
      repeating-linear-gradient(90deg, rgba(64, 196, 196, 0.15) 0px, transparent 1px, transparent 60px);
  }

  .home-page {
    --page-accent: #40C4C4;
    --page-accent-secondary: #E84A8A;
    --page-bg-light: #F6F7FA;
    --page-bg-dark: #111214;
    --page-surface: #FFFFFF;
    --page-text: #1A1A1A;
    --page-text-muted: #666666;
    --page-border: 2px solid #1A1A1A;
    --page-thick-border: 3px solid #1A1A1A;
    --page-shell-width: min(100% - clamp(1.5rem, 4vw, 4rem), 1320px);
    background: var(--page-bg-light);
    color: var(--page-text);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .section-shell {
    position: relative;
    z-index: 1;
    width: var(--page-shell-width);
    margin: 0 auto;
  }

  .home-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 8rem);
    scroll-margin-top: 1rem;
  }

  .home-section--light { background: var(--page-bg-light); position: relative; }

  .home-section + .home-section::before {
    content: '';
    position: absolute;
    top: -2px;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(64, 196, 196, 0.3) 30%,
      rgba(232, 74, 138, 0.2) 70%,
      transparent 100%
    );
    filter: blur(1px);
    z-index: 2;
  }

  .home-section--dark {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
      var(--page-bg-dark);
    color: #F6F7FA;
  }

  .home-section--teal {
    background: var(--page-accent);
    color: #FFFFFF;
  }

  /* Scroll animations handled by global scroll-reveal.css */

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: var(--page-accent);
    flex-shrink: 0;
  }

  .section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 4vw, 4.9rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  .section-title--light,
  .section-title--inverse { color: #F6F7FA; }

  .section-body {
    margin: 0;
    max-width: 42rem;
    font-size: clamp(1rem, 0.94rem + 0.35vw, 1.18rem);
    line-height: 1.75;
    color: var(--page-text);
  }

  .section-body--inverse { color: rgba(255, 255, 255, 0.9); }

  /* ═══════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════ */
  .home-hero {
    min-height: auto;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: clamp(5rem, 8vw, 7rem);
    padding-bottom: clamp(2rem, 4vw, 4rem);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-bg img {
    width: 100%;
    height: 120%; /* extra height for parallax travel */
    object-fit: cover;
    object-position: center top;
    opacity: 0.35;
    filter: brightness(0.6);
    will-change: transform;
  }

  /* ── Hero Racing Stripes ── */
  .hero-stripes {
    position: absolute;
    /* Left gutter — between viewport edge and the hero copy */
    left: clamp(1.2rem, calc(50% - 660px + 1.8rem), 5rem);
    top: 0;
    bottom: -80px; /* extend below hero so parallax translateY never exposes a gap — hero clips it */
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 9px;
    z-index: 1;
    pointer-events: none;
    overflow: visible;
  }

  .hero-stripe {
    width: 20px;
    flex-shrink: 0;
    will-change: transform;
  }

  /* Teal — RIGHT, builds DOWN first → triggers Phone 1 (marine) */
  .hero-stripe--teal {
    background: #40C4C4;
    clip-path: inset(0 0 100% 0);
    animation: stripe-build-down 0.8s steps(20, end) 0.6s forwards;
    box-shadow: 0 0 18px rgba(64, 196, 196, 0.4);
  }

  /* Orange — MIDDLE, builds UP second → triggers Phone 2 (print) */
  .hero-stripe--orange {
    background: #FA6831;
    clip-path: inset(100% 0 0 0);
    animation: stripe-build-up 0.8s steps(20, end) 1.8s forwards;
    box-shadow: 0 0 18px rgba(250, 104, 49, 0.4);
  }

  /* Magenta — LEFT, builds DOWN third → triggers Phone 3 (custom) */
  .hero-stripe--magenta {
    background: #E040FB;
    clip-path: inset(0 0 100% 0);
    animation: stripe-build-down 0.8s steps(20, end) 2.8s forwards;
    box-shadow: 0 0 18px rgba(224, 64, 251, 0.4);
  }

  @keyframes stripe-build-down {
    from { clip-path: inset(0 0 100% 0); }
    to   { clip-path: inset(0 0 0 0); }
  }

  @keyframes stripe-build-up {
    from { clip-path: inset(100% 0 0 0); }
    to   { clip-path: inset(0 0 0 0); }
  }

  /* Stripe continuous animation — never stops after build completes */
  @media (prefers-reduced-motion: no-preference) {
    .hero-stripe--teal.stripe-alive {
      animation: stripe-alive-teal 5s ease-in-out infinite;
    }
    .hero-stripe--orange.stripe-alive {
      animation: stripe-alive-orange 6.5s ease-in-out 1.2s infinite;
    }
    .hero-stripe--magenta.stripe-alive {
      animation: stripe-alive-magenta 4.8s ease-in-out 0.6s infinite;
    }
  }
  @keyframes stripe-alive-teal {
    0%, 100% {
      box-shadow: 0 0 18px rgba(64, 196, 196, 0.4);
      transform: translateY(0);
      opacity: 0.88;
    }
    50% {
      box-shadow: 0 0 36px rgba(64, 196, 196, 0.8);
      transform: translateY(-3px);
      opacity: 1;
    }
  }
  @keyframes stripe-alive-orange {
    0%, 100% {
      box-shadow: 0 0 18px rgba(250, 104, 49, 0.4);
      transform: translateY(0);
      opacity: 0.85;
    }
    50% {
      box-shadow: 0 0 36px rgba(250, 104, 49, 0.8);
      transform: translateY(3px);
      opacity: 1;
    }
  }
  @keyframes stripe-alive-magenta {
    0%, 100% {
      box-shadow: 0 0 18px rgba(224, 64, 251, 0.4);
      transform: translateY(0);
      opacity: 0.86;
    }
    50% {
      box-shadow: 0 0 36px rgba(224, 64, 251, 0.8);
      transform: translateY(-2px);
      opacity: 1;
    }
  }

  /* Mobile: equal-width racing stripes, centered */
  @media (max-width: 767px) {
    .hero-stripes {
      left: 50%;
      translate: -50% 0; /* use CSS translate so JS transform on children doesn't conflict */
      gap: 14px;
    }
    .hero-stripe {
      width: 16px;
    }
  }

  .hero-shell {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .hero-copy {
    display: grid;
    gap: 1.5rem;
    place-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    color: rgba(246, 247, 250, 0.72);
    opacity: 0;
    animation: hero-line-in 0.72s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero-eyebrow::after {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: #40C4C4;
    flex-shrink: 0;
  }

  .hero-title {
    margin: 0;
    display: grid;
    gap: 0.15em;
    justify-items: center;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1rem + 4vw, 5.5rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: #FFFFFF;
    text-transform: uppercase;
  }

  .hero-line {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0 0.2em;
  }

  .hero-line--accent { color: var(--page-accent); }

  .word-clip {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
  }

  .word {
    display: inline-block;
    transform: translateY(105%);
  }

  .word.revealed {
    transform: translateY(0%);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-subhead {
    margin: 0;
    max-width: 43rem;
    font-size: clamp(1.08rem, 0.98rem + 0.45vw, 1.28rem);
    line-height: 1.8;
    color: rgba(246, 247, 250, 0.8);
    opacity: 0;
    transform: translateY(28px);
    animation: hero-line-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
    transform: translateY(28px);
    animation: hero-line-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.4rem;
    padding: 0.95rem 1.55rem;
    border: var(--page-thick-border);
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .hero-button:hover { transform: translateY(-2px) scale(1.02); }

  .hero-button--primary {
    background: var(--page-accent);
    color: #0F1112;
    border-color: #1A1A1A;
    box-shadow: 0 14px 32px rgba(64, 196, 196, 0.24);
  }

  .hero-button--primary:hover {
    background: #53D3D3;
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.4);
  }

  .hero-button--ghost {
    border-color: #F6F7FA;
    color: #F6F7FA;
    background: transparent;
  }

  .hero-button--ghost:hover {
    border-color: var(--page-accent);
    background: rgba(64, 196, 196, 0.12);
    color: #FFFFFF;
  }

  .hero-proof-rail {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-proof-item {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-tech);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.72);
    opacity: 0;
    transform: translateX(-16px);
    animation: hero-proof-in 0.45s ease forwards;
  }

  .hero-proof-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--page-accent);
  }

  /* Phones — in-flow centerpiece */
  .hero-phones {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-bottom: 3.5rem;
  }

  .hero-video-frame {
    position: relative;
    overflow: hidden;
    min-height: clamp(24rem, 52vw, 44rem);
    border: var(--page-thick-border);
    border-radius: 1.6rem;
    box-shadow: 8px 8px 0 #40C4C4, 16px 16px 0 #FA6831, 0 30px 72px rgba(0, 0, 0, 0.38);
    clip-path: inset(0 100% 0 0 round 1.6rem);
    animation: hero-video-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .hero-video-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(17, 18, 20, 0.05), rgba(17, 18, 20, 0.18));
    pointer-events: none;
    z-index: 2;
  }


  .hero-video {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    display: block;
  }

  /* ═══════════════════════════════════════════════════
     CONTACT (FINAL CTA)
     ═══════════════════════════════════════════════════ */
  .final-cta-shell { text-align: center; }

  .final-cta-copy {
    display: grid;
    gap: 1.5rem;
    justify-items: center;
    max-width: 52rem;
    margin: 0 auto;
  }

  .final-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .final-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.4rem;
    padding: 0.95rem 1.55rem;
    border: var(--page-thick-border);
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .final-cta-button:hover { transform: translateY(-2px) scale(1.02); }

  .final-cta-button--light {
    background: #FFFFFF;
    color: #1A1A1A;
    border-color: #1A1A1A;
  }

  .final-cta-button--light:hover {
    background: #F6F7FA;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .final-cta-button--ghost {
    border-color: #FFFFFF;
    color: #FFFFFF;
    background: transparent;
  }

  .final-cta-button--ghost:hover { background: rgba(255, 255, 255, 0.12); }

  /* ═══════════════════════════════════════════════════
     KEYFRAMES
     ═══════════════════════════════════════════════════ */
  @keyframes hero-line-in {
    from { opacity: 0; transform: translateY(48px); }
    to   { opacity: 1; transform: none; }
  }

  @keyframes hero-proof-in {
