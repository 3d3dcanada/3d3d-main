---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
---

<BaseLayout title="Contact | 3D3D" description="Offshore fabricator, worldwide. Tell me the problem. I will tell you whether I can solve it, and exactly how. Marine hardware, discontinued parts, on-site deployment." activePath="/contact">

  <div class="contact-page">
    <div class="contact-hero">
      <div class="contact-shell">
        <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Contact'}]} />

        <div class="mb-8 mt-2 rounded-xl overflow-hidden shadow-sm aspect-video sm:aspect-[21/9]">
          <img src="/media/generated/software-02.jpg" alt="Dark monitor showing a complex web application router interface" class="w-full h-full object-cover" />
        </div>

        <p class="contact-eyebrow">Direct Line</p>
        <h1 class="contact-title scroll-in">Tell me the problem.</h1>
        <p class="contact-intro">
          I will tell you whether I can solve it, and exactly how we will do it. That is the whole process.
        </p>
      </div>
    </div>

    <div class="contact-paths">
      <div class="contact-shell">
        <div class="contact-paths__grid">
          <div class="contact-path">
            <span class="contact-path__num">01</span>
            <h2 class="contact-path__title">Remote Assessment</h2>
            <p class="contact-path__body">Send high-resolution photos of the broken hardware, the surrounding mounting area, and a brief description of the failure. Include caliper measurements if you have them. I will assess what can be rebuilt, what material it requires, and what it will cost.</p>
          </div>
          <div class="contact-path">
            <span class="contact-path__num">02</span>
            <h2 class="contact-path__title">Reverse Engineering</h2>
            <p class="contact-path__body">Box up the shattered part, the worn-out gear, or the broken bracket. Ship it to my workshop. I will measure, model, and rebuild it in the correct material, with the correct tolerances. Then ship it back or bring it aboard.</p>
          </div>
          <div class="contact-path">
            <span class="contact-path__num">03</span>
            <h2 class="contact-path__title">Direct Engagement</h2>
            <p class="contact-path__body">For on-site deployment, extended refit support, race campaigns, or complex structural problems aboard the vessel, contact me directly. Tell me where the vessel is, what the job is, and when you need it done.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="contact-shell contact-body">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="contact-card">
            <h2 class="contact-card__title">Direct Contact</h2>
            <div class="contact-card__row">
              <span class="contact-card__label">Email</span>
              <a href="mailto:info@3d3d.ca" class="contact-card__value contact-card__value--accent">info@3d3d.ca</a>
            </div>
            <div class="contact-card__row">
              <span class="contact-card__label">Phone / WhatsApp</span>
              <a href="https://wa.me/15069532678" class="contact-card__value" target="_blank" rel="noopener noreferrer">506-953-2678</a>
            </div>
            <div class="contact-card__row">
              <span class="contact-card__label">Location</span>
              <span class="contact-card__value">Remote-first. Serving worldwide buyers, coastal routes, and hard-to-source projects.</span>
            </div>
          </div>

          <div class="contact-card">
            <h2 class="contact-card__title">Quick Links</h2>
            <a href="/book" class="contact-card__link contact-card__link--accent">Book a Call →</a>
            <a href="/faq" class="contact-card__link">Frequently Asked Questions →</a>
            <a href="https://ko-fi.com/3d3dca" class="contact-card__link" target="_blank" rel="noopener noreferrer">Support on Ko-fi →</a>
            <a href="https://www.printables.com/@KTK3D_3050116" class="contact-card__link" target="_blank" rel="noopener noreferrer">Free designs on Printables →</a>
            <a href="/shop" class="contact-card__link">Browse the shop →</a>
          </div>
        </div>

        <div class="contact-form-wrap">
          <h2 class="contact-form__title">Send me the details.</h2>
          <form action="https://formspree.io/f/mldlydbl" method="POST" class="contact-form" data-analytics-submit="contact_submitted" data-analytics-source="contact-page">
            <input type="hidden" name="_subject" value="Contact Request | 3D3D" />
            <div aria-hidden="true" style="position: absolute; left: -100vw; width: 1px; height: 1px; overflow: hidden;">
              <label for="contact-website">Leave this field blank</label>
              <input type="text" id="contact-website" name="_gotcha" tabindex="-1" autocomplete="off" />
            </div>
            <div class="contact-form__row">
              <div class="contact-form__field">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required placeholder="Your name" />
              </div>
              <div class="contact-form__field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="you@example.com" />
              </div>
            </div>
            <div class="contact-form__field">
              <label for="subject">What do you need?</label>
              <select id="subject" name="subject">
                <option value="marine-hardware">Marine Hardware: Broken or Discontinued</option>
                <option value="on-site">On-Site Deployment: Race, Refit, or Passage</option>
                <option value="remote-assessment">Remote Assessment: Send Photos</option>
                <option value="reverse-engineering">Reverse Engineering: Ship the Part</option>
                <option value="automotive">Automotive Restoration</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="contact-form__field">
              <label for="message">Describe your project or problem</label>
              <textarea id="message" name="message" rows={6} required placeholder="Tell me the problem. Where is the vessel? What broke? What do you need? I'll take it from there."></textarea>
            </div>
            <div class="contact-form__field">
              <label for="file" class="contact-form__file-label">
                <span>Attach a file (optional)</span>
                <span class="contact-form__file-hint">Photos, drawings, STL files, or reference images</span>
              </label>
              <input type="file" id="file" name="attachment" accept=".jpg,.jpeg,.png,.pdf,.stl,.step,.3mf" />
            </div>
            <div class="contact-form__consent">
              <input type="checkbox" id="casl-consent" name="casl_consent" value="yes" required />
              <label for="casl-consent">
                I consent to receiving commercial electronic messages from 3D3D. You may unsubscribe at any time. See our <a href="/casl">CASL policy</a> and <a href="/privacy">privacy policy</a>.
              </label>
            </div>
            <button type="submit" class="contact-form__submit">Send Message →</button>
          </form>
        </div>
      </div>
    </div>

    <div class="contact-shell">
      <PageNextActions actions={[
        {label: 'Get a Quote', href: '/quote', description: 'Upload files and describe your project for a custom estimate.', accent: 'teal'},
        {label: 'FAQ', href: '/faq', description: 'Common questions about materials, turnaround, and shipping.', accent: 'magenta'},
        {label: 'About 3D3D', href: '/about', description: 'The founder story and cooperative philosophy.', accent: 'orange'},
      ]} />
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    --page-accent: var(--color-teal-primary);
    --page-bg-dark: #111214;
    --page-bg-light: #F6F7FA;
    --page-border: 3px solid #1A1A1A;
  }

  .contact-hero {
    background: var(--page-bg-dark);
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
    color: #F6F7FA;
  }

  .contact-shell {
    width: min(calc(100% - 3rem), 1100px);
    margin: 0 auto;
  }

  .contact-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--page-accent);
  }

  .contact-title {
    margin: 0.75rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 4vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: #F6F7FA;
  }

  .contact-intro {
    margin: 1.25rem 0 0;
    max-width: 42rem;
    font-size: clamp(1rem, 0.94rem + 0.3vw, 1.15rem);
    line-height: 1.75;
    color: rgba(246, 247, 250, 0.78);
  }

  /* ── Intake paths ── */
  .contact-paths {
    background: #1A1C1F;
    padding: clamp(3rem, 5vw, 4.5rem) 0;
    border-top: 1px solid rgba(64, 196, 196, 0.15);
    border-bottom: 1px solid rgba(64, 196, 196, 0.15);
  }

  .contact-paths__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .contact-path {
    display: grid;
    gap: 0.6rem;
  }

  .contact-path__num {
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--page-accent);
  }

  .contact-path__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.2;
    color: #F6F7FA;
  }

  .contact-path__body {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.7;
    color: rgba(246, 247, 250, 0.78);
  }

  .contact-body {
    padding: clamp(3rem, 5vw, 4rem) 0 clamp(4rem, 6vw, 6rem);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: clamp(2rem, 4vw, 3rem);
    align-items: start;
  }

  .contact-info {
    display: grid;
    gap: 1.2rem;
  }

  .contact-card {
    padding: clamp(1.25rem, 2.5vw, 2rem);
    border: var(--page-border);
    border-radius: 2px;
    background: var(--page-bg-light);
    display: grid;
    gap: 1rem;
  }

  .contact-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.1;
    color: #1A1A1A;
  }

  .contact-card__row {
    display: grid;
    gap: 0.2rem;
  }

  .contact-card__label {
    font-family: var(--font-tech);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #666666;
  }

  .contact-card__value {
    font-size: 0.96rem;
    line-height: 1.5;
    color: #1A1A1A;
  }

  .contact-card__value--accent {
    color: var(--page-accent);
    font-family: var(--font-mono);
  }

  .contact-card__link {
    font-size: 0.96rem;
    color: #1A1A1A;
    border-bottom: 1px solid rgba(26, 26, 26, 0.15);
    padding-bottom: 0.5rem;
    transition: color 0.15s ease;
  }

  .contact-card__link:hover {
    color: var(--page-accent);
  }

  .contact-card__link--accent {
    color: var(--page-accent);
    font-weight: 600;
  }

  .contact-form-wrap {
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border: var(--page-border);
    border-radius: 2px;
    background: #FFFFFF;
  }

  .contact-form__title {
    margin: 0 0 1.5rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.1;
    color: #1A1A1A;
  }

  .contact-form {
    display: grid;
    gap: 1.25rem;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form__field {
    display: grid;
    gap: 0.4rem;
  }

  .contact-form__field label {
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666666;
  }

  .contact-form__field input,
  .contact-form__field select,
  .contact-form__field textarea {
    padding: 0.8rem 1rem;
    border: 2px solid #1A1A1A;
    border-radius: 2px;
    background: #F6F7FA;
    color: #1A1A1A;
    font-family: var(--font-body);
    font-size: 0.96rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .contact-form__field input:focus,
  .contact-form__field select:focus,
  .contact-form__field textarea:focus {
    outline: none;
    border-color: var(--page-accent);
    box-shadow: 0 0 0 3px rgba(64, 196, 196, 0.2);
  }

  .contact-form__field input::placeholder,
  .contact-form__field textarea::placeholder {
    color: #999;
  }

  .contact-form__file-label {
    display: grid;
    gap: 0.15rem;
  }

  .contact-form__file-hint {
    font-size: 0.6rem !important;
    letter-spacing: 0.1em !important;
    color: #999 !important;
  }

  .contact-form__field input[type="file"] {
    padding: 0.6rem;
    font-size: 0.88rem;
    cursor: pointer;
  }

  .contact-form__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .contact-form__consent input[type="checkbox"] {
    margin-top: 0.2rem;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    accent-color: var(--page-accent);
  }

  .contact-form__consent label {
    font-size: 0.78rem;
    line-height: 1.5;
    color: #666666;
  }

  .contact-form__consent a {
    color: var(--page-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .contact-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.9rem 1.5rem;
    border: 3px solid #1A1A1A;
    background: var(--page-accent);
    color: #0F1112;
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.25s ease;
    width: 100%;
  }

  .contact-form__submit:hover {
    background: #53D3D3;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.3);
  }

  @media (max-width: 900px) {
    .contact-paths__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .contact-shell {
      width: min(calc(100% - 1.5rem), 1100px);
    }
  }
</style>
