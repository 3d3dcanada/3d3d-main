---
import BaseLayout from '../layouts/BaseLayout.astro';

const benefits = [
	{ title: 'Local Production', desc: '3D printing services in your city. Find makers near you for faster delivery and pickup options.' },
	{ title: 'Flexible Schedule', desc: 'Print when you want. Accept orders that fit your capacity. No minimums.' },
	{ title: 'Quality Standards', desc: 'We provide calibration specs, material guidelines, and packaging standards. You provide the quality.' },
	{ title: 'Growing Network', desc: 'Connect with other makers across Atlantic Canada. Share knowledge and grow together.' },
	{ title: 'Event Printing', desc: 'On-location 3D printing at events, markets, and festivals across the region.' },
	{ title: 'Growth Path', desc: 'Start with 1 printer. Scale to a fleet. Build your printing business.' },
];

const requirements = [
	'Working FDM 3D printer (any brand)',
	'Ability to print PLA and at least one other material',
	'Consistent print quality (we\'ll test)',
	'24-hour print start commitment',
	'48-hour shipping commitment',
	'Located in Canada (Atlantic Canada preferred)',
];

const cities = [
	{ name: 'Fredericton', province: 'NB' },
	{ name: 'Moncton', province: 'NB' },
	{ name: 'Halifax', province: 'NS' },
	{ name: 'Saint John', province: 'NB' },
	{ name: 'Charlottetown', province: 'PEI' },
];

const makerGallery = [
	{
		src: '/media/workshop/printer-frame-shot.jpg',
		alt: 'Desktop 3D printer frame and control box on a workbench',
		title: 'Printer readiness',
	},
	{
		src: '/media/workshop/nomad-joe-bracket.jpg',
		alt: 'Green 3D printed bracket labeled Nomad Joe',
		title: 'Problem-solving parts',
	},
	{
		src: '/media/workshop/blue-fitment-caps.jpg',
		alt: 'Two small blue 3D printed parts on a gray surface',
		title: 'Small batch components',
	},
];
---

<BaseLayout title="Find a Maker — 3D3D" description="Find local 3D printing in Fredericton, Moncton, Halifax, Saint John, and Charlottetown. Network is growing." activePath="/makers">

	<div class="pt-8 pb-12">
		<section class="max-w-4xl mx-auto">
			<div class="makers-hero surface-panel">
				<div class="makers-hero__background" aria-hidden="true"></div>
				<div class="makers-hero__content">
					<p class="font-display text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">Maker Network</p>
					<h1 class="font-display text-3xl sm:text-4xl font-bold mt-2 mb-4" style="color: var(--color-text-primary);">Find a Local Maker</h1>
					<p class="text-sm max-w-xl" style="color: var(--color-text-secondary);">
						Search by city to find 3D printing near you.
					</p>
				</div>
			</div>

			{/* City List */}
			<div class="mb-10 mt-10">
				<h2 class="font-display text-xl font-bold mb-4" style="color: var(--color-text-primary);">Cities We Serve</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
					{cities.map((city) => (
						<div class="p-4 rounded-xl" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle); box-shadow: var(--shadow-sm);">
							<p class="font-display text-sm font-semibold" style="color: var(--color-teal-primary);">{city.name}, {city.province}</p>
						</div>
					))}
				</div>
				<p class="text-sm mt-4" style="color: var(--color-text-muted);">
					Network is growing. More locations coming.
				</p>
			</div>

			{/* Benefits */}
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
				{benefits.map((b) => (
					<div class="p-5 rounded-xl" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle); box-shadow: var(--shadow-sm);">
						<h3 class="font-display text-sm font-semibold mb-2" style="color: var(--color-teal-primary);">{b.title}</h3>
						<p class="text-xs leading-relaxed" style="color: var(--color-text-secondary);">{b.desc}</p>
					</div>
				))}
			</div>

			<div class="makers-gallery">
				{makerGallery.map((item) => (
					<figure class="surface-panel makers-gallery__card">
						<img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
						<figcaption>
							<strong>{item.title}</strong>
						</figcaption>
					</figure>
				))}
			</div>

			{/* Requirements */}
			<div class="mb-16">
				<h2 class="font-display text-xl font-bold mb-4" style="color: var(--color-text-primary);">Requirements</h2>
				<ul class="space-y-2">
					{requirements.map((req) => (
						<li class="flex items-start gap-2 text-sm" style="color: var(--color-text-secondary);">
							<span class="mt-0.5" style="color: var(--color-teal-primary);">→</span>
							{req}
						</li>
					))}
				</ul>
			</div>

			{/* Application form */}
			<div class="p-8 rounded-xl" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle); box-shadow: var(--shadow-sm);">
				<h2 class="font-display text-lg font-semibold mb-6" style="color: var(--color-text-primary);">Become a Maker</h2>
				<form action="https://formspree.io/f/mldlydbl" method="POST" class="space-y-5" data-analytics-submit="maker_application_submitted" data-analytics-source="makers-page">
					<input type="hidden" name="_subject" value="Maker Application — 3D3D" />
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
						<div>
							<label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);">Name</label>
							<input type="text" name="name" required class="w-full px-4 py-2.5 rounded-lg text-sm outline-none" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);" />
						</div>
						<div>
							<label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);">Email</label>
							<input type="email" name="email" required class="w-full px-4 py-2.5 rounded-lg text-sm outline-none" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);" />
						</div>
					</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
						<div>
							<label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);">City / Province</label>
							<input type="text" name="location" required class="w-full px-4 py-2.5 rounded-lg text-sm outline-none" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);" />
						</div>
						<div>
							<label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);">Number of Printers</label>
							<input type="number" name="printers" min="1" required class="w-full px-4 py-2.5 rounded-lg text-sm outline-none" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);" />
						</div>
					</div>
					<div>
						<label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);">Printer Models & Materials</label>
						<textarea name="equipment" rows={3} required class="w-full px-4 py-2.5 rounded-lg text-sm outline-none resize-y" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);"></textarea>
					</div>
					<div>
						<label class="block font-display text-[10px] uppercase tracking-wider mb-1.5" style="color: var(--color-text-muted);">Why do you want to join?</label>
						<textarea name="motivation" rows={3} class="w-full px-4 py-2.5 rounded-lg text-sm outline-none resize-y" style="background: var(--color-surface-elevated); border: 1px solid var(--color-border-default); color: var(--color-text-primary);"></textarea>
					</div>
					<div class="flex items-start gap-3">
						<input type="checkbox" id="casl-consent" name="casl_consent" value="yes"
							class="mt-1 w-4 h-4 rounded flex-shrink-0"
							style="accent-color: var(--color-teal-primary);"
						/>
						<label for="casl-consent" class="text-[11px] leading-relaxed" style="color: var(--color-text-muted);">
							I consent to receiving commercial electronic messages from 3D3D regarding my maker application. You may unsubscribe at any time. See our <a href="/casl" class="underline" style="color: var(--color-teal-primary);">CASL policy</a> and <a href="/privacy" class="underline" style="color: var(--color-teal-primary);">privacy policy</a>.
						</label>
					</div>
					<button type="submit" class="btn btn-primary">
						Submit Application
					</button>
				</form>
			</div>
		</section>
	</div>
</BaseLayout>

<style>
.makers-hero {
	position: relative;
	isolation: isolate;
	overflow: hidden;
	padding: clamp(1.5rem, 4vw, 2.8rem);
}

.makers-hero__background {
	position: absolute;
	inset: 0;
	background:
		linear-gradient(135deg, rgba(242, 251, 251, 0.86), rgba(255, 240, 245, 0.7)),
		url('/media/backgrounds/makers-neon-workshop.jpg') center / cover no-repeat;
	opacity: 0.88;
}

.makers-hero__content {
	position: relative;
	z-index: 1;
}

.makers-gallery {
	display: grid;
	grid-template-columns: repeat(3, minmax(0, 1fr));
	gap: 1rem;
	margin-bottom: 4rem;
}

.makers-gallery__card {
	padding: 0.85rem;
}

.makers-gallery__card img {
	display: block;
	width: 100%;
	aspect-ratio: 1 / 1;
	object-fit: cover;
	border-radius: 20px;
}

.makers-gallery__card figcaption {
	margin-top: 0.8rem;
}

.makers-gallery__card strong {
	font-family: var(--font-display);
	font-size: 0.95rem;
	color: var(--color-text-primary);
}

@media (max-width: 900px) {
	.makers-gallery {
		grid-template-columns: 1fr;
	}
}
</style>
