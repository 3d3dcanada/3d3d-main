---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingEmbed from '../components/BookingEmbed';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ScheduleAction',
  name: 'Book a Call',
  description: 'Schedule a 15-minute discovery call or 30-minute project discussion with 3D3D.',
  target: {
    '@type': 'EntryPoint',
    urlTemplate: 'https://3d3d.ca/book',
  },
};
---

<BaseLayout
  title="Book a Call | 3D3D"
  description="Fifteen minutes. Tell us the problem. We will tell you whether we can solve it. Book a discovery call or project discussion."
  schema={schema}
  activePath="/book"
>
  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40C4C4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Services', href: '/contact'}, {label: 'Book a Call'}]} />
            <p class="hp-card__eyebrow mt-4">Schedule</p>
            <h1 class="hp-card__title mt-2 mb-4">Book a Call</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Fifteen minutes. Tell us the problem. We will tell you whether we can solve it, what material it needs, and what the job takes. That is the whole call.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="#calendar" class="hp-cta hp-cta--accent">Open Calendar</a>
              <a href="https://wa.me/15069532678" target="_blank" class="hp-cta hp-cta--glass">WhatsApp</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: What to expect -->
    <section class="hp-section" style="--section-accent: #E84A8A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/race-morning-crew.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Who you are talking to</p>
            <h2 class="hp-card__title mt-2 mb-6">Not a sales call. An engineering assessment.</h2>

            <p class="hp-card__copy mb-4">
              Our team brings 20 years of mechanical background, offshore sailing experience including transatlantic passages and the Rolex Fastnet Race, and production 3D printing in demanding environments. We know what breaks and why.
            </p>
            <p class="hp-card__copy mb-8">
              We will assess your problem, tell you whether fabrication is the right path, and if it is, recommend the exact material and process. If fabrication is not the right approach, we will tell you that too.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="bg-black/20 p-4 rounded border border-white/5">
                <strong class="text-white block mb-1">Marine Hardware</strong>
                <span class="text-sm text-gray-400">Discontinued deck fittings, custom brackets, through-hull replacements.</span>
              </div>
              <div class="bg-black/20 p-4 rounded border border-white/5">
                <strong class="text-white block mb-1">Automotive Restoration</strong>
                <span class="text-sm text-gray-400">Interior trim, dash overlays, retaining clips, custom ducting.</span>
              </div>
              <div class="bg-black/20 p-4 rounded border border-white/5">
                <strong class="text-white block mb-1">Custom Fabrication</strong>
                <span class="text-sm text-gray-400">Mounts, jigs, adapters, enclosures, tooling. No blueprint required.</span>
              </div>
              <div class="bg-black/20 p-4 rounded border border-white/5">
                <strong class="text-white block mb-1">On-Site Deployment</strong>
                <span class="text-sm text-gray-400">Race campaigns and refit support. Worldwide travel with equipment.</span>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: Calendar Embed -->
    <section id="calendar" class="hp-section" style="--section-accent: #FF6B2B; min-height: 100svh;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim" style="background: rgba(17, 18, 20, 0.85);"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="pg-card" style="padding: 0; overflow: hidden;">
          <div style="padding: clamp(1.5rem, 3vw, 2.5rem);">
            <p class="pg-card__eyebrow">Schedule</p>
            <h2 class="pg-card__title" style="margin-bottom: 1.5rem;">Pick a time that works.</h2>
          </div>
          <div style="padding: 0 clamp(1rem, 2vw, 2rem) clamp(1.5rem, 3vw, 2.5rem);">
            <BookingEmbed client:idle />
          </div>
        </article>
      </div>
    </section>

    <!-- Section 4: Next Actions -->
    <section class="hp-section" style="--section-accent: #AAFF2A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <PageNextActions actions={[
              {label: 'Get a Quote', href: '/quote', description: 'Upload files and get a structured estimate.', accent: 'teal'},
              {label: 'Materials Guide', href: '/materials', description: 'Understand which compound fits your environment.', accent: 'orange'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
</style>
