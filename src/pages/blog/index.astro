---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: 'why-distributed-3d-printing',
    title: 'Why Distributed 3D Printing Is the Future of Local Manufacturing',
    excerpt: 'Distributed manufacturing powered by maker networks is reshaping how communities produce goods. Here\'s how 3D3D is building that future in Atlantic Canada.',
    date: '2026-03-10',
    category: '3D Printing',
    readTime: '5 min',
  },
  {
    slug: 'material-guide-pla-petg-tpu',
    title: 'Material Guide: PLA vs PETG vs TPU — Choosing the Right Filament',
    excerpt: 'Each material has trade-offs. PLA for precision, PETG for durability, TPU for flex. We break down when to use each and what it costs.',
    date: '2026-03-12',
    category: 'Materials',
    readTime: '7 min',
  },
  {
    slug: 'atlantic-canada-maker-network',
    title: 'Building a Maker Network Across Atlantic Canada',
    excerpt: 'From Moncton to Halifax, St. John\'s to Charlottetown — how we recruited and onboarded makers across four provinces.',
    date: '2026-03-15',
    category: 'Community',
    readTime: '4 min',
  },
];
---

<BaseLayout title="Blog — 3D3D" description="Articles on 3D printing, materials, event projects, and maker stories from Atlantic Canada." activePath="/blog">

  <div class="pt-8 pb-12">
    <section class="max-w-4xl mx-auto">
      <p class="font-display text-xs font-semibold uppercase tracking-wider" style="color: var(--color-text-muted);">3D3D Blog</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold mt-2 mb-2" style="color: var(--color-text-primary);">Blog</h1>
      <p class="text-sm mb-12" style="color: var(--color-text-secondary);">3D printing, materials, maker economy, event projects.</p>

      <div class="space-y-6">
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="group block p-6 rounded-xl transition-all duration-300"
            style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle); box-shadow: var(--shadow-sm);"
          >
            <div class="flex items-center gap-3 mb-3">
              <span class="font-display text-[10px] uppercase tracking-wider" style="color: var(--color-teal-primary);">{post.category}</span>
              <span style="color: var(--color-text-muted);">·</span>
              <span class="font-display text-[10px] uppercase tracking-wider" style="color: var(--color-text-muted);">{post.date}</span>
              <span style="color: var(--color-text-muted);">·</span>
              <span class="font-display text-[10px] uppercase tracking-wider" style="color: var(--color-text-muted);">{post.readTime}</span>
            </div>
            <h2 class="font-display text-lg font-semibold transition-colors mb-2" style="color: var(--color-text-primary);">
              {post.title}
            </h2>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">{post.excerpt}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  a[href^="/blog/"]:hover {
    border-color: var(--color-border-strong) !important;
    box-shadow: var(--shadow-card-hover) !important;
  }
</style>
