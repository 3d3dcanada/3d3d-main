<style>
  :root {
    --hp-card-bg: rgba(10, 14, 19, 0.62);
    --hp-card-border: rgba(255, 255, 255, 0.08);
    --hp-card-shadow:
      0 24px 60px rgba(0, 0, 0, 0.34),
