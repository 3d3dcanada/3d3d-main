---
/**
 * BentoGrid — clickable grid replacing old services + workshop sections.
 * Desktop: 4 cols. Tablet: 2 cols. Mobile: 1 col.
 * Every cell is a link — users click to navigate, not scroll.
 */
---

<section id="explore" class="bento-section" aria-label="Explore 3D3D">
  <div class="bento-shell">

    <div class="bento-grid">

      <!-- Marine — 2×1 span, dark with image -->
      <a href="/contact?subject=marine" class="bento-cell bento-cell--wide bento-cell--dark bento-cell--image" data-analytics-event="bento_click" data-analytics-source="marine">
        <img src="/media/real/helm-close.jpg" alt="" loading="lazy" decoding="async" class="bento-cell__bg" />
        <div class="bento-cell__overlay"></div>
        <div class="bento-cell__content">
          <span class="bento-cell__eyebrow">Marine Fabrication</span>
          <h3 class="bento-cell__heading">Parts that survive offshore</h3>
          <span class="bento-cell__link">Contact us &rarr;</span>
        </div>
      </a>

      <!-- Auto / Restoration — 1×1, dark with image -->
      <a href="/contact?subject=automotive" class="bento-cell bento-cell--dark bento-cell--image" data-analytics-event="bento_click" data-analytics-source="automotive">
        <img src="/media/workshop/radio-button-replacement.jpg" alt="" loading="lazy" decoding="async" class="bento-cell__bg" />
        <div class="bento-cell__overlay"></div>
        <div class="bento-cell__content">
          <span class="bento-cell__eyebrow">Automotive</span>
          <h3 class="bento-cell__heading">Discontinued parts rebuilt</h3>
          <span class="bento-cell__link">Get a quote &rarr;</span>
        </div>
      </a>

      <!-- Instagram — 1×1, bold social CTA -->
      <a href="https://www.instagram.com/3d3dca/" target="_blank" rel="noopener" class="bento-cell bento-cell--social bento-cell--instagram" data-analytics-event="bento_click" data-analytics-source="instagram">
        <svg class="bento-cell__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
        </svg>
        <span class="bento-cell__social-text">Follow the builds</span>
        <span class="bento-cell__link">@3d3dca &rarr;</span>
      </a>

      <!-- Workshop photo — 2×2 span, lightbox-style -->
      <a href="/about" class="bento-cell bento-cell--large bento-cell--dark bento-cell--image" data-analytics-event="bento_click" data-analytics-source="workshop">
        <img src="/media/workshop/rv-lab-01.jpg" alt="" loading="lazy" decoding="async" class="bento-cell__bg" />
        <div class="bento-cell__overlay"></div>
        <div class="bento-cell__content bento-cell__content--bottom">
          <span class="bento-cell__eyebrow">The Workshop</span>
          <h3 class="bento-cell__heading">A mobile fabrication lab that travels to the job</h3>
          <span class="bento-cell__link">See the setup &rarr;</span>
        </div>
      </a>

      <!-- Industrial / Custom — 1×1, dark -->
      <a href="/contact?subject=industrial" class="bento-cell bento-cell--dark bento-cell--image" data-analytics-event="bento_click" data-analytics-source="industrial">
        <img src="/media/workshop/fan-reducers.jpg" alt="" loading="lazy" decoding="async" class="bento-cell__bg" />
        <div class="bento-cell__overlay"></div>
        <div class="bento-cell__content">
          <span class="bento-cell__eyebrow">Industrial</span>
          <h3 class="bento-cell__heading">Custom enclosures &amp; production runs</h3>
          <span class="bento-cell__link">Talk to us &rarr;</span>
        </div>
      </a>

      <!-- Ko-fi — 1×1, solid color CTA -->
      <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener" class="bento-cell bento-cell--social bento-cell--kofi" data-analytics-event="bento_click" data-analytics-source="kofi">
        <span class="bento-cell__icon-text">&#9749;</span>
        <span class="bento-cell__social-text">Support the lab</span>
        <span class="bento-cell__link">Ko-fi &rarr;</span>
      </a>

      <!-- Shop — 2×1 span, light cell showing products -->
      <a href="/shop" class="bento-cell bento-cell--wide bento-cell--light bento-cell--shop" data-analytics-event="bento_click" data-analytics-source="shop">
        <div class="bento-cell__shop-thumbs">
          <img src="/media/workshop/floating-keychains.jpg" alt="Floating keychains" loading="lazy" decoding="async" />
          <img src="/media/workshop/galaxy-vase.jpg" alt="Galaxy vase" loading="lazy" decoding="async" />
          <img src="/media/workshop/blue-fitment-caps.jpg" alt="Fitment caps" loading="lazy" decoding="async" />
        </div>
        <div class="bento-cell__content">
          <span class="bento-cell__eyebrow bento-cell__eyebrow--dark">Shop</span>
          <h3 class="bento-cell__heading bento-cell__heading--dark">Ready-made prints &amp; custom orders</h3>
          <span class="bento-cell__link bento-cell__link--dark">Browse shop &rarr;</span>
        </div>
      </a>

      <!-- WhatsApp — 1×1, green CTA -->
      <a href="https://wa.me/15069532678" target="_blank" rel="noopener" class="bento-cell bento-cell--social bento-cell--whatsapp" data-analytics-event="bento_click" data-analytics-source="whatsapp">
        <svg class="bento-cell__icon" viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
          <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 01-4.243-1.212l-.257-.154-2.874.854.854-2.874-.154-.257A8 8 0 1112 20z" />
        </svg>
        <span class="bento-cell__social-text">Message us directly</span>
        <span class="bento-cell__link">WhatsApp &rarr;</span>
      </a>

      <!-- Prusa — 1×1, orange accent -->
      <a href="/prusa" class="bento-cell bento-cell--dark bento-cell--prusa" data-analytics-event="bento_click" data-analytics-source="prusa">
        <img src="/media/brand/prusa-logo.svg" alt="" class="bento-cell__prusa-logo" loading="lazy" />
        <span class="bento-cell__social-text">Prusa printers, set up &amp; supported</span>
        <span class="bento-cell__link bento-cell__link--orange">See printers &rarr;</span>
      </a>

    </div>

  </div>
</section>

<style>
  .bento-section {
    padding-block: clamp(2rem, 4vw, 4rem);
    position: relative;
    z-index: 1;
  }

  .bento-shell {
    width: min(100% - clamp(1rem, 3vw, 3rem), 1320px);
    margin: 0 auto;
  }

  /* ── Grid layout ── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(180px, auto);
    gap: 1rem;
  }

  /* ── Base cell ── */
  .bento-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(1rem, 2vw, 1.5rem);
    border-radius: clamp(16px, 2vw, 24px);
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
  }

  .bento-cell:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
  }

  /* ── Span modifiers ── */
  .bento-cell--wide {
    grid-column: span 2;
  }

  .bento-cell--large {
    grid-column: span 2;
    grid-row: span 2;
  }

  /* ── Dark cell (with bg image) ── */
  .bento-cell--dark {
    background: #111214;
    color: #F6F7FA;
  }

  /* ── Light cell ── */
  .bento-cell--light {
    background: #FFFFFF;
    color: #1A1A1A;
    border: 1px solid rgba(26, 26, 26, 0.06);
  }

  /* ── Image background ── */
  .bento-cell--image .bento-cell__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .bento-cell--image:hover .bento-cell__bg {
    transform: scale(1.03);
  }

  .bento-cell--image .bento-cell__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.2) 60%, transparent 100%);
    pointer-events: none;
  }

  /* ── Content layer ── */
  .bento-cell__content {
    position: relative;
    z-index: 1;
  }

  .bento-cell__content--bottom {
    margin-top: auto;
  }

  .bento-cell__eyebrow {
    display: block;
    font-family: var(--font-tech, 'Space Grotesk', sans-serif);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #40C4C4;
    margin-bottom: 0.4rem;
  }

  .bento-cell__eyebrow--dark {
    color: #666666;
  }

  .bento-cell__heading {
    font-family: var(--font-display, 'Archivo', sans-serif);
    font-size: clamp(0.95rem, 1.6vw, 1.2rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .bento-cell__heading--dark {
    color: #1A1A1A;
  }

  .bento-cell__link {
    font-family: var(--font-tech, 'Space Grotesk', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #40C4C4;
    transition: letter-spacing 0.2s ease;
  }

  .bento-cell:hover .bento-cell__link {
    letter-spacing: 0.1em;
  }

  .bento-cell__link--dark {
    color: #1A1A1A;
  }

  .bento-cell__link--orange {
    color: #FA6831;
  }

  /* ── Social/CTA cells ── */
  .bento-cell--social {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.5rem;
    padding: clamp(1.2rem, 2vw, 1.8rem);
  }

  .bento-cell__icon {
    flex-shrink: 0;
  }

  .bento-cell__icon-text {
    font-size: 2rem;
    line-height: 1;
  }

  .bento-cell__social-text {
    font-family: var(--font-display, 'Archivo', sans-serif);
    font-size: clamp(0.85rem, 1.4vw, 1rem);
    font-weight: 700;
    line-height: 1.3;
  }

  /* Instagram */
  .bento-cell--instagram {
    background: linear-gradient(135deg, #833AB4 0%, #E1306C 50%, #F77737 100%);
    color: #FFFFFF;
  }
  .bento-cell--instagram .bento-cell__link {
    color: rgba(255, 255, 255, 0.9);
  }

  /* Ko-fi */
  .bento-cell--kofi {
    background: #FF5E5B;
    color: #FFFFFF;
  }
  .bento-cell--kofi .bento-cell__link {
    color: rgba(255, 255, 255, 0.9);
  }

  /* WhatsApp */
  .bento-cell--whatsapp {
    background: #25D366;
    color: #FFFFFF;
  }
  .bento-cell--whatsapp .bento-cell__link {
    color: rgba(255, 255, 255, 0.9);
  }

  /* Prusa */
  .bento-cell--prusa {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.5rem;
    padding: clamp(1.2rem, 2vw, 1.8rem);
    background: #111214;
    border: 1px solid rgba(250, 104, 49, 0.2);
  }

  .bento-cell--prusa:hover {
    border-color: rgba(250, 104, 49, 0.5);
    box-shadow: 0 12px 32px rgba(250, 104, 49, 0.1);
  }

  .bento-cell__prusa-logo {
    height: 24px;
    width: auto;
    opacity: 0.9;
  }

  .bento-cell--prusa .bento-cell__social-text {
    color: #F6F7FA;
  }

  /* ── Shop cell thumbnails ── */
  .bento-cell--shop {
    flex-direction: row;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .bento-cell__shop-thumbs {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .bento-cell__shop-thumbs img {
    width: clamp(60px, 8vw, 90px);
    aspect-ratio: 1;
    border-radius: 12px;
    object-fit: cover;
  }

  /* ── Tablet: 2 cols ── */
  @media (max-width: 1023px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .bento-cell--large {
      grid-column: span 2;
      grid-row: span 1;
      min-height: 260px;
    }
  }

  /* ── Mobile: 1 col ── */
  @media (max-width: 767px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .bento-cell--wide,
    .bento-cell--large {
      grid-column: span 1;
      grid-row: span 1;
    }

    .bento-cell--image {
      min-height: 180px;
    }

    .bento-cell--large {
      min-height: 220px;
    }

    .bento-cell--shop {
      flex-direction: column;
      align-items: flex-start;
    }

    .bento-cell__shop-thumbs img {
      width: 70px;
    }

    .bento-cell__heading {
      font-size: 0.95rem;
    }
  }
</style>
