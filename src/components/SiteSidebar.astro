---
interface NavItem {
  id: string;
  label: string;
  href?: string;
}

interface NavGroup {
  label: string;
  items: NavItem[];
}

interface Props {
  navGroups: NavGroup[];
  activePath?: string;
}

const { navGroups, activePath = '' } = Astro.props;

const normalizePath = (value?: string) => {
  if (!value) return '';
  if (value === '/') return '/';
  return value.replace(/\/+$/, '');
};

const currentPath = normalizePath(activePath);

const isActiveLink = (item: NavItem) => {
  if (!item.href) return item.id === activePath;
  return normalizePath(item.href) === currentPath;
};

