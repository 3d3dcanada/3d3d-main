---

<footer class="site-footer" style={`--footer-accent: ${accent};`}>
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      {showCooperativeInfo && (
        <div class="site-footer__brand">
          <h2>3D3D</h2>
          <p class="site-footer__tagline">
            Specialty fabrication for marine, motorsport, and field deployment. Founder-operated. Remote-first and serving worldwide buyers.
          </p>

          <div class="site-footer__contact">
            <a href="mailto:info@3d3d.ca">info@3d3d.ca</a>
          </div>

          <div class="site-footer__socials" aria-label="3D3D social links">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.label}
                title={link.label}
              >
                <svg viewBox={link.viewBox} aria-hidden="true" focusable="false">
                  <path d={link.path} fill="currentColor"></path>
                </svg>
                <span>{link.label}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <nav class="site-footer__column" aria-label="Navigate">
        <p class="site-footer__heading">Navigate</p>
        <ul>
          {navLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__column" aria-label="Service Areas">
        <p class="site-footer__heading">Service Areas</p>
        <ul>
          {serviceAreaLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__column" aria-label="Legal">
        <p class="site-footer__heading">Legal</p>
        <ul>
          {legalLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="site-footer__bottom">
      <p>&copy; 2026 3D3D. Founder-operated specialty fabrication for marine, restoration, and route-based work.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 0;
    background:
      radial-gradient(circle at top right, rgba(232, 74, 138, 0.12), transparent 28%),
      linear-gradient(180deg, #111214 0%, #0B0C0D 100%);
    border-top: 2px solid var(--footer-accent);
    color: #F6F7FA;
  }

  .site-footer__inner {
    width: min(calc(100% - 3rem), 1320px);
    margin: 0 auto;
    padding: clamp(3rem, 5vw, 4.5rem) 0 1.5rem;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 2.2fr) minmax(0, 1fr) minmax(0, 1fr) minmax(0, 0.8fr);
    gap: 2rem;
    align-items: start;
  }

  .site-footer__brand {
    display: grid;
    gap: 1rem;
    padding-right: 2rem;
  }

  .site-footer__brand h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.1rem + 1.5vw, 3rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: #FFFFFF;
  }

  .site-footer__tagline {
    margin: 0;
    max-width: 34rem;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(246, 247, 250, 0.76);
  }

  .site-footer__contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.2rem;
  }

  .site-footer__contact a {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--footer-accent);
  }

  .site-footer__contact a:hover,
  .site-footer__column a:hover,
  .site-footer__socials a:hover {
    color: #FFFFFF;
  }

  .site-footer__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .site-footer__socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.5rem;
    padding: 0.6rem 0.9rem;
    border: 1px solid rgba(64, 196, 196, 0.22);
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(246, 247, 250, 0.84);
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .site-footer__socials svg {
    width: 0.95rem;
    height: 0.95rem;
    color: var(--footer-accent);
    flex-shrink: 0;
  }

  .site-footer__column {
    display: grid;
    gap: 1rem;
  }

  .site-footer__heading {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.58);
  }

  .site-footer__column ul {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__column a {
    font-size: 0.98rem;
    line-height: 1.5;
    color: rgba(246, 247, 250, 0.84);
  }

  .site-footer__bottom {
    margin-top: 2.25rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(64, 196, 196, 0.16);
  }

  .site-footer__bottom p {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.6);
  }

  @media (max-width: 900px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
    }

    .site-footer__brand {
      padding-right: 0;
    }
  }

  @media (max-width: 640px) {
    .site-footer__inner {
      width: min(calc(100% - 1.5rem), 1320px);
    }

    .site-footer__socials a {
      font-size: 0.68rem;
      letter-spacing: 0.1em;
    }

    .site-footer__bottom p {
      line-height: 1.6;
    }
  }
</style>
