---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '3D3D Maker Network',
  description: 'A cooperative network of makers, fabricators, and operators. Join the network and keep 75% of the gross.',
  url: 'https://3d3d.ca/network',
};
---

<BaseLayout title="The Maker Network | 3D3D" description="Join the 3D3D maker network. We route jobs to your machines. You keep 75% of the revenue." activePath="/network" schema={schema}>

  <main class="hp-home">
    
    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40C4C4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'The Network'}]} />
            <p class="hp-card__eyebrow mt-4">Node Operations</p>
            <h1 class="hp-card__title mt-2 mb-4">Claim Your Node.</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              <strong>We route work to your machines, handle SEO and client relations, and get out of your way.</strong> You run the hardware, you manage quality, and you keep 75% of the gross.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="#apply" class="hp-cta hp-cta--accent">Start Operator Application</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: The Moat & Minimums -->
    <section class="hp-section" style="--section-accent: #E84A8A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">The Business Model</p>
            <h2 class="hp-card__title mt-2 mb-4">Why 75/25?</h2>
            <p class="hp-card__copy mb-6">Finding customers costs time and money. Managing revisions and invoicing is a second job. We handle that side so you can stay at the printer.</p>
            
            <div class="flex flex-col gap-6 mb-8">
              <div>
                <strong class="text-teal-400 font-tech tracking-wider uppercase text-sm">The Platform Handles</strong>
                <p class="hp-card__copy mt-1">SEO and inbound traffic, quoting, invoicing, billing, and client revision management.</p>
              </div>
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">The Operator Handles</strong>
                <p class="hp-card__copy mt-1">Machine calibration, filament tuning, print QA, and shipping the final part.</p>
              </div>
            </div>

            <h3 class="font-display text-xl text-white mb-2">What We Need From You</h3>
            <p class="hp-card__copy mb-4">Our contracts involve engineering materials -- ASA, nylon, polycarbonate. You need to be comfortable printing them reliably. PLA-only setups will not cut it for the work that comes through.</p>
            
            <div class="hp-card__stats bg-black/20 p-4 rounded border border-white/5">
              <div>
                <strong>Approved Materials</strong>
                <span>ASA, PA11-CF, PA12-CF, PP-GF</span>
              </div>
              <div>
                <strong>Availability</strong>
                <span>Reliable turnaround on accepted jobs</span>
              </div>
              <div>
                <strong>Quality</strong>
                <span>Caliper-checked tolerances before dispatch</span>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: The Application -->
    <section id="apply" class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Progression</p>
            <h2 class="hp-card__title mt-2 mb-6">Operator Application</h2>

            <div class="net-app-progress mb-6">
              <span class="net-step active" data-step-indicator="1">1. Hardware</span>
              <span class="net-step" data-step-indicator="2">2. Capability</span>
              <span class="net-step" data-step-indicator="3">3. Your Info</span>
            </div>

            <form id="frmNetwork" action="https://formspree.io/f/mldlydbl" method="POST" data-analytics-submit="node_application">
              
              <!-- Step 1 -->
              <div class="net-app-step active" data-step="1">
                <div class="form-field">
                  <label for="hardware" class="text-white font-display text-xl mb-4 block">What is your primary fabrication stack?</label>
                  <p class="text-sm text-gray-400 mb-2">List your active hardware (e.g., Bambu X1C, Prusa MK4, Voron 2.4, CNC)</p>
                  <textarea id="hardware" name="hardware" rows="4" required placeholder="Machine list, build volumes, and nozzle capabilities..."></textarea>
                </div>
                <div class="mt-6">
                  <button type="button" class="hp-cta hp-cta--accent" data-next="2">Continue →</button>
                </div>
              </div>

              <!-- Step 2 -->
              <div class="net-app-step" data-step="2" style="display: none;">
                <div class="form-field">
                  <label for="capability" class="text-white font-display text-xl mb-4 block">Your Experience With Engineering Materials</label>
                  <p class="text-sm text-gray-400 mb-2">Have you printed PA-CF, ASA, or similar? Tell us about your setup.</p>
                  <textarea id="capability" name="capability" rows="4" required placeholder="Enclosure type, filament drying setup, materials you print regularly, and typical tolerances you hold..."></textarea>
                </div>
                <div class="mt-6 flex gap-4">
                  <button type="button" class="hp-cta hp-cta--glass" data-prev="1">← Back</button>
                  <button type="button" class="hp-cta hp-cta--accent" data-next="3">Continue →</button>
                </div>
              </div>

              <!-- Step 3 -->
              <div class="net-app-step" data-step="3" style="display: none;">
                <h3 class="text-white font-display text-xl mb-2">Pick Your Subdomain</h3>
                <p class="text-sm text-gray-400 mb-6">If accepted, you get a page at yourname.3d3d.ca with your own dispatch dashboard and public profile.</p>
                
                <div class="form-grid mb-4">
                  <div class="form-field">
                    <label for="name">Legal / Operator Name</label>
                    <input type="text" id="name" name="name" required placeholder="Jane Doe" />
                  </div>
                  <div class="form-field">
                    <label for="email">Contact Email</label>
                    <input type="email" id="email" name="email" required placeholder="jane@example.com" />
                  </div>
                </div>

                <div class="form-field mb-6">
                  <label for="subdomain">Requested Node Subdomain</label>
                  <div class="flex items-stretch mt-1">
                    <input type="text" id="subdomain" name="subdomain" required placeholder="halifax" pattern="[a-z0-9-]+" title="Lowercase letters, numbers, and hyphens only" class="flex-1 rounded-r-none border-r-0" />
                    <span class="bg-black/30 border border-white/10 border-l-0 px-4 text-gray-400 font-mono text-sm flex items-center rounded-r-sm">.3d3d.ca</span>
                  </div>
                </div>

                <div class="mt-8 flex gap-4">
                  <button type="button" class="hp-cta hp-cta--glass" data-prev="2">← Back</button>
                  <button type="submit" class="hp-cta hp-cta--accent">Submit Application</button>
                </div>
              </div>

            </form>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .form-field {
    display: grid;
    gap: 0.4rem;
  }
  .form-field label {
    font-family: var(--font-tech);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }
  .form-field input[type="text"],
  .form-field input[type="email"],
  .form-field textarea {
    width: 100%;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    padding: 0.85rem;
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.2s ease;
  }
  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-teal-primary);
  }
  
  .net-app-progress {
    display: flex;
    gap: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 1rem;
  }
  .net-step {
    font-family: var(--font-tech);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    transition: color 0.3s ease;
  }
  .net-step.active {
    color: var(--color-orange-primary);
  }
</style>

<script>
  (() => {
    const form = document.getElementById('frmNetwork');
    if (!form) return;

    const steps = Array.from(document.querySelectorAll('.net-app-step'));
    const indicators = Array.from(document.querySelectorAll('.net-step'));
    const nextBtns = document.querySelectorAll('[data-next]');
    const prevBtns = document.querySelectorAll('[data-prev]');

    const showStep = (stepNum) => {
      steps.forEach(step => {
        if (step.dataset.step === stepNum) {
          step.style.display = 'block';
          step.classList.add('active');
        } else {
          step.style.display = 'none';
          step.classList.remove('active');
        }
      });

      indicators.forEach(ind => {
        if (ind.dataset.stepIndicator === stepNum) {
          ind.classList.add('active');
        } else {
          ind.classList.remove('active');
        }
      });
    };

    nextBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const currentStep = e.target.closest('.net-app-step');
        const requireds = Array.from(currentStep.querySelectorAll('[required]'));
        const allValid = requireds.every(el => el.checkValidity());
        
        if (allValid) {
          showStep(btn.dataset.next);
        } else {
          form.reportValidity();
        }
      });
    });

    prevBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        showStep(btn.dataset.prev);
      });
    });
  })();
</script>
