---
const reviews = [
  {
    name: 'Austin Drost',
    platform: 'Google Business',
    date: '3 weeks ago',
    text: 'Fantastic service from 3D3D! Quick communication, easy to deal with, and the only one in Fredericton who had what I needed for my printer. Reliable and highly recommended. 5 stars.',
    rating: 5,
  },
  {
    name: 'Jackson Scott',
    platform: 'Google Business',
    date: '5 months ago',
    text: 'Recently got a mouse shell printed by 3d3d very happy with how it turned out they were very helpful throughout the process. Gave suggestions on the project and made sure it came out how I visioned it',
    rating: 5,
  },
  {
    name: 'Alexander Kosachov',
    platform: 'Google Business',
    date: '5 months ago',
    text: `I've recently ordered a 3D-printing of vacuum adapter for a HyperHyper Tough 5" Random Orbital Sander which originally comes only with a dust bag and no vacuum attachment available.`,
    rating: 5,
  },
  {
    name: 'Daniel',
    platform: 'Customer',
    date: 'December 2025',
    text: 'Very professional! Wonderful print quality and unmatched customer service!',
    rating: 5,
  },
  {
    name: 'Olga',
    platform: 'Customer',
    date: 'May 2025',
    text: 'Great responce time and respones also amazing pricing he prints anything and finds all the models you need he has almost every filiment available if you need a 3d print he will do it',
    rating: 5,
  },
  {
    name: 'Matthew',
    platform: 'Customer',
    date: 'April 2025',
    text: 'Printer works great. Got home an hour ago and already pulled two nice pieces off the plate! And they look much better than they did on my older printer',
    rating: 5,
  }
];

---

<section class="reviews-section">
  <div class="reviews-shell">
    <div class="reviews-header">
      <h2 class="reviews-title">Verified by the community</h2>
      <div class="reviews-aggregate">
        <div class="flex gap-1" style="color: #FFB800;">
          ★★★★★
        </div>
        <span class="reviews-aggregate__text">5.0 Average based on verified Google and Private feedback.</span>
      </div>
    </div>

    <div class="reviews-grid">
      {reviews.map(review => (
        <div class="review-card">
          <div class="review-card__header">
            <div class="review-card__stars" style="color: #FFB800; font-size: 0.9rem;">
              {Array.from({ length: review.rating }).map(() => '★')}
            </div>
            <span class="review-card__date">{review.date}</span>
          </div>
          <p class="review-card__text">"{review.text}"</p>
          <div class="review-card__footer">
            <div class="review-card__author">{review.name}</div>
            <div class="review-card__platform">{review.platform}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews-section {
    padding: clamp(3rem, 6vw, 5rem) 0;
    background: #FFFFFF;
    border-top: 1px solid var(--color-border-default);
  }

  .reviews-shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 1200px);
    margin: 0 auto;
  }

  .reviews-header {
    margin-bottom: 3rem;
  }

  .reviews-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2vw + 1rem, 2.5rem);
    color: #111214;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  .reviews-aggregate {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .reviews-aggregate__text {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .review-card {
    background: #F6F7FA;
    padding: 1.5rem;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 1px solid rgba(17, 18, 20, 0.05);
  }

  .review-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(17, 18, 20, 0.05);
    padding-bottom: 0.5rem;
  }

  .review-card__date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .review-card__text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-primary);
    flex-grow: 1;
    font-style: italic;
    margin: 0;
  }

  .review-card__footer {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-top: 0.5rem;
  }

  .review-card__author {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: #111214;
  }

  .review-card__platform {
    font-family: var(--font-tech);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
  }
</style>
