---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="3D3D | Custom Fabrication, Software & Community — Fredericton, Canada"
    description="Custom 3D printing, event hire, software development, and community programs. Six printers. Deployable anywhere. Built in Fredericton for the ones that give a damn."
    keywords="3D printing Fredericton, custom fabrication Canada, marine parts 3D print, event hire 3D printer, open source cooperative, 3D printing New Brunswick"
  />
</head>
<body class="hp">

  <!-- ══════════════════════════════════════
       TOP NAVIGATION
  ═══════════════════════════════════════════ -->
  <header class="hp-header" id="hp-header">
    <nav class="hp-nav" aria-label="Main navigation">
      <a href="/" class="hp-nav__logo" aria-label="3D3D — Home">
        <img src="/media/brand/3d3d-logo.svg" alt="3D3D" width="72" height="30" />
      </a>
      <div class="hp-nav__links">
        <a href="/about">About</a>
        <a href="/materials">Materials</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
        <a href="/quote" class="hp-nav__cta">Get a Quote</a>
      </div>
      <button class="hp-nav__menu-btn" id="hp-menu-btn" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </header>

  <!-- Mobile Nav Drawer -->
  <dialog id="hp-mobile-nav" class="hp-mobile-nav">
    <button class="hp-mobile-nav__close" onclick="document.getElementById('hp-mobile-nav').close()" aria-label="Close menu">✕</button>
    <nav>
      <a href="/quote">Get a Quote</a>
      <a href="/about">About</a>
      <a href="/materials">Materials</a>
      <a href="/opportunities">Network</a>
      <a href="/blog">Blog</a>
      <a href="/faq">FAQ</a>
      <a href="/contact">Contact</a>
      <a href="/shop">Shop</a>
      <a href="https://oldgirl.3d3d.ca" target="_blank" rel="noopener">The Old Girl</a>
    </nav>
  </dialog>

  <main id="main-content">

    <!-- ══════════════════════════════════════
         HERO — Full viewport, dark photo
    ═══════════════════════════════════════════ -->
    <section class="hp-hero" aria-label="3D3D — Home">
      <div class="hp-hero__bg" aria-hidden="true"></div>
      <div class="hp-hero__grain" aria-hidden="true"></div>
      <div class="hp-hero__vignette" aria-hidden="true"></div>
      <div class="hp-hero__content">
        <p class="hp-hero__eyebrow">FREDERICTON, NB · CANADA · WORLDWIDE</p>
        <h1 class="hp-hero__h1">
          FOR THE<br>
          ONES THAT<br>
          GIVE A DAMN.
        </h1>
        <p class="hp-hero__sub">
          Custom fabrication. Software. Community.<br>
          Built from the ground up with nothing but grit.
        </p>
        <div class="hp-hero__ctas">
          <a href="/quote" class="hp-btn hp-btn--primary">GET A QUOTE</a>
          <button class="hp-btn hp-btn--outline-light" onclick="document.getElementById('dlg-events').showModal()">HIRE FOR EVENTS</button>
          <a href="/opportunities" class="hp-btn hp-btn--ghost-light">JOIN THE NETWORK</a>
        </div>
      </div>
      <div class="hp-hero__scroll-hint" aria-hidden="true">
        <span class="hp-hero__scroll-label">SCROLL</span>
        <div class="hp-hero__scroll-line"></div>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         01 — CUSTOM FABRICATION (light)
         Image left · Content right
    ═══════════════════════════════════════════ -->
    <section class="hp-split hp-split--light" aria-labelledby="hp-fab-title">
      <div class="hp-split__img">
        <img
          src="/media/workshop/printer-action-cf.jpg"
          alt="Carbon fiber filament running on a 3D printer"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="hp-split__content">
        <p class="hp-eyebrow">CUSTOM FABRICATION</p>
        <h2 class="hp-h2" id="hp-fab-title">Need a part<br>that doesn't exist?</h2>
        <p class="hp-text">
          Marine hardware, automotive restoration, prototypes, replacement components.
          Six printers. Deployable anywhere. Most jobs turn around same day.
        </p>
        <div class="hp-chips">
          <span>Prusa MK2.5</span>
          <span>Bambu A1</span>
          <span>Creality K1</span>
          <span>BIBO 2</span>
          <span>Anycubic Kobra 2 Max</span>
        </div>
        <a href="/quote" class="hp-btn hp-btn--teal">START A QUOTE →</a>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         02 — THE STORY (light, flipped)
         Content left · Image right
    ═══════════════════════════════════════════ -->
    <section class="hp-split hp-split--story hp-split--flip" aria-labelledby="hp-story-title">
      <div class="hp-split__content">
        <p class="hp-eyebrow">THE STORY</p>
        <h2 class="hp-h2" id="hp-story-title">Made from nothing.<br>Built for everyone.</h2>
        <p class="hp-text">
          Ankylosing spondylitis ended a decade of trucking. Instead of disability, I chose
          reinvention — self-teaching fabrication, software, and AI from the ground up.
          Ten years sober. Still building.
        </p>
        <p class="hp-text">
          If you don't fit a normal job, you're exactly who belongs here.
          The unheard, the unnamed. People with heart.
          <em>We give a damn.</em>
        </p>
        <a href="/about" class="hp-btn hp-btn--outline-dark">READ THE FULL STORY →</a>
      </div>
      <div class="hp-split__img">
        <img
          src="/media/real/helm-close.jpg"
          alt="At the helm offshore during a race"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <!-- ══════════════════════════════════════
         03 — EVENT HIRE (dark)
         Image left · Content right
    ═══════════════════════════════════════════ -->
    <section class="hp-split hp-split--dark" aria-labelledby="hp-events-title">
      <div class="hp-split__img">
        <img
          src="/media/real/race-morning-crew.jpg"
          alt="Race morning — crew on deck preparing before the start"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="hp-split__content">
        <p class="hp-eyebrow hp-eyebrow--teal">EVENTS & DEPLOYMENT</p>
        <h2 class="hp-h2 hp-h2--light" id="hp-events-title">Bring 3D3D<br>to your event.</h2>
        <p class="hp-text hp-text--muted">
          Regattas, car shows, expos, LARP, D&amp;D nights, conventions, marinas —
          I show up with printers and cameras. Parts built on-site. Video documented.
          The machines are part of the show.
        </p>
        <p class="hp-callout hp-callout--magenta">From $1,500 · Full-day deployments · Video documentation included</p>
        <button class="hp-btn hp-btn--magenta" onclick="document.getElementById('dlg-events').showModal()">BOOK AN EVENT →</button>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         04 — SOFTWARE & INNOVATION (dark, flipped)
         Content left · Image right
    ═══════════════════════════════════════════ -->
    <section class="hp-split hp-split--dark hp-split--flip" aria-labelledby="hp-software-title">
      <div class="hp-split__content">
        <p class="hp-eyebrow hp-eyebrow--teal">SOFTWARE · AI · ROBOTICS</p>
        <h2 class="hp-h2 hp-h2--light" id="hp-software-title">We build<br>digital too.</h2>
        <p class="hp-text hp-text--muted">
          Custom websites, apps, AI integrations, SaaS tools. Robotics, R&amp;D, automation.
          Built fast for local companies, community makers, anyone that needs it done right.
          We can ship in a weekend. You keep it forever.
        </p>
        <button class="hp-btn hp-btn--outline-light" onclick="document.getElementById('dlg-software').showModal()">VIEW PROJECTS →</button>
      </div>
      <div class="hp-split__img">
        <img
          src="/media/backgrounds/makers-neon-workshop.jpg"
          alt="Maker workshop lit with neon and activity"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <!-- ══════════════════════════════════════
         05 — THE NETWORK (light)
         Image left · Content right
    ═══════════════════════════════════════════ -->
    <section class="hp-split hp-split--light" aria-labelledby="hp-network-title">
      <div class="hp-split__img">
        <img
          src="/images/splash-bg-network.png"
          alt="3D3D cooperative network visualization"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="hp-split__content">
        <p class="hp-eyebrow">THE NETWORK</p>
        <h2 class="hp-h2" id="hp-network-title">3D3D connects<br>Canada.</h2>
        <p class="hp-text">
          First makers in get a free website at <strong>yourname.3d3d.ca</strong>.
          Node operator program for distributed printing across the country.
          Open source everything. Built to share.
        </p>
        <p class="hp-text">
          Makers, coders, artists, photographers, robotics techs, AI specialists —
          if you create things, there's a place for you here.
        </p>
        <a href="/opportunities" class="hp-btn hp-btn--teal">JOIN THE NETWORK →</a>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         06 — THE OLD GIRL (light, flipped)
         Content left · Image right
    ═══════════════════════════════════════════ -->
    <section class="hp-split hp-split--warm hp-split--flip" aria-labelledby="hp-oldgirl-title">
      <div class="hp-split__content">
        <p class="hp-eyebrow">COMMUNITY PROJECT</p>
        <h2 class="hp-h2" id="hp-oldgirl-title">The Old Girl.</h2>
        <p class="hp-text">
          A Prusa MK2 rescued for $50 — someone was going to throw it away.
          It belongs to the community now. Pick a file, we print it.
          Pay for filament and shipping only. No markup. No admin fee. No nonsense.
        </p>
        <div class="hp-chips hp-chips--muted">
          <span>Running 24/7</span>
          <span>Community-modded</span>
          <span>Donations welcome</span>
          <span>Wishlist open</span>
        </div>
        <a href="https://oldgirl.3d3d.ca" class="hp-btn hp-btn--outline-dark" target="_blank" rel="noopener noreferrer">SEND A PRINT JOB →</a>
      </div>
      <div class="hp-split__img">
        <img
          src="/media/workshop/printer-bed-benchy.jpg"
          alt="Printer bed with a benchy print in progress"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <!-- ══════════════════════════════════════
         GALLERY STRIP (dark)
    ═══════════════════════════════════════════ -->
    <section class="hp-gallery" aria-label="Photo gallery preview">
      <div class="hp-gallery__strip" aria-hidden="true">
        <img src="/media/real/fleet-aerial.jpg" alt="" loading="lazy" />
        <img src="/media/workshop/machine-parts-flatlay.jpg" alt="" loading="lazy" />
        <img src="/media/real/golden-hour-01.jpg" alt="" loading="lazy" />
        <img src="/media/workshop/blue-prototype-part.jpg" alt="" loading="lazy" />
        <img src="/media/real/offshore-day-01.jpg" alt="" loading="lazy" />
        <img src="/media/workshop/modular-parts-flatlay.jpg" alt="" loading="lazy" />
        <img src="/media/real/race-finish-01.jpg" alt="" loading="lazy" />
        <img src="/media/workshop/winch-cup-holder.jpg" alt="" loading="lazy" />
        <img src="/media/real/dawn-approach.jpg" alt="" loading="lazy" />
        <img src="/media/workshop/custom-tv-mount.jpg" alt="" loading="lazy" />
      </div>
      <div class="hp-gallery__cta">
        <p class="hp-gallery__headline">
          4,000+ photos. 20,000+ nautical miles.<br>One journey.
        </p>
        <div class="hp-gallery__btns">
          <a href="/gallery" class="hp-btn hp-btn--outline-light">VIEW GALLERY →</a>
          <a
            href="https://ko-fi.com/3d3dca"
            target="_blank"
            rel="noopener noreferrer"
            class="hp-btn hp-btn--kofi"
          >☕ FOLLOW ON KO-FI</a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════
         SPONSOR THE JOURNEY (light)
    ═══════════════════════════════════════════ -->
    <section class="hp-sponsor" aria-labelledby="hp-sponsor-title">
      <div class="hp-sponsor__header">
        <p class="hp-eyebrow hp-eyebrow--center">SPONSORSHIPS</p>
        <h2 class="hp-h2" id="hp-sponsor-title">Sponsor the journey.</h2>
        <p class="hp-text hp-text--centered">
          Support the cooperative. Sponsor an event. Become a patron.
          Every dollar goes back into the machines, the community, and the mission.
        </p>
      </div>
      <div class="hp-tiers">

        <div class="hp-tier">
          <div class="hp-tier__header">
            <span class="hp-tier__price">$100</span>
            <span class="hp-tier__name">SUPPORTER</span>
          </div>
          <ul class="hp-tier__list">
            <li>$25 in free prints</li>
            <li>Name in site credits</li>
            <li>Ko-fi thank-you post</li>
          </ul>
          <button class="hp-btn hp-btn--outline-dark hp-btn--full" onclick="document.getElementById('dlg-sponsor').showModal()">SPONSOR →</button>
        </div>

        <div class="hp-tier hp-tier--featured">
          <span class="hp-tier__badge">MOST POPULAR</span>
          <div class="hp-tier__header">
            <span class="hp-tier__price">$500</span>
            <span class="hp-tier__name">PARTNER</span>
          </div>
          <ul class="hp-tier__list">
            <li>$100 in free prints</li>
            <li>2 t-shirts + 2 hats</li>
            <li>1-on-1 consultation call</li>
            <li>One free software build / year</li>
            <li>Social feature + dedicated post</li>
          </ul>
          <button class="hp-btn hp-btn--teal hp-btn--full" onclick="document.getElementById('dlg-sponsor').showModal()">SPONSOR →</button>
        </div>

        <div class="hp-tier">
          <div class="hp-tier__header">
            <span class="hp-tier__price">CUSTOM</span>
            <span class="hp-tier__name">INVESTOR</span>
          </div>
          <ul class="hp-tier__list">
            <li>Custom package</li>
            <li>Event co-branding</li>
            <li>Equity conversation welcome</li>
            <li>Dedicated support channel</li>
          </ul>
          <button class="hp-btn hp-btn--magenta hp-btn--full" onclick="document.getElementById('dlg-sponsor').showModal()">LET'S TALK →</button>
        </div>

      </div>
    </section>

  </main>

  <!-- ══════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════ -->
  <footer class="hp-footer">
    <div class="hp-footer__inner">
      <a href="/" aria-label="3D3D Home">
        <img src="/media/brand/3d3d-logo.svg" alt="3D3D" width="72" height="30" class="hp-footer__logo" />
      </a>
      <nav class="hp-footer__nav" aria-label="Footer navigation">
        <a href="/quote">Quote</a>
        <a href="/about">About</a>
        <a href="/materials">Materials</a>
        <a href="/opportunities">Network</a>
        <a href="/blog">Blog</a>
        <a href="/faq">FAQ</a>
        <a href="/contact">Contact</a>
        <a href="/shop">Shop</a>
        <a href="https://oldgirl.3d3d.ca" target="_blank" rel="noopener">Old Girl</a>
        <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener">Ko-fi</a>
      </nav>
      <p class="hp-footer__copy">
        © 2025 3D3D Atlantic Cooperative · Fredericton, NB, Canada · Open Source · Built with grit.
      </p>
    </div>
  </footer>

  <!-- ══════════════════════════════════════
       DIALOGS
  ═══════════════════════════════════════════ -->

  <!-- Events Dialog -->
  <dialog id="dlg-events" class="hp-dialog">
    <button class="hp-dialog__close" onclick="this.closest('dialog').close()" aria-label="Close">✕</button>
    <p class="hp-eyebrow">BOOK AN EVENT</p>
    <h3 class="hp-dialog__title">Hire Ken for your event.</h3>
    <p>Regattas, car shows, expos, conventions, LARP nights, D&D sessions, marinas, community gatherings — I show up with printers, cameras, and the will to build.</p>
    <p>Fill out a quick inquiry and I'll get back to you within 24 hours.</p>
    <a href="/book" class="hp-btn hp-btn--teal">BOOKING FORM →</a>
    <a href="/contact?subject=event-hire" class="hp-btn hp-btn--ghost">OR SEND A MESSAGE →</a>
  </dialog>

  <!-- Software Dialog -->
  <dialog id="dlg-software" class="hp-dialog">
    <button class="hp-dialog__close" onclick="this.closest('dialog').close()" aria-label="Close">✕</button>
    <p class="hp-eyebrow">SOFTWARE & PROJECTS</p>
    <h3 class="hp-dialog__title">Digital work.</h3>
    <p>Websites, apps, AI tools, SaaS, automation, robotics. Portfolio page coming soon — in the meantime, reach out to talk about what you need built.</p>
    <p>We can usually scope, plan, and ship in a single sprint.</p>
    <a href="/contact?subject=software-project" class="hp-btn hp-btn--teal">START A CONVERSATION →</a>
    <a href="https://github.com/3d3dcanada" target="_blank" rel="noopener" class="hp-btn hp-btn--outline-dark">VIEW GITHUB →</a>
  </dialog>

  <!-- Sponsor Dialog -->
  <dialog id="dlg-sponsor" class="hp-dialog">
    <button class="hp-dialog__close" onclick="this.closest('dialog').close()" aria-label="Close">✕</button>
    <p class="hp-eyebrow">SPONSORSHIPS</p>
    <h3 class="hp-dialog__title">Sponsor the journey.</h3>
    <p>Stripe payment links are coming online soon. For now, reach out directly — we'll put together a package that works for your goals and budget.</p>
    <p>VCs, brands, individual supporters, and community members are all welcome.</p>
    <a href="/contact?subject=sponsorship" class="hp-btn hp-btn--magenta">REACH OUT →</a>
    <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener" class="hp-btn hp-btn--kofi">☕ SUPPORT ON KO-FI</a>
  </dialog>

  <!-- ══════════════════════════════════════
       SCRIPTS
  ═══════════════════════════════════════════ -->
  <script is:inline>
    // Header: transparent over hero → opaque on scroll
    (function () {
      var header = document.getElementById('hp-header');
      var hero = document.querySelector('.hp-hero');
      if (!header || !hero) return;

      function update() {
        var heroBottom = hero.getBoundingClientRect().bottom;
        header.classList.toggle('hp-header--scrolled', heroBottom < 80);
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
    })();

    // Close dialogs on backdrop click
    document.querySelectorAll('.hp-dialog').forEach(function(dlg) {
      dlg.addEventListener('click', function(e) {
        if (e.target === dlg) dlg.close();
      });
    });

    // Mobile menu
    var menuBtn = document.getElementById('hp-menu-btn');
    var mobileNav = document.getElementById('hp-mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', function() {
        mobileNav.showModal();
        menuBtn.setAttribute('aria-expanded', 'true');
      });
      mobileNav.addEventListener('close', function() {
        menuBtn.setAttribute('aria-expanded', 'false');
      });
      mobileNav.addEventListener('click', function(e) {
        if (e.target === mobileNav) mobileNav.close();
      });
    }
  </script>

</body>
</html>

<style>
  /* ══════════════════════════════════════════════
     3D3D HOMEPAGE STYLES
     Mixed light/dark · Alternating sections
  ═════════════════════════════════════════════════ */

  /* ── BASE ── */
  .hp {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    background: #F6F7FA;
    color: #1A1D21;
    font-family: var(--font-body, 'Instrument Sans', system-ui, sans-serif);
  }

  /* ── HEADER ── */
  .hp-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    height: 64px;
    display: flex;
    align-items: center;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
    background: rgba(10, 14, 19, 0.0);
    border-bottom: 1px solid transparent;
    transition: background 0.35s ease, border-color 0.35s ease;
  }
  .hp-header--scrolled {
    background: rgba(246, 247, 250, 0.92);
    border-bottom-color: rgba(0, 0, 0, 0.07);
    backdrop-filter: blur(16px);
  }

  .hp-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }
  .hp-nav__logo img { display: block; }

  .hp-nav__links {
    display: flex;
    align-items: center;
    gap: 2rem;
    font-family: var(--font-tech, 'Archivo', system-ui, sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .hp-nav__links a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.2s;
  }
  .hp-nav__links a:hover { color: #fff; }
  .hp-header--scrolled .hp-nav__links a { color: #4A5568; }
  .hp-header--scrolled .hp-nav__links a:hover { color: var(--color-teal-primary, #40C4C4); }

  .hp-nav__cta {
    padding: 0.5rem 1.1rem;
    background: var(--color-teal-primary, #40C4C4);
    color: #0F1112 !important;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s !important;
  }
  .hp-nav__cta:hover { background: #53D3D3 !important; transform: translateY(-1px); }

  .hp-nav__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .hp-nav__menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: background 0.2s;
  }
  .hp-header--scrolled .hp-nav__menu-btn span { background: #1A1D21; }

  /* ── MOBILE NAV ── */
  .hp-mobile-nav {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: 320px;
    height: 100%;
    max-height: 100%;
    margin: 0 0 0 auto;
    border: none;
    background: #0F1112;
    padding: 5rem 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid rgba(255,255,255,0.06);
  }
  .hp-mobile-nav::backdrop { background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); }
  .hp-mobile-nav__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0.4rem;
    transition: color 0.2s;
  }
  .hp-mobile-nav__close:hover { color: #fff; }
  .hp-mobile-nav nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .hp-mobile-nav nav a {
    display: block;
    padding: 1rem 0;
