---
/**
 * BottomNav — Mobile navigation bar (replaces MobileCTA.astro)
 * Shows 5 tabs: Home, Quote, Shop, Community, Menu (opens sidebar).
 * Visible only on mobile (< 768px via CSS).
 */
interface Props {
  activePath?: string;
}

const { activePath = '' } = Astro.props;

const normalizePath = (path: string) => {
  if (path === '/') return '/';
  return path.replace(/\/+$/, '');
};

const current = normalizePath(activePath);

const tabs = [
  {
    id: 'home',
    label: 'Home',
    href: '/',
    svgPath: 'M12 3l9 8v10h-6v-6H9v6H3V11z',
    viewBox: '0 0 24 24',
  },
  {
    id: 'quote',
    label: 'Quote',
    href: '/quote',
    svgPath: 'M21 10c-1 0-2 1-2 2v3H5V5h3c1 0 2-1 2-2s-1-2-2-2H3v18h18V12c0-1-1-2-2-2zm-8 6l6-8h-4V3h-4v5H7z',
    viewBox: '0 0 24 24',
  },
  {
    id: 'shop',
    label: 'Shop',
    href: '/shop',
    svgPath: 'M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM7.2 14.8l.1-.1L8.1 13h7.5c.7 0 1.4-.4 1.7-1l3.9-7-1.7-1-3.9 7H8.5L4.3 2H1v2h2l3.6 7.6-1.4 2.5c-.1.3-.2.5-.2.9 0 1.1.9 2 2 2h12v-2H7.4c-.1 0-.2-.1-.2-.2z',
    viewBox: '0 0 24 24',
  },
  {
    id: 'community',
    label: 'Community',
    href: '/community',
    svgPath: 'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z',
    viewBox: '0 0 24 24',
  },
  {
    id: 'menu',
    label: 'Menu',
    href: '#menu',
    svgPath: 'M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z',
    viewBox: '0 0 24 24',
    isMenuTrigger: true,
  },
];
---

<nav class="bottom-nav" aria-label="Mobile navigation">
  {tabs.map((tab) => {
    const isActive = !tab.isMenuTrigger && normalizePath(tab.href) === current;

    if (tab.isMenuTrigger) {
      return (
        <button
          type="button"
          class="bottom-nav__tab"
          data-bottom-menu-trigger
          aria-label="Open navigation menu"
        >
          <svg class="bottom-nav__icon" viewBox={tab.viewBox} aria-hidden="true">
            <path d={tab.svgPath} fill="currentColor" />
          </svg>
          <span class="bottom-nav__label">{tab.label}</span>
        </button>
      );
    }

    return (
      <a
        href={tab.href}
        class:list={['bottom-nav__tab', isActive && 'bottom-nav__tab--active']}
        aria-current={isActive ? 'page' : undefined}
      >
        <svg class="bottom-nav__icon" viewBox={tab.viewBox} aria-hidden="true">
          <path d={tab.svgPath} fill="currentColor" />
        </svg>
        <span class="bottom-nav__label">{tab.label}</span>
      </a>
    );
  })}
</nav>

<style>
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: none;
    justify-content: space-around;
    align-items: stretch;
    min-height: calc(3.6rem + env(safe-area-inset-bottom, 0px));
    padding-bottom: env(safe-area-inset-bottom, 0px);
    background: rgba(17, 18, 20, 0.92);
    backdrop-filter: blur(20px) saturate(1.8);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    border-top: 1px solid rgba(64, 196, 196, 0.15);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 768px) {
    .bottom-nav {
      display: flex;
    }
  }

  .bottom-nav__tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    min-height: 3.6rem;
    padding: 0.4rem 0;
    background: transparent;
    border: none;
    color: rgba(246, 247, 250, 0.5);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .bottom-nav__tab:hover,
  .bottom-nav__tab:active {
    color: rgba(246, 247, 250, 0.85);
  }

  .bottom-nav__tab--active {
    color: #40C4C4;
  }

  .bottom-nav__icon {
    width: 1.35rem;
    height: 1.35rem;
  }

  .bottom-nav__label {
    font-family: var(--font-tech);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
  }
</style>

<script>
  (() => {
    const trigger = document.querySelector('[data-bottom-menu-trigger]');
    const sidebarToggle = document.querySelector('[data-sidebar-toggle]');
    if (trigger && sidebarToggle) {
      trigger.addEventListener('click', () => {
        (sidebarToggle as HTMLButtonElement).click();
      });
    }
  })();
</script>
