---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandSidebar from '../../components/BrandSidebar.tsx';

const sidebarNav = [{
  label: 'Old Girl',
  items: [
    { id: 'home', label: 'Home', href: '/' },
    { id: 'about', label: 'About', href: '/about' },
    { id: 'blog', label: 'Blog', href: '/blog' },
    { id: 'contact', label: 'Contact', href: '/contact' },
  ],
}];

const posts = [
  {
    slug: 'old-girl-restoration-log',
    title: 'The Old Girl Restoration Log',
    date: '2026-03-12',
    excerpt: 'From broken MMU2S and bent frame to first five-colour print — a full account of the restoration.',
  },
  {
    slug: 'community-printer-launch-plan',
    title: 'How the Community Printer Launch Works',
    date: '2026-03-14',
    excerpt: 'Staged rollout, honest preview, and why we refused to fake a live system. The plan behind the Old Girl launch.',
  },
  {
    slug: '3d-printer-fleet-monitoring',
    title: '3D Printer Fleet Monitoring: What We Built and Why',
    date: '2026-03-16',
    excerpt: 'The technical stack behind real-time printer monitoring — Supabase, realtime subscriptions, and edge deployments.',
  },
];
---

<BaseLayout
  title="Blog — The Old Girl"
  description="Posts about 3D printer restoration, community printing, and fleet monitoring from the Old Girl project."
  accent="#84CC16"
>
  <BrandSidebar slot="sidebar" client:load navGroups={sidebarNav} activePath="/blog" />

  <div class="pt-16 pl-0 lg:pl-4">
    <section class="px-6 lg:px-12 py-12">
      <div class="max-w-3xl">
        <p class="text-[10px] uppercase tracking-[0.25em] mb-2" style="color: var(--color-text-muted); font-family: var(--font-display);">Blog</p>
        <h1 class="text-3xl font-bold mb-10" style="color: var(--color-text-primary); font-family: var(--font-display);">From the Old Girl</h1>

        <div class="space-y-4">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`} class="group block p-6 rounded-xl transition-all duration-200" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle);">
              <div class="flex items-center justify-between gap-4 mb-2">
                <h2 class="text-base font-bold group-hover:underline" style="color: var(--color-text-primary); font-family: var(--font-display);">{post.title}</h2>
                <span class="text-[9px] uppercase tracking-wider flex-shrink-0" style="color: var(--color-text-muted); font-family: var(--font-display);">{post.date}</span>
              </div>
              <p class="text-[13px] leading-relaxed" style="color: var(--color-text-secondary);">{post.excerpt}</p>
              <span class="inline-block mt-3 text-[10px] uppercase tracking-wider" style="color: #65A30D; font-family: var(--font-display);">Read →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
