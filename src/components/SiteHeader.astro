---
interface NavItem {
  id: string;
  label: string;
  href?: string;
}

interface NavGroup {
  label: string;
  items: NavItem[];
}

interface Props {
  navGroups: NavGroup[];
  activePath?: string;
}

const { navGroups, activePath = '' } = Astro.props;
const navItems = navGroups.flatMap((group) => group.items);
---

<header class="site-header" data-menu-open="false">
  <div class="page-shell site-header__inner">
    <a href="/" class="site-brand" aria-label="3D3D home">
      <span class="site-brand__mark">3D3D</span>
      <span class="site-brand__meta">
        <span class="site-brand__eyebrow">On-location 3D printing</span>
        <span class="site-brand__name">Custom 3D printing</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      {navItems.map((item) => {
        const isActive = item.href === activePath || item.id === activePath;

        return (
          <a
            href={item.href || `#${item.id}`}
            class:list={['site-nav__link', isActive && 'is-active']}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="site-header__actions">
      <a
        href="/quote?source=header-primary"
        class="btn btn-primary site-header__cta"
        data-analytics-event="quote_started"
        data-analytics-source="header-primary"
      >
        Request a Custom Print
      </a>
      <button
        type="button"
        class="site-menu-button"
        data-menu-toggle
        aria-expanded="false"
        aria-controls="site-mobile-panel"
        aria-label="Open navigation menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="site-mobile-backdrop" data-menu-close hidden></div>

  <div id="site-mobile-panel" class="site-mobile-panel" hidden>
    <div class="site-mobile-panel__inner">
      <nav class="site-mobile-nav" aria-label="Mobile navigation">
        {navGroups.map((group) => (
          <div class="site-mobile-nav__group">
            <p class="site-mobile-nav__label">{group.label}</p>
            <div class="site-mobile-nav__items">
              {group.items.map((item) => {
                const isActive = item.href === activePath || item.id === activePath;

                return (
                  <a
                    href={item.href || `#${item.id}`}
                    class:list={['site-mobile-nav__link', isActive && 'is-active']}
                    data-menu-link
                  >
                    {item.label}
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </nav>

      <div class="site-mobile-panel__footer">
        <a
          href="/quote?source=mobile-menu"
          class="btn btn-primary w-full"
          data-analytics-event="quote_started"
          data-analytics-source="mobile-menu"
          data-menu-link
        >
          Start a Quote
        </a>
        <a href="/contact" class="btn btn-secondary w-full" data-menu-link>
          Contact 3D3D
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.site-header');

  if (header) {
    const toggle = header.querySelector('[data-menu-toggle]');
    const panel = header.querySelector('#site-mobile-panel');
    const backdrop = header.querySelector('.site-mobile-backdrop');
    const closeTargets = header.querySelectorAll('[data-menu-close], [data-menu-link]');

    const setOpen = (open: boolean) => {
      header.dataset.menuOpen = open ? 'true' : 'false';

      if (toggle instanceof HTMLButtonElement) {
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
      }

      if (panel instanceof HTMLElement) {
        panel.hidden = !open;
      }

      if (backdrop instanceof HTMLElement) {
        backdrop.hidden = !open;
      }

      document.body.classList.toggle('menu-open', open);
    };

    if (toggle instanceof HTMLButtonElement) {
      toggle.addEventListener('click', () => {
        setOpen(header.dataset.menuOpen !== 'true');
      });
    }

    closeTargets.forEach((target) => {
      target.addEventListener('click', () => setOpen(false));
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) setOpen(false);
    });
  }
</script>
