---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Organization'],
  name: '3D3D',
  url: 'https://3d3d.ca',
  description: 'Precision fabrication for marine, automotive, and field deployment. Founder-operated out of Fredericton, New Brunswick.',
  telephone: '+1-506-953-2678',
  email: 'info@3d3d.ca',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Fredericton',
    addressRegion: 'NB',
    addressCountry: 'CA',
  },
  founder: { '@type': 'Person', name: 'Ken' },
  sameAs: [
    'https://www.youtube.com/@3D3Dcanada',
    'https://www.tiktok.com/@3d3dcanada',
    'https://www.instagram.com/3d3dca/',
    'https://www.facebook.com/profile.php?id=61575548079847',
    'https://www.printables.com/@KTK3D_3050116',
    'https://github.com/3d3dcanada/3d3d-main',
    'https://wa.me/15069532678',
    'https://ko-fi.com/3d3dca',
  ],
  image: 'https://3d3d.ca/media/real/race-morning-crew.jpg',
  logo: 'https://3d3d.ca/media/brand/logo-badge.webp',
};

const homeNavGroups = [
  {
    label: 'On This Page',
    items: [
      { id: 'home', label: 'Home', href: '/' },
      { id: 'services', label: 'Services', href: '#services' },
      { id: 'origin', label: 'Origin', href: '#origin' },
      { id: 'deployment', label: 'Deployment', href: '#deployment' },
      { id: 'support', label: 'Support', href: '#support' },
      { id: 'open-build', label: 'Open Build', href: '#open-build' },
      { id: 'partners', label: 'Partners', href: '#partners' },
      { id: 'contact', label: 'Contact', href: '#contact' },
    ],
  },
  {
    label: 'Site',
    items: [
      { id: 'blog', label: 'Blog', href: '/blog' },
      { id: 'shop', label: 'Shop', href: '/shop' },
      { id: 'about', label: 'About', href: '/about' },
    ],
  },
];

const heroProofRail = [
  'Founder-operated',
  'Fredericton, NB',
  'Marine · Motorsport · Field-tested',
  'Newport Bermuda 2026',
];

const heroStats = [
  { value: '3', label: 'Active print platforms' },
  { value: '120th', label: 'Newport Bermuda Race — June 2026' },
  { value: '1 yr', label: 'Built from nothing to here' },
];

const services = [
  {
    id: 'marine',
    drawerId: 'drawer-marine',
    eyebrow: 'Marine & Offshore',
    stakes: "If it fails at sea, it can't be MacGyvered.",
    body: 'Winch components, deck hardware, replacement fittings, and custom parts built to survive saltwater, UV, and open-ocean conditions. If it goes on a boat, we print it to last.',
    bullets: [
      'Saltwater-resistant materials: ASA, PETG, CF compounds',
      'Dimensional accuracy for mechanical fitment',
      'Replacements for discontinued or unavailable marine parts',
    ],
    cta: 'Send your fitment problem →',
    image: '/media/workshop/winch-cup-holder.jpg',
    alt: 'Marine winch accessory fabricated for offshore use',
    drawer: {
      photos: [
        {
          src: '/media/workshop/winch-cup-holder.jpg',
          alt: 'Winch-top cup holder printed for marine use',
        },
        {
          src: '/media/workshop/printer-action-cf.jpg',
          alt: 'Carbon-fibre print running in the workshop',
        },
        {
          src: '/media/real/helm-close.jpg',
          alt: 'Close view from the helm during offshore sailing',
        },
      ],
      materials: 'ASA, PETG, and carbon-fibre compounds are the baseline when salt, UV, and constant load are part of the job.',
      turnaround: 'Marine jobs move fastest when fitment dimensions or a reference part come in with the request.',
    },
  },
  {
    id: 'automotive',
    drawerId: 'drawer-automotive',
    eyebrow: 'Automotive & Motorsport',
    stakes: "Cars, trucks, rally rigs — if it broke or never existed, we make it.",
    body: 'Radio knob replacements, custom brackets, aftermarket accessories, and parts that no longer exist. Drag cars, daily drivers, build cars — if it needs a part, we figure out the part.',
    bullets: [
      'Heat-resistant materials for engine-adjacent applications',
      'Rapid iteration for fitment and clearance',
      'One-off or small production runs',
    ],
    cta: 'Send your build spec →',
    image: '/media/workshop/radio-button-replacement.jpg',
    alt: 'Replacement automotive radio knob beside the original part',
    drawer: {
      photos: [
        {
          src: '/media/workshop/radio-button-replacement.jpg',
          alt: 'Replacement Pontiac Vibe radio button',
        },
        {
          src: '/media/workshop/mouse-body-petgcf.jpg',
          alt: 'PETG-CF mouse body on the print bed',
        },
        {
          src: '/media/workshop/fan-reducers.jpg',
          alt: 'Precision black functional parts lined up after printing',
        },
      ],
      materials: 'PETG-CF, ASA, and higher-temp compounds are selected around heat, vibration, and clearance requirements.',
      turnaround: 'Fitment-first automotive work usually starts with photos, measurements, or the broken part itself.',
    },
  },
  {
    id: 'repair',
    drawerId: 'drawer-repair',
    eyebrow: 'Repair & Replacement',
    stakes: 'The part is discontinued. The supplier is gone. We print the replacement.',
    body: 'If you have a broken component, a worn piece, or a part that simply no longer exists anywhere, 3D3D can reverse-engineer and produce it. One piece. Exact fit. Ships to you.',
    bullets: [
      'From measurement or reference sample',
      'Functional-grade materials, not display prints',
      'Full review before shipping',
    ],
    cta: 'Describe what broke →',
    image: '/media/workshop/spray-can-adapter.jpg',
    alt: 'Purple functional adapter printed for replacement use',
    drawer: {
      photos: [
        {
          src: '/media/workshop/spray-can-adapter.jpg',
          alt: 'Functional spray can adapter',
        },
        {
          src: '/media/workshop/radio-button-replacement.jpg',
          alt: 'Replacement automotive button',
        },
        {
          src: '/media/workshop/nomad-joe-holder.jpg',
          alt: 'Functional holder printed for daily use',
        },
      ],
      materials: 'Material choice is driven by what the broken part had to survive in the first place: load, heat, weather, or repeated handling.',
      turnaround: 'If the geometry is straightforward and the measurements are clean, repair parts can move quickly from review to production.',
    },
  },
  {
    id: 'custom',
    drawerId: 'drawer-custom',
    eyebrow: 'Custom & Field Fabrication',
    stakes: 'No blueprint required. Bring the problem.',
    body: 'Custom mounts, jigs, adapters, enclosures, tools, and one-off solutions. If you can describe it — or even just describe the problem — 3D3D can design and build it.',
    bullets: [
      'Design-from-brief available',
      'Carbon-fibre, flexible, rigid, high-temp compound options',
      'Prototypes and production runs',
    ],
    cta: 'Start a custom build →',
    image: '/media/workshop/printer-action-cf.jpg',
    alt: 'Carbon-fibre print in progress on a fabrication platform',
    drawer: {
      photos: [
        {
          src: '/media/workshop/printer-action-cf.jpg',
          alt: 'Printer producing a carbon-fibre part',
        },
        {
          src: '/media/workshop/custom-tv-mount.jpg',
          alt: 'Custom TV mount fixed to a stair railing',
        },
        {
          src: '/media/workshop/rv-lab-01.jpg',
          alt: 'The original RV fabrication setup with printers running',
        },
      ],
      materials: 'Rigid, flexible, carbon-fibre, and higher-temp compounds stay on the table until the use case narrows the answer down.',
      turnaround: 'Custom work starts with the problem statement first, then design, then fitment and print once the direction is right.',
    },
  },
];

const originParagraphs = [
  '3D3D was not started in a workshop with a budget. It was started in a recreational vehicle, running three printers off a generator that cost $30 a day in gas. In 35-degree heat. With everything breaking — the printers, the power, the plans, all of it.',
  'That was the sacrifice required to build this. A year of daily printing, failing, iterating, and producing parts that hold up — not because the setup was ideal, but because the standards were non-negotiable.',
  "Today the operation is stable, Prusa Research is sending a CORE One L, and the Newport Bermuda Race deployment is on the horizon. But the mentality hasn't changed: if it can break, it will. So it is built not to.",
];

const originProofPoints = [
  'Started in an RV on a generator — $30/day in gas, 35-degree heat',
  'One year of daily printing, failing, and building until the work spoke for itself',
  "Prusa Research recognized that commitment — they're sending their flagship machine",
  'High-performance materials as standard: PETG-CF, ASA, annealed PLA, UV compounds',
  'Every part reviewed, processed, and tested before it ships',
];

const deploymentParagraphs = [
  "Ken's first sail was a duo passage with CSM — Halifax, Nova Scotia to Antigua. No experience. They hit a cat-one storm: 70-knot winds, 90-knot gusts. No turning back. That passage taught him everything that matters about what breaks, why it breaks, and what you have to accept when there is no option to stop.",
  'Since then: transatlantics, the Rolex Fastnet Race, two days solo up the Saint John River. The offshore experience is real, and it informs everything built at 3D3D.',
  "For the 2026 Newport Bermuda Race — the 120th running — Ken is sailing aboard CSM's boat with a Prusa CORE One L printing live onboard. This is not a sponsorship. It is proof: real parts, real problems, real conditions, no fallback.",
];

const deploymentPhotos = [
  {
    src: '/media/real/sunrise-offshore.jpg',
    alt: 'Sunrise offshore before a race day',
    caption: 'Daybreak before the system gets tested.',
  },
  {
    src: '/media/real/helm-close.jpg',
    alt: 'Close-up at the helm under load',
    caption: 'Helm time is where failure stops being theoretical.',
  },
  {
    src: '/media/real/coastal-landmark.jpg',
    alt: 'Coastal landmark at the edge of a passage',
    caption: 'Landfall is where the tolerances have to be right.',
  },
];

const workBands = [
  {
    label: 'Standard',
    intro: 'One-off requests and production needs',
    body: 'Standard queue placement, fabrication review, dimensional confirmation, and global shipping.',
    cta: 'Request a build →',
    href: '/contact',
  },
  {
    label: 'Priority',
    intro: 'Clients who need faster response and preferred scheduling',
    body: 'Accelerated turnaround, direct communication, priority queue position, and material confirmation before print. Also directly supports the 3D3D mission and operational expansion.',
    cta: 'Get priority access →',
    href: '/contact',
  },
  {
    label: 'Expedition & Retained Support',
    intro: 'Long-term partners and serious operators',
    body: 'Retained fabrication access, project involvement, concierge-level support, regular field updates, and recognition on the campaign. Direct access to the founder on every engagement. This is not a subscription. It is an operational relationship.',
    cta: 'Become a patron →',
    href: '/contact',
    featured: true,
  },
];

const openBuildParagraphs = [
  '3D3D is built on open tools, open hardware, and open community values. The repository is open. The knowledge is shared. If you want the file, you can have the file.',
];

const openResources = [
  {
    label: 'Printable Designs',
    explanation: 'Browse functional parts, tested objects, and open files available for download on Printables.',
    href: 'https://www.printables.com/@KTK3D_3050116',
    display: 'printables.com/@KTK3D_3050116',
    image: '/media/real/dawn-approach.jpg',
  },
  {
    label: 'Support the Work',
    explanation: "Ko-fi is where you can directly support 3D3D's operational costs, campaign prep, and open-source contributions. This is not a shop. It is a direct line.",
    href: 'https://ko-fi.com/3d3dca',
    display: 'ko-fi.com/3d3dca',
  },
  {
    label: 'GitHub',
    explanation: 'Code, tooling, and documentation published openly as the operation grows.',
    href: 'https://github.com/3d3dcanada/3d3d-main',
    display: 'github.com/3d3dcanada/3d3d-main',
  },
];

const partners = [
  {
    name: 'Prusa Research',
    context: '3D3D has operated on the Prusa ecosystem since day one. After a year of documented work and demonstrated commitment, Prusa Research is sending a CORE One L — their flagship machine. That is not a marketing arrangement. That is a recognition of output.',
    cta: 'About Prusa →',
    href: 'https://prusa3d.com',
    external: true,
    image: '/media/workshop/printer-action-cf.jpg',
    alt: 'Carbon-fibre print running in the Prusa-aligned production workflow',
  },
  {
    name: 'Christopher Stanmore-Major',
    context: "Captain, offshore sailor, and the reason Ken ever stepped on a boat. CSM sponsored Ken's place aboard for the 2026 Newport Bermuda Race and is the operational partner for the live deployment. He is not a client. He is a collaborator.",
    cta: 'The 2026 campaign →',
    href: '/blog',
    image: '/media/real/helm-close.jpg',
    alt: 'Christopher Stanmore-Major at the helm',
  },
  {
    name: 'Sponsorship & Partnership',
    context: 'One slot available for campaign alignment, equipment partnership, or brand presence on the Newport Bermuda deployment. This is an offshore race. This is live printing. This is real proof.',
    cta: 'Talk to us →',
    href: '/contact',
    image: '/media/real/golden-hour-02.jpg',
    alt: 'Golden-hour offshore sailing during campaign conditions',
    overlay: true,
  },
];
---

<BaseLayout
  title="3D3D | Precision fabrication for marine, automotive, and field deployment"
  description="3D3D builds functional parts for boats, cars, and anything else that needs to work under real conditions. Founder-operated out of Fredericton, NB."
  schema={orgSchema}
  activePath="/"
  navGroups={homeNavGroups}
  bodyClass="home-editorial"
>
  <div class="home-page">
    <section id="home" class="home-section home-section--dark home-hero" data-reveal-section>
      <div class="section-shell hero-shell">
        <div class="hero-copy">
          <p class="eyebrow hero-eyebrow">Precision Fabrication · Marine · Automotive · Custom</p>
          <h1 class="hero-title" aria-label="You have a problem. We have a printer.">
            <span class="hero-line">You have a problem.</span>
            <span class="hero-line">We have a printer.</span>
          </h1>
          <p class="hero-subhead">
            3D3D builds functional parts for boats, cars, and anything else that needs to work under real conditions. Marine fittings, automotive replacements, custom components that don't exist yet. Open-source at the core. Built from nothing but stubbornness and a generator.
          </p>
          <div class="hero-actions">
            <a href="/contact" class="hero-button hero-button--primary">Request Service →</a>
            <a href="/blog" class="hero-button hero-button--ghost">Follow the Campaign →</a>
          </div>
          <ul class="hero-proof-rail" aria-label="3D3D proof points">
            {heroProofRail.map((item, index) => (
              <li class="hero-proof-item" style={`animation-delay: ${0.4 + index * 0.08}s;`}>
                <span class="hero-proof-dot" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="hero-media">
          <div class="hero-video-frame">
            <video
              class="hero-video"
              src="/media/hero-loop.mp4"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster="/media/real/race-morning-crew.jpg"
              aria-label="3D3D deployment video reel"
            ></video>
          </div>
        </div>
      </div>

      <div class="section-shell hero-stats-shell">
        <div class="hero-stats">
          {heroStats.map((stat, index) => (
            <article class="hero-stat-card" style={`animation-delay: ${0.5 + index * 0.1}s;`}>
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="services" class="home-section home-section--light services-section" data-reveal-section aria-labelledby="services-label">
      <h2 id="services-label" class="sr-only">Services</h2>
      <div class="section-shell services-shell">
        {services.map((service, index) => (
          <article class:list={['service-module', index % 2 === 1 && 'service-module--reverse']}>
            <div
              class:list={[
                'service-module__media',
                'mask-wipe',
                index % 2 === 0 ? 'mask-wipe-left' : 'mask-wipe-right',
              ]}
              data-reveal
            >
              <img src={service.image} alt={service.alt} loading="lazy" decoding="async" />
            </div>

            <div class="service-module__content">
              <div class:list={['service-module__text', index % 2 === 0 ? 'reveal-right' : 'reveal-left']} data-reveal>
                <p class="eyebrow reveal-left" data-reveal>{service.eyebrow}</p>
                <p class="service-module__stakes reveal-up delay-1" data-reveal>{service.stakes}</p>
                <p class="service-module__body reveal-fade delay-2" data-reveal>{service.body}</p>
                <ul class="service-module__bullets" aria-label={`${service.eyebrow} capabilities`}>
                  {service.bullets.map((bullet, bulletIndex) => (
                    <li class="reveal-left" data-reveal style={`transition-delay: ${0.12 + bulletIndex * 0.06}s;`}>
                      {bullet}
                    </li>
                  ))}
                </ul>
                <button
                  type="button"
                  class="service-module__cta reveal-up delay-3"
                  data-reveal
                  data-drawer-trigger
                  data-drawer-id={service.drawerId}
                >
                  {service.cta}
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="origin" class="home-section home-section--dark origin-section" data-reveal-section>
      <div class="section-shell origin-shell">
        <div class="origin-grid">
          <div class="origin-photo mask-wipe mask-wipe-left" data-reveal>
            <img src="/media/workshop/rv-lab-02.jpg" alt="The RV fabrication setup that started 3D3D" loading="lazy" decoding="async" />
          </div>

          <div class="origin-copy">
            <p class="eyebrow reveal-left" data-reveal>Where this started</p>
            <h2 class="section-title section-title--light reveal-up" data-reveal>
              An RV, a generator,
              <br />
              and every reason to quit.
            </h2>

            {originParagraphs.map((paragraph, index) => (
              <p class:list={['section-body', 'section-body--light', 'reveal-fade', index > 0 && `delay-${index}`]} data-reveal>
                {paragraph}
              </p>
            ))}

            <ul class="proof-list" aria-label="Origin proof points">
              {originProofPoints.map((point, index) => (
                <li class="reveal-left" data-reveal style={`transition-delay: ${0.12 + index * 0.08}s;`}>
                  <span class="proof-dot" aria-hidden="true"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="origin-inset mask-wipe mask-wipe-left" data-reveal>
          <img src="/media/workshop/rv-lab-03.jpg" alt="Close look at the RV lab with multiple printers running" loading="lazy" decoding="async" />
        </div>
      </div>
    </section>

    <section id="deployment" class="home-section home-section--dark deployment-section" data-reveal-section>
      <div class="section-bg section-bg--photo" data-parallax="0.4" style="background-image: url('/media/real/fleet-running.jpg');"></div>
      <div class="section-shell deployment-shell">
        <div class="deployment-copy">
          <p class="eyebrow reveal-left" data-reveal>2026 Newport Bermuda Race — 120th Anniversary</p>
          <h2 class="deployment-title" aria-label="A fabrication studio in motion.">
            <span class="word-reveal" data-reveal>A</span>
            <span class="word-reveal" data-reveal style="transition-delay: 0.1s;">fabrication</span>
            <span class="word-reveal" data-reveal style="transition-delay: 0.2s;">studio</span>
            <br />
            <span class="word-reveal" data-reveal style="transition-delay: 0.3s;">in</span>
            <span class="word-reveal" data-reveal style="transition-delay: 0.4s;">motion.</span>
          </h2>

          {deploymentParagraphs.map((paragraph, index) => (
            <p class:list={['section-body', 'section-body--light', 'reveal-fade', index > 0 && `delay-${index}`]} data-reveal>
              {paragraph}
            </p>
          ))}

          <a href="/blog" class="hero-button hero-button--ghost reveal-up delay-3" data-reveal>Follow the campaign →</a>
        </div>

        <div class="deployment-strip" aria-label="Campaign photo strip">
          {deploymentPhotos.map((photo, index) => (
            <figure class="deployment-card reveal-scale" data-reveal style={`transition-delay: ${0.1 + index * 0.12}s;`}>
              <div class="deployment-card__media">
                <img src={photo.src} alt={photo.alt} loading="lazy" decoding="async" />
              </div>
              <figcaption>{photo.caption}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section id="support" class="home-section home-section--light work-section" data-reveal-section aria-labelledby="support-label">
      <h2 id="support-label" class="sr-only">How to work with 3D3D</h2>
      <div class="section-shell work-shell">
        {workBands.map((band, index) => (
          <article class:list={['work-band', band.featured && 'work-band--featured', 'reveal-left']} data-reveal style={`transition-delay: ${index * 0.12}s;`}>
            {band.featured && (
              <div class="work-band__image" aria-hidden="true">
                <img src="/media/real/golden-hour-01.jpg" alt="" loading="lazy" decoding="async" />
              </div>
            )}

            <div class="work-band__content">
              <p class="work-band__label">{band.label}</p>
              <div class="work-band__meta">
                <p><span>For:</span> {band.intro}</p>
                <p><span>What you get:</span> {band.body}</p>
              </div>
              <a href={band.href} class:list={['work-band__cta', band.featured && 'work-band__cta--featured']}>
                {band.cta}
              </a>
            </div>
          </article>
        ))}

        <div class="partner-band reveal-up" data-reveal>
          <div>
            <p class="partner-band__label">Partnerships & Sponsorships</p>
            <p class="partner-band__body">
              For brands, marine organizations, event sponsors, and media partners. Contact us to discuss campaign alignment, product placement, or equipment partnerships.
            </p>
          </div>
          <a href="/contact" class="partner-band__cta">Partner with 3D3D →</a>
        </div>
      </div>
    </section>

    <section id="open-build" class="home-section home-section--light open-build-section" data-reveal-section>
      <div class="section-shell open-build-shell">
        <div class="open-build-copy">
          <p class="eyebrow reveal-left" data-reveal>Open-source at the core</p>
          <h2 class="section-title reveal-up" data-reveal>
            The ecosystem matters
            <br />
            more than the lock-in.
          </h2>
          {openBuildParagraphs.map((paragraph) => (
            <p class="section-body reveal-fade delay-1" data-reveal>{paragraph}</p>
          ))}
        </div>

        <div class="resource-grid">
          {openResources.map((resource, index) => (
            <a
              href={resource.href}
              class:list={[
                'resource-card',
                index === 0 && 'resource-card--photo',
                index > 0 && 'resource-card--dark',
                'reveal-right',
              ]}
              target="_blank"
              rel="noopener noreferrer"
              data-reveal
              style={[
                resource.image ? `--resource-image: url('${resource.image}');` : '',
                `transition-delay: ${index * 0.1}s;`,
              ].join(' ')}
            >
              <span class="resource-card__label">{resource.label}</span>
              <p>{resource.explanation}</p>
              <span class="resource-card__link">{resource.display}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="partners" class="home-section home-section--dark partners-section" data-reveal-section aria-labelledby="partners-label">
      <h2 id="partners-label" class="sr-only">Partners</h2>
      <div class="section-shell partners-shell">
        <div class="partner-grid">
          {partners.map((partner, index) => (
            <article class="partner-card reveal-scale" data-reveal style={`transition-delay: ${index * 0.12}s;`}>
              <div class:list={['partner-card__media', partner.overlay && 'partner-card__media--overlay']}>
                <img src={partner.image} alt={partner.alt} loading="lazy" decoding="async" />
              </div>
              <div class="partner-card__body">
                <h3>{partner.name}</h3>
                <p>{partner.context}</p>
                <a
                  href={partner.href}
                  class="partner-card__cta"
                  target={partner.external ? '_blank' : undefined}
                  rel={partner.external ? 'noopener noreferrer' : undefined}
