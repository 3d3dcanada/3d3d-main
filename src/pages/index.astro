---
import BaseLayout from '../layouts/BaseLayout.astro';
import SplashOrbit from '../components/SplashOrbit';
---

<BaseLayout
  title="3D3D | Custom 3D Printing, Marine Fabrication & Field Services"
  description="Custom 3D printing, marine fabrication, reverse engineering, and field-ready fabrication services from 3D3D. Explore the market, services, network, learning, and founder story."
  noFooter
  noSidebar
  noMobileCTA
  noFeedbackBlip
  bodyClass="splash-page"
>
  <script is:inline>
    (() => {
      document.body.dataset.splashTheme = 'dark';
    })();
  </script>

  <section id="home" class="splash-home" data-section>
    <SplashOrbit client:load />
  </section>

  <section class="splash-nav-section surface-panel">
    <div class="splash-nav-container">
      <div class="splash-nav-grid">
        <a href="/services" class="splash-nav-item splash-nav-item--primary">Services</a>
        <a href="/quote" class="splash-nav-item">Get a Quote</a>
        <a href="/materials" class="splash-nav-item">Materials</a>
        <a href="/shop" class="splash-nav-item">Shop</a>
        <a href="/about" class="splash-nav-item">About</a>
        <a href="/opportunities" class="splash-nav-item">Network</a>
        <a href="/media" class="splash-nav-item">Media</a>
        <a href="/blog" class="splash-nav-item">Blog</a>
      </div>
    </div>
  </section>

  <!-- Not the cheap option hook -->
  <section class="splash-hook">
    <div class="splash-hook__inner">
      <div class="splash-hook__left">
        <p class="splash-hook__label">Who we're for</p>
        <h2 class="splash-hook__title">Not the cheap option.<br />The right one.</h2>
        <p class="splash-hook__body">
          If you need a fast commodity print in PLA, we'll point you to services that do it better and cheaper than us. If your part doesn't exist anymore, if it failed offshore, if the machining quote came back at $6,000 — that's our kind of job.
        </p>
        <div class="splash-hook__actions">
          <a href="/services" class="splash-hook__cta">See what we do →</a>
          <a href="/services#competitors" class="splash-hook__link">Cheaper options →</a>
        </div>
      </div>
      <div class="splash-hook__right">
        <div class="splash-hook__stat-row">
          <div class="splash-hook__stat">
            <span class="splash-hook__stat-val">$6k+</span>
            <span class="splash-hook__stat-key">Saved on a single marine job</span>
          </div>
          <div class="splash-hook__stat">
            <span class="splash-hook__stat-val">24h</span>
            <span class="splash-hook__stat-key">On-site deployment</span>
          </div>
        </div>
        <div class="splash-hook__pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 3L2 8l10 5 10-5-10-5z"/><path d="M2 16l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          Marine · Automotive · Industrial
        </div>
        <div class="splash-hook__pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          Retainer from $100/month
        </div>
        <div class="splash-hook__pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          Atlantic Canada · Worldwide shipping
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .splash-nav-section {
    padding-block: 4rem;
    border-top: 1px solid var(--color-border-subtle);
  }
  .splash-nav-container {
    width: min(100% - 3rem, 1200px);
    margin: 0 auto;
  }
  .splash-nav-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 1rem;
  }
  .splash-nav-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 1rem;
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: 2px;
    font-family: var(--font-tech);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .splash-nav-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    border-color: var(--color-teal-primary);
    color: var(--color-teal-primary);
  }
  .splash-nav-item--primary {
    border-color: var(--color-teal-primary);
    color: var(--color-teal-primary);
  }

  /* ── Hook section ── */
  .splash-hook {
    border-top: 1px solid var(--color-border-subtle);
    padding-block: clamp(3rem, 6vw, 5rem);
  }
  .splash-hook__inner {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 1200px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .splash-hook__label {
    font-family: var(--font-tech);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-teal-primary);
    margin-bottom: 0.75rem;
  }
  .splash-hook__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin-bottom: 1.25rem;
  }
  .splash-hook__body {
    color: var(--color-text-secondary);
    line-height: 1.7;
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    max-width: 52ch;
    margin-bottom: 2rem;
  }
  .splash-hook__actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .splash-hook__cta {
    padding: 0.8rem 1.6rem;
    background: var(--color-teal-primary);
    color: #fff;
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .splash-hook__cta:hover { background: var(--color-teal-dark); }
  .splash-hook__link {
    font-family: var(--font-tech);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .splash-hook__link:hover { color: var(--color-text-secondary); }
  .splash-hook__right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .splash-hook__stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border-default);
    border: 1px solid var(--color-border-default);
    margin-bottom: 0.5rem;
  }
  .splash-hook__stat {
    background: var(--color-surface-secondary);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .splash-hook__stat-val {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-teal-primary);
    line-height: 1;
  }
  .splash-hook__stat-key {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.35;
  }
  .splash-hook__pill {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1rem;
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    font-family: var(--font-tech);
  }
  .splash-hook__pill svg { stroke: var(--color-teal-primary); flex-shrink: 0; }

  @media (max-width: 800px) {
    .splash-hook__inner { grid-template-columns: 1fr; }
    .splash-hook__right { display: none; }
  }
</style>
