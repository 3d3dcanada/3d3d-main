    transform: scale(1.03);
  }

  .workshop-card figcaption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.2rem;
    background: linear-gradient(0deg, rgba(17, 18, 20, 0.88), transparent);
    display: grid;
    gap: 0.2rem;
  }

  .workshop-card__label {
    font-family: var(--font-tech);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--page-accent);
  }

  .workshop-card__note {
    font-size: 0.82rem;
    line-height: 1.4;
    color: rgba(246, 247, 250, 0.7);
  }

  .workshop-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(64, 196, 196, 0.2);
  }

  .workshop-stat {
    display: grid;
    gap: 0.3rem;
  }

  .workshop-stat__value {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.4rem + 2vw, 3rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--page-accent);
  }

  .workshop-stat__label {
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.5);
  }

  @media (max-width: 640px) {
    .workshop-grid {
      grid-template-columns: 1fr;
    }
    .workshop-card--hero {
      grid-row: auto;
    }
  }

  /* ═══════════════════════════════════════════════════
     CONTACT (FINAL CTA)
     ═══════════════════════════════════════════════════ */
  .final-cta-shell { text-align: center; }

  .final-cta-copy {
    display: grid;
    gap: 1.5rem;
    justify-items: center;
    max-width: 52rem;
    margin: 0 auto;
  }

  .final-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .final-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.4rem;
    padding: 0.95rem 1.55rem;
    border: var(--page-thick-border);
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .final-cta-button:hover { transform: translateY(-2px) scale(1.02); }

  .final-cta-button--light {
    background: #FFFFFF;
    color: #1A1A1A;
    border-color: #1A1A1A;
  }

  .final-cta-button--light:hover {
    background: #F6F7FA;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .final-cta-button--ghost {
    border-color: #FFFFFF;
    color: #FFFFFF;
    background: transparent;
  }

  .final-cta-button--ghost:hover { background: rgba(255, 255, 255, 0.12); }

  /* ═══════════════════════════════════════════════════
     DRAWER
     ═══════════════════════════════════════════════════ */
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: flex-end;
    pointer-events: none;
  }

  .drawer[data-open='true'] { pointer-events: all; }

  .drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 18, 20, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .drawer[data-open='true'] .drawer__backdrop { opacity: 1; }

  .drawer__panel {
    position: relative;
    width: min(420px, 92vw);
    height: 100%;
    background: var(--page-bg-dark);
    border-left: 3px solid var(--page-accent);
    overflow-y: auto;
    padding: 2rem 1.5rem;
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .drawer[data-open='true'] .drawer__panel { transform: translateX(0); }

  .drawer__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--page-accent);
    background: transparent;
    color: #F6F7FA;
    font-size: 1.1rem;
    cursor: pointer;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .drawer__close:hover { background: var(--page-accent); color: #0F1112; }

  :global(.drawer-copy) {
    display: grid;
    gap: 1.2rem;
    color: #F6F7FA;
    padding-top: 1rem;
  }

  :global(.drawer-copy__eyebrow) {
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--page-accent);
  }

  :global(.drawer-copy__title) {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.05;
    color: #F6F7FA;
  }

  :global(.drawer-copy__stakes) {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.65;
    color: rgba(246, 247, 250, 0.78);
  }

  :global(.drawer-copy__gallery) { display: grid; gap: 0.6rem; }

  :global(.drawer-copy__gallery figure) {
    margin: 0;
    overflow: hidden;
    border: 2px solid #1A1A1A;
    border-radius: 0.8rem;
  }

  :global(.drawer-copy__gallery img) {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  :global(.drawer-copy__notes) {
    display: grid;
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(64, 196, 196, 0.2);
  }

  :global(.drawer-copy__notes span) {
    display: block;
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--page-accent);
    margin-bottom: 0.3rem;
  }

  :global(.drawer-copy__notes p) {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.6;
    color: rgba(246, 247, 250, 0.78);
  }

  :global(.drawer-copy__cta) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.2rem;
    background: var(--page-accent);
    color: #0F1112;
    border: 2px solid #1A1A1A;
    font-family: var(--font-tech);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: all 0.25s ease;
    width: 100%;
    text-align: center;
  }

  :global(.drawer-copy__cta:hover) {
    background: #53D3D3;
    transform: translateY(-2px);
  }

  /* ═══════════════════════════════════════════════════
     CAMPAIGN STRIP
     ═══════════════════════════════════════════════════ */

  /* Wrapper */
  .cstrip {
    background: #0A0B0C;
    border-top: 3px solid #40C4C4;
    overflow: hidden;
    position: relative;
  }

  /* Header bar */
  .cstrip__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 1.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .cstrip__label {
    font-family: 'Courier New', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(246,247,250,0.3);
  }

  .cstrip__status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #40C4C4;
  }

  .cstrip__pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #40C4C4;
    box-shadow: 0 0 0 0 rgba(64,196,196,0.6);
    animation: cstrip-pulse 2s ease-in-out infinite;
  }

  @keyframes cstrip-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(64,196,196,0.7); }
    70%  { box-shadow: 0 0 0 8px rgba(64,196,196,0); }
    100% { box-shadow: 0 0 0 0 rgba(64,196,196,0); }
  }

  /* Rail — horizontal scroll */
  .cstrip__rail {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .cstrip__rail::-webkit-scrollbar { display: none; }

  /* Cell base */
  .cstrip__cell {
    flex: 1 0 220px;
    position: relative;
    display: block;
    border: none;
    border-right: 1px solid rgba(255,255,255,0.05);
    background: transparent;
    color: #F6F7FA;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    text-decoration: none;
    transition: background 0.22s ease;
    min-width: 0;
  }

  .cstrip__cell:hover { background: rgba(255,255,255,0.035); }

  /* Colored top accent bar (full-width bar at very top of cell) */
  .cstrip__cell-accent {
    height: 3px;
    width: 100%;
  }
  .cstrip__cell-accent--teal   { background: #40C4C4; }
  .cstrip__cell-accent--orange { background: #FA6831; }
  .cstrip__cell-accent--ghost  { background: transparent; border-top: 1px dashed rgba(64,196,196,0.25); }

  /* Two-col inner layout */
  .cstrip__cell-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 1.1rem 1.4rem 1.25rem;
  }

  /* Left column: badge → date → title → sub */
  .cstrip__cell-left {
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
    min-width: 0;
  }

  /* Status badges */
  .cstrip__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Courier New', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.18rem 0.5rem;
    border-radius: 2px;
    width: fit-content;
  }
  .cstrip__badge--done     { background: rgba(64,196,196,0.12);  color: #40C4C4; }
  .cstrip__badge--upcoming { background: rgba(64,196,196,0.08);  color: rgba(64,196,196,0.8); border: 1px solid rgba(64,196,196,0.25); }
  .cstrip__badge--open     { background: transparent; color: rgba(246,247,250,0.3); border: 1px dashed rgba(246,247,250,0.15); }

  /* Date */
  .cstrip__date {
    font-family: 'Courier New', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(246,247,250,0.35);
  }

  /* Title */
  .cstrip__title {
    font-family: var(--font-display, 'Archivo', sans-serif);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: #F6F7FA;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cstrip__title--ghost {
    color: rgba(246,247,250,0.2);
    font-weight: 700;
    letter-spacing: 0.04em;
    font-size: 0.88rem;
  }
  .cstrip__cell--open:hover .cstrip__title--ghost { color: rgba(246,247,250,0.45); }

  /* Sub */
  .cstrip__sub {
    font-family: var(--font-tech, 'Archivo', sans-serif);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(246,247,250,0.32);
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cstrip__sub--ghost { color: rgba(246,247,250,0.15); }

  /* Right column: logo or image + expand arrow */
  .cstrip__cell-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .cstrip__logo {
    height: 24px;
    width: auto;
    max-width: 80px;
    opacity: 0.55;
    filter: brightness(0) invert(1);
    transition: opacity 0.2s ease;
    object-fit: contain;
  }
  .cstrip__cell:hover .cstrip__logo { opacity: 0.9; }

  .cstrip__logo--prusa {
    filter: none;
    opacity: 0.65;
  }

  /* Fleet image inside featured cell */
  .cstrip__img {
    width: 80px;
    height: 56px;
    object-fit: cover;
    border: 2px solid rgba(255,255,255,0.12);
    display: block;
    flex-shrink: 0;
  }

  .cstrip__expand {
    font-size: 0.75rem;
    color: rgba(64,196,196,0.45);
    font-family: 'Courier New', monospace;
    transition: color 0.2s ease, transform 0.2s ease;
    display: block;
  }
  .cstrip__cell:hover .cstrip__expand { color: #40C4C4; transform: translate(2px,-2px); }
  .cstrip__expand--ghost { color: rgba(246,247,250,0.2); }
  .cstrip__cell--open:hover .cstrip__expand--ghost { color: rgba(64,196,196,0.7); }

  .cstrip__open-icon {
    font-size: 1.6rem;
    font-weight: 300;
    color: rgba(64,196,196,0.25);
    line-height: 1;
    transition: color 0.2s ease;
  }
  .cstrip__cell--open:hover .cstrip__open-icon { color: rgba(64,196,196,0.55); }

  /* Featured cell: wider */
  .cstrip__cell--featured { flex: 2 0 300px; }

  /* Open slot cell */
  .cstrip__cell--open {
    border-right: 1px dashed rgba(64,196,196,0.1);
  }
  .cstrip__cell--open .cstrip__cell-accent--ghost {
    border-top: 1px dashed rgba(64,196,196,0.18);
    height: 0;
  }

  /* Progress track */
  .cstrip__track {
    height: 2px;
    background: rgba(255,255,255,0.05);
  }
  .cstrip__track-fill {
    height: 100%;
    width: 66%;
    background: linear-gradient(90deg, #40C4C4, rgba(64,196,196,0.4));
  }

  @media (max-width: 700px) {
    .cstrip__cell { flex: 0 0 200px; }
    .cstrip__cell--featured { flex: 0 0 260px; }
    .cstrip__cell-inner { padding: 0.9rem 1rem 1rem; gap: 0.5rem; }
    .cstrip__img { width: 60px; height: 42px; }
  }

  /* ═══════════════════════════════════════════════════
     TIMELINE MODALS  (.tm)
     ═══════════════════════════════════════════════════ */

  .tm {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    pointer-events: none;
  }
  .tm[data-open='true'] { pointer-events: all; }

  .tm__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8,10,11,0.88);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 0.28s ease;
    cursor: pointer;
  }
  .tm[data-open='true'] .tm__backdrop { opacity: 1; }

  .tm__panel {
    position: relative;
    z-index: 1;
    background: #FFFFFF;
    color: #111214;
    border: 3px solid #111214;
    border-radius: 0;
    max-width: 560px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    transform: scale(0.93) translateY(20px);
    opacity: 0;
    transition: transform 0.34s cubic-bezier(0.16,1,0.3,1), opacity 0.28s ease;
    scrollbar-width: thin;
    scrollbar-color: #111214 transparent;
  }
  .tm__panel--wide { max-width: 700px; }
  .tm[data-open='true'] .tm__panel { transform: scale(1) translateY(0); opacity: 1; }

  /* Close button */
  .tm__close {
    position: absolute;
    top: 0;
    right: 0;
    width: 2.6rem;
    height: 2.6rem;
    background: #111214;
    border: none;
    color: #F6F7FA;
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.18s ease;
    z-index: 2;
  }
  .tm__close:hover { background: #40C4C4; color: #111214; }

  /* Colored head band */
  .tm__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.4rem;
    padding-right: 3.5rem;
  }
  .tm__head--teal   { background: #111214; border-bottom: 3px solid #40C4C4; }
  .tm__head--orange { background: #111214; border-bottom: 3px solid #FA6831; }

  .tm__head-date {
    font-family: 'Courier New', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(246,247,250,0.55);
  }

  .tm__head-tag {
    font-family: 'Courier New', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #40C4C4;
    border: 1px solid rgba(64,196,196,0.4);
    padding: 0.2rem 0.5rem;
  }

  .tm__head-logo {
    height: 26px;
    width: auto;
    max-width: 100px;
    filter: brightness(0) invert(1);
    opacity: 0.85;
    object-fit: contain;
  }

  /* Photo strip (Newport modal) */
  .tm__photo-strip {
    height: 200px;
    overflow: hidden;
    border-bottom: 3px solid #111214;
  }
  .tm__photo-strip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Body */
  .tm__body {
    padding: 1.6rem 1.8rem 2rem;
  }

  .tm__title {
    font-family: var(--font-display, 'Archivo', sans-serif);
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    text-transform: uppercase;
    color: #111214;
    margin: 0 0 0.3rem;
    line-height: 1.0;
  }

  .tm__location {
    font-family: 'Courier New', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(17,18,20,0.4);
    margin: 0 0 1.2rem;
  }

  .tm__text {
    font-size: 0.95rem;
    line-height: 1.78;
    color: rgba(17,18,20,0.72);
    margin: 0 0 1rem;
    border-top: 1px solid rgba(17,18,20,0.08);
    padding-top: 1.2rem;
  }
  .tm__text:first-of-type { border-top: none; padding-top: 0; }

  /* Facts grid */
  .tm__facts {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 2px solid #111214;
    margin: 1.4rem 0;
  }

  .tm__fact {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 0.6rem 0.8rem;
    gap: 0.25rem;
    border-right: 2px solid #111214;
  }
  .tm__fact:last-child { border-right: none; }

  .tm__fact-val {
    font-family: var(--font-display, 'Archivo', sans-serif);
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #111214;
    line-height: 1;
  }

  .tm__fact-key {
    font-family: 'Courier New', monospace;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(17,18,20,0.4);
    text-align: center;
  }

  /* Links */
  .tm__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.6rem;
  }

  .tm__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1rem;
    background: transparent;
    color: #111214;
    border: 2px solid rgba(17,18,20,0.2);
    font-family: var(--font-tech, 'Archivo', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .tm__cta:hover { background: rgba(17,18,20,0.05); border-color: #111214; transform: translateY(-1px); }

  .tm__cta--primary {
    background: #111214;
    color: #F6F7FA;
    border-color: #111214;
  }
  .tm__cta--primary:hover { background: #2a2b2d; }

  .tm__cta--orange {
    background: #FA6831;
    color: #FFFFFF;
    border-color: #FA6831;
  }
  .tm__cta--orange:hover { background: #e85e2a; border-color: #e85e2a; }

  @media (max-width: 520px) {
    .tm__facts { grid-template-columns: repeat(2, 1fr); }
    .tm__fact:nth-child(2) { border-right: none; }
    .tm__fact:nth-child(3) { border-top: 2px solid #111214; }
    .tm__fact:nth-child(4) { border-top: 2px solid #111214; border-right: none; }
    .tm__title { font-size: 1.5rem; }
  }

  /* ═══════════════════════════════════════════════════
     LIGHTBOX
     ═══════════════════════════════════════════════════ */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .lightbox[data-open='true'] { pointer-events: all; }

  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 17, 18, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 0.28s ease;
    cursor: pointer;
  }

