---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
---

<BaseLayout title="Opportunities | 3D3D" description="Work with 3D3D. Real positions, real pay. See what's open." activePath="/opportunities">

  <section class="opp-page">
    <div class="opp-shell">
      <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'The Network', href: '/opportunities'}, {label: 'Opportunities'}]} />
      <p class="opp-eyebrow">Opportunities</p>
      <h1 class="opp-title">Work with 3D3D</h1>
      <p class="opp-intro">
        3D3D is growing. These are real positions, not volunteer calls. If the work fits, reach out.
      </p>

      <div class="opp-listing surface-panel">
        <div class="opp-listing__header">
          <h2 class="opp-listing__role">Social Media Intern</h2>
          <div class="opp-listing__meta">
            <span>Remote / route-based travel</span>
            <span>Part-time, paid</span>
          </div>
        </div>
        <div class="opp-listing__body">
          <p>Film and produce content: video, photo, social posts. Cover 3D3D operations, builds, and events. Potential travel for events and deployments.</p>
          <p class="opp-listing__tone">You get what you put into it.</p>
        </div>
        <a href="/contact?subject=social-media-intern" class="opp-cta">Apply →</a>
      </div>

      <div class="opp-listing surface-panel">
        <div class="opp-listing__header">
          <h2 class="opp-listing__role">Fabrication Node Operator</h2>
          <div class="opp-listing__meta">
            <span>Remote / Distributed</span>
            <span>Contract / Revenue Share</span>
          </div>
        </div>
        <div class="opp-listing__body">
          <p>Operate as a verified 3D3D fabrication node. Receive over-flow print jobs, localized production requests, and participate in distributed manufacturing. Must run high-uptime engineering-grade FDM hardware and pass material validation tests.</p>
          <p class="opp-listing__tone">Build your own shop under the cooperative banner.</p>
        </div>
        <a href="/contact?subject=node-operator" class="opp-cta">Join the Network →</a>
      </div>

      <div class="opp-listing surface-panel">
        <div class="opp-listing__header">
          <h2 class="opp-listing__role">Open Source Contributor</h2>
          <div class="opp-listing__meta">
            <span>Global</span>
            <span>Community-Driven</span>
          </div>
        </div>
        <div class="opp-listing__body">
          <p>Help build the open-source infrastructure. We need Astro/TypeScript developers, 3D modelers (Fusion360/Onshape), and documentation writers to expand the 3D3D codebases and parametric model libraries.</p>
          <p class="opp-listing__tone">Everything we build is shared. Come build it with us.</p>
        </div>
        <a href="https://github.com/3d3dcanada" target="_blank" rel="noopener noreferrer" class="opp-cta">View Repositories →</a>
      </div>

      <PageNextActions actions={[
        {label: 'About 3D3D', href: '/about', description: 'Learn the cooperative philosophy behind the network.', accent: 'teal'},
        {label: 'Contact', href: '/contact', description: 'Get in touch to discuss opportunities.', accent: 'magenta'},
      ]} />
    </div>
  </section>
</BaseLayout>

<style>
  .opp-page {
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: var(--color-surface-primary);
    color: var(--color-text-primary);
  }

  .opp-shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 720px);
    margin: 0 auto;
    display: grid;
    gap: 2rem;
    padding-block: clamp(6rem, 10vw, 10rem);
  }

  .opp-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .opp-eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: var(--color-teal-primary);
    flex-shrink: 0;
  }

  .opp-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 4vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    text-transform: uppercase;
  }

  .opp-intro {
    margin: 0;
    max-width: 36rem;
    font-size: clamp(1.05rem, 0.95rem + 0.4vw, 1.2rem);
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .opp-listing {
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .opp-listing__header {
    display: grid;
    gap: 0.6rem;
  }

  .opp-listing__role {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1rem + 1.5vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .opp-listing__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.4rem;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
  }

  .opp-listing__body {
    display: grid;
    gap: 0.8rem;
  }

  .opp-listing__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .opp-listing__tone {
    font-style: italic;
    color: var(--color-text-muted) !important;
  }

  .opp-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.4rem;
    padding: 0.95rem 1.6rem;
    background: var(--color-teal-primary);
    color: #0F1112;
    border: 3px solid var(--color-text-primary);
    border-radius: 2px;
    font-family: var(--font-tech);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: background-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    box-shadow: 0 14px 32px rgba(64, 196, 196, 0.22);
  }

  .opp-cta:hover {
    background: #53D3D3; /* teal hover state */
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.4);
    transform: translateY(-2px);
  }
</style>
