---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const packages = [
  {
    name: 'Supporter',
    price: '$10 / month CAD',
    desc: 'Support the open-source mission and get early access.',
    features: [
      'Name on Supporter Wall',
      'Early Blog Access',
      'Community Discord Access',
    ],
    actionText: 'Become a Supporter',
    actionHref: '/pricing',
  },
  {
    name: 'Partner',
    price: '$50 / month CAD',
    desc: 'For local businesses and tech companies backing the network.',
    features: [
      'Everything in Supporter',
      'Logo on event banners & website',
      'Social media shoutouts',
      'Voting rights on build priorities',
      'Featured in event photography',
    ],
    actionText: 'Become a Partner',
    actionHref: '/pricing',
    isPrimary: true,
  },
  {
    name: 'Champion',
    price: '$250 / month CAD',
    desc: 'Fund a printer node directly and back major event deployments.',
    features: [
      'Everything in Partner',
      'Naming rights on a new printer',
      'Custom event presence',
      'Quarterly strategy call',
      'Logo on all printed parts packaging',
      'Dedicated blog feature',
    ],
    actionText: 'Become a Champion',
    actionHref: '/pricing',
  },
];

const ecosystemPartners = [
  { category: 'Filament & Materials', names: ['Polymaker', 'eSUN', 'Hatchbox', 'Proto-pasta', 'ColorFabb', 'Fillamentum', '3DXTech', 'MatterHackers', 'Overture', 'Prusament'] },
  { category: '3D Printer Manufacturers', names: ['Prusa Research', 'Bambu Lab', 'Creality', 'Elegoo', 'Anycubic', 'Formlabs', 'Raise3D', 'LulzBot', 'Sovol', 'Phrozen'] },
  { category: 'Electronics & Dev Boards', names: ['Raspberry Pi Foundation', 'Arduino', 'Adafruit', 'SparkFun', 'BigTreeTech', 'NVIDIA Jetson', 'Seeed Studio', 'Espressif'] },
  { category: 'Software & CAD', names: ['Autodesk Fusion', 'Shapr3D', 'FreeCAD', 'OctoPrint', 'PrusaSlicer', 'Cura', 'Klipper', 'Thangs'] },
  { category: 'PCB & Fabrication', names: ['PCBWay', 'JLCPCB', 'Slice Engineering', 'E3D', 'Bondtech'] },
  { category: 'Tools & Hardware', names: ['iFixit', 'Dremel', 'Wera Tools', 'Knipex', 'Micro Center'] },
  { category: 'Events & Community', names: ['Maker Faire', 'ERRF', 'MRRF', 'Formnext', 'Printables', 'Thingiverse', 'MakerWorld'] },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Sponsor 3D3D — Open Source 3D Printing Cooperative',
    description: 'Partner with 3D3D Atlantic Cooperative. Sponsor community workshops, offshore 3D printing deployments, STEM education, and open-source maker tools in Atlantic Canada.',
    url: 'https://3d3d.ca/sponsors',
    keywords: '3D printing sponsor, maker community sponsorship, STEM education sponsor Canada, open source 3D printing',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: 'Newport Bermuda Race 2026 — Live 3D Fabrication at Sea',
    startDate: '2026-06-19',
    location: { '@type': 'Place', name: 'Newport, Rhode Island to Bermuda' },
    description: 'Live 3D printing deployment aboard a racing yacht during the 120th Newport Bermuda Race.',
    organizer: { '@type': 'Organization', name: '3D3D Atlantic Cooperative', url: 'https://3d3d.ca' },
  },
];
---

<BaseLayout title="Sponsor 3D3D — Open Source 3D Printing & Maker Community | 3D3D" description="Partner with 3D3D to sponsor STEM workshops, offshore 3D printing at the Newport Bermuda Race, open-source tools, and Atlantic Canada's maker network." activePath="/sponsors" schema={schema}>

  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Community', href: '/community'}, {label: 'Sponsorships'}]} />
            <p class="hp-card__eyebrow mt-4">Partnerships</p>
            <h1 class="hp-card__title mt-2 mb-4">Invest in the Network</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              3D3D is a maker cooperative building open-source tools, running STEM workshops, and deploying 3D printers in extreme environments — classrooms, makerspaces, and offshore racing yachts. Your sponsorship funds real work and gets your name on it.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Impact + Campaign -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/story-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Why Partner</p>
            <h2 class="hp-card__title mt-2 mb-6">Community Impact & The 2026 Campaign</h2>

            <div class="sponsor-impact-grid">
              <div class="sponsor-impact-card">
                <h3 class="sponsor-impact-card__title">Community Impact</h3>
                <ul class="sponsor-impact-card__list">
                  <li><strong>STEM Workshops.</strong> Hands-on 3D printing education for schools and community centers.</li>
                  <li><strong>Open Source.</strong> All tools, models, and educational materials published freely.</li>
                  <li><strong>Maker Network.</strong> Distributed fabrication nodes across Atlantic Canada and growing.</li>
                  <li><strong>Event Deployment.</strong> Live 3D printing at sailing races, maker faires, and tech events.</li>
                </ul>
              </div>
              <div class="sponsor-impact-card">
                <h3 class="sponsor-impact-card__title">The 2026 Campaign</h3>
                <p class="sponsor-impact-card__copy">
                  For the 120th running of the Newport Bermuda Race, 3D3D is aboard with an enclosed CoreXY printing live. Real parts, real conditions — ASA and PA-CF at sea. This is the flagship deployment proof and your brand goes with it.
                </p>
                <p class="sponsor-impact-card__copy mt-3">
                  <strong style="color: #FF6B2B;">Sponsor activation:</strong> Your logo on the printer enclosure, event photography, blog features, social media coverage throughout the race, and post-race documentary content.
                </p>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: Sponsorship Tiers -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Tiers</p>
            <h2 class="hp-card__title mt-2 mb-6">Sponsorship Tiers</h2>

            <div class="sponsor-tiers">
              {packages.map((pkg) => (
                <div class={`sponsor-tier ${pkg.isPrimary ? 'sponsor-tier--primary' : ''}`}>
                  {pkg.isPrimary && <span class="sponsor-tier__badge">Most Popular</span>}
                  <h3 class="sponsor-tier__name">{pkg.name}</h3>
                  <p class="sponsor-tier__price">{pkg.price}</p>
                  <p class="sponsor-tier__desc">{pkg.desc}</p>
                  <ul class="sponsor-tier__features">
                    {pkg.features.map(f => <li><span class="sponsor-tier__check">&#10003;</span> {f}</li>)}
                  </ul>
                  <a href={pkg.actionHref} target="_blank" rel="noopener noreferrer" class={`hp-cta ${pkg.isPrimary ? 'hp-cta--accent' : 'hp-cta--glass'}`} style="width: 100%; text-align: center;">{pkg.actionText} →</a>
                </div>
              ))}
            </div>

            <div class="sponsor-custom mt-6">
              <h3 class="sponsor-custom__title">Custom Sponsorship</h3>
              <p class="sponsor-custom__copy">
                Need something specific? We can set up naming rights on a community printer, co-branded workshop series, event-specific deployments, or content partnerships.
              </p>
              <a href="/contact?subject=custom-sponsorship" class="hp-cta hp-cta--glass mt-4">Discuss Custom Sponsorship →</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 4: Ecosystem -->
    <section class="hp-section" style="--section-accent: #AAFF2A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Ecosystem</p>
            <h2 class="hp-card__title mt-2 mb-4">Tools &amp; Brands We Use</h2>
            <p class="hp-card__copy mb-6">
              The hardware, software, and materials we run in the shop and recommend to clients. These are the brands and tools behind the work — not sponsors, just what we trust.
            </p>

            <div class="sponsor-ecosystem">
              {ecosystemPartners.map((group) => (
                <div class="sponsor-ecosystem__group">
                  <h3 class="sponsor-ecosystem__cat">{group.category}</h3>
                  <div class="sponsor-ecosystem__names">
                    {group.names.map((name) => (
                      <span class="sponsor-ecosystem__name">{name}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-8">
              <PageNextActions actions={[
                {label: 'Contact Coordinator', href: '/contact?subject=sponsorship', description: 'Discuss custom activations and partnerships.', accent: 'teal'},
                {label: 'Community Projects', href: '/projects', description: 'See the projects your sponsorship funds.', accent: 'magenta'},
              ]} />
            </div>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .sponsor-impact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: 1rem;
  }
  .sponsor-impact-card {
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }
  .sponsor-impact-card__title {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.9);
  }
  .sponsor-impact-card__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.6rem;
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(246, 247, 250, 0.5);
  }
  .sponsor-impact-card__list strong {
    color: var(--color-teal-primary);
  }
  .sponsor-impact-card__copy {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(246, 247, 250, 0.5);
  }

  .sponsor-tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(240px, 100%), 1fr));
    gap: 1rem;
  }
  .sponsor-tier {
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .sponsor-tier--primary {
    border-color: var(--color-teal-primary);
  }
  .sponsor-tier__badge {
    position: absolute;
    top: -0.6rem;
    left: 1rem;
    background: var(--color-teal-primary);
    color: #0a0e13;
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
  }
  .sponsor-tier__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: rgba(246, 247, 250, 0.9);
    text-transform: uppercase;
  }
  .sponsor-tier__price {
    margin: 0.3rem 0 0.6rem;
    font-family: var(--font-tech);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
  }
  .sponsor-tier__desc {
    margin: 0 0 1rem;
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgba(246, 247, 250, 0.45);
  }
  .sponsor-tier__features {
    margin: 0 0 1.5rem;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: rgba(246, 247, 250, 0.5);
    flex-grow: 1;
  }
  .sponsor-tier__check {
    color: var(--color-teal-primary);
    margin-right: 0.4rem;
  }

  .sponsor-custom {
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }
  .sponsor-custom__title {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.9);
  }
  .sponsor-custom__copy {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(246, 247, 250, 0.45);
    max-width: 36rem;
  }

  .sponsor-ecosystem {
    display: grid;
    gap: 1.2rem;
  }
  .sponsor-ecosystem__cat {
    margin: 0 0 0.5rem;
    font-family: var(--font-tech);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
  }
  .sponsor-ecosystem__names {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .sponsor-ecosystem__name {
    font-size: 0.72rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    color: rgba(246, 247, 250, 0.45);
  }
</style>
