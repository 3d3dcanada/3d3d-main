---
import BaseLayout from '../layouts/BaseLayout.astro';

const prusaModels = [
  {
    name: 'Original Prusa CORE One',
    tag: 'Flagship',
    tagColor: '#40C4C4',
    description: 'Prusa\'s first CoreXY. Fully enclosed, input shaping, active chamber heating. The machine that changed Prusa from reliable to fast and reliable. Open-source firmware, field-serviceable, built to last a decade.',
    specs: [
      'CoreXY motion — 250 mm/s with input shaping',
      'Fully enclosed with active chamber heating',
      'Build volume: 250 × 210 × 220 mm',
      'Open-source firmware (PrusaLink, Buddy)',
      'Hardened nozzle upgrade available',
    ],
    bestFor: 'Production shops, engineering teams, anyone building a long-term print fleet.',
    kitCAD: 1536,
    assembledCAD: 1939,
  },
  {
    name: 'Original Prusa CORE One L',
    tag: 'Coming Soon',
    tagColor: '#E84A8A',
    description: 'Everything the CORE One does, at scale. Larger build volume for monolithic parts that used to require splitting and joining. Full enclosure, active heating, CoreXY speed. This is the machine Prusa is sending to 3D3D.',
    specs: [
      'CoreXY motion — same speed platform as CORE One',
      'Significantly larger build volume',
      'Active chamber heating for engineering polymers',
      'Full-size dashboard panels, marine housings, large brackets in one piece',
      'Prusa\'s flagship — their biggest enclosed printer',
    ],
    bestFor: 'Large-format functional parts, marine brackets, automotive panels, industrial housings.',
    kitCAD: null,
    assembledCAD: null,
    contactForPrice: true,
  },
  {
    name: 'Original Prusa MK4S',
    tag: 'Workhorse',
    tagColor: '#F5A623',
    description: 'The most proven 3D printer in the world, refined. The MK4S is the latest in a lineage that started with the MK2 and has earned its reputation through millions of print hours across tens of thousands of shops worldwide. Input shaping, Nextruder, and Prusa Connect make it the smartest i3 ever built.',
    specs: [
      'Nextruder with quick-swap nozzle system',
      'Input shaping and pressure advance',
      'Build volume: 250 × 210 × 220 mm',
      'Power panic recovery — resume after power loss',
      'PrusaConnect cloud monitoring',
    ],
    bestFor: 'Beginners who want open-source, small businesses, anyone who values repairability over speed.',
    kitCAD: 969,
    assembledCAD: 1291,
  },
  {
    name: 'Original Prusa XL',
    tag: 'Multi-Tool',
    tagColor: '#9B59B6',
    description: 'Up to five independent toolheads on a single machine. The XL is Prusa\'s answer to multi-material printing — no purge tower, no waste, just clean tool changes mid-print. CoreXY, fully enclosed, segmented heatbed. This is the production multi-material platform.',
    specs: [
      '1 to 5 independent toolheads',
      'CoreXY motion system',
      'Build volume: 360 × 360 × 360 mm',
      'Segmented heatbed — heats only what you use',
      'Automatic tool calibration and alignment',
    ],
    bestFor: 'Multi-material production, soluble supports, multi-colour functional parts.',
    kitCAD: null,
    assembledCAD: null,
    contactForPrice: true,
  },
  {
    name: 'Original Prusa MINI+',
    tag: 'Entry Level',
    tagColor: '#40C4C4',
    description: 'The most affordable way into the Prusa ecosystem. Compact, reliable, and fully supported by PrusaSlicer. The MINI+ proves that entry-level doesn\'t have to mean compromised. Same firmware quality, same community, smaller footprint.',
    specs: [
      'Build volume: 180 × 180 × 180 mm',
      'Bowden extruder — lightweight, proven design',
      'PrusaConnect compatible',
      'Full PrusaSlicer support',
      'Compact footprint — desk-friendly',
    ],
    bestFor: 'First Prusa, education, desktop use, anyone entering the open-source ecosystem.',
    kitCAD: 693,
    assembledCAD: null,
  },
  {
    name: 'Prusa MMU3',
    tag: 'Upgrade',
    tagColor: '#F5A623',
    description: 'Multi-material upgrade for the MK4S. Five filament inputs, automatic switching, and dramatically improved reliability over the MMU2S. Turn your single-material MK4S into a multi-colour machine.',
    specs: [
      '5 filament inputs',
      'Automatic filament switching mid-print',
      'Compatible with MK4S and MK3.5',
      'Improved reliability over MMU2S',
      'Soluble support capability',
    ],
    bestFor: 'MK4S owners who want multi-colour or soluble supports without buying a second machine.',
    kitCAD: 483,
    assembledCAD: null,
    isUpgrade: true,
  },
];

const setupIncludes = [
  {
    title: 'Unboxing & Assembly',
    desc: 'We receive the printer directly from Prusa, unbox it, and inspect every component. Kits are fully assembled. Nothing is missing, nothing is damaged.',
  },
  {
    title: 'Full Calibration',
    desc: 'Bed levelling, first-layer calibration, Z-offset, belt tension, flow rate testing. Every axis, every parameter, dialled in and verified.',
  },
  {
    title: 'Firmware Update',
    desc: 'Updated to the latest stable Prusa firmware before it leaves. No first-boot update loops.',
  },
  {
    title: '100 Preset Prints',
    desc: 'Your printer arrives with up to 100 ready-to-print models on an SD card. Practical household items, tools, organizers, test objects. Pick one and print — day one.',
  },
  {
    title: 'First Print Walkthrough',
    desc: 'In person or remote — we walk you through your first print. Loading filament, selecting a model, understanding what the printer is doing and why. No prior knowledge required.',
  },
  {
    title: 'Ongoing Support',
    desc: 'Questions after setup? WhatsApp us. We\'re here. Clogged nozzle, weird first layer, filament questions — we help you diagnose and fix it. You\'re not alone with a manual in German.',
  },
];
---

<BaseLayout
  title="Prusa 3D Printers — Buy from 3D3D | Setup, Delivery & Support"
  description="Buy Prusa 3D printers from 3D3D. Sponsored by Prusa Research. Professional setup, 100 preset prints, first print walkthrough, and ongoing support. We deliver it ready to print."
  activePath="/prusa"
>
  <!-- Hero -->
  <section class="prusa-hero">
    <div class="prusa-hero__shell">
      <p class="prusa-eyebrow">Prusa Printers</p>
      <h1 class="prusa-title">
        Prusa, Ready<br />
        <span class="prusa-title__accent">to Print.</span>
      </h1>
      <p class="prusa-body">
        We're sponsored by Prusa Research and we sell their printers. Every machine is professionally assembled, calibrated, loaded with 100 ready-to-print models, and delivered to your door. In person or remote — we walk you through your first print so you're never on your own.
      </p>
      <div class="prusa-hero__actions">
        <a href="/contact" class="prusa-cta">Order a Prusa →</a>
        <a href="#lineup" class="prusa-cta prusa-cta--ghost">See the lineup ↓</a>
      </div>
    </div>
  </section>

  <!-- Why Buy Through 3D3D -->
  <section class="prusa-value">
    <div class="prusa-value__shell">
      <p class="prusa-eyebrow">Why order through us</p>
      <h2 class="prusa-section-title">You're Not Just Buying a Printer.</h2>
      <div class="prusa-value__grid">
        <div class="prusa-value__card">
          <div class="prusa-value__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <h3>Prusa-Sponsored Partner</h3>
          <p>Prusa sponsors 3D3D and we sell their printers. Your machine comes through our relationship with Prusa Research — not resold, not grey market. We're a real shop running Prusa machines every day, and we stand behind what we sell.</p>
        </div>
        <div class="prusa-value__card">
          <div class="prusa-value__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3>Quality Guarantee</h3>
          <p>Every machine is tested before it reaches you. We run calibration, verification prints, and firmware updates. If something isn't right, we handle it with Prusa directly. You don't troubleshoot — we do.</p>
        </div>
        <div class="prusa-value__card">
          <div class="prusa-value__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <h3>100 Ready-to-Print Models</h3>
          <p>Your printer comes loaded with up to 100 curated models. Practical stuff — cable clips, tool holders, phone stands, calibration objects. Pick one, hit print. You're making parts on day one.</p>
        </div>
        <div class="prusa-value__card">
          <div class="prusa-value__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </div>
          <h3>Setup & First Print</h3>
          <p>In person if you're local, remote video call if you're not. We walk you through the entire first print — loading filament, choosing a model, understanding what the machine is doing. No experience required.</p>
        </div>
        <div class="prusa-value__card">
          <div class="prusa-value__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3>Priority Parts & Fast-Track</h3>
          <p>Our relationship with Prusa means we can sometimes fast-track orders and parts. Replacement nozzles, spare components, upgrade kits — we handle the logistics and get things moving faster.</p>
        </div>
        <div class="prusa-value__card">
          <div class="prusa-value__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <h3>Ongoing WhatsApp Support</h3>
          <p>Clogged nozzle at 11 PM? Weird first layer? Not sure which filament to buy? Message us on WhatsApp. We're real people who actually use these machines every day. We help you get unstuck.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Printer Lineup -->
  <section class="prusa-lineup" id="lineup">
    <div class="prusa-lineup__shell">
      <p class="prusa-eyebrow">The Prusa Lineup</p>
      <h2 class="prusa-section-title">Every Current Model. Available Now.</h2>
      <p class="prusa-body" style="margin-bottom: 2rem;">
        All prices in Canadian dollars. Includes professional assembly (for kits), calibration, firmware setup, 100 preset prints, and first-print walkthrough. Exchange rate: 1 USD = 1.37 CAD with service markup.
      </p>

      <div class="prusa-lineup__grid">
        {prusaModels.map((model) => (
          <article class={`printer-card ${model.contactForPrice ? 'printer-card--premium' : ''}`}>
            <div class="printer-card__header">
              <span class="printer-card__tag" style={`--tag-color: ${model.tagColor};`}>
                {model.tag}
              </span>
              <h3 class="printer-card__name">{model.name}</h3>
            </div>
            <p class="printer-card__desc">{model.description}</p>
            <ul class="printer-card__specs">
              {model.specs.map((spec) => (
                <li>{spec}</li>
              ))}
            </ul>
            <p class="printer-card__best">
              <strong>Best for:</strong> {model.bestFor}
            </p>
            <div class="printer-card__pricing">
              {model.contactForPrice ? (
                <div class="printer-card__price-row">
                  <span class="printer-card__price-label">Contact for current pricing and availability</span>
                </div>
              ) : (
                <>
                  {model.kitCAD && (
                    <div class="printer-card__price-row">
                      <span class="printer-card__price-label">{model.isUpgrade ? 'Kit' : 'Kit + Setup'}</span>
                      <span class="printer-card__price">${model.kitCAD.toLocaleString()} <small>CAD</small></span>
                    </div>
                  )}
                  {model.assembledCAD && (
                    <div class="printer-card__price-row">
                      <span class="printer-card__price-label">Assembled + Setup</span>
                      <span class="printer-card__price">${model.assembledCAD.toLocaleString()} <small>CAD</small></span>
                    </div>
                  )}
                </>
              )}
            </div>
            <a href="/contact" class="prusa-cta prusa-cta--sm">
              {model.contactForPrice ? 'Request a Quote →' : 'Order This Printer →'}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- The Setup Experience -->
  <section class="prusa-setup">
    <div class="prusa-setup__shell">
      <p class="prusa-eyebrow">The 3D3D Setup</p>
      <h2 class="prusa-section-title">What Happens Between Order and First Print.</h2>
      <p class="prusa-body" style="margin-bottom: 2.5rem;">
        Buying a printer online means getting a box. Buying through 3D3D means getting a ready machine with someone who knows it inside and out standing behind it.
      </p>
      <div class="prusa-setup__grid">
        {setupIncludes.map((step, i) => (
          <div class="setup-step">
            <span class="setup-step__num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="setup-step__title">{step.title}</h3>
            <p class="setup-step__desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Source Philosophy -->
  <section class="prusa-open">
    <div class="prusa-open__shell">
      <div class="prusa-open__content">
        <p class="prusa-eyebrow">Open Source</p>
        <h2 class="prusa-section-title">Your Printer. Your Firmware. Your Choice.</h2>
        <p class="prusa-body">
          Every Prusa printer runs open-source firmware. The designs are published. The slicer is free. You own the machine completely — not just the hardware, but the entire software stack. No locked filament cartridges. No mandatory cloud accounts. No firmware updates that remove features.
        </p>
        <p class="prusa-body">
          This isn't ideology — it's risk management. When your livelihood or your project depends on a machine, you need to own it. Prusa gives you that. 3D3D believes in that. It's why we chose them as our primary platform.
        </p>
        <div class="prusa-open__links">
          <a href="/blog/why-prusa">Why We Run Prusa →</a>
          <a href="/blog/open-source-why">The Files Are Open →</a>
          <a href="/blog/bambu-vs-prusa">Bambu vs Prusa — Honest Take →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Prusa Believes in 3D3D -->
  <section class="prusa-story">
    <div class="prusa-story__shell">
      <p class="prusa-eyebrow">The Relationship</p>
      <h2 class="prusa-section-title">Prusa Believes in 3D3D.</h2>
      <p class="prusa-body">
        Prusa Research is sponsoring 3D3D with a CORE One L — their flagship machine. Not as a marketing deal, but because they saw the work and backed the mission. A founder-operated fabrication operation taking 3D printing offshore, to events, to communities that have never seen it before.
      </p>
      <p class="prusa-body">
        When you buy a Prusa from us, you're buying from someone who runs these machines every day in marine environments, motorsport, and field deployment. We push them to their limits and we know what works. That's not a sales pitch — it's just how the shop runs.
      </p>
    </div>
  </section>

  <!-- Support the Journey -->
  <section class="prusa-support">
    <div class="prusa-support__shell">
      <p class="prusa-eyebrow">Support the Journey</p>
      <h2 class="prusa-section-title">This Is an Open-Source Business.</h2>
      <p class="prusa-body">
        Prusa built a global company on open-source hardware. 3D3D is building a fabrication business on the same principles — transparent pricing, shared designs, community-first. Your purchase directly funds the mission: taking 3D printing to boats, events, remote communities, and people who didn't know this technology could solve their problem.
      </p>
      <p class="prusa-body">
        If you want to support the journey beyond buying a printer, our Ko-fi is open. Every contribution locks you in as an early supporter — when we grow, you're already on the list. First access to new services, workshop events, and limited runs.
      </p>
      <div class="prusa-hero__actions">
        <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer" class="prusa-cta prusa-cta--kofi">
          Support on Ko-fi →
        </a>
        <a href="/contact" class="prusa-cta">Order a Printer →</a>
      </div>
    </div>
  </section>

  <!-- Channel Order Options -->
  <section class="prusa-channel">
    <div class="prusa-channel__shell">
      <p class="prusa-eyebrow">Flexible Ordering</p>
      <h2 class="prusa-section-title">Two Ways to Buy.</h2>
      <div class="prusa-channel__options">
        <div class="prusa-channel__option">
          <h3>Full Service</h3>
          <p>We receive the printer, assemble it (kits), calibrate everything, load 100 models, update firmware, test it, and deliver it to you. We walk you through the first print. Ongoing WhatsApp support included.</p>
          <span class="prusa-channel__label">Most popular — recommended for first-time owners</span>
        </div>
        <div class="prusa-channel__option">
          <h3>Order Through Us</h3>
          <p>Just want to buy? We handle the order, it ships to you. You get our pricing and we sort out any issues with Prusa. Setup is on you — but we're a message away if you get stuck.</p>
          <span class="prusa-channel__label">For experienced users who just want the printer</span>
        </div>
      </div>
      <a href="/contact" class="prusa-cta" style="margin-top: 2rem;">Get Started →</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Shared ─── */
  .prusa-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #40C4C4;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .prusa-eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: #40C4C4;
    flex-shrink: 0;
  }
  .prusa-section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.2rem + 2.5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }
  .prusa-body {
    margin: 0;
    max-width: 42rem;
    font-size: clamp(1.02rem, 0.92rem + 0.4vw, 1.15rem);
    line-height: 1.75;
    color: rgba(246, 247, 250, 0.82);
  }
  .prusa-body + .prusa-body {
    margin-top: 1rem;
  }
  .prusa-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.4rem;
    padding: 0.95rem 1.6rem;
    background: #40C4C4;
    color: #0F1112;
    border: 3px solid #1A1A1A;
    font-family: var(--font-tech);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    box-shadow: 0 14px 32px rgba(64, 196, 196, 0.22);
  }
  .prusa-cta:hover {
    background: #53D3D3;
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.4);
    transform: translateY(-2px);
  }
  .prusa-cta--ghost {
    background: transparent;
    color: #40C4C4;
    border-color: rgba(64, 196, 196, 0.3);
    box-shadow: none;
  }
  .prusa-cta--ghost:hover {
    background: rgba(64, 196, 196, 0.08);
    color: #FFFFFF;
    box-shadow: none;
  }
  .prusa-cta--sm {
    min-height: 2.8rem;
    padding: 0.7rem 1.2rem;
    font-size: 0.76rem;
  }
  .prusa-cta--kofi {
    background: #FF5E5B;
    border-color: #1A1A1A;
    box-shadow: 0 14px 32px rgba(255, 94, 91, 0.22);
  }
  .prusa-cta--kofi:hover {
    background: #FF7674;
    box-shadow: 0 8px 24px rgba(255, 94, 91, 0.4);
  }

  /* ─── Hero ─── */
  .prusa-hero {
    min-height: 80svh;
    display: flex;
    align-items: center;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(64, 196, 196, 0.12), transparent 50%),
      radial-gradient(ellipse at 80% 30%, rgba(232, 74, 138, 0.08), transparent 45%),
      #111214;
    color: #F6F7FA;
  }
  .prusa-hero__shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 820px);
    margin: 0 auto;
    display: grid;
    gap: 1.6rem;
    padding-block: clamp(6rem, 10vw, 10rem);
  }
  .prusa-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 2rem + 4vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: #FFFFFF;
    text-transform: uppercase;
  }
  .prusa-title__accent {
    color: #40C4C4;
  }
  .prusa-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  /* ─── Value Props ─── */
  .prusa-value {
    background: #0F1112;
    color: #F6F7FA;
    border-top: 1px solid rgba(64, 196, 196, 0.15);
    padding-block: clamp(5rem, 8vw, 8rem);
  }
  .prusa-value__shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 1200px);
    margin: 0 auto;
    display: grid;
    gap: 1.4rem;
  }
  .prusa-value__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .prusa-value__card {
    padding: 1.6rem;
    border: 1px solid rgba(64, 196, 196, 0.15);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    display: grid;
    gap: 0.8rem;
    align-content: start;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .prusa-value__card:hover {
    border-color: rgba(64, 196, 196, 0.35);
    background: rgba(255, 255, 255, 0.04);
  }
  .prusa-value__icon {
    width: 2.5rem;
    height: 2.5rem;
    color: #40C4C4;
  }
  .prusa-value__icon svg {
    width: 100%;
    height: 100%;
  }
  .prusa-value__card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.2;
    color: #FFFFFF;
  }
  .prusa-value__card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: rgba(246, 247, 250, 0.72);
  }

  /* ─── Printer Lineup ─── */
  .prusa-lineup {
    background: #111214;
    color: #F6F7FA;
    border-top: 1px solid rgba(64, 196, 196, 0.15);
    padding-block: clamp(5rem, 8vw, 8rem);
  }
  .prusa-lineup__shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 1200px);
    margin: 0 auto;
    display: grid;
