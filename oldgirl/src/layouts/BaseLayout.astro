---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  accent?: string;
  showFooter?: boolean;
  showCooperativeInfo?: boolean;
  bodyClass?: string;
}

const {
  title,
  description,
  canonicalURL,
  ogImage,
  ogType,
  schema,
  noindex = false,
  accent = '#8B5CF6',
  showFooter = true,
  showCooperativeInfo = true,
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonicalURL={canonicalURL}
      ogImage={ogImage}
      ogType={ogType}
      schema={schema}
      noindex={noindex}
    />
  </head>
  <body class:list={[bodyClass]}>
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    {/* Sidebar slot — injected per-site via named slot */}
    <slot name="sidebar" />

    <div class="flex-1 flex flex-col min-h-screen">
      <main id="main-content" class="flex-1">
        <slot />
      </main>

      {showFooter && (
        <Footer accent={accent} showCooperativeInfo={showCooperativeInfo} />
      )}
    </div>
  </body>
</html>
