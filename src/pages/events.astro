---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EventSeries',
  name: '3D3D Events & Projects',
  description: 'The logbook of offshore fabrication work. Races, deployments, and jobs where having a specialist aboard changes the outcome.',
  organizer: {
    '@type': 'Organization',
    name: '3D3D',
    url: 'https://3d3d.ca',
  },
  location: {
    '@type': 'Place',
    name: 'Coastal and international routes',
  },
};

const events = [
  {
    title: 'Newport-Bermuda Race 2026',
    date: 'Mid-June 2026',
    location: 'Newport RI to Bermuda',
    description: 'Aboard CSM the Mariner. Offshore racing is an exercise in controlled degradation. Things break. Spinnaker pole end fittings crack during night peels. Electronics brackets shatter when the hull slams into a Gulf Stream trough. Two hundred miles offshore, you cannot call a rigger. Having a fabricator aboard changes the tactical outcome. I bring the equipment, stand my watch, and when hardware fails under load, I am below deck engineering the replacement while the boat holds its heading.',
    status: 'Coming Up',
  },
  {
    title: 'On-Site Availability, 2026',
    date: 'Open for 2026 engagements',
    location: 'Worldwide',
    description: 'Available for race campaigns, refit support, trans-oceanic passages, and mechanical problems that live on a vessel. I integrate with the crew, stand my watch, and ensure the hardware survives the trip.',
    status: 'Available',
  },
];
---

<BaseLayout
  title="The Logbook | 3D3D"
  description="Offshore races, deployments, and on-location fabrication work. If you have a race, a refit, or a passage, get in touch."
  schema={schema}
  activePath="/events"
>
  <section class="page-section pt-8">
    <div class="surface-panel p-8 sm:p-10">
      <p class="eyebrow">The Logbook</p>
      <h1 class="text-heading-xl mt-4 scroll-in">Races, Deployments & Live Projects</h1>
      <p class="mt-4 text-body-lg" style="color: var(--color-text-secondary);">
        Offshore racing is an exercise in controlled degradation. Having a fabricator aboard changes the outcome.
      </p>
    </div>
  </section>

  <section class="page-section pt-0">
    <div class="grid gap-6 lg:grid-cols-2">
      {events.map((event) => (
        <article class="surface-panel p-6 scroll-in-scale">
          <div class="flex items-center justify-between mb-3">
            <span class="eyebrow" style="font-size: 0.75rem;">{event.status}</span>
          </div>
          <h2 class="text-heading-lg">{event.title}</h2>
          <p class="mt-2 text-sm" style="color: var(--color-text-muted);">
            {event.date} / {event.location}
          </p>
          <p class="mt-3" style="color: var(--color-text-secondary);">{event.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="page-section pt-0 pb-16">
    <div class="surface-panel p-8 sm:p-10">
      <h2 class="text-heading-lg">If you have a race, a refit, or a passage, get in touch.</h2>
      <p class="mt-3" style="color: var(--color-text-secondary);">
        I integrate with the crew. I stand my watch. I ensure the hardware survives the trip. For offshore races, major refits, trans-oceanic passages, or mechanical problems that live aboard, reach out with where the vessel is and what the job is.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/contact" class="btn btn-primary">Contact Ken →</a>
      </div>
    </div>
  </section>
</BaseLayout>
