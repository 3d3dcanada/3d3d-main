---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
import Reviews from '../components/Reviews.astro';
import { type ServiceArea } from '../data/serviceAreas';
import globalAreasRaw from '../data/globalServiceAreas.json';

export function getStaticPaths() {
  const SERVICE_AREAS = globalAreasRaw as unknown as ServiceArea[];
  return SERVICE_AREAS.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

interface Props {
  area: ServiceArea;
}

const SERVICE_AREAS = globalAreasRaw as unknown as ServiceArea[];

const { area } = Astro.props;

const locationLabel = area.provinceShort
  ? `${area.city}, ${area.provinceShort}`
  : area.city;

const pageTitle = `3D Printing in ${locationLabel} | Custom Fabrication | 3D3D`;
const pageDescription = `Custom 3D printing services for ${locationLabel}. Engineering-grade FDM printing in ASA, PETG-CF, Nylon, PC, TPU. ${area.shippingEstimate}. Fredericton NB, ships to ${area.city}.`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: `3D Printing Services in ${locationLabel}`,
    description: pageDescription,
    url: `https://3d3d.ca/3d-printing-${area.slug}`,
    provider: { '@id': 'https://3d3d.ca/#organization' },
    areaServed: {
      '@type': area.country === 'Canada' ? 'City' : 'Country',
      name: area.city,
      ...(area.provinceShort ? { containedInPlace: { '@type': 'State', name: area.province } } : {}),
    },
    serviceType: [
      'Custom 3D Printing',
      'Rapid Prototyping',
      'Reverse Engineering',
      'Part Fabrication',
    ],
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: `3D Printing for ${area.city}`,
      itemListElement: area.industries.map((ind) => ({
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: ind.name,
          description: ind.useCase,
        },
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: area.faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
];

const nearbyAreas = SERVICE_AREAS.filter((a) => area.nearby && area.nearby.includes(a.slug));
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schema={schema}
  activePath={`/3d-printing-${area.slug}`}
>
  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <Breadcrumbs items={[
              { label: 'Home', href: '/' },
              { label: 'Service Areas' },
              { label: area.city },
            ]} />
            <p class="hp-card__eyebrow mt-4">3D Printing Services</p>
            <h1 class="hp-card__title mt-2 mb-4">3D Printing in {locationLabel}</h1>
            <p class="hp-card__copy hp-card__copy--lead mb-6">
              {area.regionContext}
            </p>

            <div class="grid grid-cols-3 gap-2 bg-black/40 border border-white/10 p-4 rounded mb-8">
              <div class="flex flex-col">
                <span class="text-teal-400 font-display text-xl leading-none tracking-tight">{area.shippingEstimate}</span>
                <span class="font-tech text-xs font-bold uppercase tracking-widest text-gray-500 mt-1">Shipping</span>
              </div>
              <div class="flex flex-col">
                <span class="text-white font-display text-xl leading-none tracking-tight">12+</span>
                <span class="font-tech text-xs font-bold uppercase tracking-widest text-gray-500 mt-1">Materials</span>
              </div>
              <div class="flex flex-col">
                <span class="text-white font-display text-xl leading-none tracking-tight">24-48h</span>
                <span class="font-tech text-xs font-bold uppercase tracking-widest text-gray-500 mt-1">Turnaround</span>
              </div>
            </div>

            <div class="hp-card__cta-row hp-card__cta-row--start">
              <a href="/quote?source=city-page" class="hp-cta hp-cta--accent" data-analytics-event="quote_started" data-analytics-source={`city-${area.slug}`}>Get a Quote</a>
              <a href="/contact" class="hp-cta hp-cta--glass">Contact 3D3D</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Industries -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim" style="background: rgba(17, 18, 20, 0.9);"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <div class="w-full max-w-5xl mx-auto py-12 relative z-10">
          <p class="hp-card__eyebrow" style="color: #e84a8a;">Industries We Serve</p>
          <h2 class="font-display text-3xl text-white uppercase tracking-tighter mt-2 mb-8">What we build for {area.city}</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {area.industries.map((ind) => (
              <div class="bg-black/40 border border-white/10 p-5 rounded-sm hover:-translate-y-1 transition-transform flex flex-col h-full">
                <h3 class="font-display text-xl text-white tracking-tight mb-2">{ind.name}</h3>
                <p class="text-sm text-gray-400 leading-relaxed mb-4 flex-1">{ind.useCase}</p>
                <a href="/quote?source=city-industry" class="font-tech text-xs font-bold uppercase tracking-widest text-pink-400 hover:text-white transition-colors">
                  Request a quote &rarr;
                </a>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- Section 3: Why Us & Reviews -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim" style="background: rgba(17, 18, 20, 0.9);"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <div class="w-full max-w-4xl mx-auto py-12 relative z-10">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
            <div>
              <p class="hp-card__eyebrow">The 3D3D Advantage</p>
              <h2 class="font-display text-3xl text-white uppercase tracking-tighter mt-2 mb-4">Why choose us in {area.city}?</h2>
              <p class="text-sm text-gray-400 leading-relaxed mb-4">{area.infrastructureDesc}</p>
              <ul class="space-y-2 mt-4">
                <li class="flex items-center gap-2 text-sm text-gray-300">
                  <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-400 flex-shrink-0"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Engineering compounds (ASA, PA-CF, TPU)
                </li>
                <li class="flex items-center gap-2 text-sm text-gray-300">
                  <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-400 flex-shrink-0"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Marine and automotive specialisation
                </li>
                <li class="flex items-center gap-2 text-sm text-gray-300">
                  <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-400 flex-shrink-0"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  Direct engineer access, zero bureaucracy
                </li>
              </ul>
            </div>
            <div class="bg-black/40 border border-white/5 p-6 rounded">
              <div class="-mx-4 -my-4">
                <Reviews limit={2} heading="Client Feedback" />
              </div>
            </div>
          </div>

          <!-- FAQ -->
          <h2 class="font-display text-2xl text-white uppercase tracking-tighter mb-6">{area.city} FAQ</h2>
          <div class="space-y-4">
            {area.faqs.map(faq => (
              <details class="group bg-black/40 border border-white/10 rounded-sm">
                <summary class="font-display text-white text-lg p-4 cursor-pointer hover:bg-white/5 transition-colors marker:content-[''] marker:hidden list-none flex justify-between items-center outline-none">
                  {faq.question}
                  <span class="text-teal-400 font-tech text-2xl leading-none font-light group-open:rotate-45 transition-transform">+</span>
                </summary>
                <div class="p-4 pt-0 text-gray-400 text-sm leading-relaxed border-t border-white/5 mt-2">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>

          <!-- Nearby -->
          {nearbyAreas.length > 0 && (
            <div class="mt-12 pt-8 border-t border-white/10">
              <h3 class="font-tech text-xs font-bold uppercase tracking-widest text-gray-500 mb-4">Nearby Service Areas</h3>
              <div class="flex flex-wrap gap-2">
                {nearbyAreas.map(na => (
                  <a href={`/3d-printing-${na.slug}`} class="text-xs text-teal-400 hover:text-white transition-colors bg-teal-950/30 px-3 py-1.5 rounded-sm border border-teal-500/20">{na.city}{na.provinceShort ? `, ${na.provinceShort}` : ''}</a>
                ))}
              </div>
            </div>
          )}

        </div>
      </div>
    </section>

    <!-- Section 4: Next Actions -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/workshop/printer-action-cf.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <PageNextActions actions={[
              {label: 'Upload CAD', href: '/quote', description: 'Get actionable pricing.', accent: 'teal'},
              {label: 'Materials Guide', href: '/materials', description: 'Review the technical specs.', accent: 'orange'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
</style>
