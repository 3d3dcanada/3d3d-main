---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const stats = [
  { value: '7', label: 'Active Repos' },
  { value: '18+', label: 'Local Nodes' },
  { value: '3', label: 'Events/Yr' },
];

const repos = [
  {
    name: '3d3d-platform',
    desc: 'The website you are looking at. Built with Astro 6 and React.',
    url: 'https://github.com/3d3dcanada/3d3d-main',
    lang: 'Astro',
  },
  {
    name: 'ora-3d3d',
    desc: 'AI-assisted coding and fabrication agent.',
    url: 'https://github.com/3d3dcanada/',
    lang: 'Rust / TS',
  },
  {
    name: 'codequest-3d3d',
    desc: 'Interactive coding game interface for training.',
    url: 'https://github.com/3d3dcanada/',
    lang: 'C#',
  },
  {
    name: '3d3d-crm',
    desc: 'Client management and job routing backend.',
    url: 'https://github.com/3d3dcanada/',
    lang: 'NextJS',
  },
  {
    name: 'sovereign-3d3d',
    desc: 'Privacy-focused local sync app for offshore environments.',
    url: 'https://github.com/3d3dcanada/',
    lang: 'Rust',
  },
];
---

<BaseLayout title="Community & Open Source | 3D3D" description="3D3D is an open source manufacturing cooperative. Access our code, join the network, or find us at events." activePath="/community">

  <section class="opp-page">
    <div class="opp-shell">
      <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Community'}]} />
      
      <div class="mb-6 rounded-xl overflow-hidden shadow-sm aspect-video">
        <img src="/media/generated/network-03.jpg" alt="Engineers collaborating over a 3D CAD tablet at a race car garage" class="w-full h-full object-cover" />
      </div>

      <div class="hero surface-panel">
        <div class="hero__content">
          <p class="opp-eyebrow">The Network</p>
          <h1 class="opp-title">Community & Open Source</h1>
          <p class="opp-intro">
            We operate transparently. If we build a tool to make the cooperative run better, we open source it. 
            If we design a part that can help someone fix a broken machine, we publish the model.
            The 3D3D network relies on a shared pool of knowledge, hardware, and code.
          </p>
          
          <div class="flex gap-4 mt-6">
            <a href="https://github.com/3d3dcanada" target="_blank" class="opp-cta">GitHub Organization</a>
            <a href="https://www.printables.com/@KTK3D_3050116" target="_blank" class="opp-cta" style="background: var(--color-orange-primary);">Printables Catalog</a>
          </div>
        </div>
      </div>

      <div class="mt-8 border-t border-gray-200 pt-8">
        <h2 class="text-2xl font-bold mb-6" style="color: var(--color-text-primary);">Active Repositories</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {repos.map(repo => (
            <a href={repo.url} target="_blank" class="block p-4 border border-gray-200 rounded-lg hover:border-teal-400 hover:bg-teal-50/30 transition">
              <div class="flex items-center justify-between mb-2">
                <span class="font-mono font-bold text-sm text-teal-700">{repo.name}</span>
                <span class="text-[10px] uppercase tracking-wider bg-gray-100 px-2 py-1 rounded text-gray-600">{repo.lang}</span>
              </div>
              <p class="text-xs text-gray-600 leading-relaxed">{repo.desc}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mt-12">
        {stats.map((stat) => (
          <div class="text-center p-4 rounded-xl border border-gray-200">
            <span class="block font-display text-2xl font-bold" style="color: var(--color-teal-primary);">{stat.value}</span>
            <span class="font-display text-[9px] uppercase tracking-widest">{stat.label}</span>
          </div>
        ))}
      </div>

      <PageNextActions actions={[
        {label: 'Sponsor an Event', href: '/sponsors', description: 'Fund these workshops for your community.', accent: 'teal'},
        {label: 'Book a Call', href: '/book', description: 'Schedule a discovery call to plan your event.', accent: 'orange'},
      ]} />
    </div>
  </section>
</BaseLayout>

<style>
  .opp-page {
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: var(--color-surface-primary);
    color: var(--color-text-primary);
  }

  .opp-shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 720px);
    margin: 0 auto;
    display: grid;
    gap: 2rem;
    padding-block: clamp(6rem, 10vw, 10rem);
  }

  .opp-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .opp-eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: var(--color-teal-primary);
    flex-shrink: 0;
  }

  .opp-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 4vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    text-transform: uppercase;
  }

  .opp-intro {
    margin: 0;
    max-width: 36rem;
    font-size: clamp(1.05rem, 0.95rem + 0.4vw, 1.2rem);
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .opp-listing {
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .opp-listing__header {
    display: grid;
    gap: 0.6rem;
  }

  .opp-listing__role {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1rem + 1.5vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .opp-listing__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.4rem;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
  }

  .opp-listing__body {
    display: grid;
    gap: 0.8rem;
  }

  .opp-listing__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .opp-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.4rem;
    padding: 0.95rem 1.6rem;
    background: var(--color-teal-primary);
    color: #0F1112;
    border: 3px solid var(--color-text-primary);
    border-radius: 2px;
    font-family: var(--font-tech);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: background-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    box-shadow: 0 14px 32px rgba(64, 196, 196, 0.22);
  }

  .opp-cta:hover {
    background: #53D3D3;
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.4);
    transform: translateY(-2px);
  }
</style>
