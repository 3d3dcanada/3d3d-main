---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '3D3D Atlantic Cooperative',
  url: 'https://3d3d.ca',
  description: 'Distributed 3D printing cooperative connecting makers across Atlantic Canada. Custom prints, 27 products, 50+ makers, 75% revenue to creators.',
  address: { '@type': 'PostalAddress', addressLocality: 'Moncton', addressRegion: 'NB', addressCountry: 'CA' },
  founder: { '@type': 'Person', name: 'Ken' },
  contactPoint: { '@type': 'ContactPoint', telephone: '+1-506-953-2678', email: 'info@3d3d.ca' },
};

const stats = [
  { val: '27', label: 'Products' },
  { val: '50+', label: 'Makers' },
  { val: '75%', label: 'To Creators' },
  { val: '24-48h', label: 'Turnaround' },
];

const features = [
  {
    title: 'Browse Products',
    desc: '27 ready-to-print items from our catalog. Home decor, tools, gifts, and more. Each made by a local maker.',
    href: '/shop',
    cta: 'View Shop',
  },
  {
    title: 'Custom Quote',
    desc: 'Upload your own design or describe what you need. Configure material, quality, and scale for instant pricing.',
    href: '/quote',
    cta: 'Get Quote',
  },
  {
    title: 'Join as Maker',
    desc: 'Own a 3D printer? Join the cooperative and keep 75% of every order. We handle the rest.',
    href: '/makers',
    cta: 'Apply Now',
  },
];

const featuredProducts = [
  { name: 'Wave Holder', href: '/shop/wave-holder', tag: 'Home Decor' },
  { name: 'Coin Vortex', href: '/shop/coin-vortex', tag: 'Toys' },
  { name: 'Secret Note', href: '/shop/secret-note', tag: 'Gifts' },
  { name: 'Memory Book', href: '/shop/memory-book', tag: 'Crafts' },
];
---

<BaseLayout
  title="3D3D Atlantic Cooperative — Custom 3D Printing"
  description="Distributed 3D printing cooperative in Atlantic Canada. 27 products, 50+ makers, 75% revenue to creators. Custom prints with 24-48h turnaround."
  schema={orgSchema}
  activePath="/"
>
  {/* ── HERO ── */}
  <section class="pt-8 pb-12">
    <div class="flex items-center gap-3 mb-4">
      <span class="font-display text-2xl font-bold" style="color: var(--color-teal-primary);">3D3D</span>
      <span class="badge badge-teal">Atlantic Cooperative</span>
    </div>

    <h1 class="text-display">
      Distributed 3D printing.
      <br />
      <span class="text-gradient-teal">Built in Atlantic Canada.</span>
    </h1>

    <p class="mt-6 max-w-2xl text-body-lg" style="color: var(--color-text-secondary);">
      A cooperative network of 50+ independent makers across Atlantic Canada.
      Order from our catalog, get a custom quote, or join as a maker and keep 75% of every print.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a href="/shop" class="btn btn-primary">
        Browse Products
      </a>
      <a href="/quote" class="btn btn-secondary">
        Get a Quote
      </a>
    </div>

    {/* Stats */}
    <div class="mt-12 flex flex-wrap gap-8 pt-8" style="border-top: 2px solid var(--color-border-default);">
      {stats.map(s => (
        <div>
          <span class="block font-display text-2xl font-bold" style="color: var(--color-teal-primary);">{s.val}</span>
          <span class="block font-display text-sm" style="color: var(--color-text-muted);">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  {/* ── FEATURED PRODUCTS ── */}
  <section class="py-12">
    <h2 class="section-header text-heading-xl">Featured Products</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {featuredProducts.map((product) => (
        <a
          href={product.href}
          class="card group p-4"
        >
          <span class="badge badge-magenta mb-3">{product.tag}</span>
          <h3 class="font-display text-lg font-semibold" style="color: var(--color-text-primary);">
            {product.name}
          </h3>
          <span class="mt-2 inline-flex items-center text-sm font-medium" style="color: var(--color-teal-dark);">
            View details
            <svg class="ml-1 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>

    <div class="mt-8">
      <a href="/shop" class="btn btn-ghost">
        View all 27 products
      </a>
    </div>
  </section>

  {/* ── FEATURES GRID ── */}
  <section class="py-12" style="background: var(--color-surface-secondary);">
    <div class="-mx-12 px-12 py-12 rounded-feature" style="background: var(--color-surface-secondary);">
      <h2 class="section-header text-heading-xl">How It Works</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="card-flat p-6" style="background: var(--color-surface-primary);">
            <h3 class="font-display text-lg font-bold" style="color: var(--color-teal-dark);">
              {feature.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              {feature.desc}
            </p>
            <a
              href={feature.href}
              class="mt-4 inline-flex items-center text-sm font-semibold"
              style="color: var(--color-magenta-primary);"
            >
              {feature.cta}
              <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── COOPERATIVE STORY ── */}
  <section class="py-12">
    <h2 class="section-header text-heading-xl">Why Cooperative?</h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <p class="text-body-lg" style="color: var(--color-text-secondary);">
          Most marketplaces take 30-50% of each sale. We flipped that model.
          Makers in the 3D3D cooperative keep <strong style="color: var(--color-teal-dark);">75% of every order</strong>.
          The remaining 25% covers platform costs, payment processing, and growing the network.
        </p>
        <p class="mt-4 text-body-lg" style="color: var(--color-text-secondary);">
          We're not a company printing products. We're a network of 50+ independent makers
          across Atlantic Canada — each with their own equipment, materials, and expertise.
          When you order, your print goes to a real person in your region.
        </p>
      </div>
      <div class="card p-6" style="background: var(--color-teal-surface);">
        <h3 class="font-display text-xl font-bold" style="color: var(--color-teal-dark);">
          The Maker Model
        </h3>
        <ul class="mt-4 space-y-3">
          <li class="flex items-start gap-3">
            <span class="mt-1 w-2 h-2 rounded-full flex-shrink-0" style="background: var(--color-teal-primary);"></span>
            <span class="text-sm" style="color: var(--color-text-secondary);">75% revenue goes directly to the maker</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 w-2 h-2 rounded-full flex-shrink-0" style="background: var(--color-magenta-primary);"></span>
            <span class="text-sm" style="color: var(--color-text-secondary);">24-48 hour turnaround for standard prints</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 w-2 h-2 rounded-full flex-shrink-0" style="background: var(--color-teal-primary);"></span>
            <span class="text-sm" style="color: var(--color-text-secondary);">Ships to Canada and USA</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 w-2 h-2 rounded-full flex-shrink-0" style="background: var(--color-magenta-primary);"></span>
            <span class="text-sm" style="color: var(--color-text-secondary);">PLA, PETG, TPU, ABS, ASA available</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* ── CTA ── */}
  <section class="py-12">
    <div class="card-feature p-8 text-center" style="background: linear-gradient(135deg, var(--color-teal-surface), var(--color-magenta-surface));">
      <h2 class="font-display text-2xl font-bold" style="color: var(--color-text-primary);">
        Ready to start printing?
      </h2>
      <p class="mt-3" style="color: var(--color-text-secondary);">
        Browse our catalog or get a custom quote for your project.
      </p>
      <div class="mt-6 flex justify-center gap-4">
        <a href="/shop" class="btn btn-primary">
          Browse Shop
        </a>
        <a href="/quote" class="btn btn-secondary">
          Get a Quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
