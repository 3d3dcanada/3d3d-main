---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandSidebar from '../components/BrandSidebar.tsx';

const sidebarNav = [{ label: 'Old Girl', items: [
  { id: 'home', label: 'Home', href: '/' },
  { id: 'about', label: 'About', href: '/about' },
  { id: 'contact', label: 'Contact', href: '/contact' },
]}];
---

<BaseLayout title="Accessibility — The Old Girl" description="Accessibility statement for oldgirl.3d3d.ca. Our commitment to WCAG 2.1 and the Accessible Canada Act." accent="#8B5CF6">
  <BrandSidebar slot="sidebar" client:load navGroups={sidebarNav} activePath="/accessibility" />

  <div class="pt-16 pl-0 lg:pl-4">
    <section class="px-6 lg:px-12 py-12">
      <div class="max-w-3xl">
        <p class="text-[10px] uppercase tracking-[0.25em] mb-2" style="color: var(--color-text-muted); font-family: var(--font-display);">Legal</p>
        <h1 class="text-3xl font-bold mb-2" style="color: var(--color-text-primary); font-family: var(--font-display);">Accessibility Statement</h1>
        <p class="text-xs mb-8" style="color: var(--color-text-muted); font-family: var(--font-display);">Last updated: March 2026</p>

        <div class="space-y-6 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          <div>
            <h2 class="text-base font-semibold mb-2" style="color: var(--color-text-primary); font-family: var(--font-display);">Our Commitment</h2>
            <p>3D3D Atlantic Cooperative is committed to making oldgirl.3d3d.ca accessible to everyone. We aim to conform to WCAG 2.1 Level AA, as referenced by the <em>Accessible Canada Act</em> (S.C. 2019, c. 10).</p>
          </div>
          <div>
            <h2 class="text-base font-semibold mb-2" style="color: var(--color-text-primary); font-family: var(--font-display);">What We've Implemented</h2>
            <ul class="space-y-2 mt-2">
              {['Skip-to-content link for keyboard users', 'Semantic HTML with proper heading hierarchy', 'ARIA landmark regions (main, nav, footer)', 'Keyboard-navigable sidebar', 'Minimum 44×44px touch targets', 'Sufficient color contrast (WCAG 2.1 AA)', 'Responsive design up to 200% zoom', 'Reduced-motion media query support', 'Form labels associated with inputs', 'Language attribute (lang="en") on all pages'].map(item => (
                <li class="flex items-start gap-2">
                  <span style="color: var(--color-purple-primary);" class="mt-0.5 flex-shrink-0">→</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h2 class="text-base font-semibold mb-2" style="color: var(--color-text-primary); font-family: var(--font-display);">Known Limitations</h2>
            <p>The Stage Two livestream embed (YouTube) is subject to YouTube's accessibility practices. We will add captions when the livestream launches.</p>
          </div>
          <div>
            <h2 class="text-base font-semibold mb-2" style="color: var(--color-text-primary); font-family: var(--font-display);">Feedback</h2>
            <p>If you encounter accessibility barriers, please contact us. We respond within 5 business days.</p>
            <div class="mt-2 space-y-1">
              <p>Email: <a href="mailto:info@3d3d.ca" class="underline" style="color: var(--color-purple-primary);">info@3d3d.ca</a></p>
              <p>Phone: <a href="tel:+15069532678" class="underline" style="color: var(--color-purple-primary);">506-953-2678</a></p>
            </div>
          </div>
          <div>
            <h2 class="text-base font-semibold mb-2" style="color: var(--color-text-primary); font-family: var(--font-display);">Formal Complaints</h2>
            <p>If not satisfied, contact <a href="https://accessibilitycanada.ca" class="underline" style="color: var(--color-purple-primary);" target="_blank" rel="noopener noreferrer">Accessibility Standards Canada</a> or the Canadian Human Rights Commission.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
