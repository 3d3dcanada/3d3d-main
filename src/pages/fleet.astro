---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
import { FLEET, FLEET_STATS } from '../data/fleet';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'The Fleet — 3D3D',
  description: 'The 3D3D printer fleet. Five machines, multiple materials, production-ready. Specs, calibration results, and capabilities.',
  url: 'https://3d3d.ca/fleet',
};
---

<BaseLayout title="The Fleet | 3D3D" description="Production-ready 3D printing fleet. CoreXY speed, dual extrusion, multi-material, and large format capability up to 500mm. See capabilities and specs." activePath="/fleet" schema={schema}>

  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/fleet-aerial.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Fleet'}]} />
            <p class="hp-card__eyebrow mt-4">The Hardware</p>
            <h1 class="hp-card__title mt-2 mb-4">The Fleet</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Speed printing, dual extrusion, multi-material, and large format capability — all production-tested and running daily. You get the right machine for the job, matched to your part requirements.
            </p>

            <div class="fleet-stats mt-6">
              <div class="fleet-stat">
                <span class="fleet-stat__value">{FLEET_STATS.totalPrinters}</span>
                <span class="fleet-stat__label">Printers</span>
              </div>
              <div class="fleet-stat">
                <span class="fleet-stat__value">{FLEET_STATS.materialsSupported}</span>
                <span class="fleet-stat__label">Materials</span>
              </div>
              <div class="fleet-stat">
                <span class="fleet-stat__value">24-48h</span>
                <span class="fleet-stat__label">Turnaround</span>
              </div>
              <div class="fleet-stat">
                <span class="fleet-stat__value">500mm</span>
                <span class="fleet-stat__label">Max Height</span>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Printer Sections -->
    {FLEET.map((printer, i) => (
      <section class="hp-section" style={`--section-accent: ${printer.accent};`}>
        <div class="hp-section__bg">
          <div class="hp-section__bg-img hp-section__bg-img--active" style={`background-image: url('${printer.image}'), url('/media/generated/fab-0${(i % 3) + 1}.jpg'); background-position: center;`}></div>
        </div>
        <div class="hp-section__vignette"></div>
        <div class="hp-section__scrim"></div>
        <div class="hp-section__grain"></div>

        <div class="hp-section__shell hp-section__shell--start">
          <article class="hp-card scroll-in">
            <div class="hp-card__inner">
              <div class="fleet-printer-header">
                <div>
                  <p class="hp-card__eyebrow" style={`color: ${printer.accent};`}>{printer.nickname}</p>
                  <h2 class="hp-card__title mt-2">{printer.name}</h2>
                </div>
                <span class={`fleet-status fleet-status--${printer.status}`}>{printer.status}</span>
              </div>

              <p class="hp-card__copy mt-4 mb-6">{printer.story}</p>

              <div class="fleet-specs">
                <div class="fleet-spec">
                  <span class="fleet-spec__label">Type</span>
                  <span class="fleet-spec__value">{printer.type}</span>
                </div>
                <div class="fleet-spec">
                  <span class="fleet-spec__label">Build Volume</span>
                  <span class="fleet-spec__value">{printer.buildVolume}</span>
                </div>
                <div class="fleet-spec">
                  <span class="fleet-spec__label">Firmware</span>
                  <span class="fleet-spec__value">{printer.firmware}</span>
                </div>
                <div class="fleet-spec">
                  <span class="fleet-spec__label">Avg Speed</span>
                  <span class="fleet-spec__value">{printer.avgSpeed}</span>
                </div>
                <div class="fleet-spec">
                  <span class="fleet-spec__label">Materials</span>
                  <span class="fleet-spec__value">{printer.materials.join(', ')}</span>
                </div>
              </div>

              <div class="fleet-highlights mt-4">
                {printer.highlights.map((h) => (
                  <span class="fleet-highlight">
                    <span style={`color: ${printer.accent};`}>→</span> {h}
                  </span>
                ))}
              </div>
            </div>
          </article>
        </div>
      </section>
    ))}

    <!-- CTA Section -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner" style="text-align: center; align-items: center;">
            <p class="hp-card__eyebrow">Ready</p>
            <h2 class="hp-card__title mt-2 mb-4">Send Us the Job</h2>
            <p class="hp-card__copy" style="max-width: 36rem; text-align: center;">
              One prototype or a production batch. Upload your file and we will pick the right machine, quote the hours, and get it running.
            </p>
            <div class="hp-card__cta-row mt-6">
              <a href="/quote" class="hp-cta hp-cta--accent">Get a Quote</a>
              <a href="/materials" class="hp-cta hp-cta--glass">Materials Guide</a>
            </div>

            <div class="mt-8" style="text-align: left; width: 100%;">
              <PageNextActions actions={[
                {label: 'Workshops', href: '/workshops', description: 'See the fleet in action at a workshop.', accent: 'teal'},
                {label: 'Materials', href: '/materials', description: 'Choose the right material for your part.', accent: 'magenta'},
              ]} />
            </div>
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .fleet-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 0.8rem;
  }
  .fleet-stat {
    text-align: center;
    padding: 1rem 0.6rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }
  .fleet-stat__value {
    display: block;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-teal-primary);
  }
  .fleet-stat__label {
    font-family: var(--font-tech);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.4);
  }

  .fleet-printer-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .fleet-status {
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border: 1.5px solid;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .fleet-status--active { color: #4ADE80; border-color: #4ADE80; }
  .fleet-status--maintenance { color: #FBBF24; border-color: #FBBF24; }
  .fleet-status--standby { color: rgba(246, 247, 250, 0.4); border-color: rgba(246, 247, 250, 0.2); }

  .fleet-specs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(200px, 100%), 1fr));
    gap: 0.5rem;
  }
  .fleet-spec {
    display: grid;
    gap: 0.15rem;
    padding: 0.6rem 0.8rem;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 2px;
  }
  .fleet-spec__label {
    font-family: var(--font-tech);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.35);
  }
  .fleet-spec__value {
    font-size: 0.82rem;
    color: rgba(246, 247, 250, 0.75);
  }

  .fleet-highlights {
    display: grid;
    gap: 0.35rem;
  }
  .fleet-highlight {
    font-size: 0.8rem;
    line-height: 1.5;
    color: rgba(246, 247, 250, 0.5);
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }
</style>
