---
interface Props {
  accent?: string;
  showCooperativeInfo?: boolean;
}

const { accent = '#8B5CF6', showCooperativeInfo = true } = Astro.props;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
  { label: '3D3D Shop', href: 'https://3d3d.ca/shop' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
  { label: 'CASL Compliance', href: '/casl' },
  { label: 'Accessibility', href: '/accessibility' },
];
---

<footer class="relative border-t" style={`border-color: rgba(139, 92, 246, 0.2); background: linear-gradient(180deg, var(--color-surface-secondary), var(--color-surface-primary));`}>
  <div class="mx-auto max-w-5xl px-6 py-12 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-3">

      {/* Old Girl info */}
      {showCooperativeInfo && (
        <div>
          <h3 class="font-display text-lg font-bold" style={`color: ${accent};`}>
            The Old Girl
          </h3>
          <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
            A community-owned Prusa i3 MK2.5S with MMU2S. Restored, handed to the internet.
            Print queue, donations, livestream.
          </p>
          <div class="mt-4 space-y-1 text-xs uppercase tracking-widest" style="color: var(--color-text-muted); font-family: var(--font-display);">
            <p>3D3D Atlantic Cooperative</p>
            <p>Moncton, NB, Canada</p>
            <p><a href="mailto:info@3d3d.ca" class="hover:underline" style={`color: ${accent};`}>info@3d3d.ca</a></p>
          </div>
        </div>
      )}

      {/* Navigation */}
      <div>
        <h4 class="text-[10px] font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text-muted); font-family: var(--font-display);">
          Navigation
        </h4>
        <ul class="mt-3 space-y-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm transition-colors duration-150 hover:opacity-70" style="color: var(--color-text-secondary);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Legal */}
      <div>
        <h4 class="text-[10px] font-semibold uppercase tracking-[0.2em]" style="color: var(--color-text-muted); font-family: var(--font-display);">
          Legal
        </h4>
        <ul class="mt-3 space-y-2">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm transition-colors duration-150 hover:opacity-70" style="color: var(--color-text-secondary);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="mt-10 border-t pt-6 flex flex-col sm:flex-row items-center justify-between gap-4" style={`border-color: rgba(139, 92, 246, 0.15);`}>
      <p class="text-[10px] uppercase tracking-[0.15em]" style="color: var(--color-text-muted); font-family: var(--font-display);">
        &copy; {new Date().getFullYear()} 3D3D Atlantic Cooperative. Moncton, NB, Canada.
      </p>
      <a href="https://3d3d.ca" class="text-[10px] uppercase tracking-[0.15em] hover:underline" style="color: var(--color-text-muted); font-family: var(--font-display);">
        3d3d.ca
      </a>
    </div>
  </div>
</footer>
