---
import { ACCENT_HEX } from '../data/splashSections';
import { SITE_NAV } from '../data/siteNav';

const items = [
  {
    id: 'fabrication',
    label: 'Fabrication',
    accent: ACCENT_HEX.teal,
    href: '#fabrication',
    children: SITE_NAV.find(g => g.id === 'fabrication')?.items ?? [],
  },
  {
    id: 'story',
    label: 'The Story',
    accent: ACCENT_HEX.magenta,
    href: '#story',
    children: SITE_NAV.find(g => g.id === 'story')?.items ?? [],
  },
  {
    id: 'events',
    label: 'Events',
    accent: ACCENT_HEX.magenta,
    href: '#events',
    dialogId: 'dlg-events',
  },
  {
    id: 'software',
    label: 'Software & AI',
    accent: ACCENT_HEX.teal,
    href: '#software',
    dialogId: 'dlg-software',
    children: SITE_NAV.find(g => g.id === 'software')?.items.slice(0, 6) ?? [],
  },
  {
    id: 'network',
    label: 'The Network',
    accent: ACCENT_HEX.magenta,
    href: '#network',
    dialogId: 'dlg-network',
    children: SITE_NAV.find(g => g.id === 'community')?.items ?? [],
  },
  {
    id: 'oldgirl',
    label: 'The Old Girl',
    accent: ACCENT_HEX.orange,
    href: '#oldgirl',
  },
  {
    id: 'sponsor',
    label: 'Sponsor',
    accent: ACCENT_HEX.magenta,
    href: '#sponsor',
    dialogId: 'dlg-sponsor',
  },
];
---

<aside class="site-right-sidebar" data-site-right-sidebar data-expanded="false">
  <button
    type="button"
    class="site-right-sidebar__toggle"
    data-sidebar-toggle
    aria-expanded="false"
    aria-label="Toggle section navigation"
  >
    <span class="site-right-sidebar__toggle-bars" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
    <span class="site-right-sidebar__toggle-copy">Explore</span>
  </button>

  <nav class="site-right-sidebar__nav" aria-label="Homepage sections">
    {items.map((item) => (
      <div class="site-right-sidebar__group" data-group-id={item.id}>
        {item.dialogId ? (
          <button
            type="button"
            class="site-right-sidebar__pill"
            data-dialog-open={item.dialogId}
            data-sidebar-target={item.id}
            style={`--pill-accent: ${item.accent};`}
          >
            <span class="site-right-sidebar__dot" aria-hidden="true"></span>
            <span class="site-right-sidebar__label">{item.label}</span>
            {item.children?.length ? (
              <span class="site-right-sidebar__chevron" aria-hidden="true" data-chevron>&#x25BE;</span>
            ) : null}
          </button>
        ) : (
          <a
            href={item.href}
            class="site-right-sidebar__pill"
            data-sidebar-target={item.href.startsWith('#') ? item.id : undefined}
            style={`--pill-accent: ${item.accent};`}
          >
            <span class="site-right-sidebar__dot" aria-hidden="true"></span>
            <span class="site-right-sidebar__label">{item.label}</span>
            {item.children?.length ? (
              <span class="site-right-sidebar__chevron" aria-hidden="true" data-chevron>&#x25BE;</span>
            ) : null}
          </a>
        )}

        {item.children?.length ? (
          <div class="site-right-sidebar__sub" data-sub-nav aria-hidden="true">
            {item.children.map((child) => (
              <a
                href={child.href}
                class="site-right-sidebar__sub-link"
                style={`--pill-accent: ${item.accent};`}
                target={child.external ? '_blank' : undefined}
                rel={child.external ? 'noopener noreferrer' : undefined}
              >
                <span class="site-right-sidebar__sub-dot" aria-hidden="true"></span>
                {child.label}
              </a>
            ))}
          </div>
        ) : null}
      </div>
    ))}
  </nav>
</aside>

<script is:inline>
  (() => {
    const sidebar = document.querySelector('[data-site-right-sidebar]');
    if (!(sidebar instanceof HTMLElement)) return;

    const toggle = sidebar.querySelector('[data-sidebar-toggle]');
    const pills = Array.from(sidebar.querySelectorAll('.site-right-sidebar__pill'));
    const mobileQuery = window.matchMedia('(max-width: 1023px)');

    const setExpanded = (expanded) => {
      sidebar.dataset.expanded = expanded ? 'true' : 'false';
      if (toggle instanceof HTMLButtonElement) {
        toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      }
    };

    const closeOnMobile = () => {
      if (mobileQuery.matches) setExpanded(false);
    };

    if (toggle instanceof HTMLButtonElement) {
      toggle.addEventListener('click', () => {
        setExpanded(sidebar.dataset.expanded !== 'true');
      });
    }

    document.addEventListener('click', (event) => {
      if (!mobileQuery.matches || sidebar.dataset.expanded !== 'true') return;
      if (!(event.target instanceof Node)) return;
      if (!sidebar.contains(event.target)) {
        setExpanded(false);
      }
    });

    /* ── Expand/collapse sub-navigation ─────────────────────────── */
    const groups = Array.from(sidebar.querySelectorAll('.site-right-sidebar__group'));

    groups.forEach((group) => {
      const pill = group.querySelector('.site-right-sidebar__pill');
      const subNav = group.querySelector('[data-sub-nav]');
      const chevron = group.querySelector('[data-chevron]');
      if (!pill || !subNav) return;

      // Clicking the chevron toggles sub-nav; clicking the pill itself scrolls/opens dialog
      const toggleSub = (e) => {
        e.preventDefault();
        e.stopPropagation();
        const isOpen = subNav.getAttribute('aria-hidden') === 'false';
        // Close all other subs first
        groups.forEach((g) => {
          const sn = g.querySelector('[data-sub-nav]');
          const ch = g.querySelector('[data-chevron]');
          if (sn && sn !== subNav) {
            sn.setAttribute('aria-hidden', 'true');
            if (ch) ch.classList.remove('site-right-sidebar__chevron--open');
          }
        });
        subNav.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
        if (chevron) chevron.classList.toggle('site-right-sidebar__chevron--open', !isOpen);
      };

      if (chevron) {
        chevron.addEventListener('click', toggleSub);
      }

      // On the pill itself: if it has children AND sidebar is expanded, toggle sub-nav
      // If it has a dialog, let the global dialog handler deal with it
      pill.addEventListener('click', (e) => {
        if (subNav && sidebar.dataset.expanded === 'true' && !pill.hasAttribute('data-dialog-open')) {
          toggleSub(e);
        } else if (pill.hasAttribute('data-dialog-open')) {
          // Dialog items: let the homepage dialog system handle it, just close mobile sidebar
          closeOnMobile();
        } else {
          closeOnMobile();
        }
      });
    });

    /* ── Sub-nav link clicks close sidebar on mobile ────────────── */
    sidebar.querySelectorAll('.site-right-sidebar__sub-link').forEach((link) => {
      link.addEventListener('click', closeOnMobile);
    });

    /* ── IntersectionObserver for active section ─────────────────── */
    const sectionTargets = Array.from(document.querySelectorAll('[data-observe-section]'));
    const sectionLinks = new Map(
      Array.from(sidebar.querySelectorAll('[data-sidebar-target]')).map((link) => [
        link.getAttribute('data-sidebar-target'),
        link,
      ]),
    );

    const setActive = (id) => {
      sectionLinks.forEach((link, key) => {
        if (!(link instanceof HTMLElement)) return;
        const isActive = key === id;
        link.classList.toggle('site-right-sidebar__pill--active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    if (sectionTargets.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntries = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

          if (!visibleEntries.length) return;

          const activeId = visibleEntries[0].target.getAttribute('id');
          if (activeId) setActive(activeId);
        },
        {
          rootMargin: '-30% 0px -42% 0px',
          threshold: [0.2, 0.45, 0.7],
        },
      );

      sectionTargets.forEach((section) => observer.observe(section));
    }
  })();
</script>

<style>
  .site-right-sidebar {
    position: fixed;
    right: 0;
    top: 50%;
    z-index: 100;
    display: grid;
    gap: 0.35rem;
    width: min(18rem, calc(100vw - 0.75rem));
    padding: 0.75rem 0.5rem 0.75rem 0.65rem;
    transform: translateY(-50%);
    background: rgba(10, 14, 19, 0.76);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border: 3px solid rgba(255, 255, 255, 0.08);
    border-right: none;
    border-radius: 2px 0 0 2px;
    box-shadow: 0 16px 44px rgba(0, 0, 0, 0.36);
    transition: width 220ms ease, transform 220ms ease;
  }

  .site-right-sidebar__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 2.8rem;
    padding: 0.55rem 0.7rem;
    border: 0;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.05);
    color: #f4efe8;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .site-right-sidebar__toggle-bars {
    display: grid;
    gap: 4px;
    flex-shrink: 0;
  }

  .site-right-sidebar__toggle-bars span {
    display: block;
    width: 1rem;
    height: 2px;
    border-radius: 999px;
    background: rgba(244, 239, 232, 0.88);
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .site-right-sidebar[data-expanded='true'] .site-right-sidebar__toggle-bars span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .site-right-sidebar[data-expanded='true'] .site-right-sidebar__toggle-bars span:nth-child(2) {
    opacity: 0;
  }

  .site-right-sidebar[data-expanded='true'] .site-right-sidebar__toggle-bars span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .site-right-sidebar__nav {
    display: grid;
    gap: 0.15rem;
  }

  .site-right-sidebar__group {
    display: grid;
    gap: 0;
  }

  .site-right-sidebar__pill {
    --pill-accent: #40c4c4;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    min-height: 2.6rem;
    padding: 0.5rem 0.75rem;
    border: 0;
    border-radius: 2px;
    background: transparent;
    color: #c8d0dc;
    cursor: pointer;
    text-decoration: none;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .site-right-sidebar__pill:hover,
  .site-right-sidebar__pill:focus-visible {
    background: rgba(255, 255, 255, 0.06);
    color: #f4efe8;
    outline: none;
  }

  .site-right-sidebar__pill--active {
    background: rgba(255, 255, 255, 0.09);
    color: #ffffff;
  }

  .site-right-sidebar__dot {
    flex-shrink: 0;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    background: var(--pill-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--pill-accent) 18%, transparent);
  }

  .site-right-sidebar__label {
    white-space: nowrap;
    flex: 1;
  }

  .site-right-sidebar__toggle-copy {
    white-space: nowrap;
  }

  .site-right-sidebar__chevron {
    font-size: 0.7rem;
    color: rgba(244, 239, 232, 0.4);
    transition: transform 200ms ease, color 200ms ease;
    margin-left: auto;
    flex-shrink: 0;
  }

  .site-right-sidebar__chevron--open {
    transform: rotate(180deg);
    color: var(--pill-accent);
  }

  /* ── Sub-navigation ──────────────────────────────────────────── */
  .site-right-sidebar__sub {
    display: grid;
    gap: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 280ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease;
    opacity: 0;
    padding-left: 1.4rem;
  }

  .site-right-sidebar__sub[aria-hidden='false'] {
    max-height: 20rem;
    opacity: 1;
  }

  .site-right-sidebar__sub-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.35rem 0.75rem;
    color: rgba(200, 208, 220, 0.7);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-left: 2px solid rgba(255, 255, 255, 0.06);
    transition: color 160ms ease, border-color 160ms ease;
  }

  .site-right-sidebar__sub-link:hover {
    color: #f4efe8;
    border-left-color: var(--pill-accent);
  }

  .site-right-sidebar__sub-dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background: var(--pill-accent);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .site-right-sidebar__sub-link:hover .site-right-sidebar__sub-dot {
    opacity: 1;
  }

  @media (min-width: 1024px) {
    .site-right-sidebar {
      width: 4rem;
    }

    .site-right-sidebar:hover,
    .site-right-sidebar[data-expanded='true'] {
      width: 16rem;
    }

    .site-right-sidebar__label,
    .site-right-sidebar__toggle-copy,
    .site-right-sidebar__chevron {
      opacity: 0;
      max-width: 0;
      overflow: hidden;
      transition: opacity 180ms ease, max-width 180ms ease;
    }

    .site-right-sidebar:hover .site-right-sidebar__label,
    .site-right-sidebar[data-expanded='true'] .site-right-sidebar__label,
    .site-right-sidebar:hover .site-right-sidebar__toggle-copy,
    .site-right-sidebar[data-expanded='true'] .site-right-sidebar__toggle-copy,
    .site-right-sidebar:hover .site-right-sidebar__chevron,
    .site-right-sidebar[data-expanded='true'] .site-right-sidebar__chevron {
      opacity: 1;
      max-width: 12rem;
    }

    .site-right-sidebar__sub {
      display: none;
    }

    .site-right-sidebar:hover .site-right-sidebar__sub,
    .site-right-sidebar[data-expanded='true'] .site-right-sidebar__sub {
      display: grid;
    }
  }

  @media (max-width: 1023px) {
    .site-right-sidebar {
      top: auto;
      bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
      transform: translateX(calc(100% - 2.8rem));
    }

    .site-right-sidebar[data-expanded='true'] {
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-right-sidebar,
    .site-right-sidebar__pill,
    .site-right-sidebar__toggle-bars span,
    .site-right-sidebar__label,
    .site-right-sidebar__toggle-copy,
    .site-right-sidebar__sub,
    .site-right-sidebar__chevron {
      transition: none !important;
    }
  }
</style>
