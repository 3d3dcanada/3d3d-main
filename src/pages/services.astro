---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: '3D3D Custom Fabrication Services',
  provider: {
    '@type': 'LocalBusiness',
    name: '3D3D',
    url: 'https://3d3d.ca',
  },
  description: 'Field-ready custom 3D printing and fabrication for marine, automotive, and industrial applications. On-site deployment, engineering-grade materials, retainer service.',
  areaServed: 'Worldwide',
  serviceType: ['Custom 3D Printing', 'Marine Fabrication', 'Automotive Restoration', 'Field Deployment', 'Retainer Service'],
};

const competitors = [
  { name: 'Xometry', url: 'https://www.xometry.com', note: 'Best for: high-volume industrial production runs, CNC + 3D hybrid quotes' },
  { name: 'Hubs (Protolabs Network)', url: 'https://www.hubs.com', note: 'Best for: standard-tolerance engineering parts, global marketplace' },
  { name: 'Shapeways', url: 'https://www.shapeways.com', note: 'Best for: consumer products, designer goods, small-batch runs' },
  { name: 'Craftcloud', url: 'https://craftcloud3d.com', note: 'Best for: price comparison across multiple print services' },
  { name: 'Treatstock', url: 'https://www.treatstock.com', note: 'Best for: finding local 3D printers in your city' },
  { name: 'i.materialise', url: 'https://i.materialise.com', note: 'Best for: professional prototypes, wide material options' },
  { name: 'Sculpteo', url: 'https://www.sculpteo.com', note: 'Best for: European orders, BASF-grade materials' },
  { name: 'Makexyz', url: 'https://www.makexyz.com', note: 'Best for: local peer-to-peer print matching' },
  { name: 'Etsy / Amazon sellers', url: 'https://www.etsy.com/ca/search?q=custom+3d+printing', note: 'Best for: decorative items, low-stakes consumer prints' },
  { name: 'Fiverr freelancers', url: 'https://www.fiverr.com/categories/programming-tech/3d-printing-services', note: 'Best for: budget design-and-print projects with flexible scope' },
];

const savings = [
  { range: '$500–$1,500', label: 'Marine hardware', example: 'Fairlead, cleat base, or instrument bracket. Machined quote: $800+. We print it for a fraction.' },
  { range: '$1,500–$3,000', label: 'Automotive restoration', example: 'Discontinued trim pieces, bracket assemblies, or intake components no longer in production.' },
  { range: '$3,000–$6,000+', label: 'Custom structural', example: '4 custom winch components — machined quote: $6,400. No OEM source. We made them.' },
  { range: 'Immeasurable', label: 'One-of-a-kind parts', example: 'When no machinist will touch it and no supplier has it. The only option — or it stays broken.' },
];

const retainerTiers = [
  {
    name: 'Field Ready',
    price: '$100',
    period: '/month',
    accent: 'teal',
    features: [
      'Priority queue — jobs move to front of line',
      '48h guaranteed turnaround',
      '10% discount on all production runs',
      'Monthly design consultation (30 min)',
      'Email / WhatsApp direct line to Ken',
    ],
    cta: 'Start Field Ready',
  },
  {
    name: 'On Retainer',
    price: '$300',
    period: '/month',
    accent: 'orange',
    highlight: true,
    features: [
      '24h response, 24h deployment ready',
      'Materials pre-stocked for your project profile',
      'Dedicated production slot — your jobs never wait',
      'Monthly consultation + design review (1 hr)',
      'Scanner available for part capture on request',
      'All Field Ready benefits included',
    ],
    cta: 'Get On Retainer',
  },
  {
    name: 'Embedded',
    price: '$1,000',
    period: '/month',
    accent: 'magenta',
    features: [
      'Full kit deployment — printer, scanner, materials to your location',
      'On-site visits (marina, garage, paddock, workshop)',
      'Unlimited consultations + design iterations',
      'Custom design + print, no limit on complexity',
      'Fleet support for multiple vessels or vehicles',
      'First call when something breaks',
    ],
    cta: 'Get Embedded',
  },
];
---

<BaseLayout
  title="Services | 3D3D — Custom Fabrication, Field Deployment & Retainer"
  description="Marine refit, automotive restoration, custom fabrication. On-site field deployment. Retainer plans from $100/month. We solve the problems other services can't."
  schema={schema}
  activePath="/services"
>
  <div class="svc-wrap">
    <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Services'}]} />

    <!-- ═══ HERO ═══ -->
    <section class="svc-hero surface-panel">
      <div class="svc-hero__inner">
        <p class="eyebrow">Specialist Fabrication · Field Ready · Worldwide</p>
        <h1 class="svc-hero__title">We solve problems<br />other services can't.</h1>
        <p class="svc-hero__sub">
          Marine hardware that no longer exists. Automotive parts that haven't been manufactured in twenty years. Custom structural components where the machining quote came back at ten times what it should cost. That's our work. One operator. Full kit. Ready to deploy.
        </p>
        <div class="svc-hero__actions">
          <a href="/quote" class="btn btn-primary">Get a Quote</a>
          <a href="/book" class="btn btn-ghost">Book a Call with Ken</a>
        </div>
      </div>
      <div class="svc-hero__stats">
        <div class="svc-stat">
          <span class="svc-stat__val">24h</span>
          <span class="svc-stat__key">Deployment ready</span>
        </div>
        <div class="svc-stat">
          <span class="svc-stat__val">15+</span>
          <span class="svc-stat__key">Material compounds</span>
        </div>
        <div class="svc-stat">
          <span class="svc-stat__val">$6k+</span>
          <span class="svc-stat__key">Max client savings</span>
        </div>
        <div class="svc-stat">
          <span class="svc-stat__val">635nm</span>
          <span class="svc-stat__key">Offshore deployment</span>
        </div>
      </div>
    </section>

    <!-- ═══ THREE PILLARS ═══ -->
    <section class="svc-section">
      <p class="eyebrow">What we build</p>
      <h2 class="svc-h2">Three specialities. One operator.</h2>
      <div class="svc-pillars">
        <div class="svc-pillar svc-pillar--teal">
          <div class="svc-pillar__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3L2 8l10 5 10-5-10-5z"/><path d="M2 16l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="svc-pillar__title">Marine Refit</h3>
          <p class="svc-pillar__body">Deck hardware, instrument housings, winch components, ventilation cowls, fairleads, mast fittings. Parts that live in salt spray, UV, and shock load. Printed in ASA, PETG-CF, or PA-CF — the materials that survive offshore conditions.</p>
          <ul class="svc-pillar__list">
            <li>Replacement fittings for obsolete hardware</li>
            <li>Custom mounts for electronics and instruments</li>
            <li>Structural brackets for modern retrofits</li>
            <li>On-site fabrication at the marina or aboard</li>
          </ul>
        </div>
        <div class="svc-pillar svc-pillar--orange">
          <div class="svc-pillar__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/><path d="M5 17H3v-4l2-5h11l3 5v4h-2M5 17h12M9 9v8"/></svg>
          </div>
          <h3 class="svc-pillar__title">Automotive Restoration</h3>
          <p class="svc-pillar__body">Brackets, block-off plates, trim pieces, intake components, sensor mounts, carburetor insulators. Classic and modified vehicles where the OEM part stopped shipping fifteen years ago. We reverse-engineer from measurements or worn originals.</p>
          <ul class="svc-pillar__list">
            <li>Discontinued interior and exterior trim</li>
            <li>Engine bay brackets and heat shields</li>
            <li>Underbody and chassis components</li>
            <li>Templates for bodywork and fabrication</li>
          </ul>
        </div>
        <div class="svc-pillar svc-pillar--magenta">
          <div class="svc-pillar__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="10" rx="2"/><path d="M7 7V4h10v3M7 17v3h10v-3"/><circle cx="17" cy="12" r="1"/></svg>
          </div>
          <h3 class="svc-pillar__title">Custom Fabrication</h3>
          <p class="svc-pillar__body">Industrial components, prototypes, tooling, fixtures, and any part where "it doesn't exist" is the current answer. We work from your file, your sketch, your worn part, or just a description of the problem. Engineering compounds for real-world load.</p>
          <ul class="svc-pillar__list">
            <li>Engineering-grade: PETG-CF, PA-CF, ASA, PC</li>
            <li>High-temp: PEI, PEEK (on request)</li>
            <li>Field deployment with full kit to your location</li>
            <li>Design + scan + print as a single service</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ═══ SAVINGS STORY ═══ -->
    <section class="svc-section svc-savings">
      <div class="svc-savings__left">
        <p class="eyebrow">The real cost comparison</p>
        <h2 class="svc-h2">What it actually saves you.</h2>
        <p class="svc-savings__intro">
          The value of custom fabrication isn't just the print cost. It's the machining quote you didn't pay. The part you couldn't source. The day you didn't lose waiting for an overseas shipment. Below is a realistic picture of client savings — not hypothetical. Real jobs.
        </p>
        <p class="svc-savings__note">
          Sometimes the cost is immeasurable. Older winch hardware, proprietary marine fittings, automotive parts that dwindled from catalogs in 2003 — when no machinist will quote it and no supplier has stock, the alternative to fabricating it is leaving the boat at the dock or the car in the garage.
        </p>
      </div>
      <div class="svc-savings__bars">
        {savings.map((s, i) => (
          <div class="svc-bar" style={`--bar-delay: ${i * 0.08}s`}>
            <div class="svc-bar__header">
              <span class="svc-bar__range">{s.range}</span>
              <span class="svc-bar__label">{s.label}</span>
            </div>
            <div class="svc-bar__track">
              <div class="svc-bar__fill" style={`--bar-w: ${[30, 55, 82, 100][i]}%`}></div>
            </div>
            <p class="svc-bar__example">{s.example}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══ HONEST COMPETITOR SECTION ═══ -->
    <section class="svc-section svc-comp" id="competitors">
      <div class="svc-comp__header">
        <p class="eyebrow">Industry context</p>
        <h2 class="svc-h2">Looking for cheap prints?<br />Here's where to go.</h2>
        <p class="svc-comp__intro">
          We mean this genuinely. If you need a decorative part, a prototype for a pitch deck, or a commodity print in PLA — you don't need us, and we'd be overpriced for the job. Below are the services we'd recommend in that scenario. They're legitimate, professional, and well-suited to volume and standard-tolerance work.
        </p>
        <p class="svc-comp__distinction">
          Where we're different: we take on jobs these services can't — parts that require on-site scanning and deployment, engineering compounds in controlled-environment printers, structural components for marine and motorsport, and the jobs where the spec doesn't exist yet and needs to be reverse-engineered from a worn original.
        </p>
      </div>
      <div class="svc-comp__grid">
        {competitors.map((c) => (
          <a href={c.url} class="svc-comp__item" target="_blank" rel="noopener noreferrer">
            <span class="svc-comp__name">{c.name}</span>
            <span class="svc-comp__note">{c.note}</span>
            <span class="svc-comp__arrow">↗</span>
          </a>
        ))}
      </div>
      <div class="svc-comp__cta-row">
        <div class="svc-comp__cta-text">
          <strong>Need something that isn't on that list?</strong>
          <span>That's what we're here for.</span>
        </div>
        <a href="/quote" class="btn btn-primary">Describe your problem →</a>
      </div>
    </section>

    <!-- ═══ RETAINER ═══ -->
    <section class="svc-section svc-retainer">
      <div class="svc-retainer__header">
        <p class="eyebrow">Ongoing service</p>
        <h2 class="svc-h2">The retainer. For clients who need us on call.</h2>
        <p class="svc-retainer__intro">
          Some clients have a single job. Others have ongoing fabrication needs — seasonal refit work, active race campaigns, classic car restorations spread over years, or industrial operations that produce wear parts on a schedule. The retainer is built for them. You pay a flat monthly fee. I hold a slot, stock the materials, and deploy within 24 hours when the call comes.
        </p>
      </div>
      <div class="svc-retainer__grid">
        {retainerTiers.map((tier) => (
          <div class={`svc-tier svc-tier--${tier.accent}${tier.highlight ? ' svc-tier--featured' : ''}`}>
            {tier.highlight && <div class="svc-tier__badge">Most Popular</div>}
            <div class="svc-tier__top">
              <span class="svc-tier__name">{tier.name}</span>
              <div class="svc-tier__price-row">
                <span class="svc-tier__price">{tier.price}</span>
                <span class="svc-tier__period">{tier.period}</span>
              </div>
            </div>
            <ul class="svc-tier__features">
              {tier.features.map((f) => (
                <li class="svc-tier__feature">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contact" class="svc-tier__cta">{tier.cta} →</a>
          </div>
        ))}
      </div>
      <p class="svc-retainer__note">
        Retainer pricing is month-to-month. No contracts, no lock-ins. If the workload shifts, the plan adjusts. <a href="/book">Book a call</a> to figure out what tier makes sense for your situation.
      </p>
    </section>

    <PageNextActions actions={[
      {label: 'Get a Quote', href: '/quote', description: 'Send files, describe the job. We review and respond within 24h.', accent: 'teal'},
      {label: 'Materials Guide', href: '/materials', description: 'Compare compounds by environment, temperature, and load requirements.', accent: 'orange'},
      {label: 'Book a Call', href: '/book', description: 'Talk directly with Ken. 30 minutes, no sales pitch.', accent: 'magenta'},
    ]} />
  </div>
</BaseLayout>

<style>
  .svc-wrap {
    width: min(100% - clamp(1rem, 3vw, 3rem), 1280px);
    margin: 0 auto;
    padding-block: 1.5rem 4rem;
  }

  /* ── Hero ── */
  .svc-hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 3vw, 3rem);
    margin-block: 1.5rem 2rem;
  }
  .svc-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin: 0.75rem 0 1rem;
    color: var(--color-text-primary);
  }
  .svc-hero__sub {
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    max-width: 60ch;
    margin-bottom: 2rem;
  }
  .svc-hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .svc-hero__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border-default);
    border: 1px solid var(--color-border-default);
    min-width: 200px;
    align-self: center;
  }
  .svc-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem;
    background: var(--color-surface-secondary);
  }
  .svc-stat__val {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1;
    color: var(--color-teal-primary);
  }
  .svc-stat__key {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-family: var(--font-tech);
  }

  /* ── Section common ── */
  .svc-section {
    margin-block: 3rem;
  }
  .svc-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0.5rem 0 1.5rem;
    color: var(--color-text-primary);
  }

  /* ── Pillars ── */
  .svc-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .svc-pillar {
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
    padding: clamp(1.5rem, 2.5vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: relative;
    overflow: hidden;
  }
  .svc-pillar::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
  }
  .svc-pillar--teal::before { background: var(--color-teal-primary); }
  .svc-pillar--orange::before { background: var(--color-orange-primary); }
  .svc-pillar--magenta::before { background: var(--color-magenta-primary); }
  .svc-pillar__icon {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    background: var(--color-surface-card, #F4F4F4);
    border: 1px solid var(--color-border-default);
  }
  .svc-pillar--teal .svc-pillar__icon svg { stroke: var(--color-teal-primary); }
  .svc-pillar--orange .svc-pillar__icon svg { stroke: var(--color-orange-primary); }
  .svc-pillar--magenta .svc-pillar__icon svg { stroke: var(--color-magenta-primary); }
  .svc-pillar__icon svg { width: 22px; height: 22px; }
  .svc-pillar__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: 0;
    color: var(--color-text-primary);
  }
  .svc-pillar__body {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .svc-pillar__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: auto;
  }
  .svc-pillar__list li {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }
  .svc-pillar__list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-border-default);
  }

  /* ── Savings ── */
  .svc-savings {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: start;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 3vw, 3rem);
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
  }
  .svc-savings__intro {
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .svc-savings__note {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    border-left: 2px solid var(--color-teal-primary);
    padding-left: 1rem;
    margin: 0;
  }
  .svc-savings__bars {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .svc-bar {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    animation: bar-in 0.5s ease both;
    animation-delay: var(--bar-delay, 0s);
  }
  @keyframes bar-in {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .svc-bar__header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .svc-bar__range {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-teal-primary);
    white-space: nowrap;
  }
  .svc-bar__label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-family: var(--font-tech);
  }
  .svc-bar__track {
    height: 6px;
    background: var(--color-border-default);
    border-radius: 2px;
    overflow: hidden;
  }
  .svc-bar__fill {
    height: 100%;
    width: var(--bar-w, 50%);
    background: linear-gradient(90deg, var(--color-teal-primary), var(--color-teal-light));
    border-radius: 2px;
  }
  .svc-bar:last-child .svc-bar__fill {
    background: linear-gradient(90deg, var(--color-magenta-primary), var(--color-magenta-light));
  }
  .svc-bar__example {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Competitors ── */
  .svc-comp {
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 3vw, 3rem);
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
  }
  .svc-comp__intro, .svc-comp__distinction {
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 72ch;
    margin-bottom: 1rem;
  }
  .svc-comp__distinction {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    padding: 1rem 1.2rem;
    border: 1px solid var(--color-border-default);
    background: var(--color-surface-card, #F8F8F8);
    margin-bottom: 2rem;
  }
  .svc-comp__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .svc-comp__item {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.25rem 0.5rem;
    padding: 1rem 1.1rem;
    background: var(--color-surface-card, #fff);
    border: 1px solid var(--color-border-default);
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .svc-comp__item:hover {
    border-color: var(--color-teal-primary);
    transform: translateY(-1px);
  }
  .svc-comp__name {
    font-family: var(--font-tech);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-text-primary);
    grid-column: 1;
    grid-row: 1;
  }
  .svc-comp__note {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    grid-column: 1;
    grid-row: 2;
  }
  .svc-comp__arrow {
    grid-column: 2;
    grid-row: 1;
    font-size: 0.9rem;
