---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
import { RACING_EVENTS, type RacingEvent } from '../data/racingEvents';

export function getStaticPaths() {
  return RACING_EVENTS.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

interface Props {
  event: RacingEvent;
}

const { event } = Astro.props;

const pageTitle = `3D Printed Marine Parts for ${event.name} | 3D3D Offshore Support`;
const pageDescription = `Emergency 3D printing and custom fabrication for ${event.name} teams. Structural marine hardware in CF-Nylon, ASA, and PC-Blend to survive offshore conditions.`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: `Marine 3D Printing Support for ${event.name}`,
    description: pageDescription,
    url: `https://3d3d.ca/event-support-${event.slug}`,
    provider: { '@id': 'https://3d3d.ca/#organization' },
    areaServed: event.location,
    serviceType: [
      'Marine 3D Printing',
      'Offshore Hardware Prototyping',
      'Emergency Spare Parts',
    ]
  }
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schema={schema}
  activePath={`/event-support-${event.slug}`}
>
  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/race-morning-crew.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <Breadcrumbs items={[
              { label: 'Home', href: '/' },
              { label: 'Event Support' },
              { label: event.name },
            ]} />
            <p class="hp-card__eyebrow mt-4">Offshore Fabrication Support</p>
            <h1 class="hp-card__title mt-2 mb-4">3D Printing for the {event.name}</h1>
            <p class="hp-card__copy hp-card__copy--lead mb-6">
              {event.description}
            </p>

            <div class="grid grid-cols-2 gap-4 bg-black/40 border border-white/10 p-4 rounded mb-8">
              <div class="flex flex-col">
                <span class="font-tech text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">Location</span>
                <span class="text-pink-400 font-display text-lg leading-none tracking-tight">{event.location}</span>
              </div>
              <div class="flex flex-col">
                <span class="font-tech text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">Timing</span>
                <span class="text-white font-display text-lg leading-none tracking-tight">{event.month}</span>
              </div>
            </div>

            <div class="hp-card__cta-row hp-card__cta-row--start">
              <a href="/contact" class="hp-cta hp-cta--accent">Request Support</a>
              <a href="/quote" class="hp-cta hp-cta--glass">Upload CAD for Quote</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Hardware Capabilities -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/golden-hour-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim" style="background: rgba(17, 18, 20, 0.85);"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <div class="w-full max-w-3xl mx-auto py-12 relative z-10">
          <h2 class="font-display text-3xl text-white uppercase tracking-tighter mb-4">Hardware capabilities for offshore teams</h2>
          <p class="text-lg text-gray-300 leading-relaxed mb-8">
            We do not print in hobby-grade plastics. When you are outfitting for {event.name}, you need parts that will survive UV, salt, and impact. We run ASA for permanent above-deck exposure, CF-Nylon for structural loaded fittings, and PC-Blend for massive impact resistance.
          </p>
          
          <div class="bg-black/40 border border-white/10 p-6 rounded-sm">
            <h3 class="font-tech text-teal-400 font-bold uppercase tracking-widest text-sm mb-4">Common Replacements</h3>
            <ul class="space-y-3">
              {event.hardwareNeeds.map(need => (
                <li class="flex items-start gap-3">
                  <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                  <span class="text-gray-300">{need}</span>
                </li>
              ))}
              <li class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <span class="text-gray-300">Halyard diverters and custom chafe guards</span>
              </li>
              <li class="flex items-start gap-3">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-teal-400 flex-shrink-0 mt-0.5"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <span class="text-gray-300">Instrument cowlings & electronics housing</span>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- Section 3: Next Actions -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <PageNextActions actions={[
              {label: 'Upload CAD for Quote', href: '/quote', description: 'Immediate pricing and structural review.', accent: 'teal'},
              {label: 'Contact Us', href: '/contact', description: 'Discuss complex reverse engineering.', accent: 'orange'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
</style>
