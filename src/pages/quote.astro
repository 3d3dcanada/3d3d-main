---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteCalculator from '../components/QuoteCalculator.tsx';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '3D3D Quote Request',
  description: 'Upload files, describe your part, and send a structured custom 3D printing request to 3D3D.',
  url: 'https://3d3d.ca/quote',
  applicationCategory: 'BusinessApplication',
};
---

<BaseLayout title="Get a Quote | 3D3D" description="Request a custom 3D print quote. Upload your design or describe what you need." schema={schema} activePath="/quote">
  <div class="max-w-4xl mx-auto px-4">
    <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Services', href: '/contact'}, {label: 'Get a Quote'}]} />
  </div>
  <section class="page-section">
    <div class="surface-panel quote-page-intro">
      <p class="quote-eyebrow">Project Intake</p>
      <h1 class="quote-title">Upload a File.<br />Get a Firm Quote.</h1>
      
      <div class="quote-intro-grid">
        <div class="quote-intro-text">
          <p class="quote-intro">
            Submit your CAD file or replacement part photos. Tell us what it does and the environment it lives in. We assess the mechanics, select the material, and return a firm quote within 24 hours.
          </p>
          <ul class="quote-bullets">
            <li><svg viewBox="0 0 24 24" fill="currentColor" width="16"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg> Direct operator contact — no middleman.</li>
            <li><svg viewBox="0 0 24 24" fill="currentColor" width="16"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg> Exact pricing based on machine hours + material.</li>
            <li><svg viewBox="0 0 24 24" fill="currentColor" width="16"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg> 100% functional guarantee.</li>
          </ul>
        </div>
        <div class="quote-hero-img">
          <img src="/media/workshop/printer-action-cf.jpg" alt="FDM machine printing carbon fiber" />
        </div>
      </div>
    </div>
  </section>

  <section class="page-section pt-0">
    <QuoteCalculator client:load />
  </section>

  <div class="max-w-4xl mx-auto px-4">
    <PageNextActions actions={[
      {label: 'Materials Guide', href: '/materials', description: 'Compare engineering compounds by environment and performance.', accent: 'teal'},
      {label: 'Browse the Shop', href: '/shop', description: 'Ready-made prints available for immediate order.', accent: 'orange'},
      {label: 'Book a Call', href: '/book', description: 'Talk through your project directly with Ken.', accent: 'magenta'},
    ]} />
  </div>
</BaseLayout>

<style>
  .quote-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .quote-eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: var(--color-teal-primary);
    flex-shrink: 0;
  }

  .quote-title {
    margin: 0 0 1.5rem 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 3vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    text-transform: uppercase;
  }

  .quote-intro-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .quote-intro-grid {
      grid-template-columns: 3fr 2fr;
    }
  }

  .quote-intro {
    margin: 0;
    font-size: clamp(1rem, 0.95rem + 0.4vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .quote-bullets {
    margin-top: 1.5rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .quote-bullets li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .quote-bullets svg {
    color: var(--color-teal-primary);
  }

  .quote-hero-img img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--color-border-subtle);
  }

  .quote-calculator-wrapper {
    margin-top: 1rem;
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: 4px;
    overflow: hidden;
  }
</style>
