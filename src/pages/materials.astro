---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const materials = [
  // ── ENGINEERING TIER ────────────────────────────────────
  {
    tier: 'Engineering',
    id: 'asa',
    name: 'ASA',
    full: 'Acrylonitrile Styrene Acrylate',
    hdt: '93°C',
    tags: ['UV-stable', 'Outdoor', 'Marine'],
    body: 'The outdoor compound. UV-stable where ABS yellows and cracks, ASA holds colour and geometry through full seasons of sun, salt spray, and temperature cycling. 93°C heat deflection. The default choice for above-deck marine hardware, exterior automotive panels, and anything that lives outside. Acetone-smoothable. Available in multiple colours.',
  },
  {
    tier: 'Engineering',
    id: 'petg-cf',
    name: 'PETG-CF',
    full: 'PETG Carbon Fiber',
    hdt: '>68°C (improved)',
    tags: ['Structural', 'Stiff', 'Low-creep'],
    body: 'PETG with recycled carbon fibre reinforcement. Better dimensional stability, higher modulus, and lower creep than standard PETG. Nearly odourless during printing. Matte black finish. The right call for structural brackets, load-bearing mounts, and parts that need to hold geometry under sustained force. Hardened nozzle required.',
  },
  {
    tier: 'Engineering',
    id: 'pc-blend',
    name: 'PC Blend',
    full: 'Polycarbonate Blend',
    hdt: '113°C',
    tags: ['Tough', 'Impact-resistant', 'Heat-resistant'],
    body: 'Strong, tough, and heat-resistant. PC Blend maintains toughness at low temperatures and resists creep under mechanical stress, properties that pure CF composites trade away for stiffness. 113°C heat deflection. The choice when a part takes real impacts and can\'t afford to shatter. Fan shrouds, structural enclosures, machine components.',
  },
  {
    tier: 'Engineering',
    id: 'pc-blend-cf',
    name: 'PC Blend CF',
    full: 'Polycarbonate Blend Carbon Fiber',
    hdt: '114°C / 130°C annealed',
    tags: ['Stiff', 'Structural', 'Heat-resistant'],
    body: 'PC Blend with recycled carbon fibre for added stiffness and improved temperature resistance. Annealing at 140°C for two hours raises the effective heat deflection to 130°C with less than 1% shrinkage. Flexural modulus reaches 4.2–4.9 GPa depending on orientation. Matte black. Hardened nozzle required. For mechanically loaded parts that also need heat performance.',
  },
  {
    tier: 'Engineering',
    id: 'pp-gf',
    name: 'PP Glass Fiber',
    full: 'Polypropylene Glass Fiber',
    hdt: '138°C',
    tags: ['Chemical-resistant', 'Marine', 'Lab'],
    body: 'Polypropylene with glass fibre reinforcement. The standout property: 0.11% moisture absorption at both 24 hours and 7 days. Stable, essentially zero. No swelling, no delamination, no geometry shift in saltwater or wet environments. Resists acids, solvents, non-oxidised bases, and oils. 138°C heat deflection. The right material for through-hull fittings, lab hardware, chemical-environment components, and anything in constant contact with water. Requires PP sheet and hardened nozzle.',
  },
  {
    tier: 'Engineering',
    id: 'pp-cf',
    name: 'PP Carbon Fiber',
    full: 'Polypropylene Carbon Fiber',
    hdt: '120°C',
    tags: ['Chemical-resistant', 'Lightweight', 'Structural'],
    body: 'Polypropylene with recycled carbon fibre. The same near-zero moisture absorption and chemical resistance of PP Glass Fiber, with added structural stiffness and a higher stiffness-to-weight ratio. Lightweight. No warping. 120°C HDT. The choice when PP-GF\'s chemical resistance is required alongside structural load-bearing. Hardened nozzle required. PP sheet bed surface.',
  },
  {
    tier: 'Engineering',
    id: 'pa11-cf',
    name: 'PA11 CF',
    full: 'Polyamide 11 Carbon Fiber',
    hdt: '192°C @ 0.45 MPa / 152°C @ 1.80 MPa',
    tags: ['High-temp', 'Automotive', 'Structural'],
    body: 'The engine bay material. PA11 CF runs to 192°C under low load and 152°C under 1.80 MPa, the highest heat deflection of any standard FDM compound short of PEI. Chemical resistance includes motor oils, fuels, benzene, ethanol, methanol, toluene, acetone, and NaOH. Bio-based from castor oil, reinforced with recycled carbon fibre. Charpy impact of 30–51 kJ/m² depending on orientation. Hardened nozzle required, enclosure recommended.',
  },
  {
    tier: 'Engineering',
    id: 'pc-space',
    name: 'PC Space Grade',
    full: 'Polycarbonate ESD, Space Grade',
    hdt: '137°C',
    tags: ['ESD-safe', 'Low-outgassing', 'Structural'],
    body: 'Purpose-built for space industry and particle physics. ESD-safe (surface resistivity 6.0×10⁷ Ω/sq). Total Mass Loss of 0.25% against an ESA limit of 1.0%, certified for vacuum environments. 137°C heat deflection, 72–75 MPa tensile yield strength. For electronics enclosures requiring ESD dissipation, satellite components, and any application where outgassing in vacuum is a disqualifying factor. Hardened nozzle required.',
  },
  {
    tier: 'Engineering',
    id: 'petg-v0',
    name: 'PETG V0',
    full: 'PETG Flame Retardant',
    hdt: '68°C',
    tags: ['Flame-retardant', 'UL94 V0', 'Enclosures'],
    body: 'The world\'s first UL94 V0-certified PETG filament. Self-extinguishing: forms a carbonised crust that cuts off oxygen and stops flame propagation. Compliant with IEC 60695-11-10. For electronics enclosures, insulation components, and machine guards where fire protection compliance is a requirement, not a preference. Must be dried before use. Natural and black available.',
  },
  {
    tier: 'Elite',
    id: 'pei-1010',
    name: 'PEI 1010',
    full: 'Polyetherimide (Ultem-class)',
    hdt: '207°C @ 0.45 MPa / 194°C @ 1.80 MPa',
    tags: ['Metal-replacement', 'Extreme-temp', 'Flame-retardant'],
    body: 'The ceiling. PEI 1010 runs to 207°C under low load and 194°C under 1.80 MPa, beyond anything else in FDM except specialised industrial systems. Inherent UL94 VTM-0 flame retardancy without additives. Autoclave sterilisable, gamma radiation resistant, electron beam sterilisable. 95 MPa tensile yield strength printed. Positioned as a direct metal-alloy replacement for aerospace, medical instruments, and any structural application that has exhausted every other material option. Requires Prusa Pro HT90 or equivalent heated-chamber system at 90°C minimum. Nozzle at 410°C. Must be dried 6–8 hours at 150°C before printing.',
  },
  // ── FLEXIBLE ────────────────────────────────────────────
  {
    tier: 'Flexible',
    id: 'tpu-95a',
    name: 'TPU 95A',
    full: 'Thermoplastic Polyurethane, Ether Type',
    hdt: '78°C @ 1.80 MPa',
    tags: ['Flexible', 'Seals', 'Impact-resistant'],
    body: 'Ether-type TPU, not ester. The distinction matters: ether formulation resists hydrolysis where ester degrades in wet environments over time. Maintains impact resistance to -50°C. Shore 95A hardness: firm at thick sections, flexible at thin. Extreme wear resistance. High microbial resistance. The compound for O-rings, seals, gaskets, cable boots, vibration dampening mounts, and any part that needs to flex without failing. Print slowly.',
  },
  // ── SPECIALTY ───────────────────────────────────────────
  {
    tier: 'Specialty',
    id: 'petg-magnetite',
    name: 'PETG Magnetite',
    full: 'PETG 40% Magnetite',
    hdt: '93°C',
    tags: ['Paramagnetic', 'ESD', 'High-density'],
    body: '40% magnetite fill by weight. Paramagnetic: attracted to magnets, cannot be permanently magnetised under standard conditions. Significantly higher density than standard PETG. For electromagnetic components, switches, induction loops, and weight-ballasting applications where mass per volume matters. Hardened nozzle required.',
  },
  {
    tier: 'Specialty',
    id: 'petg-tungsten',
    name: 'PETG Tungsten',
    full: 'PETG 75% Tungsten',
    hdt: '94°C',
    tags: ['Radiation-shielding', 'High-density', 'Lead-free'],
    body: '75% tungsten fill, the highest filler concentration in the catalogue and the densest printable material available. ~19 g/cm³, comparable to gold. Non-toxic, hypoallergenic, non-reactive. Purpose-built for X-ray and gamma radiation shielding in medical and radiography environments where lead is not acceptable. Hardened nozzle required. Polishable surface.',
  },
  // ── STANDARD ────────────────────────────────────────────
  {
    tier: 'Standard',
    id: 'petg',
    name: 'PETG',
    full: 'Polyethylene Terephthalate Glycol',
    hdt: '68°C',
    tags: ['General-purpose', 'Tough', 'Low-warp'],
    body: 'The general-purpose functional material. Tougher than PLA, lower warp than ABS, good chemical resistance, low moisture absorption. 68°C heat deflection limits it to non-heat-critical applications. Ductile, flexes before it shatters. Strong layer adhesion. The baseline for parts that need to work but don\'t face extreme conditions.',
  },
  {
    tier: 'Standard',
    id: 'pla',
    name: 'PLA',
    full: 'Polylactic Acid',
    hdt: '55°C',
    tags: ['Prototyping', 'Detail', 'Easy-print'],
    body: 'The prototyping compound. Easy to print, excellent detail resolution, no enclosure needed. Softens at 55–60°C. Not for functional parts exposed to heat, UV, or mechanical stress. Used for jigs, fit-check models, form prototypes, and anything that needs to be right before committing to an engineering compound. Not for end-use structural or outdoor applications.',
  },
  {
    tier: 'Standard',
    id: 'pvb',
    name: 'PVB',
    full: 'Polyvinyl Butyral',
    hdt: '<60°C',
    tags: ['Smoothable', 'Transparent', 'Design'],
    body: 'IPA-smoothable to a glass-like transparent finish. Similar mechanical properties to PETG. Used for design objects, lamp shades, transparent enclosures, and display components where surface quality and optical clarity matter more than structural performance. Isopropyl alcohol vapour or wipe produces near-glass surface quality.',
  },
];

const getPrusaNote = (m: { id: string }): string | null => {
  const hardenedNozzleRequired: string[] = [
    'petg-cf',
    'pc-blend-cf',
    'pp-gf',
    'pp-cf',
    'pa11-cf',
    'pc-space',
    'petg-magnetite',
    'petg-tungsten'
  ];
  if (hardenedNozzleRequired.includes(m.id)) {
    return 'Requires hardened nozzle. Available from Prusa Research.';
  }
  if (m.id === 'pei-1010') {
    return 'Requires Prusa Pro HT90 or equivalent heated-chamber system.';
  }
  return null;
};

const tiers = ['Elite', 'Engineering', 'Flexible', 'Specialty', 'Standard'];
const tierDescriptions: Record<string, string> = {
  Elite: 'Metal-replacement performance. Heated chamber required.',
  Engineering: 'Purpose-built for real working environments: marine, automotive, industrial.',
  Flexible: 'Seals, gaskets, vibration dampening. Flex without failure.',
  Specialty: 'Functional fill materials for specific electromagnetic, shielding, or magnetic applications.',
  Standard: 'Prototyping and general use. Know the limits.',
};

const tierColors: Record<string, string> = {
  Elite: '#E84A8A',
  Engineering: 'var(--color-teal-primary)',
  Flexible: '#F5A623',
  Specialty: '#9B59B6',
  Standard: '#7F8C8D',
};
---

<BaseLayout
  title="Materials | 3D3D"
  description="Every material I run. Engineering-grade compounds for marine, automotive, and field fabrication — from ASA to PEI 1010."
  activePath="/materials"
>
  <section class="mat-page">

    <!-- ═══ HERO ═══ -->
    <div class="mat-hero">
      <div class="mat-shell">
        <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Materials'}]} />
        <p class="mat-eyebrow scroll-in-left">Material Stack</p>
        <h1 class="mat-title scroll-in">What it takes<br />to survive<br />the salt.</h1>
        <p class="mat-intro scroll-in">
          Standard 3D printing plastics belong in a hobby shop. PLA softens at 55 degrees Celsius, absorbs moisture, and shatters under UV load. None of that is acceptable aboard a working vessel.
        </p>
        <p class="mat-intro scroll-in">
          Every material I run is selected for the conditions it will face, not for ease of printing. Marine hardware sees salt spray, UV cycling, and sustained mechanical load. Automotive parts live near fuel, oil, and heat. Field deployment means no spare parts, no excuses. The material has to be correct on the first print.
        </p>
      </div>
    </div>

    <!-- ═══ SALT RULE ═══ -->
    <div class="mat-salt-rule">
      <div class="mat-shell">
        <div class="mat-salt-rule__grid">
          <div class="mat-salt-rule__item mat-salt-rule__item--no">
            <span class="mat-salt-rule__label">PLA at sea</span>
            <span class="mat-salt-rule__verdict mat-salt-rule__verdict--no">Fails</span>
            <p class="mat-salt-rule__note">Softens at 55°C. Absorbs moisture. Degrades under UV. Not for any functional application.</p>
          </div>
          <div class="mat-salt-rule__item">
            <span class="mat-salt-rule__label">ASA above deck</span>
            <span class="mat-salt-rule__verdict mat-salt-rule__verdict--yes">Correct</span>
            <p class="mat-salt-rule__note">UV-stable. 93°C HDT. Holds colour and geometry through full seasons of salt spray and sun.</p>
          </div>
          <div class="mat-salt-rule__item">
            <span class="mat-salt-rule__label">PP Glass Fiber through-hull</span>
            <span class="mat-salt-rule__verdict mat-salt-rule__verdict--yes">Correct</span>
            <p class="mat-salt-rule__note">0.11% moisture absorption. Resists solvents, acids, and saltwater. Zero geometry shift in wet environments.</p>
          </div>
          <div class="mat-salt-rule__item">
            <span class="mat-salt-rule__label">PA11 CF in the engine bay</span>
            <span class="mat-salt-rule__verdict mat-salt-rule__verdict--yes">Correct</span>
            <p class="mat-salt-rule__note">192°C HDT. Resists motor oils, fuels, benzene, ethanol. The only FDM compound that survives a working engine compartment.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ MATERIAL TIERS ═══ -->
    {tiers.map((tier) => {
      const tierMats = materials.filter(m => m.tier === tier);
      const accentColor = tierColors[tier];
      return (
        <div class="mat-tier">
          <div class="mat-tier__header">
            <div class="mat-shell">
              <div class="mat-tier__header-inner">
                <span class="mat-tier__accent" style={`background: ${accentColor};`}></span>
                <div>
                  <p class="mat-tier__label" style={`color: ${accentColor};`}>{tier}</p>
                  <p class="mat-tier__desc">{tierDescriptions[tier]}</p>
                </div>
                <span class="mat-tier__count">{tierMats.length} material{tierMats.length !== 1 ? 's' : ''}</span>
              </div>
            </div>
          </div>
          <div class="mat-shell">
            <div class="mat-grid">
              {tierMats.map((m) => {
                const prusaNote = getPrusaNote(m);
                return (
                  <article class="mat-card scroll-in" id={m.id}>
                    <div class="mat-card__head">
                      <h2 class="mat-card__name">{m.name}</h2>
                      <span class="mat-card__hdt" style={`color: ${accentColor};`}>{m.hdt}</span>
                    </div>
                    <p class="mat-card__full">{m.full}</p>
                    <div class="mat-card__tags">
                      {m.tags.map(tag => (
                        <span class="mat-tag" style={`border-color: ${accentColor}30; color: ${accentColor};`}>{tag}</span>
                      ))}
                    </div>
                    <p class="mat-card__body">{m.body}</p>
                    {prusaNote && (
                      <p class="mat-card__prusa-note">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:2px;">
                          <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                        </svg>
                        {prusaNote}
                      </p>
                    )}
                    <a href="/contact" class="mat-card__cta" style={`border-color: ${accentColor};`}>Request Quote →</a>
                  </article>
                );
              })}
            </div>
          </div>
        </div>
      );
    })}

    <!-- ═══ WHEN TO USE WHAT ═══ -->
    <div class="mat-guide">
      <div class="mat-shell">
        <p class="mat-eyebrow" style="padding-top: 0;">When To Use What</p>
        <h2 class="mat-guide__title scroll-in">Start with the environment.<br />The material follows.</h2>
        <p class="mat-intro scroll-in" style="color: rgba(17,18,20,0.6);">
          Every material decision starts with the same question: what does this part have to survive? Pick the scenario below that matches your application. The recommendation is the compound I would use.
        </p>

        <div class="mat-guide__grid">
          <div class="mat-guide__card scroll-in">
            <div class="mat-guide__icon">&#9875;</div>
            <h3 class="mat-guide__scenario">Above deck, full sun</h3>
            <p class="mat-guide__conditions">UV exposure, salt spray, temperature cycling, rain</p>
            <div class="mat-guide__answer">
              <span class="mat-guide__pick">ASA</span>
              <p class="mat-guide__reason">UV-stable. 93°C HDT. Holds colour and geometry through full seasons of direct sun and salt. The only correct choice for anything permanently exposed above deck.</p>
            </div>
          </div>

          <div class="mat-guide__card scroll-in">
            <div class="mat-guide__icon">&#9881;</div>
            <h3 class="mat-guide__scenario">Engine bay or exhaust proximity</h3>
            <p class="mat-guide__conditions">Oil, fuel, high ambient heat, vibration</p>
            <div class="mat-guide__answer">
              <span class="mat-guide__pick">PA11 CF</span>
              <p class="mat-guide__reason">192°C HDT. Resists motor oils, fuels, benzene, ethanol. The only FDM compound that survives a working engine compartment without softening or outgassing.</p>
            </div>
          </div>

          <div class="mat-guide__card scroll-in">
            <div class="mat-guide__icon">&#127754;</div>
            <h3 class="mat-guide__scenario">Constant water contact</h3>
            <p class="mat-guide__conditions">Submerged, through-hull, bilge, saltwater immersion</p>
            <div class="mat-guide__answer">
              <span class="mat-guide__pick">PP Glass Fiber</span>
              <p class="mat-guide__reason">0.11% moisture absorption. Resists acids, solvents, and saltwater. Zero geometry shift in wet environments. The only compound rated for permanent water contact.</p>
            </div>
          </div>

          <div class="mat-guide__card scroll-in">
            <div class="mat-guide__icon">&#128296;</div>
            <h3 class="mat-guide__scenario">Structural bracket or mount</h3>
            <p class="mat-guide__conditions">Sustained mechanical load, vibration, impact risk</p>
            <div class="mat-guide__answer">
              <span class="mat-guide__pick">PETG-CF or PC Blend</span>
              <p class="mat-guide__reason">PETG-CF for stiff, low-creep brackets. PC Blend when the part takes real impacts and cannot afford to shatter. Choose based on whether rigidity or toughness matters more.</p>
            </div>
          </div>

          <div class="mat-guide__card scroll-in">
            <div class="mat-guide__icon">&#128260;</div>
            <h3 class="mat-guide__scenario">Seals, gaskets, vibration mounts</h3>
            <p class="mat-guide__conditions">Flex cycling, compression, temperature range, water</p>
            <div class="mat-guide__answer">
              <span class="mat-guide__pick">TPU 95A</span>
              <p class="mat-guide__reason">Ether-type, not ester. Resists hydrolysis. Maintains impact resistance to -50°C. Shore 95A hardness: firm at thick sections, flexible at thin. No substitute for parts that need to flex.</p>
            </div>
          </div>

          <div class="mat-guide__card scroll-in">
            <div class="mat-guide__icon">&#9889;</div>
            <h3 class="mat-guide__scenario">ESD-sensitive electronics</h3>
            <p class="mat-guide__conditions">Static discharge risk, clean environments, vacuum</p>
            <div class="mat-guide__answer">
              <span class="mat-guide__pick">PC Space Grade</span>
              <p class="mat-guide__reason">ESD-safe with 6.0x10&#8311; ohm/sq surface resistivity. 0.25% total mass loss (ESA limit is 1.0%). For enclosures where static discharge would destroy what is inside.</p>
            </div>
          </div>

          <div class="mat-guide__card scroll-in">
            <div class="mat-guide__icon">&#128293;</div>
            <h3 class="mat-guide__scenario">Fire compliance required</h3>
            <p class="mat-guide__conditions">UL94 rating needed, electrical enclosures, machine guards</p>
            <div class="mat-guide__answer">
              <span class="mat-guide__pick">PETG V0 or PEI 1010</span>
              <p class="mat-guide__reason">PETG V0 is UL94 V0 certified, self-extinguishing. PEI 1010 is inherent VTM-0 without additives and handles 207°C. Choose based on temperature and budget.</p>
            </div>
          </div>

          <div class="mat-guide__card scroll-in">
            <div class="mat-guide__icon">&#128736;</div>
            <h3 class="mat-guide__scenario">Prototype or fit check</h3>
            <p class="mat-guide__conditions">No heat, no UV, no structural load. Geometry verification only.</p>
            <div class="mat-guide__answer">
              <span class="mat-guide__pick">PLA</span>
              <p class="mat-guide__reason">Easy to print, excellent detail. Softens at 55°C. Not for end-use. Used to confirm geometry before committing to an engineering compound. Prototyping only.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ PRUSA ECOSYSTEM ═══ -->
    <div class="mat-prusa">
      <div class="mat-shell">
        <div class="mat-prusa__inner">
          <div>
            <p class="mat-eyebrow" style="padding-top:0; color: #FA6831;">Prusa Ecosystem</p>
            <h2 class="mat-prusa__title">Built on open-source hardware.</h2>
            <p class="mat-prusa__body">
              3D3D runs exclusively on the Prusa ecosystem. Open-source firmware, documented hardware, and a material compatibility library that is public. After a year of daily printing, Prusa Research recognized the work and is sending a CORE One L — their flagship enclosed CoreXY machine. That is recognition, not marketing.
            </p>
            <p class="mat-prusa__body">
              Materials marked with a hardened nozzle requirement work on any Prusa printer with the appropriate nozzle swap. PEI 1010 requires the Prusa Pro HT90 or an equivalent heated-chamber system.
            </p>
            <a href="https://www.prusa3d.com/" class="mat-prusa__link" target="_blank" rel="noopener noreferrer">
              Learn more at Prusa Research →
            </a>
          </div>
          <img src="/media/brand/prusa-logo.svg" alt="Prusa Research" class="mat-prusa__logo" loading="lazy" />
        </div>
      </div>
    </div>

    <!-- ═══ CTA ═══ -->
    <div class="mat-cta-block">
      <div class="mat-shell">
        <p class="mat-cta-block__eyebrow">Not sure what you need?</p>
        <h2 class="mat-cta-block__title">Tell me the problem.<br />I'll spec the material.</h2>
        <div class="mat-cta-block__actions">
          <a href="/contact" class="mat-cta">Request Service →</a>
          <a href="/book" class="mat-cta mat-cta--ghost">Book a Call →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════
     LIGHT-FIRST MATERIALS PAGE
     ═══════════════════════════════════════════════════ */

  .mat-page {
    background: var(--color-surface-primary);
    color: var(--color-text-primary);
    min-height: 100svh;
  }

  .mat-shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 1100px);
    margin: 0 auto;
  }

  /* ── Hero (dark band) ── */
  .mat-hero {
    background: #111214;
    padding-block: clamp(5rem, 8vw, 8rem) clamp(3rem, 5vw, 5rem);
  }

  .mat-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding-top: clamp(3rem, 5vw, 5rem);
  }

  .mat-eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: var(--color-teal-primary);
    flex-shrink: 0;
  }

  .mat-title {
    margin: 1rem 0 1.2rem;
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 4vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: #FFFFFF;
    text-transform: uppercase;
  }

  .mat-intro {
    margin: 0 0 1.25rem;
    max-width: 44rem;
    font-size: clamp(1rem, 0.9rem + 0.4vw, 1.15rem);
    line-height: 1.75;
    color: rgba(246, 247, 250, 0.78);
  }

  /* ── Salt rule comparison (dark band) ── */
  .mat-salt-rule {
    background: #111214;
    border-top: 1px solid rgba(64, 196, 196, 0.15);
    padding-block: clamp(2rem, 4vw, 3rem) clamp(3rem, 5vw, 5rem);
  }

  .mat-salt-rule__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
    gap: 1.2rem;
  }

  .mat-salt-rule__item {
    display: grid;
    gap: 0.5rem;
    padding: 1.2rem 1.4rem;
    border: 2px solid rgba(64, 196, 196, 0.2);
