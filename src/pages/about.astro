---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATALOG } from '../lib/catalog';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: '3D3D',
	description: 'Founder-operated specialty fabrication for marine, restoration, and route-based field deployment.',
	url: 'https://3d3d.ca',
	email: 'info@3d3d.ca',
	founder: { '@type': 'Person', name: 'Ken' },
	areaServed: ['Worldwide', 'Caribbean', 'Coastal United States', 'Europe'],
};

const stats = [
	{ value: `${CATALOG.length}+`, label: 'Products' },
	{ value: '24-48h', label: 'Turnaround' },
	{ value: 'Worldwide', label: 'Shipping' },
	{ value: '100%', label: 'Open Source' },
];
---

<BaseLayout title="About | 3D3D" description="Specialty fabrication cooperative for marine, restoration, and field deployment. What we do, why we exist, and how the network works." schema={schema} activePath="/about">

  <main class="hp-home">
    
    <!-- Section 1: What We Do -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/open-ocean-01.jpg'); background-position: center 40%;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'About'}]} />
            <p class="hp-card__eyebrow mt-4">Who We Are</p>
            <h1 class="hp-card__title mt-2 mb-4">Specialty fabrication for parts that survive real conditions.</h1>
            <p class="hp-card__copy">
              3D3D is a manufacturing cooperative that builds replacement parts, custom hardware, and functional components for marine, automotive restoration, and field deployment. We print in engineering-grade materials — ASA, PA-CF, PP-GF — designed for UV exposure, saltwater, heat, and mechanical stress.
            </p>
            <p class="hp-card__copy mt-3">
              You get firm quotes within 24 hours, parts shipping in 24 to 48 hours, and direct access to the operator building your part. No middlemen, no call centres, no mystery factories.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <button type="button" class="hp-cta hp-cta--accent" data-dialog-open="dlg-quote">Get a Quote</button>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: The Cooperative -->
    <section class="hp-section" style="--section-accent: #e84a8a;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">The Model</p>
            <h2 class="hp-card__title mt-2 mb-4">An open source manufacturing cooperative.</h2>
            <p class="hp-card__copy">
              We operate as a cooperative. Designs, code, operational blueprints, and documentation are all open source. We build tools so that makers anywhere can run the same quality process locally and independently.
            </p>
            <p class="hp-card__copy mt-3">
              When supply chains fail, you should not be waiting on a shipment from across the world. You contact the network, a local node builds the tested part, and it ships same-region. Makers keep 75% of order value.
            </p>
            
            <div class="hp-card__stats mt-8">
              {stats.map((stat) => (
                <div>
                  <strong>{stat.value}</strong>
                  <span>{stat.label}</span>
                </div>
              ))}
            </div>
            
            <div class="hp-card__cta-row hp-card__cta-row--start mt-8">
              <a href="https://github.com/3d3dcanada" target="_blank" class="hp-cta hp-cta--glass">GitHub Repositories</a>
              <a href="https://printables.com/@KTK3D_3050116" target="_blank" class="hp-cta hp-cta--glass">Printables</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: How it Works & Next Steps -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/workshop/printer-action-cf.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">The Execution</p>
            <h2 class="hp-card__title mt-2 mb-6">How it works on the ground.</h2>
            
            <div class="flex flex-col gap-6 mb-8">
              <div>
                <strong class="text-teal-400 font-tech tracking-wider uppercase text-sm">01 / The Brief</strong>
                <p class="hp-card__copy mt-1">Describe what you need: hard-to-find parts for a boat, props for a race, or custom pieces for a community build.</p>
              </div>
              <div>
                <strong class="text-teal-400 font-tech tracking-wider uppercase text-sm">02 / The Fleet</strong>
                <p class="hp-card__copy mt-1">We bring the equipment on-site, print parts in real time, and document the process on video, or we dispatch it to a local node.</p>
              </div>
              <div>
                <strong class="text-teal-400 font-tech tracking-wider uppercase text-sm">03 / The Delivery</strong>
                <p class="hp-card__copy mt-1">Walk away with functional printed parts, video content of the build, and a story worth sharing.</p>
              </div>
            </div>

            <PageNextActions actions={[
              {label: 'Get a Quote', href: '/quote', description: 'Upload your file and get a firm quote.', accent: 'teal'},
              {label: 'Join the Network', href: '/network', description: 'Work with us as a maker or node operator.', accent: 'magenta'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  /* Local overrides mapped directly to index.astro architecture */
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
</style>
