---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const faqs = [
  {
    category: 'Process',
    items: [
      {
        q: 'How do I get a quote?',
        a: 'Send us photos of the broken or missing part, the mounting area, and caliper measurements if you have them. Email, WhatsApp, or the contact form. We will assess the job and quote it within 24 hours.',
      },
      {
        q: 'Do I need a CAD file?',
        a: 'No. Most of our clients do not have CAD files. We reverse-engineer from the physical part, from photos, or from measurements. If you have a file, great. If not, we handle it.',
      },
      {
        q: 'What is the turnaround time?',
        a: 'Most parts ship within 24 to 48 hours of design approval. Complex multi-part assemblies or on-site deployments are scoped individually. We will give you an exact timeline before we start.',
      },
      {
        q: 'Do you ship internationally?',
        a: 'Yes. Worldwide. We have shipped parts to the Caribbean, Europe, Southeast Asia, and the Pacific. If your vessel is somewhere, we can get the part there.',
      },
    ],
  },
  {
    category: 'Materials',
    items: [
      {
        q: 'Can I use PLA on a boat?',
        a: 'No. PLA softens at 55 degrees Celsius, absorbs moisture, and degrades under UV. For marine applications, we use ASA above deck, PP Glass Fiber for saltwater contact, and PA11 CF near engines.',
      },
      {
        q: 'What material goes above deck?',
        a: 'ASA. UV-stable, 93 degree heat deflection, holds colour and geometry through full seasons of salt spray and sun. It is the default for any part that lives outside.',
      },
      {
        q: 'What about parts near the engine?',
        a: 'PA11 CF. 192 degree heat deflection under low load. Resists motor oils, fuels, benzene, ethanol, acetone. The only FDM compound that survives a working engine compartment.',
      },
      {
        q: 'What material resists saltwater immersion?',
        a: 'PP Glass Fiber. 0.11% moisture absorption. No swelling, no delamination, no geometry shift. Resists acids, solvents, and saltwater. The right call for through-hull fittings and anything in constant contact with water.',
      },
      {
        q: 'Can you match metal part strength?',
        a: 'PEI 1010 runs to 207 degrees and has 95 MPa tensile yield. It is positioned as a direct metal-alloy replacement for specific applications. Not everything, but many brackets, enclosures, and structural components.',
      },
    ],
  },
  {
    category: 'On-Site Work',
    items: [
      {
        q: 'Will you come to my boat?',
        a: 'Yes. We travel worldwide with the equipment. Tell us where the vessel is and what the problem is. We will assess whether on-site work is the right approach and handle the logistics from there.',
      },
      {
        q: 'What do you bring on-site?',
        a: 'Full material stack, printer, measurement tools, and everything needed to assess, design, and fabricate on location. We arrive self-contained.',
      },
      {
        q: 'Can you join a race crew?',
        a: 'Yes. Our team stands watch and brings the fabrication equipment. Newport-Bermuda 2026 aboard CSM the Mariner is the next deployment. When hardware fails at sea, we are below deck engineering the replacement while the boat holds heading.',
      },
    ],
  },
  {
    category: 'Pricing',
    items: [
      {
        q: 'How much does a part cost?',
        a: 'Depends on the part. Simple brackets and fittings start around $30 to $50 CAD. Complex multi-component assemblies or high-temperature engineering compounds cost more. We quote every job individually after assessment.',
      },
      {
        q: 'Is it cheaper than OEM?',
        a: 'Almost always. And faster. A discontinued marine fitting from a dealer, if they even have it, can cost hundreds and take weeks. We can rebuild it in days for a fraction. The real savings are in dockage fees you are not paying while waiting.',
      },
      {
        q: 'Do you charge for assessment?',
        a: 'No. Send us the photos and measurements. We will tell you what it takes, what it costs, and whether we can do it. No obligation.',
      },
    ],
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.flatMap(cat =>
    cat.items.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    }))
  ),
};
---

<BaseLayout
  title="FAQ | 3D3D"
  description="Frequently asked questions about 3D3D's fabrication services, materials, turnaround, pricing, and on-site deployment."
  schema={schema}
  activePath="/faq"
>
  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40C4C4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'FAQ'}]} />
            <p class="hp-card__eyebrow mt-4">Questions</p>
            <h1 class="hp-card__title mt-2 mb-4">Frequently Asked</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              If the answer is not here, use the chatbot or contact us directly. We do not charge for assessments.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: Questions -->
    <section class="hp-section" style="--section-accent: #E84A8A; min-height: 100svh;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim" style="background: rgba(17, 18, 20, 0.9);"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="pg-card scroll-in" style="max-width: 52rem;">
          {faqs.map((cat) => (
            <div class="pg-faq-group">
              <h2 class="pg-faq-group__title">{cat.category}</h2>
              {cat.items.map((item) => (
                <details class="pg-faq">
                  <summary>{item.q}</summary>
                  <div class="pg-faq__answer">{item.a}</div>
                </details>
              ))}
            </div>
          ))}
        </article>
      </div>
    </section>

    <!-- Section 3: Next Actions -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/workshop/printer-action-cf.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <PageNextActions actions={[
              {label: 'Get a Quote', href: '/quote', description: 'Ready to start? Upload your files and get an estimate.', accent: 'teal'},
              {label: 'Materials Guide', href: '/materials', description: 'Deep technical specs on every compound we print.', accent: 'orange'},
              {label: 'Contact', href: '/contact', description: 'Question not answered? Reach out directly.', accent: 'magenta'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
</style>
