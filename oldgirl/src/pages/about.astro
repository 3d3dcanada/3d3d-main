---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandSidebar from '../components/BrandSidebar.tsx';

const sidebarNav = [{
  label: 'Old Girl',
  items: [
    { id: 'home', label: 'Home', href: '/' },
    { id: 'about', label: 'About', href: '/about' },
    { id: 'blog', label: 'Blog', href: '/blog' },
    { id: 'contact', label: 'Contact', href: '/contact' },
  ],
}];
---

<BaseLayout
  title="About — The Old Girl"
  description="The story of a broken Prusa i3 MK2.5S, restored by one operator and handed over to the internet. Community 3D printing from Moncton, NB."
  accent="#8B5CF6"
>
  <BrandSidebar slot="sidebar" client:load navGroups={sidebarNav} activePath="/about" />

  <div class="pt-16 pl-0 lg:pl-4">
    <section class="px-6 lg:px-12 py-12">
      <div class="max-w-3xl">
        <p class="text-[10px] uppercase tracking-[0.25em] mb-2" style="color: var(--color-text-muted); font-family: var(--font-display);">The Story</p>
        <h1 class="text-3xl sm:text-4xl font-bold mb-8" style="color: var(--color-text-primary); font-family: var(--font-display);">About the Old Girl</h1>

        <div class="space-y-5 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          <p>
            The Old Girl is a Prusa i3 MK2.5S with MMU2S — a multi-material upgrade that lets the printer switch between five filament colours mid-print. She arrived broken in February 2026: a bent frame, a dead extruder motor, and an MMU that wouldn't index. Cost: $0.
          </p>
          <p>
            After a full teardown and rebuild — new extruder motor, straightened frame, rebuilt heatblock, new MMU idler and selector motor — the first five-colour test print succeeded on March 10th. The current load is Lime Green Galaxy ABS.
          </p>
          <p>
            The concept is simple: a community-owned printer that takes print jobs from the internet, funded by Ko-fi donations, with a public queue and community voting on what gets printed. No accounts, no subscriptions — just a printer that belongs to everyone.
          </p>
          <p>
            The Old Girl is run by <a href="https://3d3d.ca" class="underline" style="color: var(--color-purple-primary);">3D3D Atlantic Cooperative</a> in Moncton, NB. The cooperative coordinates 50+ independent 3D printing makers across Atlantic Canada.
          </p>
        </div>

        {/* Specs */}
        <div class="mt-12 border-t pt-8" style="border-color: var(--color-border-subtle);">
          <h2 class="text-lg font-bold mb-4" style="color: var(--color-text-primary); font-family: var(--font-display);">Hardware Specs</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {[
              { label: 'Printer', val: 'Prusa i3 MK2.5S' },
              { label: 'Multi-Material', val: 'MMU2S (5 channels)' },
              { label: 'Build Volume', val: '250 × 210 × 200 mm' },
              { label: 'Layer Height', val: '0.05 – 0.35 mm' },
              { label: 'Current Material', val: 'Lime Green Galaxy ABS' },
              { label: 'Nozzle', val: '0.4 mm hardened' },
            ].map(s => (
              <div class="p-3 rounded-lg" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle);">
                <span class="block text-[9px] uppercase tracking-wider mb-1" style="color: var(--color-text-muted); font-family: var(--font-display);">{s.label}</span>
                <span class="block text-[13px] font-medium" style="color: var(--color-text-primary);">{s.val}</span>
              </div>
            ))}
          </div>
        </div>

        {/* Roadmap */}
        <div class="mt-12 border-t pt-8" style="border-color: var(--color-border-subtle);">
          <h2 class="text-lg font-bold mb-6" style="color: var(--color-text-primary); font-family: var(--font-display);">Roadmap</h2>
          <div class="space-y-4">
            {[
              { stage: 'Stage One (Live)', status: 'done', items: ['Printer restored and operational', 'Blog live and crawlable', 'Community preview page', 'Ko-fi support link active', 'Honest "coming soon" gating'] },
              { stage: 'Stage Two (Coming)', status: 'pending', items: ['Live print queue with submissions', 'Supabase realtime printer monitoring', 'Ko-fi filament fund with progress bar', 'Community voting on next print', 'Livestream integration', 'Queue jump via Ko-fi'] },
            ].map(r => (
              <div class="p-5 rounded-xl" style={`background: var(--color-surface-card); border: 1px solid ${r.status === 'done' ? 'var(--color-border-default)' : 'var(--color-border-subtle)'};`}>
                <div class="flex items-center gap-2 mb-3">
                  <span class="w-2 h-2 rounded-full" style={`background: ${r.status === 'done' ? 'var(--color-lime-primary)' : 'var(--color-text-muted)'};`} />
                  <span class="text-sm font-bold" style="color: var(--color-text-primary); font-family: var(--font-display);">{r.stage}</span>
                </div>
                <ul class="space-y-1">
                  {r.items.map(item => (
                    <li class="text-[13px]" style="color: var(--color-text-secondary);">• {item}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
