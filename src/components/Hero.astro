---
interface Props {
  headline: string;
  subhead?: string;
  accent?: string;
  bgColor?: string;
  size?: 'full' | 'large' | 'medium' | 'small';
}

const {
  headline,
  subhead,
  accent = '#40C4C4',
  bgColor = 'var(--color-surface-primary)',
  size = 'large',
} = Astro.props;

// Size configurations - no more 80-100vh heroes
const sizeClasses = {
  full: 'py-16 lg:py-24',
  large: 'py-12 lg:py-20',
  medium: 'py-8 lg:py-14',
  small: 'py-6 lg:py-10',
};

const headingSizes = {
  full: 'text-hero',
  large: 'text-display',
  medium: 'text-heading-xl',
  small: 'text-heading-lg',
};
---

<section
  class:list={['relative', 'overflow-hidden', sizeClasses[size]]}
  style={`background: ${bgColor};`}
>
  {/* Ambient gradient mesh - light, colorful */}
  <div
    class="absolute inset-0 pointer-events-none"
    style=`
      background: 
        radial-gradient(ellipse at 20% 30%, rgba(64, 196, 196, 0.12) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(232, 74, 138, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(240, 136, 176, 0.06) 0%, transparent 40%);
    `
  />

  <div class="relative z-10 max-w-4xl">
    <h1
      class:list={['font-display', 'font-bold', 'tracking-tight', 'leading-tight', headingSizes[size]]}
      style="color: var(--color-text-primary);"
    >
      <slot name="headline">
        {headline}
      </slot>
    </h1>

    {subhead && (
      <p
        class="mt-6 max-w-2xl text-body-lg"
        style="color: var(--color-text-secondary);"
      >
        {subhead}
      </p>
    )}

    <div class="mt-8">
      <slot />
    </div>
  </div>

  {/* Visual slot (optional side content) */}
  <slot name="visual" />
</section>
