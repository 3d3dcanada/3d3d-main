---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
---

<BaseLayout title="Community Workshops & Events | 3D3D" description="Book 3D3D for STEM workshops, library events, and community festivals. We bring the printers to you." activePath="/community">

  <section class="opp-page">
    <div class="opp-shell">
      <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Explore', href: '/about'}, {label: 'Community Events'}]} />
      <p class="opp-eyebrow">Deployments</p>
      <h1 class="opp-title">Book the Lab</h1>
      <p class="opp-intro">
        We don't just print parts. We teach communities how to build the tools. Book 3D3D for your next STEM event, library workshop, or festival. We show up with the printers, the filament, and the knowledge.
      </p>

      <div class="mt-8 space-y-6">
        <div class="opp-listing surface-panel">
          <div class="opp-listing__header">
            <h2 class="opp-listing__role">Intro to 3D Printing Workshop</h2>
            <div class="opp-listing__meta">
              <span>2-4 Hours</span>
              <span>Libraries & Schools</span>
            </div>
          </div>
          <div class="opp-listing__body">
            <p>A hands-on introduction to the FDM workflow. We cover the history, materials, and CAD basics. Participants get to prepare a file and watch it print live. Built for audiences 14+ with capacity for up to 20 participants.</p>
          </div>
          <a href="/contact?subject=book-workshop" class="opp-cta">Request Workshop →</a>
        </div>

        <div class="opp-listing surface-panel">
          <div class="opp-listing__header">
            <h2 class="opp-listing__role">Youth STEM Discovery Day</h2>
            <div class="opp-listing__meta">
              <span>Full Day</span>
              <span>Ages 8-18</span>
            </div>
          </div>
          <div class="opp-listing__body">
            <p>An immersive day of building and prototyping. Focuses on inspiring the next generation of engineers and problem solvers through active CAD design and rapid prototyping challenges.</p>
          </div>
          <a href="/contact?subject=book-stem-day" class="opp-cta">Book Discovery Day →</a>
        </div>

        <div class="opp-listing surface-panel">
          <div class="opp-listing__header">
            <h2 class="opp-listing__role">Festival & Public Activations</h2>
            <div class="opp-listing__meta">
              <span>Multi-Day</span>
              <span>High Volume</span>
            </div>
          </div>
          <div class="opp-listing__body">
            <p>From the Cardboard Boat Regatta to local maker faires. We set up an active print farm environment, producing functional parts and engaging with hundreds of attendees in real-time.</p>
          </div>
          <a href="/contact?subject=event-activation" class="opp-cta">Discuss Activation →</a>
        </div>
      </div>

      <PageNextActions actions={[
        {label: 'Sponsor an Event', href: '/sponsors', description: 'Fund these workshops for your community.', accent: 'teal'},
        {label: 'Book a Call', href: '/book', description: 'Schedule a discovery call to plan your event.', accent: 'orange'},
      ]} />
    </div>
  </section>
</BaseLayout>

<style>
  .opp-page {
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: var(--color-surface-primary);
    color: var(--color-text-primary);
  }

  .opp-shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 720px);
    margin: 0 auto;
    display: grid;
    gap: 2rem;
    padding-block: clamp(6rem, 10vw, 10rem);
  }

  .opp-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .opp-eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: var(--color-teal-primary);
    flex-shrink: 0;
  }

  .opp-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 4vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    text-transform: uppercase;
  }

  .opp-intro {
    margin: 0;
    max-width: 36rem;
    font-size: clamp(1.05rem, 0.95rem + 0.4vw, 1.2rem);
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .opp-listing {
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .opp-listing__header {
    display: grid;
    gap: 0.6rem;
  }

  .opp-listing__role {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1rem + 1.5vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .opp-listing__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.4rem;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal-primary);
  }

  .opp-listing__body {
    display: grid;
    gap: 0.8rem;
  }

  .opp-listing__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .opp-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.4rem;
    padding: 0.95rem 1.6rem;
    background: var(--color-teal-primary);
    color: #0F1112;
    border: 3px solid var(--color-text-primary);
    border-radius: 2px;
    font-family: var(--font-tech);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: background-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
    box-shadow: 0 14px 32px rgba(64, 196, 196, 0.22);
  }

  .opp-cta:hover {
    background: #53D3D3;
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.4);
    transform: translateY(-2px);
  }
</style>
