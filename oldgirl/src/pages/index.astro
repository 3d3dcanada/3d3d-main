---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandSidebar from '../components/BrandSidebar.tsx';

const sidebarNav = [{
  label: 'Old Girl',
  items: [
    { id: 'home', label: 'Home', href: '/' },
    { id: 'about', label: 'About', href: '/about' },
    { id: 'blog', label: 'Blog', href: '/blog' },
    { id: 'contact', label: 'Contact', href: '/contact' },
  ],
}];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Thing',
  name: 'The Old Girl',
  description: 'Community 3D printer — Prusa i3 MK2.5S with MMU2S. Print queue, donations, livestream. Run by 3D3D Atlantic Cooperative.',
  url: 'https://oldgirl.3d3d.ca',
};

const restorationLog = [
  { date: '2026-02-14', status: 'done', entry: 'Acquired the printer — broken MMU2S, bent frame, dead extruder motor. $0 cost.' },
  { date: '2026-02-28', status: 'done', entry: 'Full teardown. Replaced extruder motor, straightened frame, rebuilt heatblock.' },
  { date: '2026-03-10', status: 'done', entry: 'MMU2S rebuilt with new idler and selector motor. First successful 5-colour test print.' },
  { date: '2026-03-12', status: 'done', entry: 'Loaded Lime Green Galaxy ABS. Stage One preview launched — blog live, queue in standby.' },
  { date: 'TBD', status: 'pending', entry: 'Stage Two — live queue, Supabase realtime, Ko-fi filament fund, community voting.' },
];

const fundingTiers = [
  { name: 'Filament Backer', amount: '$5+', desc: 'Your donation goes directly to filament. Every $5 buys ~30m of material.' },
  { name: 'Queue Jumper', amount: '$15+', desc: 'Skip the line. Your print moves to the top of the community queue.' },
  { name: 'Patron', amount: '$25+', desc: 'Named on the donor wall, priority queue access, and a print of your choice each month.' },
];

const suggestions = [
  { text: 'A launch-day keychain for community backers', votes: 12 },
  { text: 'Benchy colour test once the MMU channels are stable', votes: 9 },
  { text: 'A live repair part pack for other aging Prusas', votes: 7 },
];

// Printer color mapping
const C = {
  purple: '#8B5CF6',   // Galaxy purple — frame panels
  lime: '#84CC16',     // Neon lime — filament
  orange: '#F97316',   // Prusa orange — brand
  frame: '#1C1917',    // Black frame — structural
};
---

<BaseLayout
  title="The Old Girl — Community 3D Printer"
  description="A Prusa i3 MK2.5S with MMU2S, restored and given to the community. Print queue, Ko-fi donations, livestream. Run by 3D3D Atlantic Cooperative in Moncton, NB."
  schema={schema}
  accent="#8B5CF6"
>
  <BrandSidebar slot="sidebar" client:load navGroups={sidebarNav} activePath="/" />

  <div class="pt-16 pl-0 lg:pl-4">

    {/* ── STAGE ONE BANNER ── */}
    <div class="px-6 lg:px-12 pt-6">
      <div class="max-w-4xl rounded-lg px-5 py-3 flex items-start gap-3" style={`background: rgba(249,115,22,0.1); border: 1px solid rgba(249,115,22,0.3);`}>
        <span class="text-[10px] uppercase tracking-[0.18em] mt-0.5 flex-shrink-0" style={`color: ${C.orange}; font-family: var(--font-display);`}>Stage One Preview</span>
        <p class="text-[12px] leading-relaxed" style="color: var(--color-text-secondary);">
          The Old Girl is restored and standing by. Live queue, realtime monitoring, and Ko-fi integration are in final hardening. This page is a live preview — the printer is ready, systems are not yet.
        </p>
      </div>
    </div>

    {/* ── HERO ── */}
    <section class="relative px-6 lg:px-12 py-14">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 30% 0%, rgba(139,92,246,0.1) 0%, transparent 55%);" aria-hidden="true" />

      <div class="relative max-w-4xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-3 h-3 rounded-full" style={`background: ${C.purple}; box-shadow: 0 0 12px rgba(139,92,246,0.5);`} />
          <span class="text-[9px] uppercase tracking-[0.2em]" style="color: var(--color-text-muted); font-family: var(--font-display);">Community Printer · Moncton NB</span>
        </div>

        <h1 class="font-display font-bold leading-[1.05]" style="font-size: clamp(2.5rem, 6vw, 5rem); color: var(--color-text-primary);">
          The Old<br />
          <span style={`color: ${C.purple};`}>Girl</span>
        </h1>

        <p class="mt-5 max-w-xl leading-relaxed" style="font-size: 0.9375rem; color: var(--color-text-secondary);">
          A Prusa i3 MK2.5S with MMU2S. Acquired broken, rebuilt from scratch, loaded with Lime Green Galaxy ABS. This printer belongs to the internet.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md px-6 py-3 text-[11px] font-semibold uppercase tracking-[0.12em] transition-all duration-200"
            style={`background: ${C.purple}; color: #fff; min-height: 44px; font-family: var(--font-display);`}>
            Support on Ko-fi
          </a>
          <a href="/about"
            class="inline-flex items-center gap-2 rounded-md px-6 py-3 text-[11px] font-semibold uppercase tracking-[0.12em] transition-all duration-200"
            style="background: transparent; color: var(--color-text-primary); border: 2px solid var(--color-border-default); min-height: 44px; font-family: var(--font-display);">
            The Story
          </a>
        </div>

        {/* Printer specs strip — each spec uses a different printer color */}
        <div class="mt-12 flex flex-wrap gap-x-8 gap-y-4 border-t pt-6" style="border-color: var(--color-border-subtle);">
          {[
            { val: 'Prusa i3 MK2.5S', label: 'Printer', color: C.orange },
            { val: 'MMU2S', label: 'Multi-Material', color: C.purple },
            { val: 'Lime Green Galaxy', label: 'Current Filament', color: C.lime },
            { val: 'ABS', label: 'Material', color: C.frame },
            { val: 'Stage One', label: 'Mode', color: C.orange },
          ].map(s => (
            <div>
              <span class="block text-sm font-bold" style={`color: ${s.color}; font-family: var(--font-display);`}>{s.val}</span>
              <span class="block text-[9px] uppercase tracking-[0.18em] mt-0.5" style="color: var(--color-text-muted); font-family: var(--font-display);">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── PRINTER STATUS (PREVIEW) ── */}
    <section class="px-6 lg:px-12 pb-14" aria-labelledby="status-heading">
      <div class="max-w-4xl">
        <h2 id="status-heading" class="text-[10px] font-semibold uppercase tracking-[0.25em] mb-4" style="color: var(--color-text-muted); font-family: var(--font-display);">
          Printer Status
        </h2>
        <div class="p-5 rounded-xl" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle); box-shadow: var(--shadow-sm);">
          <div class="flex items-center gap-3 mb-3">
            <span class="w-2 h-2 rounded-full" style={`background: ${C.orange};`} />
            <span class="font-display text-xs uppercase tracking-wider" style={`color: ${C.orange};`}>Idle — Preview Mode</span>
          </div>
          <p class="text-[13px]" style="color: var(--color-text-secondary);">Community queue opens after live systems test. Material: Lime Green Galaxy ABS.</p>
          <p class="mt-3 text-[11px] uppercase tracking-wider" style="color: var(--color-text-muted); font-family: var(--font-display);">Live monitoring and realtime queue coming in Stage Two.</p>
        </div>
      </div>
    </section>

    {/* ── COMMUNITY QUEUE (PREVIEW) ── */}
    <section class="px-6 lg:px-12 pb-14" aria-labelledby="queue-heading">
      <div class="max-w-4xl">
        <div class="border-t pt-10" style="border-color: var(--color-border-subtle);">
          <h2 id="queue-heading" class="text-lg font-bold mb-6" style="color: var(--color-text-primary); font-family: var(--font-display);">Print Queue</h2>
          <div class="space-y-2">
            {[
              { name: 'Replacement MMU2S latch prototype', status: 'Preview', email: 'ken@3d3d.ca' },
              { name: 'First community calibration print', status: 'Waitlist', email: '—' },
              { name: 'Filament swatch set for launch day', status: 'Waitlist', email: '—' },
            ].map((item, i) => (
              <div class="flex items-center gap-4 px-4 py-3 rounded-lg" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle);">
                <span class="text-[10px]" style="color: var(--color-text-muted); font-family: var(--font-display);">#{String(i+1).padStart(2,'0')}</span>
                <span class="flex-1 text-[13px]" style="color: var(--color-text-primary);">{item.name}</span>
                <span class="text-[9px] uppercase tracking-wider" style={`color: ${C.orange}; font-family: var(--font-display);`}>{item.status}</span>
              </div>
            ))}
          </div>
          <p class="mt-4 text-[11px] uppercase tracking-wider" style="color: var(--color-text-muted); font-family: var(--font-display);">
            Queue submissions open in Stage Two. <a href="https://ko-fi.com/3d3dca" class="underline" style={`color: ${C.purple};`} target="_blank" rel="noopener noreferrer">Ko-fi queue jump</a> available at launch.
          </p>
        </div>
      </div>
    </section>

    {/* ── COMMUNITY SUGGESTIONS (PREVIEW) ── */}
    <section class="px-6 lg:px-12 pb-14" aria-labelledby="suggestions-heading">
      <div class="max-w-4xl border-t pt-10" style="border-color: var(--color-border-subtle);">
        <h2 id="suggestions-heading" class="text-lg font-bold mb-6" style="color: var(--color-text-primary); font-family: var(--font-display);">Community Suggestions</h2>
        <div class="space-y-2">
          {suggestions.map(s => (
            <div class="flex items-center gap-4 px-4 py-3 rounded-lg" style="background: var(--color-surface-card); border: 1px solid var(--color-border-subtle);">
              <div class="flex-shrink-0 w-8 text-center">
                <span class="text-sm font-bold" style={`color: ${C.lime}; font-family: var(--font-display);`}>{s.votes}</span>
                <span class="block text-[8px] uppercase tracking-wider" style="color: var(--color-text-muted); font-family: var(--font-display);">votes</span>
              </div>
              <span class="flex-1 text-[13px]" style="color: var(--color-text-primary);">{s.text}</span>
            </div>
          ))}
        </div>
        <p class="mt-4 text-[11px] uppercase tracking-wider" style="color: var(--color-text-muted); font-family: var(--font-display);">
          Voting and new suggestions open in Stage Two.
        </p>
      </div>
    </section>

    {/* ── RESTORATION LOG ── */}
    <section class="px-6 lg:px-12 pb-14" aria-labelledby="restoration-heading">
      <div class="max-w-4xl border-t pt-10" style="border-color: var(--color-border-subtle);">
        <h2 id="restoration-heading" class="text-lg font-bold mb-6" style="color: var(--color-text-primary); font-family: var(--font-display);">Restoration Log</h2>
        <div class="space-y-3">
          {restorationLog.map(entry => (
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 pt-0.5">
                <span class="w-2 h-2 rounded-full block mt-1.5" style={`background: ${entry.status === 'done' ? C.lime : 'var(--color-text-muted)'};`} />
              </div>
              <div>
                <span class="text-[9px] uppercase tracking-wider" style="color: var(--color-text-muted); font-family: var(--font-display);">{entry.date}</span>
                <p class="text-[13px] leading-relaxed mt-0.5" style="color: var(--color-text-secondary);">{entry.entry}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── COMMUNITY FUNDING ── */}
    <section class="px-6 lg:px-12 pb-14" aria-labelledby="funding-heading">
      <div class="max-w-4xl border-t pt-10" style="border-color: var(--color-border-subtle);">
        <h2 id="funding-heading" class="text-lg font-bold mb-2" style="color: var(--color-text-primary); font-family: var(--font-display);">Community Funding</h2>
        <p class="text-[13px] mb-6" style="color: var(--color-text-secondary);">Every donation goes directly to filament, parts, and uptime. Ko-fi is the primary channel.</p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          {fundingTiers.map((tier, i) => {
            const colors = [C.purple, C.orange, C.lime];
            return (
              <div class="p-5 rounded-xl flex flex-col" style="background: var(--color-surface-card); border: 1px solid var(--color-border-default); box-shadow: var(--shadow-sm);">
                <span class="text-base font-bold mb-1" style={`color: ${colors[i]}; font-family: var(--font-display);`}>{tier.amount}</span>
                <span class="text-[10px] uppercase tracking-wider mb-2" style="color: var(--color-text-primary); font-family: var(--font-display);">{tier.name}</span>
                <p class="text-[12px] leading-relaxed flex-1" style="color: var(--color-text-secondary);">{tier.desc}</p>
              </div>
            );
          })}
        </div>

        <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md px-6 py-3 text-[11px] font-semibold uppercase tracking-[0.12em]"
          style={`background: rgba(139,92,246,0.12); color: ${C.purple}; border: 2px solid rgba(139,92,246,0.3); min-height: 44px; font-family: var(--font-display);`}>
          Support on Ko-fi →
        </a>
      </div>
    </section>

    {/* ── CONTACT STRIP ── */}
    <section class="px-6 lg:px-12 pb-16">
      <div class="max-w-4xl border-t pt-8 flex flex-wrap items-center gap-x-8 gap-y-3" style="border-color: var(--color-border-subtle);">
        <a href="mailto:info@3d3d.ca" class="text-[10px] uppercase tracking-[0.15em] hover:underline" style="color: var(--color-text-muted); font-family: var(--font-display);">info@3d3d.ca</a>
        <a href="https://3d3d.ca" class="text-[10px] uppercase tracking-[0.15em] hover:underline" style="color: var(--color-text-muted); font-family: var(--font-display);">3d3d.ca</a>
        <span class="text-[10px] uppercase tracking-[0.15em]" style="color: var(--color-text-muted); font-family: var(--font-display);">Moncton, NB, Canada</span>
      </div>
    </section>

  </div>
</BaseLayout>
