---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import SiteSidebar from '../components/SiteSidebar.astro';
import '../styles/global.css';

interface NavGroup {
  label: string;
  items: { id: string; label: string; href?: string }[];
}

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  accent?: string;
  showFooter?: boolean;
  showCooperativeInfo?: boolean;
  bodyClass?: string;
  navGroups?: NavGroup[];
  activePath?: string;
}

const {
  title,
  description,
  canonicalURL,
  ogImage,
  ogType,
  schema,
  noindex = false,
  accent = '#40C4C4',
  showFooter = true,
  showCooperativeInfo = true,
  bodyClass = '',
  navGroups = [],
  activePath = '',
} = Astro.props;

// Default navigation groups for 3D3D main site
const defaultNavGroups: NavGroup[] = [
  {
    label: 'Services',
    items: [
      { id: 'home', label: 'Home', href: '/' },
      { id: 'tiers', label: 'Service Tiers', href: '/#tiers' },
      { id: 'contact', label: 'Request Service', href: '/contact' },
      { id: 'events', label: 'Events', href: '/events' },
    ],
  },
  {
    label: 'Explore',
    items: [
      { id: 'shop', label: 'Shop', href: '/shop' },
      { id: 'materials', label: 'Materials', href: '/materials' },
      { id: 'about', label: 'About', href: '/about' },
      { id: 'blog', label: 'Updates', href: '/blog' },
      { id: 'opportunities', label: 'Opportunities', href: '/opportunities' },
    ],
  },
];

const finalNavGroups = navGroups.length > 0 ? navGroups : defaultNavGroups;
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={title}
    description={description}
    canonicalURL={canonicalURL}
    ogImage={ogImage}
    ogType={ogType}
    schema={schema}
    noindex={noindex}
  />
</head>
<body class:list={[bodyClass, 'light-theme']}>
  <a href="#main-content" class="skip-to-content">Skip to content</a>
  <SiteSidebar navGroups={finalNavGroups} activePath={activePath} />
  <div class="content-wrapper">
    <main id="main-content" class="site-main min-h-screen">
      <slot />
    </main>

    {showFooter && (
      <Footer accent={accent} showCooperativeInfo={showCooperativeInfo} />
    )}
  </div>

  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.track3d3d = window.track3d3d || function (eventName, detail = {}) {
      const payload = { event: eventName, ...detail };
      window.dataLayer.push(payload);
      window.dispatchEvent(new CustomEvent('3d3d-analytics', { detail: payload }));
      if (typeof window.plausible === 'function') {
        window.plausible(eventName, { props: detail });
      }
    };

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target.closest('[data-analytics-event]') : null;
      if (!target) return;

      window.track3d3d(target.getAttribute('data-analytics-event'), {
        source: target.getAttribute('data-analytics-source') || window.location.pathname,
        href: target.getAttribute('href') || null,
      });
    });

    document.addEventListener('submit', (event) => {
      const form = event.target instanceof HTMLFormElement ? event.target : null;
      if (!form) return;

      const eventName = form.getAttribute('data-analytics-submit');
      if (!eventName) return;

      window.track3d3d(eventName, {
        source: form.getAttribute('data-analytics-source') || window.location.pathname,
      });
    });
  </script>
</body>
</html>

<style is:global>
  .light-theme {
    background-color: var(--color-surface-primary);
    color: var(--color-text-primary);
  }
</style>
