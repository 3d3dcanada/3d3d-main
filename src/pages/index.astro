---
import BaseLayout from '../layouts/BaseLayout.astro';
import CampaignStrip from '../components/CampaignStrip';
import DeviceShowcase from '../components/DeviceShowcase';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'Organization'],
  name: '3D3D',
  url: 'https://3d3d.ca',
  description: 'Specialty fabrication for marine, motorsport, replacement parts, and field deployment. Founder-operated and serving worldwide buyers.',
  telephone: '+1-506-953-2678',
  email: 'info@3d3d.ca',
  areaServed: ['Worldwide', 'Caribbean', 'Coastal United States', 'Europe'],
  founder: { '@type': 'Person', name: '3D3D' },
  sameAs: [
    'https://www.youtube.com/@3D3Dcanada',
    'https://www.tiktok.com/@3d3dcanada',
    'https://www.instagram.com/3d3dca/',
    'https://www.facebook.com/profile.php?id=61575548079847',
    'https://www.printables.com/@KTK3D_3050116',
    'https://github.com/3d3dcanada/3d3d-main',
    'https://wa.me/15069532678',
    'https://ko-fi.com/3d3dca',
  ],
  image: 'https://3d3d.ca/media/real/fleet-running.jpg',
  logo: 'https://3d3d.ca/media/brand/logo-badge.webp',
};

const homeNavGroups = [
  {
    label: 'On This Page',
    items: [
      { id: 'home', label: 'Home', href: '/' },
      { id: 'what-i-do', label: 'What I Do', href: '#what-i-do' },
      { id: 'workshop', label: 'The Workshop', href: '#workshop' },
      { id: 'contact', label: 'Contact', href: '#contact' },
    ],
  },
  {
    label: 'Site',
    items: [
      { id: 'blog', label: 'Blog', href: '/blog' },
      { id: 'shop', label: 'Shop', href: '/shop' },
      { id: 'prusa', label: 'Prusa', href: '/prusa' },
      { id: 'about', label: 'About', href: '/about' },
    ],
  },
];

const services = [
  {
    id: 'marine',
    drawerId: 'drawer-marine',
    eyebrow: 'Marine Hardware',
    headline: 'The part does not exist anymore. So we build it.',
    description: 'Supply chains do not care about your passage plan. When a stainless pawl wears through a bronze pocket on a discontinued Barient 27 winch, or a Spinlock XA clutch handle snaps under a loaded halyard, you cannot wait three weeks for a mismatched part that may not fit. We reverse-engineer deck fittings, fairleads, winch components, and custom brackets — all built to handle offshore dynamic loads.',
    drawer: {
      materials: 'ASA above deck. UV-stable, 93°C heat deflection. PETG-CF below deck for structural fittings. PP Glass Fiber or PP Carbon Fiber for constant saltwater contact. TPU 95A for seals and gaskets. PA11 CF near engines. 192°C, resists oils and fuels.',
      turnaround: 'Send the broken component, or provide precise caliper measurements. If you\'re offshore, dimensions by message are enough. We\'ve built from blurry photos and measurements taken on a rolling deck.',
    },
  },
  {
    id: 'automotive',
    drawerId: 'drawer-automotive',
    eyebrow: 'Automotive Restoration',
    headline: 'Unobtainium ceases to be a problem.',
    description: 'Halting a multi-year build because an interior trim panel, a dash overlay, or a specific retaining clip was last stamped forty years ago — that frustration ends here. We fabricate exact geometric replicas of discontinued OEM parts for AMC, Dodge, Plymouth, and beyond. Parts that fit, hold, and survive the road.',
    drawer: {
      materials: 'PA11 CF for engine bay. 192°C heat deflection, resists oils and fuels. PETG-CF for structural brackets. ASA for exterior and underhood UV exposure. PC Blend for impact-critical parts. PEI 1010 when nothing else survives.',
      turnaround: 'Ship the shattered original piece or the surrounding housing. We rebuild the geometry digitally and print the final part. For discontinued OEM parts, bring the original. We measure, model, and test-fit before committing.',
    },
  },
  {
    id: 'onsite',
    drawerId: 'drawer-onsite',
    eyebrow: 'On-Site Deployment',
    headline: 'The vessel cannot move. We can.',
    description: 'Marina fees bleed cruising budgets dry. If your vessel is tied up in Antigua, Newport, or a remote boatyard waiting on a critical refit component, the fastest path to the water is bringing the factory to the dock. We travel worldwide with the necessary equipment, assess the failure, design the fix, and fabricate the hardware on location.',
    drawer: {
      materials: 'Full material stack on location. ASA, PA11 CF, PETG-CF, TPU, PP-CF, matched to the failure mode after on-site assessment. No guessing from a product page.',
      turnaround: 'Call us. Tell us where the boat is and what is broken. We pack the cases and sort the flights.',
    },
  },
  {
    id: 'remote',
    drawerId: 'drawer-remote',
    eyebrow: 'Remote Fabrication',
    headline: 'Engineered here. Deployed anywhere.',
    description: 'For components that do not require a physical presence on deck. Send high-resolution photos, the load requirements, and exact caliper measurements. We design the replacement and ship the finished hardware to your current coordinates. Your marina, your boatyard, wherever the vessel is sitting.',
    drawer: {
      materials: 'Material matched to the environment after intake. Saltwater, UV, heat, chemical exposure, dynamic load. We specify based on what the part has to survive, not what is easiest to print.',
      turnaround: 'Send photos of the broken component, the mounting area, and caliper measurements. We confirm the geometry, quote the job, and ship to your coordinates.',
    },
  },
];

---

<BaseLayout
  title="3D3D | You Have a Problem. I Am Your Solution."
  description="Offshore marine fabrication and discontinued part replacement. Worldwide on-site deployment and remote engineering by a 20,000nm offshore specialist."
  schema={orgSchema}
  activePath="/"
  navGroups={homeNavGroups}
  bodyClass="home-editorial"
>
  <div class="home-page">

    <!-- ═══════════════════════════════════════════════════
         HERO — dark, full-height
         ═══════════════════════════════════════════════════ -->
    <section id="home" class="home-section home-section--dark home-hero" data-section>
      <div class="hero-bg" aria-hidden="true">
        <img src="/media/real/fleet-running.jpg" alt="" loading="eager" decoding="async" />
      </div>
      <div class="hero-stripes" aria-hidden="true">
        <div class="hero-stripe hero-stripe--magenta" data-speed="0.19"></div>
        <div class="hero-stripe hero-stripe--orange" data-speed="0.07"></div>
        <div class="hero-stripe hero-stripe--teal" data-speed="0.12"></div>
      </div>
      <!-- Phones overlay the entire hero -->
      <div class="hero-devices-layer">
        <DeviceShowcase client:visible />
      </div>

      <div class="section-shell hero-shell">
        <div class="hero-copy">
          <p class="eyebrow hero-eyebrow" data-scramble>3D Printing · Fabrication · Marine Specialist</p>
          <h1 class="hero-title" aria-label="You have a problem. Let's find your solution.">
             <span class="hero-line" data-word-reveal>
               <span class="word-clip"><span class="word">You</span></span>
               <span class="word-clip"><span class="word">have</span></span>
               <span class="word-clip"><span class="word">a</span></span>
               <span class="word-clip"><span class="word">problem.</span></span>
             </span>
             <span class="hero-line hero-line--accent" data-word-reveal>
               <span class="word-clip"><span class="word">Let's</span></span>
               <span class="word-clip"><span class="word">find</span></span>
               <span class="word-clip"><span class="word">your</span></span>
               <span class="word-clip"><span class="word">solution.</span></span>
             </span>
           </h1>
          <p class="hero-subhead">
            If the part doesn't exist anymore, we build it. If you just need something printed, we print it. A maker community spanning Atlantic Canada and beyond — available to anyone with a problem worth solving. Ship it, send a photo, or just describe what broke. Worldwide.
          </p>
          <div class="hero-actions">
            <a href="/contact" class="hero-button hero-button--primary" data-analytics-event="contact_started" data-analytics-source="hero-cta">One Call. We'll Assess It. →</a>
            <a href="https://ko-fi.com/3d3dca" class="hero-button hero-button--ghost" target="_blank" rel="noopener noreferrer" data-analytics-event="kofi_clicked" data-analytics-source="hero-cta">Support the Campaign →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         CAMPAIGN STRIP (React + Motion)
         ═══════════════════════════════════════════════════ -->
    <CampaignStrip client:visible />

    <!-- ═══════════════════════════════════════════════════
         WHAT WE DO — light
         ═══════════════════════════════════════════════════ -->
    <section id="what-i-do" class="home-section home-section--light work-section" data-section aria-labelledby="work-label">
      <div class="section-shell work-shell">

        <header class="work-header">
          <p class="eyebrow scroll-in-left">What I Do</p>
          <h2 class="section-title scroll-in" aria-label="I scan it. I model it. I build it.">
            <span class="typewriter-line" data-typewriter>I scan it.</span><br />
            <span class="typewriter-line" data-typewriter>I model it.</span><br />
            <span class="typewriter-line" data-typewriter>I build it.</span>
          </h2>
          <p class="section-body scroll-in-fade scroll-delay-1">
            We reverse-engineer broken and obsolete components into exact-fit replacements: deck fittings, winch hardware, discontinued OEM parts, vintage automotive pieces, and one-off solutions that no supply chain carries anymore. Bring us the part, a photo, or just the problem.
          </p>
        </header>

        <div class="services-scroll" role="region" aria-label="Service areas" tabindex="0">
          {services.map((service, i) => (
            <article
              class={`service-card scroll-in-rotate scroll-delay-${Math.min(i + 1, 4)}`}
              data-drawer-trigger
              data-drawer-id={service.drawerId}
              role="button"
              tabindex="0"
            >
              <p class="service-card__eyebrow">{service.eyebrow}</p>
              <h3 class="service-card__headline">{service.headline}</h3>
              <p class="service-card__desc">{service.description}</p>
              <span class="service-card__cta">Learn more →</span>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         THE WORKSHOP — dark
         ═══════════════════════════════════════════════════ -->
    <section id="workshop" class="home-section home-section--dark workshop-section" data-section aria-labelledby="workshop-label">
      <div class="section-shell workshop-shell">
        <header class="workshop-header">
          <p class="eyebrow eyebrow--light scroll-in-left">The Workshop</p>
          <h2 class="section-title section-title--light scroll-in" id="workshop-label">
            Built to solve problems.<br />Not to look pretty on a shelf.
          </h2>
          <p class="section-body section-body--inverse scroll-in-float scroll-delay-1">
            Two Prusa MK4S printers running engineering compounds. A full mechanical tool kit, calipers, micrometers, and a scanner for reverse engineering parts that no longer have drawings. Not a hobby setup. A portable fabrication lab that travels to the job.
          </p>
        </header>

        <div class="workshop-grid">
          <figure class="workshop-card workshop-card--hero scroll-in-pop" data-lightbox data-lightbox-src="/media/workshop/printer-action-cf.jpg" data-lightbox-label="Live print" data-lightbox-note="PETG-CF structural bracket, 0.2mm layer height. Carbon fiber reinforced compound printed on the Prusa MK4S with a hardened steel nozzle. This bracket replaces a factory aluminium piece that cracked under cyclic loading." role="button" tabindex="0">
            <img src="/media/workshop/printer-action-cf.jpg" alt="Prusa MK4S printing carbon fiber compound" loading="lazy" decoding="async" />
            <figcaption>
              <span class="workshop-card__label">Live print</span>
              <span class="workshop-card__note">PETG-CF structural bracket, 0.2mm layer height</span>
            </figcaption>
          </figure>
          <figure class="workshop-card scroll-in scroll-delay-1" data-lightbox data-lightbox-src="/media/workshop/printer-frame-shot.jpg" data-lightbox-label="The machine" data-lightbox-note="Prusa MK4S with hardened steel nozzle for abrasive compounds like PETG-CF, PA11-CF, and PP Glass Fiber. Input shaping enabled for high-speed printing without ringing artifacts." role="button" tabindex="0">
            <img src="/media/workshop/printer-frame-shot.jpg" alt="Prusa printer frame close-up" loading="lazy" decoding="async" />
            <figcaption>
              <span class="workshop-card__label">The machine</span>
              <span class="workshop-card__note">Prusa MK4S with hardened nozzle for abrasive compounds</span>
            </figcaption>
          </figure>
          <figure class="workshop-card scroll-in scroll-delay-2" data-lightbox data-lightbox-src="/media/workshop/machine-parts-flatlay.jpg" data-lightbox-label="Output" data-lightbox-note="Finished parts ready for fitment and deployment. Each component is printed in the compound matched to its failure mode and environment. Nothing leaves the bench until dimensional checks pass." role="button" tabindex="0">
            <img src="/media/workshop/machine-parts-flatlay.jpg" alt="Finished machine parts laid out for inspection" loading="lazy" decoding="async" />
            <figcaption>
              <span class="workshop-card__label">Output</span>
              <span class="workshop-card__note">Finished parts ready for fitment and deployment</span>
            </figcaption>
          </figure>
          <figure class="workshop-card scroll-in scroll-delay-1" data-lightbox data-lightbox-src="/media/workshop/modular-parts-flatlay.jpg" data-lightbox-label="Modular builds" data-lightbox-note="Replacement components printed in matched compounds. Modular design allows field assembly and individual piece replacement without reprinting the entire assembly." role="button" tabindex="0">
            <img src="/media/workshop/modular-parts-flatlay.jpg" alt="Modular replacement parts array" loading="lazy" decoding="async" />
            <figcaption>
              <span class="workshop-card__label">Modular builds</span>
              <span class="workshop-card__note">Replacement components printed in matched compounds</span>
            </figcaption>
          </figure>
          <figure class="workshop-card scroll-in scroll-delay-2" data-lightbox data-lightbox-src="/media/workshop/rv-lab-01.jpg" data-lightbox-label="Mobile lab" data-lightbox-note="The whole operation travels. Worldwide deployment ready. Two printers, full tool kit, scanner, and materials library packed for on-site fabrication at marinas, boatyards, and race events." role="button" tabindex="0">
            <img src="/media/workshop/rv-lab-01.jpg" alt="Mobile fabrication lab interior" loading="lazy" decoding="async" />
            <figcaption>
              <span class="workshop-card__label">Mobile lab</span>
              <span class="workshop-card__note">The whole operation travels. Worldwide deployment ready.</span>
            </figcaption>
          </figure>
        </div>

        <div class="workshop-capabilities">
          <div class="capability glass-dark scroll-in-rotate">
            <span class="capability__icon">+</span>
            <span class="capability__text">Engineering-grade compounds matched to your environment</span>
          </div>
          <div class="capability glass-dark scroll-in-rotate scroll-delay-1">
            <span class="capability__icon">+</span>
            <span class="capability__text">Reverse engineering from photos, measurements, or broken originals</span>
          </div>
          <div class="capability glass-dark scroll-in-rotate scroll-delay-2">
            <span class="capability__icon">+</span>
            <span class="capability__text">Worldwide shipping and on-site deployment</span>
          </div>
          <div class="capability glass-dark scroll-in-rotate scroll-delay-3">
            <span class="capability__icon">+</span>
            <span class="capability__text">From simple prints to custom fabrication projects</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         CONTACT — teal/dark
         ═══════════════════════════════════════════════════ -->
    <section id="contact" class="home-section home-section--teal final-cta-section" data-section>
      <div class="section-shell final-cta-shell">
        <div class="final-cta-copy">
          <h2 class="section-title section-title--inverse scroll-in-float">
            One call. We'll assess it.<br />We'll sort it out.
          </h2>
          <p class="section-body section-body--inverse scroll-in-fade scroll-delay-1">
            Tell us the problem. Tell us where the vessel is. We'll tell you whether we can solve it, how we'll do it, and exactly what it takes. That is the whole process.
          </p>
          <div class="final-cta-actions">
            <a href="/contact" class="final-cta-button final-cta-button--light scroll-in-pop scroll-delay-2">Get in Touch →</a>
            <a href="/book" class="final-cta-button final-cta-button--ghost scroll-in-pop scroll-delay-3">Book a Call →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         OFF-CANVAS DRAWER
         ═══════════════════════════════════════════════════ -->
    <div class="drawer" id="service-drawer" data-open="false" hidden>
      <div class="drawer__backdrop" data-drawer-close></div>
      <aside class="drawer__panel" role="dialog" aria-modal="true" aria-label="Service details">
        <button class="drawer__close" data-drawer-close aria-label="Close">✕</button>
        <div class="drawer__content" id="drawer-content"></div>
      </aside>
    </div>

    {services.map((service) => (
      <template id={service.drawerId}>
        <div class="drawer-copy">
          <p class="drawer-copy__eyebrow">{service.eyebrow}</p>
          <h3 class="drawer-copy__title">{service.headline}</h3>
          <p class="drawer-copy__stakes">{service.description}</p>
          <div class="drawer-copy__notes">
            <div>
              <span>Materials & compounds</span>
              <p>{service.drawer.materials}</p>
            </div>
            <div>
              <span>How to start</span>
              <p>{service.drawer.turnaround}</p>
            </div>
          </div>
          <a href="/contact" class="drawer-copy__cta">Request this type of work</a>
        </div>
      </template>
    ))}
  </div>

  <!-- ═══════════════════════════════════════════════════
       IMAGE LIGHTBOX
       ═══════════════════════════════════════════════════ -->
  <div class="lightbox" id="image-lightbox" data-open="false" hidden>
    <div class="lightbox__backdrop" data-lightbox-close></div>
    <div class="lightbox__container">
      <button class="lightbox__close" data-lightbox-close aria-label="Close">&times;</button>
      <img class="lightbox__img" id="lightbox-img" src="" alt="" />
      <div class="lightbox__info">
        <span class="lightbox__label" id="lightbox-label"></span>
        <p class="lightbox__note" id="lightbox-note"></p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       SCRIPTS
       ═══════════════════════════════════════════════════ -->
  <script is:inline>
    (() => {
      const drawer = document.getElementById('service-drawer');
      const content = document.getElementById('drawer-content');
      const triggers = Array.from(document.querySelectorAll('[data-drawer-trigger]'));

      if (!(drawer instanceof HTMLElement) || !(content instanceof HTMLElement) || triggers.length === 0) return;

      let closeTimer = 0;

      const closeDrawer = () => {
        drawer.dataset.open = 'false';
        document.body.classList.remove('drawer-open');
        window.clearTimeout(closeTimer);
        closeTimer = window.setTimeout(() => {
          drawer.hidden = true;
          content.innerHTML = '';
        }, 320);
      };

      const openDrawer = (templateId) => {
        const template = document.getElementById(templateId);
        if (!(template instanceof HTMLTemplateElement)) return;
        content.innerHTML = '';
        content.appendChild(template.content.cloneNode(true));
        drawer.hidden = false;
        window.requestAnimationFrame(() => {
          drawer.dataset.open = 'true';
          document.body.classList.add('drawer-open');
        });
      };

      triggers.forEach((trigger) => {
        const handler = () => {
          const id = trigger instanceof HTMLElement ? trigger.dataset.drawerId : null;
          if (id) openDrawer(id);
        };
        trigger.addEventListener('click', handler);
        trigger.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); }
        });
      });

      drawer.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-drawer-close]') : null;
        if (!target) return;
        closeDrawer();
      });

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && drawer.dataset.open === 'true') closeDrawer();
      });
    })();

    // Image lightbox for workshop cards
    (() => {
      const lightbox = document.getElementById('image-lightbox');
      const lbImg = document.getElementById('lightbox-img');
      const lbLabel = document.getElementById('lightbox-label');
      const lbNote = document.getElementById('lightbox-note');
      const triggers = Array.from(document.querySelectorAll('[data-lightbox]'));

      if (!lightbox || !lbImg || !lbLabel || !lbNote || triggers.length === 0) return;

      const closeLightbox = () => {
        lightbox.dataset.open = 'false';
        document.body.classList.remove('drawer-open');
        setTimeout(() => { lightbox.hidden = true; }, 280);
      };

      const openLightbox = (el) => {
        lbImg.src = el.dataset.lightboxSrc || '';
        lbImg.alt = el.dataset.lightboxLabel || '';
        lbLabel.textContent = el.dataset.lightboxLabel || '';
        lbNote.textContent = el.dataset.lightboxNote || '';
        lightbox.hidden = false;
        requestAnimationFrame(() => {
          lightbox.dataset.open = 'true';
          document.body.classList.add('drawer-open');
        });
      };

      triggers.forEach((t) => {
        t.addEventListener('click', () => openLightbox(t));
        t.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLightbox(t); }
        });
      });

      lightbox.addEventListener('click', (e) => {
        if (e.target.closest('[data-lightbox-close]')) closeLightbox();
      });

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lightbox.dataset.open === 'true') closeLightbox();
      });
    })();

    // Campaign strip and modals handled by CampaignStrip React component

    // Word-split masked reveal for hero title
    (() => {
      const lines = Array.from(document.querySelectorAll('[data-word-reveal]'));
      if (!lines.length || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        // Immediately reveal all words if reduced motion
        document.querySelectorAll('.word').forEach(w => w.classList.add('revealed'));
        return;
      }

      let wordIndex = 0;
      lines.forEach((line, lineIdx) => {
        const words = line.querySelectorAll('.word');
        words.forEach((word) => {
          const delay = wordIndex * 70 + lineIdx * 150;
          setTimeout(() => word.classList.add('revealed'), delay + 200);
          wordIndex++;
        });
      });
    })();

    // Eyebrow character scramble
    (() => {
      const el = document.querySelector('[data-scramble]');
      if (!el || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const finalText = el.textContent || '';
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789#@!%·';
      const duration = 900;
      const start = performance.now();

      function scramble(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const revealedCount = Math.floor(progress * finalText.length);

        let result = '';
        for (let i = 0; i < finalText.length; i++) {
          if (i < revealedCount) {
            result += finalText[i];
          } else if (finalText[i] === ' ' || finalText[i] === '·') {
            result += finalText[i];
          } else {
            result += chars[Math.floor(Math.random() * chars.length)];
          }
        }
        el.textContent = result;

        if (progress < 1) {
          requestAnimationFrame(scramble);
        } else {
          el.textContent = finalText;
        }
      }

      requestAnimationFrame(scramble);
    })();

    // Typewriter effect for "I scan it. I model it. I build it."
    (() => {
      const lines = Array.from(document.querySelectorAll('[data-typewriter]'));
      if (lines.length === 0) return;
      let started = false;

      const runTypewriter = () => {
        if (started) return;
        started = true;
        lines.forEach((line, i) => {
          setTimeout(() => {
            line.classList.add('typing');
            line.addEventListener('animationend', () => {
              line.classList.remove('typing');
              line.classList.add('typed');
            }, { once: true });
          }, i * 700);
        });
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            runTypewriter();
            observer.disconnect();
          }
        });
      }, { threshold: 0.3 });

      observer.observe(lines[0].closest('.work-header') || lines[0]);
    })();
  </script>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════
     PAGE TOKENS
     ═══════════════════════════════════════════════════ */
  :global(body.home-editorial) {
    background-color: #F6F7FA;
    background-image:
      radial-gradient(circle at 88% 8%, rgba(232, 74, 138, 0.07) 0%, transparent 28%),
      radial-gradient(circle at 10% 92%, rgba(64, 196, 196, 0.06) 0%, transparent 32%),
      radial-gradient(circle at 50% 50%, rgba(64, 196, 196, 0.03) 0%, transparent 60%),
      linear-gradient(180deg, rgba(246, 247, 250, 0.95), rgba(238, 242, 243, 1));
    background-attachment: fixed;
  }

  :global(body.home-editorial::after) {
    display: block;
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.025;
    background-image:
      repeating-linear-gradient(0deg, rgba(64, 196, 196, 0.15) 0px, transparent 1px, transparent 60px),
      repeating-linear-gradient(90deg, rgba(64, 196, 196, 0.15) 0px, transparent 1px, transparent 60px);
  }

  :global(body.drawer-open) {
    overflow: hidden;
  }

  .home-page {
    --page-accent: #40C4C4;
    --page-accent-secondary: #E84A8A;
    --page-bg-light: #F6F7FA;
    --page-bg-dark: #111214;
    --page-surface: #FFFFFF;
    --page-text: #1A1A1A;
    --page-text-muted: #666666;
    --page-border: 2px solid #1A1A1A;
    --page-thick-border: 3px solid #1A1A1A;
    --page-shell-width: min(100% - clamp(1.5rem, 4vw, 4rem), 1320px);
    background: var(--page-bg-light);
    color: var(--page-text);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .section-shell {
    position: relative;
    z-index: 1;
    width: var(--page-shell-width);
    margin: 0 auto;
  }

  .home-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 8rem);
    scroll-margin-top: 1rem;
  }

  .home-section--light { background: var(--page-bg-light); position: relative; }

  .home-section + .home-section::before {
    content: '';
    position: absolute;
    top: -2px;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(64, 196, 196, 0.3) 30%,
      rgba(232, 74, 138, 0.2) 70%,
      transparent 100%
    );
    filter: blur(1px);
    z-index: 2;
  }

  .home-section--dark {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
      var(--page-bg-dark);
    color: #F6F7FA;
  }

  .home-section--teal {
    background: var(--page-accent);
    color: #FFFFFF;
  }

  /* Scroll animations handled by global scroll-reveal.css */

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: var(--page-accent);
    flex-shrink: 0;
  }

  .section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 4vw, 4.9rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  .section-title--light,
  .section-title--inverse { color: #F6F7FA; }

  .section-body {
    margin: 0;
    max-width: 42rem;
    font-size: clamp(1rem, 0.94rem + 0.35vw, 1.18rem);
    line-height: 1.75;
    color: var(--page-text);
  }

  .section-body--inverse { color: rgba(255, 255, 255, 0.9); }

  /* ═══════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════ */
  .home-hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: clamp(5rem, 8vw, 7rem);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-bg img {
    width: 100%;
    height: 120%; /* extra height for parallax travel */
    object-fit: cover;
    object-position: center top;
    opacity: 0.35;
    filter: brightness(0.6);
    will-change: transform;
  }

  /* ── Hero Racing Stripes ── */
  .hero-stripes {
    position: absolute;
    /* Left gutter — between viewport edge and the hero copy */
    left: clamp(1.2rem, calc(50% - 660px + 1.8rem), 5rem);
    top: 0;
    bottom: -80px; /* extend below hero so parallax translateY never exposes a gap — hero clips it */
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 9px;
    z-index: 1;
    pointer-events: none;
    overflow: visible;
  }

  .hero-stripe {
    width: 20px;
    flex-shrink: 0;
    will-change: transform;
  }

  /* Teal — RIGHT, builds DOWN first → triggers Phone 1 (marine) */
  .hero-stripe--teal {
    background: #40C4C4;
    clip-path: inset(0 0 100% 0);
    animation: stripe-build-down 0.8s steps(20, end) 0.6s forwards;
    box-shadow: 0 0 18px rgba(64, 196, 196, 0.4);
  }

  /* Orange — MIDDLE, builds UP second → triggers Phone 2 (print) */
  .hero-stripe--orange {
    background: #FA6831;
    clip-path: inset(100% 0 0 0);
    animation: stripe-build-up 0.8s steps(20, end) 1.8s forwards;
    box-shadow: 0 0 18px rgba(250, 104, 49, 0.4);
  }

  /* Magenta — LEFT, builds DOWN third → triggers Phone 3 (custom) */
  .hero-stripe--magenta {
    background: #E040FB;
    clip-path: inset(0 0 100% 0);
    animation: stripe-build-down 0.8s steps(20, end) 2.8s forwards;
    box-shadow: 0 0 18px rgba(224, 64, 251, 0.4);
  }

  @keyframes stripe-build-down {
    from { clip-path: inset(0 0 100% 0); }
    to   { clip-path: inset(0 0 0 0); }
  }

  @keyframes stripe-build-up {
    from { clip-path: inset(100% 0 0 0); }
    to   { clip-path: inset(0 0 0 0); }
  }

  /* Mobile: equal-width racing stripes, centered */
  @media (max-width: 767px) {
    .hero-stripes {
      left: 50%;
      translate: -50% 0; /* use CSS translate so JS transform on children doesn't conflict */
      gap: 14px;
    }
    .hero-stripe {
      width: 16px;
    }
  }

  .hero-shell {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .hero-copy {
    display: grid;
    gap: 1.5rem;
    place-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    color: rgba(246, 247, 250, 0.72);
    opacity: 0;
    animation: hero-line-in 0.72s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero-title {
    margin: 0;
    display: grid;
    gap: 0.15em;
    font-family: var(--font-display);
    font-size: clamp(3rem, 1.8rem + 5vw, 6.6rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: #FFFFFF;
    text-transform: uppercase;
  }

  .hero-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.2em;
  }

  .hero-line--accent { color: var(--page-accent); }

  .word-clip {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
  }

  .word {
    display: inline-block;
    transform: translateY(105%);
  }

  .word.revealed {
    transform: translateY(0%);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-subhead {
    margin: 0;
    max-width: 43rem;
    font-size: clamp(1.08rem, 0.98rem + 0.45vw, 1.28rem);
    line-height: 1.8;
    color: rgba(246, 247, 250, 0.8);
    opacity: 0;
    transform: translateY(28px);
    animation: hero-line-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
    transform: translateY(28px);
    animation: hero-line-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.4rem;
    padding: 0.95rem 1.55rem;
    border: var(--page-thick-border);
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .hero-button:hover { transform: translateY(-2px) scale(1.02); }

  .hero-button--primary {
    background: var(--page-accent);
    color: #0F1112;
    border-color: #1A1A1A;
    box-shadow: 0 14px 32px rgba(64, 196, 196, 0.24);
  }

  .hero-button--primary:hover {
    background: #53D3D3;
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.4);
  }

  .hero-button--ghost {
    border-color: #F6F7FA;
    color: #F6F7FA;
    background: transparent;
  }

  .hero-button--ghost:hover {
    border-color: var(--page-accent);
    background: rgba(64, 196, 196, 0.12);
    color: #FFFFFF;
  }

  .hero-proof-rail {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.4rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-proof-item {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-tech);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 247, 250, 0.72);
    opacity: 0;
    transform: translateX(-16px);
    animation: hero-proof-in 0.45s ease forwards;
  }

  .hero-proof-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--page-accent);
  }

  /* Phones layer — overlays entire hero */
  .hero-devices-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    padding-top: clamp(8rem, 18vw, 14rem);
  }

  .hero-devices-layer > * {
    pointer-events: auto;
  }

  .hero-video-frame {
    position: relative;
    overflow: hidden;
    min-height: clamp(24rem, 52vw, 44rem);
    border: var(--page-thick-border);
    border-radius: 1.6rem;
    box-shadow: 8px 8px 0 #40C4C4, 16px 16px 0 #FA6831, 0 30px 72px rgba(0, 0, 0, 0.38);
    clip-path: inset(0 100% 0 0 round 1.6rem);
    animation: hero-video-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .hero-video-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(17, 18, 20, 0.05), rgba(17, 18, 20, 0.18));
    pointer-events: none;
    z-index: 2;
  }


  .hero-video {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    display: block;
  }

  /* ═══════════════════════════════════════════════════
     WHAT I DO
     ═══════════════════════════════════════════════════ */
  .work-shell {
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
  }

  .work-header {
    display: grid;
    gap: 1.4rem;
    max-width: 52rem;
  }

  /* Typewriter animation for section title lines */
  .typewriter-line {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
    border-right: 3px solid var(--page-accent);
    transition: none;
  }

  .typewriter-line.typing {
    animation: typewriter-expand 0.6s steps(14, end) forwards;
  }

  .typewriter-line.typed {
    width: auto;
    border-right-color: transparent;
  }

  .typewriter-line.typing:last-of-type {
    animation: typewriter-expand 0.6s steps(14, end) forwards, blink-cursor 0.6s step-end 3;
  }

  @keyframes typewriter-expand {
    from { width: 0; }
    to { width: 100%; }
  }

  @keyframes blink-cursor {
    50% { border-right-color: transparent; }
  }

  /* Scrollable service card gallery */
  .services-scroll {
    display: flex;
    gap: clamp(1rem, 2vw, 1.5rem);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-inline-start: clamp(0.75rem, 2vw, 2rem);
    padding-bottom: 1rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--page-accent) rgba(0, 0, 0, 0.08);
    perspective: 1000px;
  }

  .services-scroll::-webkit-scrollbar { height: 4px; }
  .services-scroll::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.06); border-radius: 2px; }
  .services-scroll::-webkit-scrollbar-thumb { background: var(--page-accent); border-radius: 2px; }

  .service-card {
    flex: 0 0 min(85vw, 420px);
    scroll-snap-align: start;
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-left: 4px solid var(--page-accent);
    border-radius: var(--radius-lg);
    box-shadow: var(--glass-shadow);
    cursor: pointer;
    transform-style: preserve-3d;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-card:hover {
      transform: rotateY(-4deg) rotateX(2deg) translateZ(16px);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    .service-card:nth-child(even):hover {
      transform: rotateY(4deg) rotateX(-2deg) translateZ(16px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card:hover {
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    }
  }

  .service-card__eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--page-accent);
  }

  .service-card__headline {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1rem + 1vw, 1.8rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--page-text);
  }

  .service-card__desc {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--page-text-muted);
  }

  .service-card__cta {
    display: inline-flex;
    align-items: center;
    margin-top: 0.5rem;
    font-family: var(--font-tech);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--page-accent);
    transition: color 0.2s ease, transform 0.3s ease;
  }

  .service-card:hover .service-card__cta {
    color: var(--page-accent-secondary);
    transform: translateX(4px);
  }

  /* ═══════════════════════════════════════════════════
     THE WORKSHOP
     ═══════════════════════════════════════════════════ */
  .eyebrow--light { color: rgba(246, 247, 250, 0.72); }
  .eyebrow--light::before { background: var(--page-accent); }

  .workshop-shell {
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
  }

  .workshop-header {
    display: grid;
    gap: 1.4rem;
    max-width: 52rem;
  }

  .workshop-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .workshop-card {
    margin: 0;
    overflow: hidden;
    border: 2px solid rgba(64, 196, 196, 0.15);
    border-radius: 1rem;
    position: relative;
  }

  .workshop-card--hero {
    grid-row: 1 / 3;
  }

  .workshop-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 4 / 3;
    transition: transform 0.4s ease;
  }

  .workshop-card--hero img {
    aspect-ratio: auto;
    min-height: 100%;
  }

  .workshop-card:hover img {
    transform: scale(1.03);
  }

  .workshop-card figcaption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.2rem;
    background: linear-gradient(0deg, rgba(17, 18, 20, 0.88), transparent);
    display: grid;
    gap: 0.2rem;
  }

  .workshop-card__label {
    font-family: var(--font-tech);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--page-accent);
  }

  .workshop-card__note {
    font-size: 0.82rem;
    line-height: 1.4;
    color: rgba(246, 247, 250, 0.7);
  }

  .workshop-capabilities {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    padding-top: 1rem;
    perspective: 1200px;
  }

  .capability {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 1.2rem 1.4rem;
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--page-accent);
    transform-style: preserve-3d;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .capability:hover {
      transform: translateZ(8px) rotateY(-2deg);
    }
  }

  .capability__icon {
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1;
    color: var(--page-accent);
    flex-shrink: 0;
  }

  .capability__text {
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: rgba(246, 247, 250, 0.85);
  }

  @media (max-width: 640px) {
    .workshop-grid {
      grid-template-columns: 1fr;
    }
    .workshop-card--hero {
      grid-row: auto;
    }
  }

  /* ═══════════════════════════════════════════════════
     CONTACT (FINAL CTA)
     ═══════════════════════════════════════════════════ */
  .final-cta-shell { text-align: center; }

  .final-cta-copy {
    display: grid;
    gap: 1.5rem;
    justify-items: center;
    max-width: 52rem;
    margin: 0 auto;
  }

  .final-cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .final-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.4rem;
    padding: 0.95rem 1.55rem;
    border: var(--page-thick-border);
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .final-cta-button:hover { transform: translateY(-2px) scale(1.02); }

  .final-cta-button--light {
    background: #FFFFFF;
    color: #1A1A1A;
    border-color: #1A1A1A;
  }

  .final-cta-button--light:hover {
    background: #F6F7FA;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .final-cta-button--ghost {
    border-color: #FFFFFF;
    color: #FFFFFF;
    background: transparent;
  }

  .final-cta-button--ghost:hover { background: rgba(255, 255, 255, 0.12); }

  /* ═══════════════════════════════════════════════════
     DRAWER
     ═══════════════════════════════════════════════════ */
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: flex-end;
    pointer-events: none;
  }

  .drawer[data-open='true'] { pointer-events: all; }

  .drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 18, 20, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .drawer[data-open='true'] .drawer__backdrop { opacity: 1; }

  .drawer__panel {
    position: relative;
    width: min(420px, 92vw);
    height: 100%;
    background: var(--page-bg-dark);
    border-left: 3px solid var(--page-accent);
    overflow-y: auto;
    padding: 2rem 1.5rem;
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .drawer[data-open='true'] .drawer__panel { transform: translateX(0); }

  .drawer[data-open='true'] .drawer__content > * {
    animation: fade-in-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .drawer[data-open='true'] .drawer__content > *:nth-child(1) { animation-delay: 0.05s; }
  .drawer[data-open='true'] .drawer__content > *:nth-child(2) { animation-delay: 0.1s; }
  .drawer[data-open='true'] .drawer__content > *:nth-child(3) { animation-delay: 0.15s; }
