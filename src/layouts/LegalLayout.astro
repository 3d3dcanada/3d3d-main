---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  pageTitle: string;
  eyebrow?: string;
  lastUpdated?: string;
  activePath?: string;
  accent?: string;
}

const {
  title,
  description,
  pageTitle,
  eyebrow = 'Legal',
  lastUpdated,
  activePath = '',
  accent = '#40C4C4',
} = Astro.props;

const legalSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: description,
  url: `https://3d3d.ca${activePath}`,
};
---

<BaseLayout title={title} description={description} activePath={activePath} accent={accent} schema={legalSchema}>
  <main class="hp-home">
    <section class="pg-section pg-section--hero" style={`--section-accent: ${accent};`}>
      <div class="pg-section__bg">
        <div class="pg-section__bg-img" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="pg-section__scrim"></div>
      <div class="pg-section__grain"></div>

      <div class="pg-shell pg-shell--narrow">
        <article class="pg-card">
          <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: pageTitle}]} />
          <p class="pg-card__eyebrow" style="margin-top: 1rem;">{eyebrow}</p>
          <h1 class="pg-card__title" itemprop="name">{pageTitle}</h1>
          {lastUpdated && (
            <p class="legal-updated">Last updated: {lastUpdated}</p>
          )}
        </article>
      </div>
    </section>

    <section class="pg-section pg-section--compact" style={`--section-accent: ${accent};`}>
      <div class="pg-section__bg">
        <div class="pg-section__bg-img" style="background-image: url('/media/generated/fab-02.jpg'); background-position: center;"></div>
      </div>
      <div class="pg-section__scrim"></div>
      <div class="pg-section__grain"></div>

      <div class="pg-shell pg-shell--narrow">
        <article class="pg-card legal-body scroll-in">
          <slot />
        </article>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .legal-updated {
    margin: 0.5rem 0 0;
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(246, 247, 250, 0.4);
  }

  .legal-body {
    line-height: 1.8;
  }

  .legal-body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 0.9rem + 0.8vw, 1.4rem);
    color: var(--section-accent);
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid color-mix(in srgb, var(--section-accent) 25%, transparent);
  }

  .legal-body :global(h2:first-child) {
    margin-top: 0;
  }

  .legal-body :global(h3) {
    font-family: var(--font-tech);
    font-size: 0.95rem;
    font-weight: 700;
    color: rgba(246, 247, 250, 0.9);
    margin: 1.5rem 0 0.5rem;
  }

  .legal-body :global(p) {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.8;
    color: rgba(246, 247, 250, 0.7);
    margin: 0 0 0.75rem;
  }

  .legal-body :global(ul),
  .legal-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0.5rem 0 1rem;
  }

  .legal-body :global(li) {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(246, 247, 250, 0.65);
    margin-bottom: 0.35rem;
  }

  .legal-body :global(strong) {
    color: rgba(246, 247, 250, 0.9);
    font-weight: 600;
  }

  .legal-body :global(a) {
    color: var(--section-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-body :global(a:hover) {
    color: #F6F7FA;
  }

  .legal-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.82rem;
  }

  .legal-body :global(th) {
    padding: 0.6rem 0.8rem;
    text-align: left;
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--section-accent);
    border-bottom: 2px solid var(--section-accent);
  }

  .legal-body :global(td) {
    padding: 0.6rem 0.8rem;
    color: rgba(246, 247, 250, 0.65);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
</style>
