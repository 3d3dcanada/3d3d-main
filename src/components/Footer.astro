---

<footer
  class="relative mt-16"
  style={`
    background: linear-gradient(180deg, var(--color-surface-primary), var(--color-surface-secondary));
    border-top: 2px solid var(--color-border-default);
  `}
>
  {/* Organic wave divider at top */}
  <div
    class="absolute -top-[58px] left-0 right-0 h-[60px]"
    style="
      background: var(--color-surface-secondary);
      -webkit-mask-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 1200 60%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cpath d=%27M0,30 Q300,60 600,30 T1200,30 L1200,60 L0,60 Z%27 fill=%27white%27/%3E%3C/svg%3E');
      mask-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 1200 60%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cpath d=%27M0,30 Q300,60 600,30 T1200,30 L1200,60 L0,60 Z%27 fill=%27white%27/%3E%3C/svg%3E');
      -webkit-mask-size: cover;
      mask-size: cover;
    "
  />

  <div class="mx-auto max-w-5xl px-6 py-12 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {/* Business info */}
      {showCooperativeInfo && (
      	<div class="lg:col-span-2">
      		<h3
      			class="font-display text-xl font-bold"
      			style={`color: var(--color-teal-dark);`}
      		>
      			3D3D
      		</h3>
      		<p
      			class="mt-3 text-base leading-relaxed"
      			style="color: var(--color-text-secondary);"
      		>
      			Precision 3D printing, marine-grade fabrication, and field-ready production. Based in Fredericton, NB.
      		</p>
          <div
            class="mt-4 space-y-2 font-display text-sm"
            style="color: var(--color-text-secondary);"
          >
            <p>Fredericton, NB, Canada</p>
            <p>
              <a
                href="tel:+15069532678"
                class="font-medium transition-colors duration-150"
                style={`color: ${accent};`}
              >
                506-953-2678
              </a>
            </p>
            <p>
              <a
                href="mailto:info@3d3d.ca"
                class="font-medium transition-colors duration-150"
                style={`color: ${accent};`}
              >
                info@3d3d.ca
              </a>
            </p>
          </div>
          <div class="footer-socials" aria-label="3D3D social links">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                class="footer-social"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.label}
                title={link.label}
              >
                <svg viewBox={link.viewBox} aria-hidden="true" focusable="false">
                  <path d={link.path} fill="currentColor"></path>
                </svg>
                <span>{link.label}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      {/* Navigation */}
      <div>
        <h4
          class="font-display text-xs font-semibold uppercase tracking-wider"
          style="color: var(--color-text-muted);"
        >
          Navigate
        </h4>
        <ul class="mt-3 space-y-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium transition-colors duration-150 hover:underline"
                style="color: var(--color-text-secondary);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Legal */}
      <div>
        <h4
          class="font-display text-xs font-semibold uppercase tracking-wider"
          style="color: var(--color-text-muted);"
        >
          Legal
        </h4>
        <ul class="mt-3 space-y-3">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium transition-colors duration-150 hover:underline"
                style="color: var(--color-text-secondary);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Bottom bar */}
    <div
      class="mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4"
      style="border-top: 1px solid var(--color-border-subtle);"
    >
      <p
      	class="font-display text-xs font-medium"
      	style="color: var(--color-text-muted);"
      >
      	&copy; {new Date().getFullYear()} 3D3D. Fredericton, NB.
      </p>
      <p
        class="font-display text-xs"
        style="color: var(--color-text-muted);"
      >
        Materials: PLA &middot; PETG &middot; TPU &middot; ABS &middot; ASA
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .footer-social {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    box-shadow: inset 0 0 0 1px rgba(64, 196, 196, 0.18);
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .footer-social:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.94);
    transform: translateY(-1px);
  }

  .footer-social svg {
    width: 1rem;
    height: 1rem;
    color: var(--color-teal-dark);
    flex-shrink: 0;
  }
 </style>
