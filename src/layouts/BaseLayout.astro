---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import BrandSidebar from '../components/BrandSidebar';
import '../styles/global.css';

interface NavGroup {
  label: string;
  items: { id: string; label: string; href?: string }[];
}

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
  accent?: string;
  showFooter?: boolean;
  showCooperativeInfo?: boolean;
  bodyClass?: string;
  navGroups?: NavGroup[];
  activePath?: string;
}

const {
  title,
  description,
  canonicalURL,
  ogImage,
  ogType,
  schema,
  noindex = false,
  accent = '#40C4C4',
  showFooter = true,
  showCooperativeInfo = true,
  bodyClass = '',
  navGroups = [],
  activePath = '',
} = Astro.props;

// Default navigation groups for 3D3D main site
const defaultNavGroups: NavGroup[] = [
  {
    label: 'Shop',
    items: [
      { id: 'shop', label: 'All Products', href: '/shop' },
      { id: 'quote', label: 'Get a Quote', href: '/quote' },
    ],
  },
  {
    label: 'About',
    items: [
      { id: 'about', label: 'Our Story', href: '/about' },
      { id: 'makers', label: 'Our Makers', href: '/makers' },
    ],
  },
  {
    label: 'Connect',
    items: [
      { id: 'contact', label: 'Contact Us', href: '/contact' },
      { id: 'blog', label: 'Blog', href: '/blog' },
    ],
  },
];

const finalNavGroups = navGroups.length > 0 ? navGroups : defaultNavGroups;
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={title}
    description={description}
    canonicalURL={canonicalURL}
    ogImage={ogImage}
    ogType={ogType}
    schema={schema}
    noindex={noindex}
  />
</head>
<body class:list={[bodyClass, 'light-theme']}>
  <a href="#main-content" class="skip-to-content">Skip to content</a>

  {/* Sidebar Navigation */}
  <BrandSidebar
    client:load
    navGroups={finalNavGroups}
    activePath={activePath}
  />

  {/* Main Content Area - accounts for sidebar */}
  <div class="content-wrapper">
    <main id="main-content" class="min-h-screen">
      <slot />
    </main>

    {showFooter && (
      <Footer accent={accent} showCooperativeInfo={showCooperativeInfo} />
    )}
  </div>
</body>
</html>

<style is:global>
  .light-theme {
    background-color: var(--color-surface-primary);
    color: var(--color-text-primary);
  }
</style>
