---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  CATALOG,
  SOURCE_LABELS,
  getCatalogItemPurchaseOptions,
  getCatalogDefaultSelection,
  getCatalogItemStartingPrice,
  getCatalogItemHasPriceRange,
  getCatalogItemMaterialSummary,
  SHOP_CATEGORY_LABELS,
} from '../../lib/catalog';
import type { CatalogItem } from '../../lib/types';

export function getStaticPaths() {
  return CATALOG.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

interface Props {
  item: CatalogItem;
}

const { item } = Astro.props;
const { option: defaultOption, pricing: defaultPricing } = getCatalogDefaultSelection(item);
const purchaseOptions = getCatalogItemPurchaseOptions(item);
const startPrice = getCatalogItemStartingPrice(item);
const hasRange = getCatalogItemHasPriceRange(item);
const materialSummary = getCatalogItemMaterialSummary(item);
const sourceInfo = item.source ? SOURCE_LABELS[item.source] : null;
const categoryLabel = SHOP_CATEGORY_LABELS[item.category] ?? item.category;
const heroImg = item.images[0] || '/images/splash-bg-market.png';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: item.name,
  description: item.description,
  image: item.images,
  brand: { '@type': 'Brand', name: '3D3D' },
  offers: {
    '@type': 'Offer',
    price: startPrice,
    priceCurrency: 'CAD',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: '3D3D' },
  },
};
---

<BaseLayout
  title={`${item.name} | 3D3D`}
  description={item.seoDescription || item.description}
  schema={schema}
  activePath="/shop"
  noFooter
  noSidebar
  noMobileCTA
  noFeedbackBlip
  bodyClass="market-page"
>
  {/* ── Dark hero band with product image ── */}
  <section class="pdp-hero">
    <div class="pdp-hero__bg" style={`background-image: url('${heroImg}');`}></div>
    <div class="pdp-hero__scrim"></div>
    <div class="pdp-hero__content">
      <a href="/shop" class="pdp-back">
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 3L4 7l5 4"/></svg>
        Market
      </a>
      <span class="pdp-crumb">{categoryLabel}</span>
    </div>
  </section>

  {/* ── Light content ── */}
  <div class="pdp-shell">
    {/* Gallery + Details stacked on mobile, side-by-side tablet+ */}
    <div class="pdp-layout">

      {/* Gallery */}
      <div class="pdp-gallery">
        <div class="pdp-gallery__main">
          {item.images[0] ? (
            <img src={item.images[0]} alt={item.name} id="main-image" />
          ) : (
            <span class="pdp-gallery__empty">No image</span>
          )}
          <div class="pdp-gallery__badges">
            {sourceInfo && <span class="pdp-badge" style={`background:${sourceInfo.color};`}>{sourceInfo.label}</span>}
            {item.isNew && <span class="pdp-badge pdp-badge--mag">New</span>}
            {item.isPopular && <span class="pdp-badge pdp-badge--teal">Popular</span>}
          </div>
        </div>
        {item.images.length > 1 && (
          <div class="pdp-thumbs">
            {item.images.slice(0, 6).map((img, i) => (
              <button class="pdp-thumb" data-src={img} data-index={i}>
                <img src={img} alt={`${item.name} ${i + 1}`} loading="lazy" decoding="async" />
              </button>
            ))}
          </div>
        )}
      </div>

      {/* Details */}
      <div class="pdp-details">
        <span class="pdp-meta">{materialSummary}</span>
        <h1 class="pdp-title">{item.name}</h1>
        <p class="pdp-desc">{item.description}</p>

        {item.makerNote && (
          <div class="pdp-note">
            <span class="pdp-note__label">Maker note</span>
            <p>{item.makerNote}</p>
          </div>
        )}

        {/* Price */}
        <div class="pdp-price-row">
          <span class="pdp-price">{hasRange ? 'From ' : ''}${startPrice.toFixed(2)}</span>
          <span class="pdp-currency">CAD</span>
        </div>

        {/* Options */}
        {purchaseOptions.length > 1 && (
          <div class="pdp-section">
            <span class="pdp-label">Options</span>
            <div class="pdp-chips">
              {purchaseOptions.map((opt) => (
                <button class="pdp-chip" data-default={opt.isDefault ? 'true' : 'false'}>{opt.label}</button>
              ))}
            </div>
          </div>
        )}

        {/* Colors */}
        {item.colors.length > 0 && (
          <div class="pdp-section">
            <span class="pdp-label">Colors</span>
            <div class="pdp-chips">
              {item.colors.map((c) => <span class="pdp-chip">{c}</span>)}
            </div>
          </div>
        )}

        {/* Buy */}
        <div class="pdp-cta-row">
          {item.stripeLink ? (
            <a href={item.stripeLink} class="pdp-buy" target="_blank" rel="noopener noreferrer"
              data-analytics-event="checkout_started" data-analytics-source="product-page">
              Buy Now
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 6h8m-3-3 3 3-3 3"/></svg>
            </a>
          ) : (
            <a href={`mailto:info@3d3d.ca?subject=${encodeURIComponent(`Order: ${item.name}`)}`} class="pdp-buy"
              data-analytics-event="order_inquiry" data-analytics-source="product-page">
              Order Inquiry
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2 6h8m-3-3 3 3-3 3"/></svg>
            </a>
          )}
          <a href="/contact" class="pdp-secondary">Contact</a>
        </div>

        {/* Specs */}
        <div class="pdp-specs">
          <div class="pdp-spec">
            <span class="pdp-spec__val">{item.grams}g</span>
            <span class="pdp-spec__lbl">Weight</span>
          </div>
          <div class="pdp-spec">
            <span class="pdp-spec__val">{item.hours}h</span>
            <span class="pdp-spec__lbl">Print</span>
          </div>
          <div class="pdp-spec">
            <span class="pdp-spec__val">{item.colors.length}</span>
            <span class="pdp-spec__lbl">Colors</span>
          </div>
        </div>

        {/* Tags */}
        {item.tags.length > 0 && (
          <div class="pdp-tags">
            {item.tags.map((t) => <span class="pdp-tag">{t}</span>)}
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.pdp-thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      const main = document.getElementById('main-image') as HTMLImageElement;
      if (main && btn.dataset.src) {
        main.src = btn.dataset.src;
        document.querySelectorAll('.pdp-thumb').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
      }
    });
  });
</script>

<style>
  .market-page {
    background: var(--color-surface-primary);
    background-image: none;
  }

  /* ══════════════════════════════════════════
     DARK HERO BAND
     ══════════════════════════════════════════ */
  .pdp-hero {
    position: relative;
    overflow: hidden;
    height: 120px;
  }

  .pdp-hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(8px) brightness(0.5);
    transform: scale(1.1);
  }

  .pdp-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 14, 19, 0.4) 0%, rgba(10, 14, 19, 0.85) 100%);
  }

  .pdp-hero__content {
    position: relative;
    z-index: 1;
    width: min(100%, 1100px);
    margin: 0 auto;
    padding: 0 1.25rem;
    height: 100%;
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
    padding-bottom: 1rem;
  }

  .pdp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c8d0dc;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .pdp-back:hover { color: #40C4C4; }

  .pdp-crumb {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.06em;
    color: rgba(200, 208, 220, 0.4);
  }

  .pdp-crumb::before {
    content: '/';
    margin-right: 0.6rem;
    color: rgba(200, 208, 220, 0.2);
  }

  /* ══════════════════════════════════════════
     LIGHT CONTENT
     ══════════════════════════════════════════ */
  .pdp-shell {
    width: min(100%, 1100px);
    margin: 0 auto;
    padding: 1rem 1.25rem 2rem;
  }

  .pdp-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  /* ── Gallery ── */
  .pdp-gallery__main {
    position: relative;
    aspect-ratio: 1;
    border-radius: 2px;
    overflow: hidden;
    background: var(--color-surface-tertiary);
    border: 1px solid var(--color-border-default);
  }

  .pdp-gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp-gallery__empty {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .pdp-gallery__badges {
    position: absolute;
    top: 0.4rem;
    left: 0.4rem;
    display: flex;
    gap: 0.25rem;
  }

  .pdp-badge {
    padding: 2px 6px;
    font-size: 0.48rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 1px;
    color: white;
  }

  .pdp-badge--mag { background: var(--color-magenta-primary); }
  .pdp-badge--teal { background: var(--color-teal-primary); }

  .pdp-thumbs {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.3rem;
    margin-top: 0.3rem;
  }

  .pdp-thumb {
    aspect-ratio: 1;
    border-radius: 2px;
    overflow: hidden;
    border: 1px solid var(--color-border-default);
    cursor: pointer;
    background: transparent;
    padding: 0;
    transition: border-color 150ms ease;
  }

  .pdp-thumb:hover,
  .pdp-thumb.active,
  .pdp-thumb:first-child { border-color: var(--color-teal-primary); }

  .pdp-thumb img { width: 100%; height: 100%; object-fit: cover; }

  /* ── Details ── */
  .pdp-meta {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .pdp-title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1rem + 1vw, 1.7rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0.25rem 0 0;
  }

  .pdp-desc {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0.4rem 0 0;
  }

  .pdp-note {
    margin-top: 0.6rem;
    padding: 0.5rem 0.65rem;
    border-radius: 2px;
    background: var(--color-teal-surface);
    border: 1px solid rgba(64, 196, 196, 0.2);
  }

  .pdp-note__label {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-teal-dark);
    font-weight: 600;
  }

  .pdp-note p {
    margin: 0.2rem 0 0;
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
  }

  /* Price */
  .pdp-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    margin-top: 0.75rem;
  }

  .pdp-price {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--color-teal-dark);
  }

  .pdp-currency {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Sections */
  .pdp-section { margin-top: 0.6rem; }

  .pdp-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.3rem;
  }

  .pdp-chips { display: flex; flex-wrap: wrap; gap: 0.25rem; }

  .pdp-chip {
    padding: 0.28rem 0.55rem;
    border-radius: 2px;
    border: 1px solid var(--color-border-default);
    background: var(--color-surface-card);
    font-family: var(--font-tech);
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    cursor: default;
  }

  button.pdp-chip { cursor: pointer; transition: border-color 150ms ease; }
  button.pdp-chip:hover { border-color: var(--color-teal-light); }
  button.pdp-chip[data-default='true'] {
    border-color: var(--color-teal-primary);
    color: var(--color-teal-dark);
    background: var(--color-teal-surface);
  }

  /* CTA */
  .pdp-cta-row {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.85rem;
  }

  .pdp-buy {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1rem;
    border-radius: 2px;
    background: var(--color-teal-primary);
    color: #fff;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 150ms ease;
    box-shadow: 0 4px 12px rgba(64, 196, 196, 0.2);
  }

  .pdp-buy:hover {
    background: var(--color-teal-dark);
    color: #fff;
  }

  .pdp-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.8rem;
    border-radius: 2px;
    border: 1px solid var(--color-border-default);
    background: transparent;
    color: var(--color-text-secondary);
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 150ms ease;
  }

  .pdp-secondary:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text-primary);
  }

  /* Specs */
  .pdp-specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
    margin-top: 0.75rem;
  }

  .pdp-spec {
    text-align: center;
    padding: 0.4rem 0.2rem;
    border-radius: 2px;
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
  }

  .pdp-spec__val {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-teal-dark);
  }

  .pdp-spec__lbl {
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Tags */
  .pdp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem;
    margin-top: 0.6rem;
  }

  .pdp-tag {
    padding: 0.1rem 0.35rem;
    border-radius: 1px;
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    background: var(--color-surface-secondary);
  }

  /* ── Tablet+ ── */
  @media (min-width: 700px) {
    .pdp-layout {
      grid-template-columns: 1fr 1fr;
      gap: 1.75rem;
    }

    .pdp-shell { padding-inline: 2rem; }
    .pdp-hero__content { padding-inline: 2rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pdp-buy, .pdp-secondary, .pdp-thumb, .pdp-back { transition: none !important; }
  }
</style>
