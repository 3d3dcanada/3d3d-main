---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const prusaSchema = {
  "@context": "https://schema.org",
  "@type": "Store",
  "name": "3D3D Prusa Dealership & Setup Service",
  "description": "Local Canadian provider of fully assembled, calibrated Prusa 3D printers and bulk Prusament.",
  "url": "https://3d3d.ca/prusa",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Prusa 3D Printers",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Product",
          "name": "Prusa CORE One+"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Product",
          "name": "Prusa MK4S"
        }
      }
    ]
  }
};

/**
 * Prusa pricing as of March 2026.
 * Base: Prusa.com CAD prices.
 * 3D3D markup: ~10-15% for professional setup, calibration, 100 preset prints,
 * first-print walkthrough, and ongoing local support.
 */
const printers = [
  {
    name: 'Prusa CORE One+',
    slug: 'core-one-plus',
    tag: 'Flagship',
    tagColor: '#40C4C4',
    desc: 'Fully enclosed CoreXY. Input shaping, active chamber heating, open-source firmware. The machine that made Prusa fast and reliable.',
    specs: ['CoreXY · 250 mm/s', 'Enclosed + active heating', '250 × 210 × 220 mm'],
    variants: [
      { label: 'Turnkey Setup', cad: 2099 },
    ],
  },
  {
    name: 'Prusa CORE One+ Ultimate',
    slug: 'core-one-plus-ultimate',
    tag: 'Ultimate',
    tagColor: '#E84A8A',
    desc: 'Everything the CORE One+ offers, with the complete upgrade package pre-installed. Hardened nozzle, filament sensor, and more — ready for engineering materials out of the box.',
    specs: ['Full upgrade package', 'Hardened nozzle included', 'Engineering-ready'],
    variants: [
      { label: 'Turnkey Setup', cad: 2749 },
    ],
  },
  {
    name: 'Prusa CORE One L',
    slug: 'core-one-l',
    tag: 'Large Format',
    tagColor: 'var(--prusa-accent)',
    desc: 'Everything the CORE One+ does, at scale. Full enclosure, active heating, CoreXY speed. Monolithic parts that used to require splitting.',
    specs: ['Large build volume', 'Active chamber heating', 'CoreXY motion'],
    variants: [
      { label: 'Turnkey Setup', cad: 2899 },
    ],
    note: 'High demand — 4-5 week lead time',
  },
  {
    name: 'Original Prusa MK4S',
    slug: 'mk4s',
    tag: 'Workhorse',
    tagColor: '#F5A623',
    desc: 'The most proven 3D printer in the world. Nextruder, input shaping, PrusaConnect. Millions of print hours across tens of thousands of shops worldwide.',
    specs: ['Nextruder + quick-swap nozzle', 'Input shaping + pressure advance', '250 × 210 × 220 mm'],
    variants: [
      { label: 'Turnkey Setup', cad: 1599 },
    ],
  },
];
---

<BaseLayout
  title="Buy Prusa 3D Printers & Filament | 3D3D Dealership"
  description="Buy Prusa 3D printers, Prusament, and engineering materials directly from 3D3D. Professional setup, local service, and ongoing technical support in Canada."
  schema={prusaSchema}
  activePath="/prusa"
>
  <!-- Hero — clean, aggressive -->
  <section class="prusa-hero">
    <div class="prusa-shell">
      <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Prusa Dealership'}]} />
      <div class="prusa-hero__content">
        <p class="prusa-eyebrow">Prusa Hardware & Materials</p>
        <h1 class="prusa-title">
          We sell them.<br />
          We set them up.<br />
          <span class="prusa-title--accent">We support them.</span>
        </h1>
        <p class="prusa-lead">
          3D3D is your local deployment hub for Prusa equipment. We don't drop-ship boxes. We deliver machines that are fully assembled, calibrated, burn-in tested, and backed by a local shop that runs them every single day. <strong>We absolutely believe in Prusa and actively run an MK2</strong> alongside our modern fleet. We know these machines down to the frame.
        </p>
        <a href="#lineup" class="prusa-cta" style="margin-top: 1rem;">View the Lineup</a>
      </div>
    </div>
  </section>

  <!-- Filament Bulk Order Section -->
  <section class="prusa-filament" id="filament">
    <div class="prusa-shell">
      <div class="prusa-filament__inner">
        <h2 class="prusa-service__title" style="color: white; margin-bottom: 0.5rem;">Community Bulk Ordering</h2>
        <p class="prusa-filament__desc">
          Stop paying individual shipping rates from Europe or grabbing terrible Amazon filament because it's fast. We do bulk pallet orders of Prusament and high-grade engineering compounds directly from the manufacturers. By pooling our orders, we save the community massive shipping and tariff costs.
        </p>
        <ul class="prusa-filament__list">
          <li><strong>Prusament PLA/PETG:</strong> Sourced at scale to beat landed costs.</li>
          <li><strong>Engineering (ASA/PC/PEEK):</strong> Reliable, trusted batches for professional use.</li>
          <li><strong>Frequency:</strong> We run community bulk buys every month.</li>
        </ul>
        <a href="/quote?subject=bulk-filament-request" class="prusa-cta prusa-cta--ghost prusa-cta--light">Submit Order Request &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Printer Catalog -->
  <section id="lineup" class="prusa-catalog">
    <div class="prusa-shell">
      <h2 class="prusa-service__title">Turnkey Printers</h2>
      <p class="prusa-subhead">Every price includes our complete setup and calibration service.</p>
      
      <div class="prusa-grid">
        {printers.map((p) => (
          <article class="printer-card">
            <div class="printer-card__head">
              <span class="printer-card__tag" style={`color: ${p.tagColor}; border-color: ${p.tagColor}40`}>{p.tag}</span>
              <h2 class="printer-card__name">{p.name}</h2>
              <p class="printer-card__desc">{p.desc}</p>
            </div>

            <ul class="printer-card__specs">
              {p.specs.map((s) => (
                <li>{s}</li>
              ))}
            </ul>

            <div class="printer-card__pricing">
              {p.variants.map((v) => (
                <div class="printer-card__variant">
                  <span class="printer-card__variant-label">{v.label}</span>
                  <span class="printer-card__variant-price">CA${v.cad.toLocaleString()}</span>
                </div>
              ))}
              {p.note && <span class="printer-card__note">{p.note}</span>}
            </div>

            <a href={`/quote?subject=order-${p.slug}`} class="printer-card__cta">Order this machine &rarr;</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Service strip — what's included -->
  <section class="prusa-service">
    <div class="prusa-shell">
      <h2 class="prusa-service__title">The 3D3D Advantage</h2>
      <div class="prusa-service__grid">
        <div class="prusa-service__item">
          <strong>Burn-In & Calibration</strong>
          <p>We don't just assemble it. We run stress tests, dial in the Z-offset, and ensure the CoreXY belts are perfectly tensioned.</p>
        </div>
        <div class="prusa-service__item">
          <strong>100 Preset Prints</strong>
          <p>Ready-to-print models on USB. Practical tools, replacement parts, and test objects so you can print on day one.</p>
        </div>
        <div class="prusa-service__item">
          <strong>Local Support Network</strong>
          <p>When something inevitably clogs or jams, you aren't stuck waiting 48 hours for an email reply. You WhatsApp us, and we solve it.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="prusa-shell" style="padding-bottom: clamp(3rem, 5vw, 4rem); padding-top: 3rem;">
    <PageNextActions actions={[
      {label: 'Materials Guide', href: '/materials', description: 'See all materials compatible with the Prusa ecosystem.', accent: 'teal'},
      {label: 'Get a Quote', href: '/quote', description: 'Request custom fabrication on our fleet.', accent: 'orange'},
    ]} />
  </div>
</BaseLayout>

<style>
  :root {
    --prusa-accent: #FA6831;
    --prusa-accent-hover: #e85a25;
  }

  /* ─── Shared ─── */
  .prusa-shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 1200px);
    margin: 0 auto;
  }

  .prusa-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--prusa-accent);
  }

  .prusa-subhead {
    margin: 0 0 2rem;
    color: #555;
    font-size: 1.1rem;
  }

  .prusa-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.2rem;
    padding: 0.85rem 1.5rem;
    background: var(--prusa-accent);
    color: #FFFFFF;
    border: 2px solid transparent;
    border-radius: 2px;
    font-family: var(--font-tech);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 24px rgba(250, 104, 49, 0.2);
  }
  .prusa-cta:hover {
    background: var(--prusa-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(250, 104, 49, 0.35);
  }
  .prusa-cta--ghost {
    background: transparent;
    color: var(--prusa-accent);
    border-color: rgba(250, 104, 49, 0.5);
    box-shadow: none;
  }
  .prusa-cta--ghost:hover {
    background: rgba(250, 104, 49, 0.1);
    box-shadow: none;
  }
  
  .prusa-cta--light {
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }
  .prusa-cta--light:hover {
    background: rgba(255,255,255,0.1);
    border-color: #fff;
  }

  /* ─── Hero ─── */
  .prusa-hero {
    display: flex;
    align-items: center;
    min-height: 50svh;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(250, 104, 49, 0.12), transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(64, 196, 196, 0.06), transparent 50%),
      #FAFBFC;
    color: #1A1A1A;
    padding-block: clamp(5rem, 8vw, 8rem);
  }

  .prusa-hero__content {
    max-width: 700px;
    display: grid;
    gap: 1.2rem;
  }

  .prusa-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 2.5rem + 3.5vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: #1A1A1A;
  }

  .prusa-title--accent {
    color: var(--prusa-accent);
  }

  .prusa-lead {
    margin: 0;
    font-size: clamp(1.05rem, 0.95rem + 0.3vw, 1.2rem);
    line-height: 1.7;
    color: #444;
    max-width: 600px;
  }

  /* ─── Filament ─── */
  .prusa-filament {
    background: #111214;
    color: #fff;
    padding-block: clamp(3rem, 6vw, 4rem);
    border-top: 3px solid var(--prusa-accent);
  }

  .prusa-filament__inner {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .prusa-filament__desc {
    color: #ccc;
    font-size: 1.1rem;
    line-height: 1.7;
    margin: 0;
  }

  .prusa-filament__list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0 0 1rem 0;
    padding: 0;
    list-style: none;
  }

  .prusa-filament__list li {
    font-family: var(--font-tech);
    color: var(--prusa-accent);
    font-size: 0.9rem;
  }

  .prusa-filament__list strong {
    color: #fff;
    margin-right: 0.5rem;
  }


  /* ─── Catalog Grid ─── */
  .prusa-catalog {
    background: #FFFFFF;
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .prusa-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  /* ─── Printer Card ─── */
  .printer-card {
    display: flex;
    flex-direction: column;
    background: #FAFBFC;
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: 2px;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .printer-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(250, 104, 49, 0.1);
    border-color: rgba(250, 104, 49, 0.2);
  }

  .printer-card__head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .printer-card__tag {
    display: inline-flex;
    width: fit-content;
    padding: 0.2rem 0.6rem;
    border: 1px solid;
    border-radius: 2px;
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .printer-card__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1rem + 0.6vw, 1.5rem);
    font-weight: 800;
    line-height: 1.15;
    color: #1A1A1A;
  }

  .printer-card__desc {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: #666666;
  }

  .printer-card__specs {
    list-style: none;
    padding: 0;
    margin: 0 0 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border-top: 1px solid rgba(26, 26, 26, 0.06);
    padding-top: 1rem;
  }

  .printer-card__specs li {
    font-family: var(--font-tech);
    font-size: 0.74rem;
    color: #444444;
    letter-spacing: 0.02em;
  }

  .printer-card__specs li::before {
    content: '+ ';
    color: var(--prusa-accent);
    font-weight: 700;
  }

  .printer-card__pricing {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(26, 26, 26, 0.06);
  }

  .printer-card__variant {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .printer-card__variant-label {
    font-family: var(--font-tech);
    font-size: 0.72rem;
    color: #1a1a1a;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .printer-card__variant-price {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--prusa-accent);
  }

  .printer-card__note {
    font-size: 0.7rem;
    color: #E84A8A;
    font-weight: 600;
  }

  .printer-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.2rem;
    padding: 0.7rem 1.2rem;
    background: #111;
    color: #FFFFFF;
    border-radius: 2px;
    font-family: var(--font-tech);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .printer-card__cta:hover {
    background: var(--prusa-accent);
    transform: translateY(-2px);
  }

  /* ─── Service Strip ─── */
  .prusa-service {
    background:
      radial-gradient(ellipse at 70% 30%, rgba(250, 104, 49, 0.06), transparent 50%),
      #F6F2EE;
    color: #1A1A1A;
    padding-block: clamp(3rem, 5vw, 4rem);
    border-top: 3px solid var(--prusa-accent);
  }

  .prusa-service__title {
    margin: 0 0 1.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1.2rem + 1vw, 2.2rem);
    font-weight: 800;
    color: #1A1A1A;
    text-transform: uppercase;
  }

  .prusa-service__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .prusa-service__item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    background: #FFFFFF;
    border-radius: 2px;
    padding: 1.2rem;
    border: 1px solid rgba(250, 104, 49, 0.1);
  }

  .prusa-service__item strong {
    font-family: var(--font-tech);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--prusa-accent);
  }

  .prusa-service__item p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: #666666;
  }
</style>
