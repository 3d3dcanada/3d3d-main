---
import { SITE_NAV, SOCIAL_LINKS } from '../data/siteNav';

// We extract just the groups we want in the footer, or we can use all of them.
const navGroup = SITE_NAV.find(g => g.id === 'fabrication');
const storyGroup = SITE_NAV.find(g => g.id === 'story');
const legalGroup = SITE_NAV.find(g => g.id === 'legal');
---

<footer class="site-footer-full">
  <div class="site-footer-full__panel">
    <div class="site-footer-full__brand">
      <img src="/favicon.png" alt="3D3D logo" class="site-footer-full__logo" loading="lazy" />
      <div class="site-footer-full__brand-copy">
        <p class="site-footer-full__eyebrow">3D3D Atlantic Cooperative</p>
        <h2>Fabrication, software, and field deployment built to move with the job.</h2>
        <p>
          Founder-operated in Fredericton. Built for marine work, event deployment, restoration projects,
          and the people who need real operators instead of generic platforms.
        </p>
      </div>
    </div>

    <div class="site-footer-full__grid">
      <nav class="site-footer-full__column" aria-label="Footer navigation">
        <p class="site-footer-full__heading">Fabrication</p>
        <div class="site-footer-full__links">
          {navGroup?.items.map((link) => (
            <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener noreferrer' : undefined}>
              {link.label}
            </a>
          ))}
        </div>
      </nav>

      <nav class="site-footer-full__column" aria-label="The Story">
        <p class="site-footer-full__heading">The Story</p>
        <div class="site-footer-full__links">
          {storyGroup?.items.map((link) => (
            <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener noreferrer' : undefined}>
              {link.label}
            </a>
          ))}
        </div>
      </nav>

      <nav class="site-footer-full__column" aria-label="3D3D social links">
        <p class="site-footer-full__heading">Social</p>
        <div class="site-footer-full__links">
          {SOCIAL_LINKS.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      </nav>

      <nav class="site-footer-full__column" aria-label="Legal links">
        <p class="site-footer-full__heading">Legal</p>
        <div class="site-footer-full__links">
          {legalGroup?.items.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </div>
      </nav>

      <div class="site-footer-full__column">
        <p class="site-footer-full__heading">Contact</p>
        <div class="site-footer-full__contact">
          <p>© 2025–2026 3D3D Atlantic Cooperative</p>
          <p>Fredericton, NB, Canada</p>
          <a href="mailto:info@3d3d.ca">info@3d3d.ca</a>
          <a href="https://wa.me/15069532678" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer-full {
    position: relative;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(0.75rem, 3vw, 2rem)
      calc(1.25rem + env(safe-area-inset-bottom, 0px));
    background:
      radial-gradient(circle at top center, rgba(64, 196, 196, 0.08), transparent 32%),
      #060810;
  }

  .site-footer-full__panel {
    width: min(100%, 78rem);
    margin: 0 auto;
    padding: clamp(1.4rem, 3vw, 2rem);
    background: rgba(10, 14, 19, 0.76);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border: 3px solid rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    box-shadow: 0 16px 44px rgba(0, 0, 0, 0.36);
  }

  .site-footer-full__panel::before {
    content: '';
    display: block;
    width: 100%;
    height: 2px;
    margin-bottom: 1.4rem;
    background: linear-gradient(90deg, #40c4c4 0%, #e84a8a 50%, #ff6b2b 100%);
  }

  .site-footer-full__brand {
    display: grid;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1.5rem;
  }

  .site-footer-full__logo {
    width: clamp(4rem, 11vw, 5.5rem);
    height: auto;
    border-radius: 2px;
  }

  .site-footer-full__brand-copy {
    display: grid;
    gap: 0.6rem;
  }

  .site-footer-full__eyebrow,
  .site-footer-full__heading {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .site-footer-full__eyebrow {
    color: #c8d0dc;
  }

  .site-footer-full__brand-copy h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.2rem + 1.6vw, 3rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    color: #f4efe8;
  }

  .site-footer-full__brand-copy p:last-child,
  .site-footer-full__contact p,
  .site-footer-full__contact a {
    margin: 0;
    color: #c8d0dc;
    line-height: 1.65;
  }

  .site-footer-full__grid {
    display: grid;
    gap: 1.25rem;
  }

  .site-footer-full__column {
    display: grid;
    gap: 0.65rem;
  }

  .site-footer-full__heading {
    color: #f4efe8;
  }

  .site-footer-full__links,
  .site-footer-full__contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .site-footer-full__links a,
  .site-footer-full__contact a {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.5rem 0.7rem;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.05);
    border: 3px solid rgba(255, 255, 255, 0.08);
    color: #f4efe8;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .site-footer-full__links a:hover,
  .site-footer-full__contact a:hover {
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(255, 255, 255, 0.16);
    color: #ffffff;
  }

  @media (min-width: 900px) {
    .site-footer-full__brand {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .site-footer-full__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      align-items: start;
    }
  }
</style>
