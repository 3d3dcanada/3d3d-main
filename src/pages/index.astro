---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Organization'],
  name: '3D3D',
  url: 'https://3d3d.ca',
  description: 'Specialty fabrication for marine, motorsport, and field deployment. Founder-operated. Atlantic Canada.',
  telephone: '+1-506-953-2678',
  email: '3d3dcanada@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Moncton',
    addressRegion: 'NB',
    addressCountry: 'CA',
  },
  founder: { '@type': 'Person', name: 'Ken' },
  sameAs: [
    'https://www.youtube.com/@3D3Dcanada',
    'https://www.tiktok.com/@3d3dcanada',
    'https://www.instagram.com/3d3dca/',
    'https://www.facebook.com/profile.php?id=61575548079847',
    'https://www.printables.com/@KTK3D_3050116',
    'https://github.com/3d3dcanada/3d3d-main',
    'https://wa.me/15069532678',
    'https://ko-fi.com/3d3dca',
  ],
  image: 'https://3d3d.ca/media/real/fleet-start-press.jpg',
  logo: 'https://3d3d.ca/media/brand/logo-badge.webp',
};

const homeNavGroups = [
  {
    label: 'On This Page',
    items: [
      { id: 'home', label: 'Home', href: '/' },
      { id: 'what-we-do', label: 'What We Do', href: '#what-we-do' },
      { id: 'contact', label: 'Contact', href: '#contact' },
    ],
  },
  {
    label: 'Site',
    items: [
      { id: 'blog', label: 'Blog', href: '/blog' },
      { id: 'shop', label: 'Shop', href: '/shop' },
      { id: 'prusa', label: 'Prusa', href: '/prusa' },
      { id: 'about', label: 'About', href: '/about' },
    ],
  },
];

const services = [
  {
    id: 'marine',
    drawerId: 'drawer-marine',
    eyebrow: 'Marine & Offshore',
    headline: 'Built for conditions that destroy everything else.',
    description: 'Custom winch components, deck hardware, and purpose-built parts engineered for saltwater, UV exposure, and open-ocean conditions. If it lives on a vessel, we build it to last.',
    image: '/media/race/crew-helm-offshore.jpg',
    alt: 'Crew working the helm offshore during ocean racing',
    drawer: {
      materials: 'ASA, PETG-CF, PPS, PPA — marine-grade compounds rated for salt, UV, and constant mechanical load. Standard PLA and PETG fail offshore. We specify compounds that survive teak decks, standing water, UV cycles, and the vibration of an engine running 24 hours straight.',
      turnaround: 'Marine jobs start with the problem, not a file. Bring the broken part, a photo, or calipers measurements. If you\'re offshore or on the hook, send dimensions by message. We\'ve worked from blurry photos and hand-sketched dimensions. We figure it out.',
    },
  },
  {
    id: 'automotive',
    drawerId: 'drawer-automotive',
    eyebrow: 'Automotive & Motorsport',
    headline: "We know performance. We've built it.",
    description: 'Ten years as a mechanic. Engine builds, drag cars, daily drivers. Discontinued trim pieces, custom brackets, heat-resistant underhood components — if the dealer stopped making it or never made it, we do.',
    image: '/media/race/helm-racing-wake.jpg',
    alt: 'Helmsman steering at speed on open water',
    drawer: {
      materials: 'PETG-CF for structural brackets. ASA for exterior and under-hood exposure. High-temp compounds — PPS, PA12-CF — for engine bay and exhaust-adjacent parts. Material selection starts with where the part lives: heat soak, vibration frequency, clearance requirements, and whether it\'s cosmetic or load-bearing.',
      turnaround: 'Fitment-first. Send photos of the part location, the broken piece, and dimensions if you have them. For discontinued OEM parts, bring the original or a clear image — we\'ll measure, model, and test fit before committing to a run. One-off or batch — same process.',
    },
  },
  {
    id: 'scan',
    drawerId: 'drawer-scan',
    eyebrow: 'Scan · Measure · Recreate',
    headline: 'If you can bring the part, we can recreate it.',
    description: 'We reverse-engineer broken and discontinued components from physical reference — calipers, measurement, and scanning techniques. Vessel hardware, vintage car parts, antique hardware, obsolete fittings. One piece is a real job.',
    image: '/media/race/fastnet-fleet-horizon.jpg',
    alt: 'Racing fleet spread across the horizon offshore',
    drawer: {
      materials: 'Material is matched to what the original had to survive. Nylon and PETG-CF for structural fittings. PPS and PEEK for high-temp or chemical exposure. Flexible TPU for seals, grommets, and vibration-dampening mounts. If the original was injection-moulded ABS, we match the mechanical properties, not just the appearance.',
      turnaround: 'One piece is a real job. Bring the broken part — or what\'s left of it. We measure with calipers and take reference from the mating surfaces. If you don\'t have the part at all, tell us the system it belongs to and we can often source a drawing or work from photos. Turnaround depends on complexity, not on quantity — single parts are not a problem.',
    },
  },
  {
    id: 'custom',
    drawerId: 'drawer-custom',
    eyebrow: 'Custom & Field Fabrication',
    headline: 'No blueprint required. Bring the problem.',
    description: 'Custom mounts, jigs, adapters, enclosures, tooling, and one-off solutions. Carbon fibre, flexible, rigid, high-temp compounds including PPS and PEEK. We deploy — fly us to your location, your event, your boat.',
    image: '/media/race/dragon-sail-racing.jpg',
    alt: 'Custom race boat with dramatic dragon sail design',
    drawer: {
      materials: 'Full material roster: PLA for prototyping and jigs, PETG-CF and ASA for structural outdoor parts, flexible TPU for gaskets and dampening, carbon-fibre composites, PPS and PEEK for extreme heat or chemical environments. We select material after we understand the load case — not before.',
      turnaround: 'Custom work starts with a conversation, not a quote. Tell us what the part has to do, where it lives, and what failed before. We\'ll design to fit the actual conditions. Field deployment is available — if your project is on-site, on a vessel, or at an event and you need fabrication in the field, we bring the equipment to you.',
    },
  },
];

const galleryImages = [
  { src: '/media/race/crew-sail-handling.jpg', alt: 'Full crew handling sails offshore during ocean racing' },
  { src: '/media/race/offshore-racing-deck.jpg', alt: 'Racing offshore, deck view with competitors on the horizon' },
  { src: '/media/race/crew-deck-offshore.jpg', alt: 'Crew on deck, open ocean, overcast sky' },
  { src: '/media/race/night-watch-offshore.jpg', alt: 'Night passage offshore — sails up, crew on watch' },
  { src: '/media/race/crew-sunset-offshore.jpg', alt: 'Crew at the helm during a sunset passage offshore' },
  { src: '/media/race/fleet-solent-racing.jpg', alt: 'Fleet racing in the Solent, multiple boats visible' },
];
---

<BaseLayout
  title="3D3D — Specialty Fabrication for Marine, Motorsport & Field Deployment"
  description="3D3D builds functional parts for boats, cars, and anything that needs to work under real conditions. We scan, measure, and recreate broken or obsolete components. Founder-operated. Atlantic Canada."
  schema={orgSchema}
  activePath="/"
  navGroups={homeNavGroups}
  bodyClass="home-editorial"
>
  <div class="home-page">

    <!-- ═══════════════════════════════════════════════════
         HERO — dark, full-height
         ═══════════════════════════════════════════════════ -->
    <section id="home" class="home-section home-section--dark home-hero" data-reveal-section>
      <div class="hero-bg" aria-hidden="true">
        <img src="/media/real/fleet-start-press.jpg" alt="" loading="eager" decoding="async" />
      </div>
      <div class="section-shell hero-shell">
        <div class="hero-copy">
          <p class="eyebrow hero-eyebrow">Specialty Fabrication · Marine · Motorsport · Field Deployment</p>
          <h1 class="hero-title" aria-label="You have a problem. I am your solution.">
            <span class="hero-line">You have a problem.</span>
            <span class="hero-line hero-line--accent">I am your solution.</span>
          </h1>
          <p class="hero-subhead">
            If it's broken, discontinued, or doesn't exist yet — we build it. Marine hardware, automotive parts, field fabrication, on-site deployment. Atlantic Canada based, serving Canada and the United States.
          </p>
          <div class="hero-actions">
            <a href="/contact" class="hero-button hero-button--primary" data-analytics-event="contact_started" data-analytics-source="hero-cta">Request Service →</a>
            <a href="https://ko-fi.com/3d3dca" class="hero-button hero-button--ghost" target="_blank" rel="noopener noreferrer" data-analytics-event="kofi_clicked" data-analytics-source="hero-cta">Support the Campaign →</a>
          </div>
        </div>

        <div class="hero-media">
          <div class="hero-video-frame">
            <video
              class="hero-video"
              src="/media/hero-loop.mp4"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster="/media/real/race-morning-crew.jpg"
              aria-label="3D3D deployment video reel"
            ></video>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         WHAT WE DO — light
         ═══════════════════════════════════════════════════ -->
    <section id="what-we-do" class="home-section home-section--light work-section" data-reveal-section aria-labelledby="work-label">
      <div class="section-shell work-shell">

        <header class="work-header">
          <p class="eyebrow reveal-left" data-reveal>What We Do</p>
          <h2 class="section-title reveal-up" data-reveal>
            We scan it.<br />We model it.<br />We build it.
          </h2>
          <p class="section-body reveal-fade delay-1" data-reveal>
            3D3D fabricates functional parts for boats, cars, machines, and anything that can't afford to fail. We measure and reverse-engineer broken or obsolete components into exact-fit replacements — hull hardware, deck fittings, vintage automotive parts, antique hardware, discontinued fittings. Bring us the part, a photo, or just the problem. We handle the rest.
          </p>
        </header>

        <div class="services-grid" aria-label="Service areas">
          {services.map((service, i) => (
            <article
              class="service-card reveal-up"
              data-reveal
              style={`transition-delay: ${i * 0.08}s;`}
            >
              <div class="service-card__media">
                <img
                  src={service.image}
                  alt={service.alt}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="service-card__body">
                <p class="service-card__eyebrow">{service.eyebrow}</p>
                <h3 class="service-card__headline">{service.headline}</h3>
                <button
                  type="button"
                  class="service-card__cta"
                  data-drawer-trigger
                  data-drawer-id={service.drawerId}
                >
                  Learn more →
                </button>
              </div>
            </article>
          ))}
        </div>

        <!-- Swipeable gallery -->
        <div class="gallery-strip" role="region" aria-label="Work gallery" tabindex="0">
          {galleryImages.map((img) => (
            <figure class="gallery-item">
              <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
            </figure>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         CONTACT — teal/dark
         ═══════════════════════════════════════════════════ -->
    <section id="contact" class="home-section home-section--teal final-cta-section" data-reveal-section>
      <div class="section-shell final-cta-shell">
        <div class="final-cta-copy">
          <h2 class="section-title section-title--inverse reveal-up" data-reveal>
            Need a part? Need a fabricator on call?<br />Need someone who actually knows what breaks?
          </h2>
          <p class="section-body section-body--inverse reveal-fade delay-1" data-reveal>
            Send the problem. Send the broken part. Send the photo. 3D3D builds for people who need performance, not excuses.
          </p>
          <div class="final-cta-actions">
            <a href="/contact" class="final-cta-button final-cta-button--light reveal-up delay-2" data-reveal>Request Service →</a>
            <a href="https://ko-fi.com/3d3dca" class="final-cta-button final-cta-button--ghost reveal-up delay-3" data-reveal target="_blank" rel="noopener noreferrer">Support on Ko-fi →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         OFF-CANVAS DRAWER
         ═══════════════════════════════════════════════════ -->
    <div class="drawer" id="service-drawer" data-open="false" hidden>
      <div class="drawer__backdrop" data-drawer-close></div>
      <aside class="drawer__panel" role="dialog" aria-modal="true" aria-label="Service details">
        <button class="drawer__close" data-drawer-close aria-label="Close">✕</button>
        <div class="drawer__content" id="drawer-content"></div>
      </aside>
    </div>

    {services.map((service) => (
      <template id={service.drawerId}>
        <div class="drawer-copy">
          <p class="drawer-copy__eyebrow">{service.eyebrow}</p>
          <h3 class="drawer-copy__title">{service.headline}</h3>
          <p class="drawer-copy__stakes">{service.description}</p>
          <div class="drawer-copy__notes">
            <div>
              <span>Materials note</span>
              <p>{service.drawer.materials}</p>
            </div>
            <div>
              <span>Turnaround note</span>
              <p>{service.drawer.turnaround}</p>
            </div>
          </div>
          <a href="/contact" class="drawer-copy__cta">Request this type of work</a>
        </div>
      </template>
    ))}
  </div>

  <!-- ═══════════════════════════════════════════════════
       SCRIPTS
       ═══════════════════════════════════════════════════ -->
  <script is:inline>
    (() => {
      const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
      const sectionItems = Array.from(document.querySelectorAll('[data-reveal-section]'));

      const updateVisibleState = () => {
        const threshold = window.innerHeight + 300;
        revealItems.forEach((item) => {
          if (!(item instanceof HTMLElement)) return;
          if (item.getBoundingClientRect().top < threshold) {
            item.classList.add('revealed');
          }
        });
        sectionItems.forEach((item) => {
          if (!(item instanceof HTMLElement)) return;
          if (item.getBoundingClientRect().top < threshold) {
            item.classList.add('revealed-section');
          }
        });
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(() => { updateVisibleState(); ticking = false; });
      };

      const scheduleInitialChecks = () => {
        updateVisibleState();
        window.requestAnimationFrame(updateVisibleState);
        window.setTimeout(updateVisibleState, 120);
        window.setTimeout(updateVisibleState, 320);
      };

      scheduleInitialChecks();
      window.addEventListener('load', scheduleInitialChecks);
      window.addEventListener('hashchange', scheduleInitialChecks);
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
    })();

    (() => {
      const drawer = document.getElementById('service-drawer');
      const content = document.getElementById('drawer-content');
      const triggers = Array.from(document.querySelectorAll('[data-drawer-trigger]'));

      if (!(drawer instanceof HTMLElement) || !(content instanceof HTMLElement) || triggers.length === 0) return;

      let closeTimer = 0;

      const closeDrawer = () => {
        drawer.dataset.open = 'false';
        document.body.classList.remove('drawer-open');
        window.clearTimeout(closeTimer);
        closeTimer = window.setTimeout(() => {
          drawer.hidden = true;
          content.innerHTML = '';
        }, 320);
      };

      const openDrawer = (templateId) => {
        const template = document.getElementById(templateId);
        if (!(template instanceof HTMLTemplateElement)) return;
        content.innerHTML = '';
        content.appendChild(template.content.cloneNode(true));
        drawer.hidden = false;
        window.requestAnimationFrame(() => {
          drawer.dataset.open = 'true';
          document.body.classList.add('drawer-open');
        });
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const id = trigger instanceof HTMLElement ? trigger.dataset.drawerId : null;
          if (id) openDrawer(id);
        });
      });

      drawer.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-drawer-close]') : null;
        if (!target) return;
        closeDrawer();
      });

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && drawer.dataset.open === 'true') closeDrawer();
      });
    })();
  </script>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════
     PAGE TOKENS
     ═══════════════════════════════════════════════════ */
  :global(body.home-editorial) {
    background: #F6F7FA;
    background-image: none;
  }

  :global(body.drawer-open) {
    overflow: hidden;
  }

  .home-page {
    --page-accent: #40C4C4;
    --page-accent-secondary: #E84A8A;
    --page-bg-light: #F6F7FA;
    --page-bg-dark: #111214;
    --page-surface: #FFFFFF;
    --page-text: #1A1A1A;
    --page-text-muted: #666666;
    --page-border: 2px solid #1A1A1A;
    --page-thick-border: 3px solid #1A1A1A;
    --page-shell-width: min(100% - clamp(1.5rem, 4vw, 4rem), 1320px);
    background: var(--page-bg-light);
    color: var(--page-text);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .section-shell {
    position: relative;
    z-index: 1;
    width: var(--page-shell-width);
    margin: 0 auto;
  }

  .home-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 8rem);
    scroll-margin-top: 1rem;
  }

  .home-section--light { background: var(--page-bg-light); }

  .home-section--dark {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
      var(--page-bg-dark);
    color: #F6F7FA;
  }

  .home-section--teal {
    background: var(--page-accent);
    color: #FFFFFF;
  }

  /* ═══════════════════════════════════════════════════
     REVEAL
     ═══════════════════════════════════════════════════ */
  .reveal-up    { opacity: 0; transform: translateY(32px); transition: opacity 0.65s, transform 0.65s cubic-bezier(0.16,1,0.3,1); }
  .reveal-scale { opacity: 0; transform: scale(0.94); transition: opacity 0.6s, transform 0.6s cubic-bezier(0.16,1,0.3,1); }
  .reveal-left  { opacity: 0; transform: translateX(-40px); transition: opacity 0.65s, transform 0.65s cubic-bezier(0.16,1,0.3,1); }
  .reveal-fade  { opacity: 0; transition: opacity 0.65s; }
  .reveal-mask  { clip-path: inset(0 100% 0 0); transition: clip-path 0.8s cubic-bezier(0.16,1,0.3,1); }
  .reveal-mask.revealed { clip-path: inset(0 0% 0 0); }
  .revealed     { opacity: 1; transform: none; }
  .delay-1 { transition-delay: 0.1s; }
  .delay-2 { transition-delay: 0.2s; }
  .delay-3 { transition-delay: 0.3s; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: '';
    width: 2.75rem;
    height: 2px;
    background: var(--page-accent);
    flex-shrink: 0;
  }

  .section-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 4vw, 4.9rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  .section-title--light,
  .section-title--inverse { color: #F6F7FA; }

  .section-body {
    margin: 0;
    max-width: 42rem;
    font-size: clamp(1rem, 0.94rem + 0.35vw, 1.18rem);
    line-height: 1.75;
    color: var(--page-text);
  }

  .section-body--inverse { color: rgba(255, 255, 255, 0.9); }

  /* ═══════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════ */
  .home-hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: clamp(5rem, 8vw, 7rem);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: brightness(0.6);
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    align-items: center;
    gap: clamp(2rem, 4vw, 4rem);
  }

  .hero-copy { display: grid; gap: 1.5rem; }

  .hero-eyebrow {
    color: rgba(246, 247, 250, 0.72);
    animation: hero-line-in 0.72s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-title {
    margin: 0;
    display: grid;
    gap: 0.15em;
    font-family: var(--font-display);
    font-size: clamp(3rem, 1.8rem + 5vw, 6.6rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: #FFFFFF;
    text-transform: uppercase;
  }

  .hero-line {
    display: block;
    overflow: hidden;
    opacity: 0;
    transform: translateY(48px);
    animation: hero-line-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-line:nth-child(1) { animation-delay: 0s; }
  .hero-line:nth-child(2) { animation-delay: 0.1s; }
  .hero-line--accent { color: var(--page-accent); }

  .hero-subhead {
    margin: 0;
    max-width: 43rem;
    font-size: clamp(1.08rem, 0.98rem + 0.45vw, 1.28rem);
    line-height: 1.8;
    color: rgba(246, 247, 250, 0.8);
    opacity: 0;
    transform: translateY(28px);
    animation: hero-line-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
    transform: translateY(28px);
    animation: hero-line-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.4rem;
    padding: 0.95rem 1.55rem;
    border: var(--page-thick-border);
    font-family: var(--font-tech);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .hero-button:hover { transform: translateY(-2px) scale(1.02); }

  .hero-button--primary {
    background: var(--page-accent);
    color: #0F1112;
    border-color: #1A1A1A;
    box-shadow: 0 14px 32px rgba(64, 196, 196, 0.24);
  }

  .hero-button--primary:hover {
    background: #53D3D3;
    box-shadow: 0 8px 24px rgba(64, 196, 196, 0.4);
  }

  .hero-button--ghost {
    border-color: #F6F7FA;
    color: #F6F7FA;
    background: transparent;
  }

  .hero-button--ghost:hover {
    border-color: var(--page-accent);
    background: rgba(64, 196, 196, 0.12);
    color: #FFFFFF;
  }

  .hero-proof-rail {
    display: flex;
    flex-wrap: wrap;
