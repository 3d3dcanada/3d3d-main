---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Join 3D3D — Free Website for Makers',
  description: 'Join the 3D3D cooperative network. Get a free professional website, subdomain, and access to enterprise contracts.',
  url: 'https://3d3d.ca/join',
};
---

<BaseLayout title="Join the Network — Free Website for Makers | 3D3D" description="Get a free professional website, yourname.3d3d.ca subdomain, and access to enterprise-level contracts. Makers keep 75% of revenue." activePath="/join" schema={schema}>

  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40C4C4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Community', href: '/community'}, {label: 'Join'}]} />
            <p class="hp-card__eyebrow mt-4">Makers & Creators</p>
            <h1 class="hp-card__title mt-2 mb-4">Free Website. Your Name. Our Network.</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              You build things. We build the infrastructure so people can find you. Join 3D3D and get a professional website on your own subdomain — <strong>yourname.3d3d.ca</strong> — fully hosted, fully yours, zero cost.
            </p>
            <div class="hp-card__cta-row hp-card__cta-row--start mt-6">
              <a href="#apply" class="hp-cta hp-cta--accent">Start Your Application</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: What You Get -->
    <section class="hp-section" style="--section-accent: #E84A8A;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">The Offer</p>
            <h2 class="hp-card__title mt-2 mb-6">What You Get</h2>

            <div class="flex flex-col gap-6 mb-8">
              <div>
                <strong class="text-teal-400 font-tech tracking-wider uppercase text-sm">Your Own Website</strong>
                <p class="hp-card__copy mt-1">A professional Astro-powered site on <strong>yourname.3d3d.ca</strong>. Portfolio, services, contact form, blog. Hosted on Cloudflare — fast worldwide, SSL included, zero hosting fees.</p>
              </div>
              <div>
                <strong class="text-teal-400 font-tech tracking-wider uppercase text-sm">75% Revenue Share</strong>
                <p class="hp-card__copy mt-1">Enterprise contracts routed to your node. We handle quoting, invoicing, client management, and global SEO. You print. You keep 75% of the gross.</p>
              </div>
              <div>
                <strong class="text-teal-400 font-tech tracking-wider uppercase text-sm">Network Access</strong>
                <p class="hp-card__copy mt-1">Bulk material discounts. Referrals between nodes when one shop is overloaded. Shared tools. Support from people who actually run production printers.</p>
              </div>
              <div>
                <strong class="text-teal-400 font-tech tracking-wider uppercase text-sm">Marketing & Discovery</strong>
                <p class="hp-card__copy mt-1">Your work featured on the 3D3D platform. City-specific landing pages that bring local search traffic to you. Promotion across 3D3D social media.</p>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 3: Who We Want -->
    <section class="hp-section" style="--section-accent: #FF6B2B;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Who We Want</p>
            <h2 class="hp-card__title mt-2 mb-6">Makers We Work With</h2>

            <div class="flex flex-col gap-6 mb-8">
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">3D Printer Operators</strong>
                <p class="hp-card__copy mt-1">FDM, SLA, SLS — any production-capable hardware.</p>
              </div>
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">CNC Machinists</strong>
                <p class="hp-card__copy mt-1">Metal and wood subtractive manufacturing.</p>
              </div>
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">Designers & Modelers</strong>
                <p class="hp-card__copy mt-1">CAD, parametric design, Fusion 360, Onshape, FreeCAD.</p>
              </div>
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">Developers</strong>
                <p class="hp-card__copy mt-1">Astro, React, TypeScript, Rust, open-source contributors.</p>
              </div>
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">Content Creators</strong>
                <p class="hp-card__copy mt-1">Photography, video, documentation, technical writing.</p>
              </div>
              <div>
                <strong class="text-pink-400 font-tech tracking-wider uppercase text-sm">Artists & Sculptors</strong>
                <p class="hp-card__copy mt-1">Digital sculpting, miniatures, props, cosplay fabrication.</p>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 4: Application Form -->
    <section class="hp-section" style="--section-accent: #AAFF2A;" id="apply">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/network-02.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <p class="hp-card__eyebrow">Apply</p>
            <h2 class="hp-card__title mt-2 mb-2">Join the Network</h2>
            <p class="hp-card__copy mb-6">Fill this out. We review within 48 hours. If accepted, your site goes live within a week.</p>

            <form action="https://formspree.io/f/mldlydbl" method="POST" class="hp-form" data-analytics-submit="member_application">
              <input type="hidden" name="_subject" value="New Member Application — 3D3D Network" />

              <div class="hp-form__grid">
                <label class="hp-field">
                  <span>Full Name *</span>
                  <input type="text" name="name" required autocomplete="name" placeholder="Jane Doe" />
                </label>
                <label class="hp-field">
                  <span>Email *</span>
                  <input type="email" name="email" required autocomplete="email" placeholder="jane@example.com" />
                </label>
              </div>

              <div class="hp-form__grid">
                <label class="hp-field">
                  <span>City / Region *</span>
                  <input type="text" name="city" required autocomplete="address-level2" placeholder="Halifax, NS" />
                </label>
                <label class="hp-field">
                  <span>Requested Subdomain</span>
                  <div class="join-subdomain-wrap">
                    <input type="text" name="subdomain" placeholder="yourname" pattern="[a-z0-9-]+" title="Lowercase letters, numbers, and hyphens only" />
                    <span class="join-subdomain-suffix">.3d3d.ca</span>
                  </div>
                </label>
              </div>

              <label class="hp-field">
                <span>What do you make? *</span>
                <select name="role" required>
                  <option value="">Select your primary skill</option>
                  <option value="3d-printing">3D Printing (FDM/SLA/SLS)</option>
                  <option value="cnc">CNC Machining</option>
                  <option value="design">CAD / 3D Modeling</option>
                  <option value="developer">Software Development</option>
                  <option value="content">Content Creation (Photo/Video)</option>
                  <option value="artist">Digital Art / Sculpting</option>
                  <option value="other">Other</option>
                </select>
              </label>

              <label class="hp-field">
                <span>Describe your setup</span>
                <textarea name="hardware" rows="4" placeholder="What machines do you run? What materials? What kind of work do you do? Links to portfolio or social media welcome."></textarea>
              </label>

              <label class="hp-field">
                <span>Existing website or portfolio (optional)</span>
                <input type="url" name="website" placeholder="https://your-portfolio.com" />
              </label>

              <div class="join-consent">
                <label class="join-checkbox-wrap">
                  <input type="checkbox" name="consent_tos" required />
                  <span>I agree to the <a href="/terms" target="_blank">Terms of Service</a> and <a href="/privacy" target="_blank">Privacy Policy</a>. *</span>
                </label>
                <label class="join-checkbox-wrap">
                  <input type="checkbox" name="consent_casl" />
                  <span>I consent to receiving emails from 3D3D about network opportunities, updates, and community news per <a href="/casl" target="_blank">CASL</a>.</span>
                </label>
              </div>

              <div class="hp-dialog__actions">
                <button type="submit" class="hp-cta hp-cta--accent">Submit Application</button>
              </div>
            </form>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 5: Next Steps -->
    <section class="hp-section" style="--section-accent: #40C4C4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/real/golden-hour-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start">
        <article class="hp-card scroll-in">
          <div class="hp-card__inner">
            <PageNextActions actions={[
              {label: 'Operator Network', href: '/network', description: 'Already have production hardware? Apply as an operator node.', accent: 'teal'},
              {label: 'Community', href: '/community', description: 'See our open-source repos and community projects.', accent: 'magenta'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .join-subdomain-wrap {
    display: flex;
    align-items: stretch;
  }
  .join-subdomain-wrap input {
    flex: 1;
    border-radius: 2px 0 0 2px;
    border-right: 0;
  }
  .join-subdomain-suffix {
    display: flex;
    align-items: center;
    padding: 0 1rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-left: 0;
    border-radius: 0 2px 2px 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: rgba(246, 247, 250, 0.5);
    white-space: nowrap;
  }
  .join-consent {
    display: grid;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }
  .join-checkbox-wrap {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    cursor: pointer;
  }
  .join-checkbox-wrap input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    accent-color: var(--color-teal-primary);
    flex-shrink: 0;
  }
  .join-checkbox-wrap span {
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgba(246, 247, 250, 0.55);
  }
  .join-checkbox-wrap a {
    color: var(--color-teal-primary);
    text-decoration: underline;
  }
</style>
