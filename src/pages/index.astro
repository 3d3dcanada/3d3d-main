---
import BaseLayout from '../layouts/BaseLayout.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'Organization'],
  name: '3D3D',
  url: 'https://3d3d.ca',
  description: 'Specialty fabrication for marine, motorsport, replacement parts, and field deployment. Founder-operated and serving worldwide buyers.',
  telephone: '+1-506-953-2678',
  email: 'info@3d3d.ca',
  areaServed: ['Worldwide', 'Caribbean', 'Coastal United States', 'Europe'],
  founder: { '@type': 'Person', name: 'Ken' },
  sameAs: [
    'https://www.youtube.com/@3D3Dcanada',
    'https://www.tiktok.com/@3d3dcanada',
    'https://www.instagram.com/3d3dca/',
    'https://www.facebook.com/profile.php?id=61575548079847',
    'https://www.printables.com/@KTK3D_3050116',
    'https://github.com/3d3dcanada/3d3d-main',
    'https://wa.me/15069532678',
    'https://ko-fi.com/3d3dca',
  ],
  image: 'https://3d3d.ca/media/real/fleet-start-press.jpg',
  logo: 'https://3d3d.ca/media/brand/logo-badge.webp',
};

const homeNavGroups = [
  {
    label: 'On This Page',
    items: [
      { id: 'home', label: 'Home', href: '/' },
      { id: 'what-i-do', label: 'What I Do', href: '#what-i-do' },
      { id: 'workshop', label: 'The Workshop', href: '#workshop' },
      { id: 'contact', label: 'Contact', href: '#contact' },
    ],
  },
  {
    label: 'Site',
    items: [
      { id: 'blog', label: 'Blog', href: '/blog' },
      { id: 'shop', label: 'Shop', href: '/shop' },
      { id: 'prusa', label: 'Prusa', href: '/prusa' },
      { id: 'about', label: 'About', href: '/about' },
    ],
  },
];

const services = [
  {
    id: 'marine',
    drawerId: 'drawer-marine',
    eyebrow: 'Marine Hardware',
    headline: 'The part does not exist anymore. So I build it.',
    description: 'Supply chains do not care about your passage plan. When a stainless pawl wears through a bronze pocket on a discontinued Barient 27 winch, or a Spinlock XA clutch handle snaps under a loaded halyard, you cannot wait three weeks for a mismatched part that may not fit. I reverse-engineer deck fittings, fairleads, winch components, and custom brackets, all built to handle offshore dynamic loads.',
    drawer: {
      materials: 'ASA above deck. UV-stable, 93°C heat deflection. PETG-CF below deck for structural fittings. PP Glass Fiber or PP Carbon Fiber for constant saltwater contact. TPU 95A for seals and gaskets. PA11 CF near engines. 192°C, resists oils and fuels.',
      turnaround: 'Send the broken component, or provide precise caliper measurements. If you\'re offshore, dimensions by message are enough. I\'ve built from blurry photos and measurements taken on a rolling deck.',
    },
  },
  {
    id: 'automotive',
    drawerId: 'drawer-automotive',
    eyebrow: 'Automotive Restoration',
    headline: 'Unobtainium ceases to be a problem.',
    description: 'I spent ten years turning wrenches on heavy iron. I have personally restored the AMC AMX, Dodge Polara, GTX, and Roadrunner. I know the frustration of halting a multi-year build because an interior trim panel, a dash overlay, or a specific retaining clip was last stamped forty years ago. I fabricate exact geometric replicas of discontinued OEM parts that fit and hold.',
    drawer: {
      materials: 'PA11 CF for engine bay. 192°C heat deflection, resists oils and fuels. PETG-CF for structural brackets. ASA for exterior and underhood UV exposure. PC Blend for impact-critical parts. PEI 1010 when nothing else survives.',
      turnaround: 'Ship the shattered original piece or the surrounding housing. I will rebuild the geometry digitally and print the final part. For discontinued OEM parts, bring the original. I measure, model, and test-fit before committing.',
    },
  },
  {
    id: 'onsite',
    drawerId: 'drawer-onsite',
    eyebrow: 'On-Site Deployment',
    headline: 'The vessel cannot move. I can.',
    description: 'Marina fees bleed cruising budgets dry. If your vessel is tied up in Antigua, Newport, or a remote boatyard waiting on a critical refit component, the fastest path to the water is bringing the factory to the dock. I travel worldwide with the necessary equipment, assess the failure, design the fix, and fabricate the hardware on location.',
    drawer: {
      materials: 'Full material stack on location. ASA, PA11 CF, PETG-CF, TPU, PP-CF, matched to the failure mode after I\'ve assessed it in person. No guessing from a product page.',
      turnaround: 'Call me. Tell me where the boat is and what is broken. I will pack the cases and sort the flights.',
    },
  },
  {
    id: 'remote',
    drawerId: 'drawer-remote',
    eyebrow: 'Remote Fabrication',
    headline: 'Engineered here. Deployed anywhere.',
    description: 'For components that do not require my physical presence on deck. Send high-resolution photos, the load requirements, and exact caliper measurements. I design the replacement and ship the finished hardware to your current coordinates. Your marina, your boatyard, wherever the vessel is sitting.',
    drawer: {
      materials: 'Material matched to the environment after intake. Saltwater, UV, heat, chemical exposure, dynamic load. I specify based on what the part has to survive, not what is easiest to print.',
      turnaround: 'Send photos of the broken component, the mounting area, and caliper measurements. I will confirm the geometry, quote the job, and ship to your coordinates.',
    },
  },
];

---

<BaseLayout
  title="3D3D | You Have a Problem. I Am Your Solution."
  description="Offshore marine fabrication and discontinued part replacement. Worldwide on-site deployment and remote engineering by a 20,000nm offshore specialist."
  schema={orgSchema}
  activePath="/"
  navGroups={homeNavGroups}
  bodyClass="home-editorial"
>
  <div class="home-page">

    <!-- ═══════════════════════════════════════════════════
         HERO — dark, full-height
         ═══════════════════════════════════════════════════ -->
    <section id="home" class="home-section home-section--dark home-hero" data-section>
      <div class="hero-bg" aria-hidden="true">
        <img src="/media/real/fleet-start-press.jpg" alt="" loading="eager" decoding="async" />
      </div>
      <div class="section-shell hero-shell">
        <div class="hero-copy">
          <p class="eyebrow hero-eyebrow">Offshore Fabrication & Mechanical Specialist</p>
          <h1 class="hero-title" aria-label="You have a problem. I am your solution.">
            <span class="hero-line">You have a problem.</span>
            <span class="hero-line hero-line--accent">I am your solution.</span>
          </h1>
          <p class="hero-subhead">
            I am not a 3D printing service. I am an offshore specialist with a twenty-year mechanical background, advanced fabrication tools, and the hard-won knowledge of what keeps a vessel moving. The printer is just the newest tool in a kit built to fix things that cannot fail at sea. Available for on-site work, worldwide. One call.
          </p>
          <div class="hero-actions">
            <a href="/contact" class="hero-button hero-button--primary" data-analytics-event="contact_started" data-analytics-source="hero-cta">One Call. I'll Assess It. →</a>
            <a href="https://ko-fi.com/3d3dca" class="hero-button hero-button--ghost" target="_blank" rel="noopener noreferrer" data-analytics-event="kofi_clicked" data-analytics-source="hero-cta">Support the Campaign →</a>
          </div>
        </div>

        <div class="hero-media">
          <div class="hero-video-frame">
            <video
              class="hero-video"
              src="/media/hero-loop.mp4"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster="/media/real/race-morning-crew.jpg"
              aria-label="3D3D deployment video reel"
            ></video>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         CAMPAIGN STRIP
         ═══════════════════════════════════════════════════ -->
    <section class="cstrip" aria-label="Campaign timeline">

      <!-- Strip label -->
      <div class="cstrip__header">
        <span class="cstrip__label">Campaign Timeline</span>
        <span class="cstrip__status">
          <span class="cstrip__pulse"></span>
          Live — Newport-Bermuda 2026
        </span>
      </div>

      <div class="cstrip__rail">

        <!-- COMPLETED: 3D3D Founded -->
        <button class="cstrip__cell cstrip__cell--done" data-timeline-modal="modal-3d3d" aria-label="3D3D Founded — click for details">
          <div class="cstrip__cell-accent cstrip__cell-accent--teal"></div>
          <div class="cstrip__cell-inner">
            <div class="cstrip__cell-left">
              <span class="cstrip__badge cstrip__badge--done">&#10003; Done</span>
              <time class="cstrip__date">03 / 2025</time>
              <strong class="cstrip__title">3D3D Founded</strong>
              <span class="cstrip__sub">RV. Generator. Three printers.</span>
            </div>
            <div class="cstrip__cell-right">
              <img src="/media/brand/3d3d-logo.svg" alt="3D3D" class="cstrip__logo" loading="lazy" />
              <span class="cstrip__expand">&#8599;</span>
            </div>
          </div>
        </button>

        <!-- COMPLETED: Prusa Sponsorship -->
        <button class="cstrip__cell cstrip__cell--done cstrip__cell--prusa" data-timeline-modal="modal-prusa" aria-label="Prusa CORE One L sponsorship — click for details">
          <div class="cstrip__cell-accent cstrip__cell-accent--orange"></div>
          <div class="cstrip__cell-inner">
            <div class="cstrip__cell-left">
              <span class="cstrip__badge cstrip__badge--done">&#10003; Done</span>
              <time class="cstrip__date">03 / 2026</time>
              <strong class="cstrip__title">Prusa CORE One L</strong>
              <span class="cstrip__sub">Sponsorship acquired</span>
            </div>
            <div class="cstrip__cell-right">
              <img src="/media/brand/prusa-logo.svg" alt="Prusa Research" class="cstrip__logo cstrip__logo--prusa" loading="lazy" />
              <span class="cstrip__expand">&#8599;</span>
            </div>
          </div>
        </button>

        <!-- UPCOMING: Newport-Bermuda — featured, wider -->
        <button class="cstrip__cell cstrip__cell--upcoming cstrip__cell--featured" data-timeline-modal="modal-newport" aria-label="Newport-Bermuda Race 2026 — click for details">
          <div class="cstrip__cell-accent cstrip__cell-accent--teal"></div>
          <div class="cstrip__cell-inner">
            <div class="cstrip__cell-left">
              <span class="cstrip__badge cstrip__badge--upcoming">&#9654; Upcoming</span>
              <time class="cstrip__date">06 / 2026</time>
              <strong class="cstrip__title">Newport &rarr; Bermuda</strong>
              <span class="cstrip__sub">120th running &middot; 635nm &middot; Live fabrication aboard</span>
            </div>
            <div class="cstrip__cell-right">
              <img src="/media/real/fleet-running.jpg" alt="Fleet at sea" class="cstrip__img" loading="lazy" />
              <span class="cstrip__expand">&#8599;</span>
            </div>
          </div>
        </button>

        <!-- OPEN: Sponsor slot 1 -->
        <a href="/contact?subject=sponsorship" class="cstrip__cell cstrip__cell--open">
          <div class="cstrip__cell-accent cstrip__cell-accent--ghost"></div>
          <div class="cstrip__cell-inner">
            <div class="cstrip__cell-left">
              <span class="cstrip__badge cstrip__badge--open">Available</span>
              <time class="cstrip__date">2026</time>
              <strong class="cstrip__title cstrip__title--ghost">Your Brand Here</strong>
              <span class="cstrip__sub cstrip__sub--ghost">Campaign partner slot</span>
            </div>
            <div class="cstrip__cell-right">
              <span class="cstrip__open-icon">+</span>
              <span class="cstrip__expand cstrip__expand--ghost">Apply &rarr;</span>
            </div>
          </div>
        </a>

        <!-- OPEN: Sponsor slot 2 -->
        <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer" class="cstrip__cell cstrip__cell--open">
          <div class="cstrip__cell-accent cstrip__cell-accent--ghost"></div>
          <div class="cstrip__cell-inner">
            <div class="cstrip__cell-left">
              <span class="cstrip__badge cstrip__badge--open">Available</span>
              <time class="cstrip__date">2026</time>
              <strong class="cstrip__title cstrip__title--ghost">Support the Mission</strong>
              <span class="cstrip__sub cstrip__sub--ghost">Ko-fi &middot; Any amount</span>
            </div>
            <div class="cstrip__cell-right">
              <span class="cstrip__open-icon">&#9825;</span>
              <span class="cstrip__expand cstrip__expand--ghost">Ko-fi &rarr;</span>
            </div>
          </div>
        </a>

      </div>

      <!-- Progress track -->
      <div class="cstrip__track" aria-hidden="true">
        <div class="cstrip__track-fill"></div>
      </div>

    </section>

    <!-- ═══ MODALS ═══ -->
    <div class="tm" id="modal-3d3d" data-open="false" hidden>
      <div class="tm__backdrop" data-timeline-modal-close></div>
      <div class="tm__panel">
        <button class="tm__close" data-timeline-modal-close aria-label="Close">&times;</button>

        <div class="tm__head tm__head--teal">
          <span class="tm__head-date">Founded 03 / 2025</span>
          <img src="/media/brand/3d3d-logo.svg" alt="3D3D" class="tm__head-logo" />
        </div>

        <div class="tm__body">
          <h3 class="tm__title">3D3D</h3>
          <p class="tm__location">Atlantic Canada &middot; Serving worldwide</p>

          <p class="tm__text">
            One-person specialty fabrication operation. Started in an RV running three printers off a $30/day generator in 35-degree heat. Ten years as a mechanic — built performance engines, worked drag cars, restored classics. 20,000+ nautical miles offshore. Learned sailing on a duo passage from Halifax to Antigua that hit a cat-one storm: 70-knot sustained winds, 90-knot gusts.
          </p>
          <p class="tm__text">
            17 engineering-grade compounds in the stack — ASA, PETG-CF, PA11-CF, PP-GF, PPS, PEI 1010 and more. Every part designed for the conditions it has to survive. Not for display cases.
          </p>

          <div class="tm__facts">
            <div class="tm__fact">
              <span class="tm__fact-val">17</span>
              <span class="tm__fact-key">Materials</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">20k+</span>
              <span class="tm__fact-key">Nautical miles</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">10yr</span>
              <span class="tm__fact-key">Mechanical</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">1</span>
              <span class="tm__fact-key">Founder</span>
            </div>
          </div>

          <div class="tm__links">
            <a href="/about" class="tm__cta tm__cta--primary">About Ken &rarr;</a>
            <a href="/materials" class="tm__cta">Material Stack &rarr;</a>
            <a href="/contact" class="tm__cta">Request Service &rarr;</a>
            <a href="https://www.printables.com/@KTK3D_3050116" target="_blank" rel="noopener noreferrer" class="tm__cta">Printables &rarr;</a>
          </div>
        </div>
      </div>
    </div>

    <div class="tm" id="modal-prusa" data-open="false" hidden>
      <div class="tm__backdrop" data-timeline-modal-close></div>
      <div class="tm__panel">
        <button class="tm__close" data-timeline-modal-close aria-label="Close">&times;</button>

        <div class="tm__head tm__head--orange">
          <span class="tm__head-date">Acquired 03 / 2026</span>
          <img src="/media/brand/prusa-logo.svg" alt="Prusa Research" class="tm__head-logo" />
        </div>

        <div class="tm__body">
          <h3 class="tm__title">Prusa CORE One L</h3>
          <p class="tm__location">Flagship enclosed CoreXY &middot; Open-source</p>

          <p class="tm__text">
            After a year of daily documented work on the Prusa ecosystem, Prusa Research recognized 3D3D's commitment and is sending the CORE One L — their flagship enclosed CoreXY machine. This isn't marketing. It's recognition. The CORE One L ships with active chamber heating to 90°C, input shaping for high-speed printing without ringing, and tool-changing capability for multi-material runs.
          </p>
          <p class="tm__text">
            The machine will be deployed live aboard CSM the Mariner during the 2026 Newport-Bermuda Race, printing engineering-grade parts 635nm offshore in open-ocean conditions.
          </p>

          <div class="tm__facts">
            <div class="tm__fact">
              <span class="tm__fact-val">360</span>
              <span class="tm__fact-key">mm³/s flow</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">90°C</span>
              <span class="tm__fact-key">Chamber heat</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">IS</span>
              <span class="tm__fact-key">Input shaping</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">AMS</span>
              <span class="tm__fact-key">Tool changing</span>
            </div>
          </div>

          <div class="tm__links">
            <a href="https://www.prusa3d.com/en/category/original-prusa-core-one/" target="_blank" rel="noopener noreferrer" class="tm__cta tm__cta--primary tm__cta--orange">Prusa CORE One &rarr;</a>
            <a href="/materials" class="tm__cta">Material Stack &rarr;</a>
            <a href="/events" class="tm__cta">Campaign Log &rarr;</a>
            <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer" class="tm__cta">Support on Ko-fi &rarr;</a>
          </div>
        </div>
      </div>
    </div>

    <div class="tm" id="modal-newport" data-open="false" hidden>
      <div class="tm__backdrop" data-timeline-modal-close></div>
      <div class="tm__panel tm__panel--wide">
        <button class="tm__close" data-timeline-modal-close aria-label="Close">&times;</button>

        <div class="tm__head tm__head--teal">
          <span class="tm__head-date">June 2026 &middot; 120th Running</span>
          <span class="tm__head-tag">LIVE FABRICATION</span>
        </div>

        <div class="tm__photo-strip">
          <img src="/media/real/fleet-start-press.jpg" alt="Fleet at the start" loading="lazy" />
        </div>

        <div class="tm__body">
          <h3 class="tm__title">Newport, RI &rarr; Bermuda</h3>
          <p class="tm__location">635nm &middot; Open Atlantic &middot; Gulf Stream crossing</p>

          <p class="tm__text">
            Aboard CSM the Mariner with a Prusa CORE One L printing live during the crossing. Spinnaker pole end fittings crack during night peels. Electronics brackets shatter when the hull slams a Gulf Stream trough. 200 miles offshore you cannot call a rigger — you fabricate the replacement while the boat holds its heading. Every part documented, tested, and published.
          </p>

          <div class="tm__facts">
            <div class="tm__fact">
              <span class="tm__fact-val">635</span>
              <span class="tm__fact-key">Nautical miles</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">120</span>
              <span class="tm__fact-key">Years running</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">Live</span>
              <span class="tm__fact-key">3D printing</span>
            </div>
            <div class="tm__fact">
              <span class="tm__fact-val">0</span>
              <span class="tm__fact-key">Excuses</span>
            </div>
          </div>

          <div class="tm__links">
            <a href="/events" class="tm__cta tm__cta--primary">Campaign details &rarr;</a>
            <a href="https://ko-fi.com/3d3dca" target="_blank" rel="noopener noreferrer" class="tm__cta">Support on Ko-fi &rarr;</a>
            <a href="/contact?subject=sponsorship" class="tm__cta">Become a sponsor &rarr;</a>
            <a href="/book" class="tm__cta">Book a call &rarr;</a>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
         WHAT WE DO — light
         ═══════════════════════════════════════════════════ -->
    <section id="what-i-do" class="home-section home-section--light work-section" data-section aria-labelledby="work-label">
      <div class="section-shell work-shell">

        <header class="work-header">
          <p class="eyebrow scroll-in-left">What I Do</p>
          <h2 class="section-title scroll-in" aria-label="I scan it. I model it. I build it.">
            <span class="typewriter-line" data-typewriter>I scan it.</span><br />
            <span class="typewriter-line" data-typewriter>I model it.</span><br />
            <span class="typewriter-line" data-typewriter>I build it.</span>
          </h2>
          <p class="section-body scroll-in-fade scroll-delay-1">
            My background is not in software. It is in keeping complex machinery alive when failure has severe consequences. I reverse-engineer broken and obsolete components into exact-fit replacements: deck fittings, winch hardware, discontinued OEM parts, vintage automotive pieces, and one-off solutions that no supply chain carries anymore. Bring me the part, a photo, or just the problem.
          </p>
        </header>

        <div class="services-scroll" role="region" aria-label="Service areas" tabindex="0">
          {services.map((service, i) => (
            <article
              class="service-card scroll-in"
              style={`transition-delay: ${i * 0.12}s;`}
              data-drawer-trigger
              data-drawer-id={service.drawerId}
              role="button"
              tabindex="0"
            >
              <p class="service-card__eyebrow">{service.eyebrow}</p>
              <h3 class="service-card__headline">{service.headline}</h3>
              <p class="service-card__desc">{service.description}</p>
              <span class="service-card__cta">Learn more →</span>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════
         THE WORKSHOP — dark
         ═══════════════════════════════════════════════════ -->
    <section id="workshop" class="home-section home-section--dark workshop-section" data-section aria-labelledby="workshop-label">
      <div class="section-shell workshop-shell">
        <header class="workshop-header">
          <p class="eyebrow eyebrow--light scroll-in-left">The Workshop</p>
          <h2 class="section-title section-title--light scroll-in" id="workshop-label">
            Built to solve problems.<br />Not to look pretty on a shelf.
          </h2>
          <p class="section-body section-body--inverse scroll-in-fade scroll-delay-1">
            Two Prusa MK4S printers running engineering compounds. A full mechanical tool kit built over twenty years of turning wrenches. Calipers, micrometers, and a scanner for reverse engineering parts that no longer have drawings. This is not a hobby setup. It is a portable fabrication lab that travels to the job.
          </p>
        </header>

        <div class="workshop-grid">
          <figure class="workshop-card workshop-card--hero scroll-in" data-lightbox data-lightbox-src="/media/workshop/printer-action-cf.jpg" data-lightbox-label="Live print" data-lightbox-note="PETG-CF structural bracket, 0.2mm layer height. Carbon fiber reinforced compound printed on the Prusa MK4S with a hardened steel nozzle. This bracket replaces a factory aluminium piece that cracked under cyclic loading." role="button" tabindex="0">
            <img src="/media/workshop/printer-action-cf.jpg" alt="Prusa MK4S printing carbon fiber compound" loading="lazy" decoding="async" />
            <figcaption>
              <span class="workshop-card__label">Live print</span>
              <span class="workshop-card__note">PETG-CF structural bracket, 0.2mm layer height</span>
            </figcaption>
          </figure>
          <figure class="workshop-card scroll-in scroll-delay-1" data-lightbox data-lightbox-src="/media/workshop/printer-frame-shot.jpg" data-lightbox-label="The machine" data-lightbox-note="Prusa MK4S with hardened steel nozzle for abrasive compounds like PETG-CF, PA11-CF, and PP Glass Fiber. Input shaping enabled for high-speed printing without ringing artifacts." role="button" tabindex="0">
            <img src="/media/workshop/printer-frame-shot.jpg" alt="Prusa printer frame close-up" loading="lazy" decoding="async" />
            <figcaption>
              <span class="workshop-card__label">The machine</span>
              <span class="workshop-card__note">Prusa MK4S with hardened nozzle for abrasive compounds</span>
            </figcaption>
          </figure>
          <figure class="workshop-card scroll-in scroll-delay-2" data-lightbox data-lightbox-src="/media/workshop/machine-parts-flatlay.jpg" data-lightbox-label="Output" data-lightbox-note="Finished parts ready for fitment and deployment. Each component is printed in the compound matched to its failure mode and environment. Nothing leaves the bench until dimensional checks pass." role="button" tabindex="0">
            <img src="/media/workshop/machine-parts-flatlay.jpg" alt="Finished machine parts laid out for inspection" loading="lazy" decoding="async" />
            <figcaption>
              <span class="workshop-card__label">Output</span>
              <span class="workshop-card__note">Finished parts ready for fitment and deployment</span>
            </figcaption>
          </figure>
