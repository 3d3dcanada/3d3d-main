<LegalLayout
  title="Accessibility | 3D3D"
  description="3D3D Atlantic Cooperative accessibility statement. Our commitment to WCAG 2.1 and the Accessible Canada Act."
  pageTitle="Accessibility Statement"
  eyebrow="Legal"
