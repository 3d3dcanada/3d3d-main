---
interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  keywords?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
}

const {
  title,
  description,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  ogImage = new URL('/og-default.png', Astro.site).href,
  ogType = 'website',
  schema,
  noindex = false,
  keywords,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
} = Astro.props;

const isArticle = ogType === 'article';

// Global Organization + LocalBusiness + WebSite schema injected on every page
const globalSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': ['LocalBusiness', 'Organization'],
    '@id': 'https://3d3d.ca/#organization',
    name: '3D3D',
    legalName: '3D3D Atlantic Cooperative',
    url: 'https://3d3d.ca',
    logo: 'https://3d3d.ca/favicon.svg',
    image: 'https://3d3d.ca/og-default.png',
    description: 'Founder-operated 3D printing and custom fabrication operating as an open-source cooperative. Marine hardware, automotive restoration parts, prototyping, and engineering-grade FDM printing. Based in Atlantic Canada. Ships worldwide.',
    email: 'info@3d3d.ca',
    founder: { '@type': 'Person', name: 'Ken' },
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Fredericton',
      addressRegion: 'NB',
      addressCountry: 'CA',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 45.9636,
      longitude: -66.6431,
    },
    areaServed: [
      { '@type': 'Country', name: 'Canada' },
      { '@type': 'Country', name: 'United States' },
      { '@type': 'AdministrativeArea', name: 'Caribbean' },
      { '@type': 'AdministrativeArea', name: 'Europe' },
      { '@type': 'State', name: 'New Brunswick' },
      { '@type': 'State', name: 'Nova Scotia' },
      { '@type': 'State', name: 'Prince Edward Island' },
      { '@type': 'State', name: 'Newfoundland and Labrador' },
      { '@type': 'State', name: 'Ontario' },
      { '@type': 'State', name: 'Quebec' },
      { '@type': 'State', name: 'British Columbia' },
      { '@type': 'State', name: 'Alberta' },
    ],
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: '3D3D Services',
      itemListElement: [
        { '@type': 'OfferCatalog', name: 'Custom 3D Printing', description: 'FDM printing in PLA, PETG, ASA, TPU, ABS, Nylon CF, PC, PEI. Marine-grade and engineering compounds.' },
        { '@type': 'OfferCatalog', name: 'Reverse Engineering & Part Recovery', description: 'Discontinued parts fabricated from measurements or 3D scanning. Automotive, marine, industrial.' },
        { '@type': 'OfferCatalog', name: '3D Printer Sales & Setup', description: 'Open-source printers sold with professional installation, calibration, and training.' },
        { '@type': 'OfferCatalog', name: 'Open Source Hardware Consulting', description: 'Assistance with open-source 3D printer builds, community fabrication nodes, and localized manufacturing.' },
        { '@type': 'OfferCatalog', name: 'Prototyping & Consulting', description: 'Rapid prototyping, material selection, design-for-manufacturing consulting.' },
      ],
    },
    priceRange: '$$',
    currenciesAccepted: 'CAD, USD',
    paymentAccepted: 'Credit Card, E-Transfer, PayPal',
    openingHoursSpecification: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
    sameAs: [
      'https://www.youtube.com/@3D3Dcanada',
      'https://www.instagram.com/3d3dca/',
      'https://www.tiktok.com/@3d3dcanada',
      'https://www.facebook.com/profile.php?id=61575548079847',
      'https://ko-fi.com/3d3dca',
    ],
    knowsAbout: [
      'FDM 3D printing',
      'Marine hardware fabrication',
      'Automotive restoration parts',
      'Engineering-grade polymers',
      'Open-source 3D printers',
      'Rapid prototyping',
      'Additive manufacturing',
      'Open-source hardware',
      'Manufacturing cooperative'
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': 'https://3d3d.ca/#website',
    url: 'https://3d3d.ca',
    name: '3D3D Cooperative',
    description: 'Founder-operated 3D printing and custom fabrication cooperative. Marine, automotive, prototyping. Atlantic Canada based, ships worldwide.',
    publisher: { '@id': 'https://3d3d.ca/#organization' },
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: 'https://3d3d.ca/blog?q={search_term_string}' },
      'query-input': 'required name=search_term_string',
    },
  },
];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#111214" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
<meta name="author" content={articleAuthor ?? '3D3D'} />
{keywords && <meta name="keywords" content={keywords} />}
<link rel="canonical" href={canonicalURL} />

<!-- RSS Feed Discovery -->
<link rel="alternate" type="application/rss+xml" title="3D3D Blog" href="/rss.xml" />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content={ogType} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="3D3D" />
<meta property="og:locale" content="en_CA" />
{isArticle && articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
{isArticle && articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
{isArticle && articleAuthor && <meta property="article:author" content={articleAuthor} />}
{isArticle && articleSection && <meta property="article:section" content={articleSection} />}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@3d3dcanada" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Favicons -->
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Global Structured Data: Organization + WebSite -->
<script type="application/ld+json" set:html={JSON.stringify(globalSchemas)} />

<!-- Page-specific Structured Data -->
{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}

