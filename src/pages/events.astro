---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EventSeries',
  name: '3D3D Events & Projects',
  description: 'On-location 3D printing at races, builds, and community events across Atlantic Canada and beyond.',
  organizer: {
    '@type': 'Organization',
    name: '3D3D',
    url: 'https://3d3d.ca',
  },
  location: {
    '@type': 'Place',
    name: 'Atlantic Canada and beyond',
  },
};

const events = [
  {
    title: 'Newport-Bermuda Race 2026',
    date: 'Mid-June 2026',
    location: 'Newport RI to Bermuda',
    description: '3D printing hard-to-find parts aboard CSM the Mariner. On-boat fabrication, filmed start to finish.',
    status: 'Coming Up',
  },
  {
    title: 'Cardboard Construction Contest',
    date: 'Fredericton, NB',
    location: 'Exhibition grounds, Smyth Street',
    description: 'A hands-on cardboard building competition with 3D printed reinforcements.',
    status: 'Planning',
  },
];
---

<BaseLayout
  title="Events & Projects — 3D3D"
  description="On-location 3D printing at races, builds, and community events across Atlantic Canada and beyond."
  schema={schema}
  activePath="/events"
>
  <section class="page-section pt-8">
    <div class="surface-panel p-8 sm:p-10">
      <p class="eyebrow">Events</p>
      <h1 class="text-heading-xl mt-4">Events & Projects</h1>
      <p class="mt-4 text-body-lg" style="color: var(--color-text-secondary);">
        On-location 3D printing at races, builds, and community events.
      </p>
    </div>
  </section>

  <section class="page-section pt-0">
    <div class="grid gap-6 lg:grid-cols-2">
      {events.map((event) => (
        <article class="surface-panel p-6">
          <div class="flex items-center justify-between mb-3">
            <span class="eyebrow" style="font-size: 0.75rem;">{event.status}</span>
          </div>
          <h2 class="text-heading-lg">{event.title}</h2>
          <p class="mt-2 text-sm" style="color: var(--color-text-muted);">
            {event.date} — {event.location}
          </p>
          <p class="mt-3" style="color: var(--color-text-secondary);">{event.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="page-section pt-0 pb-16">
    <div class="surface-panel p-8 sm:p-10">
      <h2 class="text-heading-lg">Want 3D3D at your event?</h2>
      <p class="mt-3" style="color: var(--color-text-secondary);">
        From sailboat races to community builds, 3D3D brings on-location printing capabilities to events across Atlantic Canada and beyond.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/contact" class="btn btn-primary">Get in Touch</a>
      </div>
    </div>
  </section>
</BaseLayout>
