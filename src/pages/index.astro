---
import BaseLayout from '../layouts/BaseLayout.astro';
import SplashOrbit from '../components/SplashOrbit';
---

<BaseLayout
  title="3D3D"
  description="3D3D splash orbit. Explore the market, services, network, learning, and the story behind the platform."
  noFooter
  noSidebar
  noMobileCTA
  noFeedbackBlip
  bodyClass="splash-page"
>
  <section id="home" class="splash-home" data-section>
    <SplashOrbit client:load />
  </section>
</BaseLayout>
