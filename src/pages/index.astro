  <!-- ═══════════════════════════════════════════════════
       SCRIPTS
       ═══════════════════════════════════════════════════ -->
  <script is:inline>
    (() => {
      const drawer = document.getElementById('service-drawer');
      const content = document.getElementById('drawer-content');
      const triggers = Array.from(document.querySelectorAll('[data-drawer-trigger]'));

      if (!(drawer instanceof HTMLElement) || !(content instanceof HTMLElement) || triggers.length === 0) return;

      let closeTimer = 0;

      const closeDrawer = () => {
        drawer.dataset.open = 'false';
        document.body.classList.remove('drawer-open');
        window.clearTimeout(closeTimer);
        closeTimer = window.setTimeout(() => {
          drawer.hidden = true;
          content.innerHTML = '';
        }, 320);
      };

      const openDrawer = (templateId) => {
        const template = document.getElementById(templateId);
        if (!(template instanceof HTMLTemplateElement)) return;
        content.innerHTML = '';
        content.appendChild(template.content.cloneNode(true));
        drawer.hidden = false;
        window.requestAnimationFrame(() => {
          drawer.dataset.open = 'true';
          document.body.classList.add('drawer-open');
        });
      };

      triggers.forEach((trigger) => {
        const handler = () => {
          const id = trigger instanceof HTMLElement ? trigger.dataset.drawerId : null;
          if (id) openDrawer(id);
        };
        trigger.addEventListener('click', handler);
        trigger.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); }
        });
      });

      drawer.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-drawer-close]') : null;
        if (!target) return;
        closeDrawer();
      });

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && drawer.dataset.open === 'true') closeDrawer();
      });
    })();

    // Image lightbox for workshop cards
    (() => {
      const lightbox = document.getElementById('image-lightbox');
      const lbImg = document.getElementById('lightbox-img');
      const lbLabel = document.getElementById('lightbox-label');
      const lbNote = document.getElementById('lightbox-note');
      const triggers = Array.from(document.querySelectorAll('[data-lightbox]'));

      if (!lightbox || !lbImg || !lbLabel || !lbNote || triggers.length === 0) return;

      const closeLightbox = () => {
        lightbox.dataset.open = 'false';
        document.body.classList.remove('drawer-open');
        setTimeout(() => { lightbox.hidden = true; }, 280);
      };

      const openLightbox = (el) => {
        lbImg.src = el.dataset.lightboxSrc || '';
        lbImg.alt = el.dataset.lightboxLabel || '';
        lbLabel.textContent = el.dataset.lightboxLabel || '';
        lbNote.textContent = el.dataset.lightboxNote || '';
        lightbox.hidden = false;
        requestAnimationFrame(() => {
          lightbox.dataset.open = 'true';
          document.body.classList.add('drawer-open');
        });
      };

      triggers.forEach((t) => {
        t.addEventListener('click', () => openLightbox(t));
        t.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLightbox(t); }
        });
      });

      lightbox.addEventListener('click', (e) => {
        if (e.target.closest('[data-lightbox-close]')) closeLightbox();
      });

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lightbox.dataset.open === 'true') closeLightbox();
      });
    })();

    // Timeline modal triggers
    (() => {
      const triggers = Array.from(document.querySelectorAll('[data-timeline-modal]'));
      triggers.forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.timelineModal;
          const modal = id ? document.getElementById(id) : null;
          if (!modal) return;
          modal.hidden = false;
          requestAnimationFrame(() => {
            modal.dataset.open = 'true';
            document.body.classList.add('drawer-open');
          });
        });
      });

      document.querySelectorAll('.tm').forEach((modal) => {
        const close = () => {
          modal.dataset.open = 'false';
          document.body.classList.remove('drawer-open');
          setTimeout(() => { modal.hidden = true; }, 300);
        };
        modal.querySelectorAll('[data-timeline-modal-close]').forEach((el) => {
          el.addEventListener('click', close);
        });
        window.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && modal.dataset.open === 'true') close();
        });
      });
    })();

    // Typewriter effect for "I scan it. I model it. I build it."
    (() => {
      const lines = Array.from(document.querySelectorAll('[data-typewriter]'));
      if (lines.length === 0) return;
      let started = false;

      const runTypewriter = () => {
        if (started) return;
        started = true;
        lines.forEach((line, i) => {
          setTimeout(() => {
            line.classList.add('typing');
            line.addEventListener('animationend', () => {
              line.classList.remove('typing');
              line.classList.add('typed');
            }, { once: true });
          }, i * 700);
        });
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            runTypewriter();
            observer.disconnect();
          }
        });
      }, { threshold: 0.3 });

      observer.observe(lines[0].closest('.work-header') || lines[0]);
    })();
  </script>
</BaseLayout>

