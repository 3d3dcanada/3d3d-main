---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteCalculator from '../components/QuoteCalculator.tsx';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '3D3D Quote Request',
  description: 'Upload files, describe your part, and send a structured custom 3D printing request to 3D3D.',
  url: 'https://3d3d.ca/quote',
  applicationCategory: 'BusinessApplication',
};
---

<BaseLayout title="Get a Quote | 3D3D" description="Request a custom 3D print quote. Upload your design or describe what you need." schema={schema} activePath="/quote">
  <main class="hp-home">

    <!-- Section 1: Hero -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/workshop/printer-action-cf.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Services', href: '/contact'}, {label: 'Get a Quote'}]} />
            <p class="hp-card__eyebrow mt-4">Project Intake</p>
            <h1 class="hp-card__title mt-2 mb-4">Upload a File. Get a Firm Quote.</h1>
            <p class="hp-card__copy hp-card__copy--lead">
              Submit your CAD file or replacement part photos. Tell us what it does and the environment it lives in. We assess the mechanics, select the material, and return a firm quote within 24 hours.
            </p>
            
            <div class="flex flex-col gap-2 mt-6">
              <span class="text-white text-sm flex items-center gap-2">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-400"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                Direct operator contact — no middleman.
              </span>
              <span class="text-white text-sm flex items-center gap-2">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-400"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                Exact pricing based on machine hours + material.
              </span>
              <span class="text-white text-sm flex items-center gap-2">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-teal-400"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                100% functional guarantee.
              </span>
            </div>

            <div class="hp-card__cta-row hp-card__cta-row--start mt-8">
              <a href="#quote-engine" class="hp-cta hp-cta--accent">Start Quote Engine</a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 2: React Engine -->
    <section id="quote-engine" class="hp-section" style="--section-accent: #e84a8a; min-height: 100svh;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/software-03.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim" style="background: rgba(17, 18, 20, 0.85);"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <div class="w-full max-w-4xl mx-auto py-12 relative z-10">
          <QuoteCalculator client:load />  
        </div>
      </div>
    </section>

    <!-- Section 3: Next Actions -->
    <section class="hp-section" style="--section-accent: #40c4c4;">
      <div class="hp-section__bg">
        <div class="hp-section__bg-img hp-section__bg-img--active" style="background-image: url('/media/generated/fab-01.jpg'); background-position: center;"></div>
      </div>
      <div class="hp-section__vignette"></div>
      <div class="hp-section__scrim"></div>
      <div class="hp-section__grain"></div>

      <div class="hp-section__shell hp-section__shell--start"> 
        <article class="hp-card">
          <div class="hp-card__inner">
            <PageNextActions actions={[
              {label: 'Materials Guide', href: '/materials', description: 'Compare engineering compounds by environment and performance.', accent: 'teal'},
              {label: 'Book a Call', href: '/book', description: 'Talk through your project directly with Ken.', accent: 'magenta'},
            ]} />
          </div>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .hp-card__copy {
    color: var(--color-text-secondary);
  }
</style>
