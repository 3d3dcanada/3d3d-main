---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';

/**
 * Prusa pricing as of March 2026.
 * Base: Prusa.com CAD prices.
 * 3D3D markup: ~10-15% for professional setup, calibration, 100 preset prints,
 * first-print walkthrough, and ongoing WhatsApp support.
 *
 * We do NOT drop ship. We support our clients.
 */
const printers = [
  {
    name: 'Prusa CORE One+',
    slug: 'core-one-plus',
    tag: 'Flagship',
    tagColor: '#40C4C4',
    desc: 'Fully enclosed CoreXY. Input shaping, active chamber heating, open-source firmware. The machine that made Prusa fast and reliable.',
    specs: ['CoreXY · 250 mm/s', 'Enclosed + active heating', '250 × 210 × 220 mm'],
    variants: [
      { label: 'Kit', cad: 1599 },
      { label: 'Assembled', cad: 2099 },
    ],
  },
  {
    name: 'Prusa CORE One+ Ultimate',
    slug: 'core-one-plus-ultimate',
    tag: 'Ultimate',
    tagColor: '#E84A8A',
    desc: 'Everything the CORE One+ offers, with the complete upgrade package pre-installed. Hardened nozzle, filament sensor, and more — ready for engineering materials out of the box.',
    specs: ['Full upgrade package', 'Hardened nozzle included', 'Engineering-ready'],
    variants: [
      { label: 'Kit', cad: 2249 },
      { label: 'Assembled', cad: 2749 },
    ],
  },
  {
    name: 'Prusa CORE One L',
    slug: 'core-one-l',
    tag: 'Large Format',
    tagColor: '#FA6831',
    desc: 'Everything the CORE One+ does, at scale. Full enclosure, active heating, CoreXY speed. Monolithic parts that used to require splitting.',
    specs: ['Large build volume', 'Active chamber heating', 'CoreXY motion'],
    variants: [
      { label: 'Assembled', cad: 2899 },
    ],
    note: 'High demand — 4-5 week lead time',
  },
  {
    name: 'Original Prusa MK4S',
    slug: 'mk4s',
    tag: 'Workhorse',
    tagColor: '#F5A623',
    desc: 'The most proven 3D printer in the world. Nextruder, input shaping, PrusaConnect. Millions of print hours across tens of thousands of shops worldwide.',
    specs: ['Nextruder + quick-swap nozzle', 'Input shaping + pressure advance', '250 × 210 × 220 mm'],
    variants: [
      { label: 'Kit', cad: 1149 },
      { label: 'Assembled', cad: 1599 },
    ],
  },
  {
    name: 'Original Prusa MINI+',
    slug: 'mini-plus',
    tag: 'Compact',
    tagColor: '#40C4C4',
    desc: 'The most affordable way into the Prusa ecosystem. Compact, reliable, same firmware quality and community. Desk-friendly.',
    specs: ['180 × 180 × 180 mm', 'PrusaConnect compatible', 'Full PrusaSlicer support'],
    variants: [
      { label: 'Kit', cad: 899 },
      { label: 'Semi-assembled', cad: 899 },
    ],
  },
  {
    name: 'Original Prusa XL',
    slug: 'xl',
    tag: 'Multi-Tool',
    tagColor: '#9B59B6',
    desc: 'Up to five independent toolheads. CoreXY, fully enclosed, segmented heatbed. The production multi-material platform.',
    specs: ['1-5 toolheads', '360 × 360 × 360 mm', 'Segmented heatbed'],
    variants: [],
    contactForPrice: true,
  },
];
---

<BaseLayout
  title="Prusa 3D Printers — Buy from 3D3D | Setup & Support Included"
  description="Buy Prusa 3D printers from 3D3D. Professional setup, 100 preset prints, first-print walkthrough, and ongoing support. We deliver it ready to print."
  activePath="/prusa"
>
  <!-- Hero — clean, short -->
  <section class="prusa-hero">
    <div class="prusa-shell">
      <Breadcrumbs items={[{label: 'Home', href: '/'}, {label: 'Prusa'}]} />
      <div class="prusa-hero__content">
        <p class="prusa-eyebrow">Prusa Printers</p>
        <h1 class="prusa-title">
          Set Up. Calibrated.<br />
          <span class="prusa-title--accent">Ready to Print.</span>
        </h1>
        <p class="prusa-lead">
          We sell Prusa printers with full service included. Every machine is assembled, calibrated, loaded with 100 ready-to-print models, and supported by us directly. You're never on your own.
        </p>
      </div>
    </div>
  </section>

  <!-- Printer Catalog -->
  <section id="lineup" class="prusa-catalog">
    <div class="prusa-shell">
      <div class="prusa-grid">
        {printers.map((p) => (
          <article class="printer-card">
            <div class="printer-card__head">
              <span class="printer-card__tag" style={`color: ${p.tagColor}; border-color: ${p.tagColor}40`}>{p.tag}</span>
              <h2 class="printer-card__name">{p.name}</h2>
              <p class="printer-card__desc">{p.desc}</p>
            </div>

            <ul class="printer-card__specs">
              {p.specs.map((s) => (
                <li>{s}</li>
              ))}
            </ul>

            <div class="printer-card__pricing">
              {p.contactForPrice ? (
                <a href="/contact?subject=prusa-xl" class="printer-card__price-cta">Contact for pricing &rarr;</a>
              ) : (
                <>
                  {p.variants.map((v) => (
                    <div class="printer-card__variant">
                      <span class="printer-card__variant-label">{v.label}</span>
                      <span class="printer-card__variant-price">CA${v.cad.toLocaleString()}</span>
                    </div>
                  ))}
                </>
              )}
              {p.note && <span class="printer-card__note">{p.note}</span>}
            </div>

            {!p.contactForPrice && (
              <a href={`/contact?subject=prusa-${p.slug}`} class="printer-card__cta">Order this printer &rarr;</a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Service strip — what's included -->
  <section class="prusa-service">
    <div class="prusa-shell">
      <h2 class="prusa-service__title">Every Printer Includes</h2>
      <div class="prusa-service__grid">
        <div class="prusa-service__item">
          <strong>Assembly & Calibration</strong>
          <p>Kits are fully assembled. Every axis calibrated, every parameter dialled in.</p>
        </div>
        <div class="prusa-service__item">
          <strong>100 Preset Prints</strong>
          <p>Ready-to-print models on an SD card. Practical items, tools, test objects. Print on day one.</p>
        </div>
        <div class="prusa-service__item">
          <strong>First Print Walkthrough</strong>
          <p>In person or remote video call. We walk you through everything. No experience required.</p>
        </div>
        <div class="prusa-service__item">
          <strong>Ongoing Support</strong>
          <p>WhatsApp us anytime. Clogged nozzle, weird first layer, filament questions — we help.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Accessory kit recommendation -->
  <section class="prusa-accessory">
    <div class="prusa-shell">
      <div class="prusa-accessory__card">
        <div class="prusa-accessory__icon">🔧</div>
        <div class="prusa-accessory__content">
          <h3 class="prusa-accessory__title">We Recommend Adding the Accessory & Repair Kit</h3>
          <p class="prusa-accessory__text">
            Not because Prusa printers break down — they don't. But having spare nozzles, PTFE tubing, lubricant, and essential tools on hand means you're never waiting for parts when you want to keep printing. It's peace of mind from day one.
          </p>
          <a href="/contact?subject=accessory-kit" class="prusa-accessory__link">Ask about the kit &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Brief note -->
  <section class="prusa-note">
    <div class="prusa-shell">
      <p class="prusa-note__text">
        Prusa believes in 3D3D. We're sponsored by Prusa Research and we run their machines every single day. Our pricing reflects real service — assembly, calibration, support, and the confidence that your printer works from the moment you unbox it. <strong>We don't race to the bottom. We focus on service.</strong>
      </p>
      <div class="prusa-note__actions">
        <a href="/contact" class="prusa-cta">Order a Prusa &rarr;</a>
        <a href="https://wa.me/15069532678" target="_blank" rel="noopener" class="prusa-cta prusa-cta--ghost">WhatsApp us &rarr;</a>
      </div>
    </div>
  </section>

  <div class="prusa-shell" style="padding-bottom: clamp(3rem, 5vw, 4rem);">
    <PageNextActions actions={[
      {label: 'Materials Guide', href: '/materials', description: 'See all materials compatible with the Prusa ecosystem.', accent: 'teal'},
      {label: 'Get a Quote', href: '/quote', description: 'Order a custom print on Prusa hardware.', accent: 'orange'},
    ]} />
  </div>
</BaseLayout>

<style>
  /* ─── Shared ─── */
  .prusa-shell {
    width: min(100% - clamp(1.5rem, 4vw, 4rem), 1200px);
    margin: 0 auto;
  }

  .prusa-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #FA6831;
  }

  .prusa-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.2rem;
    padding: 0.85rem 1.5rem;
    background: #FA6831;
    color: #FFFFFF;
    border: 2px solid transparent;
    border-radius: 4px;
    font-family: var(--font-tech);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 24px rgba(250, 104, 49, 0.2);
  }
  .prusa-cta:hover {
    background: #e85a25;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(250, 104, 49, 0.35);
  }
  .prusa-cta--ghost {
    background: transparent;
    color: #FA6831;
    border-color: rgba(250, 104, 49, 0.3);
    box-shadow: none;
  }
  .prusa-cta--ghost:hover {
    background: rgba(250, 104, 49, 0.08);
    box-shadow: none;
  }

  /* ─── Entrance animations ─── */
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: scale(1); }
  }

  /* ─── Hero ─── */
  .prusa-hero {
    display: flex;
    align-items: center;
    min-height: 50svh;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(250, 104, 49, 0.12), transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(64, 196, 196, 0.06), transparent 50%),
      #FAFBFC;
    color: #1A1A1A;
    padding-block: clamp(5rem, 8vw, 8rem);
  }

  .prusa-hero__content {
    max-width: 700px;
    display: grid;
    gap: 1.2rem;
    animation: slide-up 0.6s ease-out both;
  }

  .prusa-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 3.5vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #1A1A1A;
  }

  .prusa-title--accent {
    color: #FA6831;
  }

  .prusa-lead {
    margin: 0;
    font-size: clamp(0.95rem, 0.9rem + 0.3vw, 1.1rem);
    line-height: 1.65;
    color: #555555;
    max-width: 540px;
  }

  /* ─── Catalog Grid ─── */
  .prusa-catalog {
    background: #FFFFFF;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .prusa-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  /* ─── Printer Card ─── */
  .printer-card {
    display: flex;
    flex-direction: column;
    background: #FAFBFC;
    border: 1px solid rgba(26, 26, 26, 0.06);
    border-radius: 16px;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
    animation: scale-in 0.5s ease-out both;
  }

  .printer-card:nth-child(1) { animation-delay: 0.1s; }
  .printer-card:nth-child(2) { animation-delay: 0.18s; }
  .printer-card:nth-child(3) { animation-delay: 0.26s; }
  .printer-card:nth-child(4) { animation-delay: 0.34s; }
  .printer-card:nth-child(5) { animation-delay: 0.42s; }
  .printer-card:nth-child(6) { animation-delay: 0.50s; }

  .printer-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(250, 104, 49, 0.1);
    border-color: rgba(250, 104, 49, 0.2);
  }

  .printer-card__head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .printer-card__tag {
    display: inline-flex;
    width: fit-content;
    padding: 0.2rem 0.6rem;
    border: 1px solid;
    border-radius: 3px;
    font-family: var(--font-tech);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .printer-card__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1rem + 0.6vw, 1.5rem);
    font-weight: 800;
    line-height: 1.15;
    color: #1A1A1A;
  }

  .printer-card__desc {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: #666666;
  }

  .printer-card__specs {
    list-style: none;
    padding: 0;
    margin: 0 0 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border-top: 1px solid rgba(26, 26, 26, 0.06);
    padding-top: 1rem;
  }

  .printer-card__specs li {
    font-family: var(--font-tech);
    font-size: 0.74rem;
    color: #444444;
    letter-spacing: 0.02em;
  }

  .printer-card__specs li::before {
    content: '+ ';
    color: #FA6831;
    font-weight: 700;
  }

  .printer-card__pricing {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(26, 26, 26, 0.06);
  }

  .printer-card__variant {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .printer-card__variant-label {
    font-family: var(--font-tech);
    font-size: 0.72rem;
    color: #666666;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .printer-card__variant-price {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    color: #1A1A1A;
  }

  .printer-card__note {
    font-size: 0.7rem;
    color: #E84A8A;
    font-weight: 600;
  }

  .printer-card__price-cta {
    font-family: var(--font-tech);
    font-size: 0.78rem;
    font-weight: 700;
    color: #FA6831;
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: color 0.2s;
  }
  .printer-card__price-cta:hover {
    color: #e85a25;
  }

  .printer-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.2rem;
    padding: 0.7rem 1.2rem;
    background: #FA6831;
    color: #FFFFFF;
    border-radius: 4px;
    font-family: var(--font-tech);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .printer-card__cta:hover {
    background: #e85a25;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(250, 104, 49, 0.25);
  }

  /* ─── Service Strip ─── */
  .prusa-service {
    background:
      radial-gradient(ellipse at 70% 30%, rgba(250, 104, 49, 0.06), transparent 50%),
      #F6F2EE;
    color: #1A1A1A;
    padding-block: clamp(3rem, 5vw, 4rem);
    border-top: 3px solid #FA6831;
  }

  .prusa-service__title {
    margin: 0 0 1.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1rem + 1vw, 1.8rem);
    font-weight: 800;
    color: #1A1A1A;
    animation: slide-up 0.5s ease-out both;
  }

  .prusa-service__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .prusa-service__item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    background: #FFFFFF;
    border-radius: 12px;
    padding: 1.2rem;
    border: 1px solid rgba(250, 104, 49, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    animation: scale-in 0.5s ease-out both;
  }

  .prusa-service__item:nth-child(1) { animation-delay: 0.1s; }
  .prusa-service__item:nth-child(2) { animation-delay: 0.2s; }
  .prusa-service__item:nth-child(3) { animation-delay: 0.3s; }
  .prusa-service__item:nth-child(4) { animation-delay: 0.4s; }

  .prusa-service__item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(250, 104, 49, 0.08);
  }

  .prusa-service__item strong {
    font-family: var(--font-tech);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #FA6831;
  }

  .prusa-service__item p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: #666666;
  }

  /* ─── Accessory Kit ─── */
  .prusa-accessory {
    background: #FFFFFF;
    padding-block: clamp(2rem, 4vw, 3rem);
  }

  .prusa-accessory__card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background:
      linear-gradient(135deg, rgba(64, 196, 196, 0.06), rgba(250, 104, 49, 0.04));
    border: 1px solid rgba(64, 196, 196, 0.15);
    border-radius: 16px;
    padding: clamp(1.5rem, 3vw, 2rem);
    animation: slide-up 0.5s ease-out both;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .prusa-accessory__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(64, 196, 196, 0.1);
  }

  .prusa-accessory__icon {
    font-size: 2rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .prusa-accessory__content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prusa-accessory__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.9rem + 0.4vw, 1.2rem);
    font-weight: 800;
    color: #1A1A1A;
  }

  .prusa-accessory__text {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: #555555;
  }

  .prusa-accessory__link {
    font-family: var(--font-tech);
    font-size: 0.76rem;
    font-weight: 700;
    color: #40C4C4;
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: color 0.2s, letter-spacing 0.2s;
  }

  .prusa-accessory__link:hover {
    color: #2da8a8;
    letter-spacing: 0.1em;
  }

  /* ─── Note ─── */
  .prusa-note {
    background:
      radial-gradient(ellipse at 50% 50%, rgba(250, 104, 49, 0.05), transparent 60%),
      #FAFBFC;
    color: #1A1A1A;
    padding-block: clamp(3rem, 5vw, 4rem);
    text-align: center;
    animation: fade-in 0.6s ease-out both;
  }

  .prusa-note__text {
    margin: 0 auto 1.5rem;
    max-width: 640px;
    font-size: 0.92rem;
    line-height: 1.65;
    color: #555555;
  }

  .prusa-note__text strong {
    color: #FA6831;
  }

  .prusa-note__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .prusa-hero__content,
    .printer-card,
    .prusa-service__title,
    .prusa-service__item,
    .prusa-accessory__card,
    .prusa-note {
      animation: none;
    }
  }

  /* ─── Mobile ─── */
  @media (max-width: 767px) {
    .prusa-grid {
      grid-template-columns: 1fr;
    }
    .prusa-accessory__card {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
