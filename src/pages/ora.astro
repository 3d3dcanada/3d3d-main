---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageNextActions from '../components/PageNextActions.astro';
import OraCodeTabs from '../components/OraCodeTabs';
import OraRaven from '../components/OraRaven';
import OraTrustStats from '../components/OraTrustStats';
import {
  ORA_CONSTITUTION,
  ORA_MCP_TOOLS,
  ORA_PRICING,
  ORA_PRODUCT_FAMILY,
  ORA_TECH_STACK,
} from '../data/ora';
import {
  ORA_CODE_EXAMPLES,
  ORA_COMPETITOR_MATRIX,
  ORA_HERO_TERMINAL_LINES,
  ORA_PRICING_VIEWS,
  ORA_PROTOCOL_ARTICLE_INDEX,
  ORA_REPO_URL,
  ORA_TOOL_REQUESTS,
  ORA_TRUST_STATS,
  type ComparisonMark,
} from '../data/oraPresentation';

const heroWords = ['Sovereign', 'AI.', 'Constitutional', 'by', 'Design.'];
const installCommand = `git clone https://github.com/3d3dcanada/ora.git
cd ora/rust && cargo build --release
./target/release/ora serve`;

const pricingTierKeys = {
  'ORA Core': 'core',
  'ORA Pro': 'pro',
  'ORA Compute': 'compute',
  'ORA Enterprise': 'enterprise',
} as const;

const familyStatusCopy = {
  'ORA Core': { label: 'Live', tone: 'live' },
  'ORA Browser': { label: 'In development', tone: 'build' },
  PulZ: { label: 'Live — AGPL-3.0', tone: 'live' },
} as const;

const toolIcons: Record<
  string,
  { label: string; paths: string[]; fills?: string[]; circles?: { cx: string; cy: string; r: string }[] }
> = {
  verified_answer: {
    label: 'Shield',
    paths: ['M12 3l7 3v5c0 5-3.1 8.6-7 10-3.9-1.4-7-5-7-10V6l7-3z', 'M9.2 12.3l1.9 1.9 3.7-4.1'],
  },
  grounded_summarize: {
    label: 'Stacked documents',
    paths: ['M6 5.5h12', 'M6 10.5h12', 'M6 15.5h8', 'M4.5 3.5h15v17h-15z'],
  },
  memory_search: {
    label: 'Memory core',
    paths: [
      'M12 6.5a5.5 5.5 0 110 11 5.5 5.5 0 010-11z',
      'M12 3v2.2',
      'M12 18.8V21',
      'M3 12h2.2',
      'M18.8 12H21',
      'M6.1 6.1l1.6 1.6',
      'M16.3 16.3l1.6 1.6',
    ],
  },
  safe_browser_task: {
    label: 'Eye',
    paths: ['M2.5 12s3.3-6 9.5-6 9.5 6 9.5 6-3.3 6-9.5 6-9.5-6-9.5-6z', 'M12 9.2a2.8 2.8 0 110 5.6 2.8 2.8 0 010-5.6z'],
  },
  approval_queue: {
    label: 'Lock',
    paths: ['M7 10V8a5 5 0 0110 0v2', 'M6 10.5h12v9H6z', 'M12 14v2.8'],
  },
  evidence_bundle: {
    label: 'Package',
    paths: ['M4 8.5l8-4 8 4-8 4-8-4z', 'M4 8.5v7l8 4 8-4v-7', 'M12 12.5v7'],
  },
  create_mission: {
    label: 'Target',
    paths: ['M12 4v4', 'M12 16v4', 'M4 12h4', 'M16 12h4', 'M12 7.5a4.5 4.5 0 110 9 4.5 4.5 0 010-9z', 'M12 10.7a1.3 1.3 0 110 2.6 1.3 1.3 0 010-2.6z'],
  },
  list_missions: {
    label: 'Checklist',
    paths: ['M8.5 7.5h8', 'M8.5 12h8', 'M8.5 16.5h8', 'M5.4 7.5l1.2 1.2 2-2.3', 'M5.4 12l1.2 1.2 2-2.3', 'M5.4 16.5l1.2 1.2 2-2.3'],
  },
};

const getRomanNumeral = (value: number) => {
  const numerals = [
    [10, 'X'],
    [9, 'IX'],
    [5, 'V'],
    [4, 'IV'],
    [1, 'I'],
  ] as const;

  let remainder = value;
  let result = '';

  for (const [amount, symbol] of numerals) {
    while (remainder >= amount) {
      result += symbol;
      remainder -= amount;
    }
  }

  return result;
};

const getMarkLabel = (mark: ComparisonMark) => {
  switch (mark) {
    case 'yes':
      return { glyph: 'Yes', detail: 'Included' };
    case 'partial':
      return { glyph: 'Partial', detail: 'Configurable' };
    default:
      return { glyph: 'No', detail: 'Not included' };
  }
};

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'ORA',
    alternateName: 'ORA Sovereign AI Runtime',
    description:
      'Sovereign AI runtime built in Rust with constitutional governance, 8 MCP tools, evidence-based reasoning, and durable memory. Local-first, provider-agnostic.',
    url: 'https://3d3d.ca/ora',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Linux, macOS, Windows',
    programmingLanguage: 'Rust',
    softwareRequirements: 'Rust toolchain, LiteLLM (optional)',
    author: { '@type': 'Organization', name: '3D3D Atlantic Cooperative', url: 'https://3d3d.ca' },
    offers: [
      { '@type': 'Offer', name: 'ORA Core', price: '0', priceCurrency: 'CAD', description: 'Free and open source' },
      { '@type': 'Offer', name: 'ORA Pro', price: '19', priceCurrency: 'CAD', description: 'Managed cloud instance' },
    ],
    keywords: 'sovereign AI, MCP server, constitutional AI, local AI runtime, AI governance, Rust AI, Odin Protocol',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'odin-labs.ai',
    description: 'A 50-50 cooperation initiative toward sovereign AI. Partnership between 3D3D Atlantic Cooperative and the open-source community.',
    url: 'https://odin-labs.ai',
  },
];
---

<BaseLayout
  title="ORA - Sovereign AI Runtime | Constitutional by Design"
  description="ORA is a Rust-built AI runtime with constitutional governance, 8 MCP tools, evidence-based reasoning, and durable memory. Local-first, provider-agnostic, sovereign by design. Created by 3D3D. Given life by odin-labs.ai."
  activePath="/ora"
  schema={schema}
  accent="#4F46E5"
  bodyClass="ora-shell"
  noFeedbackBlip={true}
>
  <main class="hp-home ora-page" data-ora-page>
    <section class="ora-hero">
      <div class="ora-hero__mesh" aria-hidden="true"></div>
      <div class="ora-hero__grid" aria-hidden="true"></div>
      <div class="ora-hero__halo ora-hero__halo--indigo" aria-hidden="true"></div>
      <div class="ora-hero__halo ora-hero__halo--violet" aria-hidden="true"></div>

      <div class="ora-wrap ora-hero__inner">
        <div class="ora-hero__copy">
          <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'ORA' }]} />

          <p class="ora-eyebrow ora-hero__eyebrow">Sovereign AI Runtime</p>

          <h1 class="ora-hero__title" aria-label="Sovereign AI. Constitutional by Design.">
            {heroWords.map((word, index) => (
              <span class="ora-hero__word" style={`--ora-word-delay: ${index * 110}ms;`}>
                {word}
              </span>
            ))}
          </h1>

          <p class="ora-hero__lede">
            A governed AI runtime built in Rust: local-first, evidence-backed, and accountable to you. Other agent stacks ask you to trust the model. ORA asks the model to prove itself.
          </p>

          <div class="ora-brand-line">
            <span>Created by 3D3D</span>
            <span class="ora-brand-line__dot"></span>
            <span>Given life by odin-labs.ai</span>
          </div>

          <div class="ora-hero__actions">
            <a href={ORA_REPO_URL} target="_blank" rel="noreferrer" class="ora-button ora-button--primary" data-analytics-event="ora_repo_click" data-analytics-source="/ora">
              View the repo
            </a>
            <a href="#ora-pricing" class="ora-button ora-button--ghost">
              Explore pricing
            </a>
            <a href="#ora-waitlist" class="ora-button ora-button--secondary">
              Join the waitlist
            </a>
          </div>

          <div class="ora-proof-strip">
            <span>Rust runtime</span>
            <span>Provider-agnostic</span>
            <span>8 MCP tools</span>
            <span>Evidence required</span>
          </div>
        </div>

        <div class="ora-hero__stage">
          <div class="ora-raven-hero" aria-hidden="true">
            <div class="ora-raven-hero__bubble">Govern the model. Keep the proof.</div>
            <svg viewBox="0 0 120 120" class="ora-raven-hero__svg">
              <defs>
                <linearGradient id="ora-raven-wing" x1="0%" x2="100%" y1="0%" y2="100%">
                  <stop offset="0%" stop-color="#818CF8"></stop>
                  <stop offset="100%" stop-color="#4F46E5"></stop>
                </linearGradient>
              </defs>
              <ellipse cx="60" cy="68" rx="28" ry="31" fill="url(#ora-raven-wing)" opacity="0.96"></ellipse>
              <path d="M33 61Q18 45 14 63q6 10 19 9z" fill="#312E81"></path>
              <path d="M87 61q15-16 19 2-6 10-19 9z" fill="#312E81"></path>
              <circle cx="60" cy="42" r="18" fill="#4F46E5"></circle>
              <path d="M60 48 53 55 67 55Z" fill="#D4A847"></path>
              <circle cx="51" cy="40" r="4.8" fill="#1E1B4B"></circle>
              <circle cx="69" cy="40" r="4.8" fill="#1E1B4B"></circle>
              <circle cx="51" cy="40" r="2.2" fill="#F4D06E"></circle>
              <circle cx="69" cy="40" r="2.2" fill="#F4D06E"></circle>
              <path d="M48 26q2-7 5 0" fill="#7C3AED"></path>
              <path d="M58 22q2-9 4 0" fill="#7C3AED"></path>
              <path d="M66 26q3-7 5 0" fill="#7C3AED"></path>
              <path d="M48 94q12 10 24 0" fill="none" stroke="#4338CA" stroke-width="3" stroke-linecap="round"></path>
            </svg>
          </div>

          <div class="ora-terminal-window">
            <div class="ora-terminal-window__bar">
              <span class="ora-terminal-window__lights">
                <i></i><i></i><i></i>
              </span>
              <span>Terminal</span>
              <button class="ora-copy-button" type="button" data-copy={installCommand} data-copy-label="Copy install commands">
                Copy install
              </button>
            </div>

            <pre class="ora-terminal" aria-label="ORA startup output">
              {ORA_HERO_TERMINAL_LINES.map((line, index) => (
                <span
                  class:list={['ora-terminal__line', index === 0 && 'is-command']}
                  style={`--ora-line-delay: ${index * 340}ms; --ora-char-count: ${line.length};`}
                >
                  {line}
                </span>
              ))}
            </pre>
          </div>
        </div>
      </div>
    </section>

    <section class="ora-section ora-section--trust" id="trust">
      <div class="ora-wrap ora-section__inner ora-trust">
        <div class="ora-section__intro">
          <p class="ora-eyebrow">The trust problem</p>
          <h2 class="ora-heading">AI shipped faster than governance did.</h2>
          <p class="ora-copy">
            Enterprises now know the problem: hallucination is expensive, unverifiable answers do not survive audit, and black-box tool use kills deployment confidence. ORA is built to answer that exact gap.
          </p>

          <div class="ora-trust__reasons">
            <article class="ora-trust__reason">
              <h3>No evidence trail</h3>
              <p>Most agent stacks can tell you what they think, but not why they think it.</p>
            </article>
            <article class="ora-trust__reason">
              <h3>No sovereignty boundary</h3>
              <p>Prompts, context, and memory leak into someone else&apos;s infrastructure unless you control the runtime.</p>
            </article>
            <article class="ora-trust__reason">
              <h3>No operator checkpoint</h3>
              <p>Irreversible actions need human review. ORA treats approval as architecture, not etiquette.</p>
            </article>
          </div>
        </div>

        <OraTrustStats client:visible stats={ORA_TRUST_STATS} />
      </div>
    </section>

    <section class="ora-section ora-section--tools" id="ora-tools">
      <div class="ora-wrap">
        <div class="ora-section__intro ora-section__intro--center">
          <p class="ora-eyebrow">MCP tools</p>
          <h2 class="ora-heading">Eight governed tools. Zero blind trust.</h2>
          <p class="ora-copy">
            Hover or focus a tool to open the wire-format call it exposes. Copy the tool id, inspect the shape, and wire ORA into the client you already use.
          </p>
        </div>

        <div class="ora-tools-grid">
          {ORA_MCP_TOOLS.map((tool) => {
            const icon = toolIcons[tool.id];
            return (
              <article class="ora-tool-card" tabindex="0">
                <div class="ora-tool-card__top">
                  <div class="ora-tool-card__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      {icon.paths.map((path) => (
                        <path d={path} />
                      ))}
                    </svg>
                  </div>

                  <button class="ora-copy-chip" type="button" data-copy={tool.id} data-copy-label={`Copy ${tool.name} tool id`}>
                    <code>{tool.id}</code>
                  </button>
                </div>

                <h3>{tool.name}</h3>
                <p>{tool.description}</p>

                <div class="ora-tool-card__code">
                  <div class="ora-tool-card__code-head">
                    <span>Tool call</span>
                    <a href={ORA_REPO_URL} target="_blank" rel="noreferrer">
                      Try it
                    </a>
                  </div>
                  <pre><code>{ORA_TOOL_REQUESTS[tool.id]}</code></pre>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="ora-section ora-section--examples" id="ora-examples">
      <div class="ora-wrap">
        <div class="ora-section__intro">
          <p class="ora-eyebrow">See it in action</p>
          <h2 class="ora-heading">Show the request. Show the response. Show the proof.</h2>
          <p class="ora-copy">
            The fastest way to understand ORA is to look at the actual payloads: governed requests in, evidence-aware responses out.
          </p>
        </div>

        <OraCodeTabs client:visible examples={ORA_CODE_EXAMPLES} />
      </div>
    </section>

    <section class="ora-section ora-section--protocol" id="ora-protocol">
      <div class="ora-wrap">
        <div class="ora-section__intro">
          <p class="ora-eyebrow">The constitution</p>
          <h2 class="ora-heading">The Odin Protocol reads like law because it behaves like law.</h2>
          <p class="ora-copy">
            ORA boots with constitutional constraints already loaded. Prompts cannot supersede them. Operators cannot politely ignore them. The runtime can refuse work that violates the protocol.
          </p>
        </div>

        <div class="ora-protocol-card">
          <div class="ora-protocol-card__watermark" aria-hidden="true">
            <svg viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="45"></circle>
              <path d="M60 28 48 48h24z"></path>
              <path d="M42 72q18 16 36 0"></path>
            </svg>
          </div>

          <div class="ora-protocol-card__hero">
            <p>Protocol version 0.3.0</p>
            <span>27 articles. 8 chapters. Immutable principles.</span>
          </div>

          <div class="ora-protocol-grid">
            {ORA_CONSTITUTION.map((article) => (
              <article class="ora-article-card">
                <p class="ora-article-card__num">
                  Article {getRomanNumeral(article.article)}
                </p>
                <h3>{article.title}</h3>
                <p>{article.summary}</p>
              </article>
            ))}
          </div>

          <details class="ora-protocol-details">
            <summary>Read protocol outline from the runtime constitution</summary>
            <div class="ora-protocol-outline">
              {ORA_PROTOCOL_ARTICLE_INDEX.map((article) => (
                <div class="ora-protocol-outline__row">
                  <span>Article {getRomanNumeral(article.article)}</span>
                  <strong>{article.title}</strong>
                  <small>{article.chapter}</small>
                </div>
              ))}
            </div>
          </details>
        </div>
      </div>
    </section>

    <section class="ora-section ora-section--architecture" id="ora-architecture">
      <div class="ora-wrap ora-architecture">
        <div class="ora-section__intro">
          <p class="ora-eyebrow">Architecture</p>
          <h2 class="ora-heading">One runtime in the middle. Governance wrapped around every path.</h2>
          <p class="ora-copy">
            ORA sits between the user, the model provider, memory, evidence storage, and approval boundaries. That placement is the product: the runtime owns the rails, not the provider.
          </p>
        </div>

        <div class="ora-architecture__grid">
          <div class="ora-flow" data-ora-observe>
            <div class="ora-flow__row ora-flow__row--primary">
              <div class="ora-node ora-node--user">User</div>
              <span class="ora-flow__line ora-flow__line--horizontal"></span>
              <div class="ora-node">MCP Client</div>
              <span class="ora-flow__line ora-flow__line--horizontal"></span>
              <div class="ora-node ora-node--runtime">ORA Runtime</div>
            </div>

            <div class="ora-flow__branches">
              <div class="ora-flow__branch">
                <span class="ora-flow__line ora-flow__line--vertical"></span>
                <div class="ora-node ora-node--branch">Constitution Check</div>
              </div>
              <div class="ora-flow__branch">
                <span class="ora-flow__line ora-flow__line--vertical"></span>
                <div class="ora-node ora-node--branch">Evidence Bundle</div>
              </div>
              <div class="ora-flow__branch">
                <span class="ora-flow__line ora-flow__line--vertical"></span>
                <div class="ora-node ora-node--branch">Memory Store</div>
              </div>
              <div class="ora-flow__branch ora-flow__branch--approval">
                <span class="ora-flow__line ora-flow__line--vertical"></span>
                <div class="ora-node ora-node--branch">Approval Queue</div>
                <span class="ora-flow__line ora-flow__line--horizontal"></span>
                <div class="ora-node ora-node--human">Human</div>
              </div>
            </div>

            <div class="ora-flow__provider">
              <span class="ora-flow__line ora-flow__line--horizontal"></span>
              <div class="ora-node ora-node--provider">LLM Provider</div>
            </div>
          </div>

          <div class="ora-architecture__side">
            <div class="ora-terminal-window ora-terminal-window--install">
              <div class="ora-terminal-window__bar">
                <span class="ora-terminal-window__lights">
                  <i></i><i></i><i></i>
                </span>
                <span>Install ORA</span>
                <button class="ora-copy-button" type="button" data-copy={installCommand} data-copy-label="Copy ORA install commands">
                  Copy
                </button>
              </div>
              <pre class="ora-install"><code>{installCommand}</code></pre>
            </div>

            <div class="ora-stack-list">
              {ORA_TECH_STACK.map((item) => (
                <div class="ora-stack-list__row">
                  <span>{item.label}</span>
                  <strong>{item.value}</strong>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="ora-section ora-section--family" id="ora-family">
      <div class="ora-wrap">
        <div class="ora-section__intro">
          <p class="ora-eyebrow">Product family</p>
          <h2 class="ora-heading ora-heading--manifesto">One engine. Many vehicles.</h2>
          <p class="ora-copy">
            ORA Core is the runtime. ORA Browser brings governed web action. PulZ turns the same constitutional engine into business orchestration. Same rails, different surfaces.
          </p>
        </div>

        <div class="ora-roadmap">
          {ORA_PRODUCT_FAMILY.map((product) => {
            const status = familyStatusCopy[product.name as keyof typeof familyStatusCopy];
            return (
              <article class="ora-roadmap__item">
                <div class={`ora-roadmap__dot ora-roadmap__dot--${status?.tone ?? 'soon'}`}></div>
                <div class="ora-roadmap__card" style={`--roadmap-accent: ${product.accent};`}>
                  <div class="ora-roadmap__meta">
                    <p>{product.name}</p>
                    <span class={`ora-status-pill ora-status-pill--${status?.tone ?? 'soon'}`}>
                      {status?.label ?? 'Planned'}
                    </span>
                  </div>
                  <h3>{product.tagline}</h3>
                  <p>
                    {product.name === 'ORA Core' && 'Shipping today with governed answers, memory, approvals, and evidence bundles.'}
                    {product.name === 'ORA Browser' && 'Adding governed web browsing and task execution to the runtime.'}
                    {product.name === 'PulZ' && 'Using the same governance engine for business workflows and human approval gates.'}
                  </p>
                  {product.href && (
                    <a href={product.href} class="ora-inline-link">
                      Learn more
                    </a>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="ora-section ora-section--pricing" id="ora-pricing">
      <div class="ora-wrap">
        <div class="ora-section__intro">
          <p class="ora-eyebrow">Pricing</p>
          <h2 class="ora-heading">The runtime is free. Forever. No tricks.</h2>
          <p class="ora-copy">
            Start with self-hosted ORA Core. Add hosted layers only when you want managed infrastructure, cloud memory, or enterprise deployment support.
          </p>
        </div>

        <div class="ora-pricing-hero">
          {ORA_PRICING.map((tier) => {
            const tierKey = pricingTierKeys[tier.name as keyof typeof pricingTierKeys];
            const isCore = tier.name === 'ORA Core';
            const isEnterprise = tier.name === 'ORA Enterprise';
            return (
              <article class:list={['ora-price-card', isCore && 'ora-price-card--core', tier.isPrimary && 'ora-price-card--pro', isEnterprise && 'ora-price-card--enterprise']}>
                <div class="ora-price-card__header">
                  <div>
                    <p class="ora-price-card__name">{tier.name}</p>
                    <div class="ora-price-card__price">
                      <strong>{tier.price}</strong>
                      {tier.period && <span>{tier.period}</span>}
                    </div>
                  </div>
                  {isCore && <span class="ora-status-pill ora-status-pill--live">Free forever</span>}
                  {!isCore && tier.isPrimary && <span class="ora-status-pill ora-status-pill--build">Managed</span>}
                  {isEnterprise && <span class="ora-status-pill ora-status-pill--soon">Enterprise</span>}
                </div>

                <ul class="ora-price-card__features">
                  {tier.features.map((feature) => (
                    <li>{feature}</li>
                  ))}
                </ul>

                {isEnterprise ? (
                  <form
                    action="https://formspree.io/f/mldlydbl"
                    method="POST"
                    class="ora-enterprise-form"
                    data-analytics-submit="ora_enterprise_interest"
                    data-analytics-source="/ora"
                  >
                    <input type="hidden" name="_subject" value="ORA Enterprise" />
                    <input type="text" name="name" placeholder="Name" required />
                    <input type="email" name="email" placeholder="Work email" required />
                    <input type="text" name="company" placeholder="Company" />
                    <textarea name="message" rows="3" placeholder="Tell us about deployment, compliance, or governance needs."></textarea>
                    <button type="submit" class="ora-button ora-button--primary">Talk to us</button>
                  </form>
                ) : (
                  <a href={tier.cta.href} class="ora-button ora-button--secondary">
                    {tier.cta.label}
                  </a>
                )}

                <p class="ora-price-card__anchor">
                  {tierKey === 'core' && 'Best for builders who want the constitutional engine in their own environment.'}
                  {tierKey === 'pro' && 'Best for teams that want managed hosting without dropping governance.'}
                  {tierKey === 'compute' && 'Best for heavier workloads and GPU-backed execution paths.'}
                </p>
              </article>
            );
          })}
        </div>

        <div class="ora-pricing-view" data-pricing-root data-active-view="selfHosted">
          <div class="ora-pricing-view__switch">
            <button type="button" class="ora-toggle is-active" data-pricing-toggle data-view-key="selfHosted" aria-pressed="true">
              {ORA_PRICING_VIEWS.selfHosted.label}
            </button>
