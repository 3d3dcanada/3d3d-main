---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandSidebar from '../../components/BrandSidebar.tsx';
import {
  CATALOG,
  SOURCE_LABELS,
  getCatalogItemPurchaseOptions,
  getCatalogDefaultSelection,
  getCatalogItemStartingPrice,
  getCatalogItemHasPriceRange,
  getCatalogItemMaterialSummary,
  SHOP_CATEGORY_LABELS,
} from '../../lib/catalog';
import type { CatalogItem } from '../../lib/types';

export function getStaticPaths() {
  return CATALOG.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

interface Props {
  item: CatalogItem;
}

const { item } = Astro.props;
const { option: defaultOption, pricing: defaultPricing } = getCatalogDefaultSelection(item);
const purchaseOptions = getCatalogItemPurchaseOptions(item);
const startPrice = getCatalogItemStartingPrice(item);
const hasRange = getCatalogItemHasPriceRange(item);
const materialSummary = getCatalogItemMaterialSummary(item);
const sourceInfo = item.source ? SOURCE_LABELS[item.source] : null;
const categoryLabel = SHOP_CATEGORY_LABELS[item.category] ?? item.category;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: item.name,
  description: item.description,
  image: item.images,
  brand: { '@type': 'Brand', name: '3D3D Atlantic Cooperative' },
  offers: {
    '@type': 'Offer',
    price: startPrice,
    priceCurrency: 'CAD',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: '3D3D Atlantic Cooperative' },
  },
};

const sidebarNav = [
  {
    label: '3D3D',
    items: [
      { id: 'shop', label: 'Shop', href: '/shop' },
      { id: 'quote', label: 'Quote Calculator', href: '/quote' },
      { id: 'makers', label: 'Makers', href: '/makers' },
      { id: 'blog', label: 'Blog', href: '/blog' },
      { id: 'about', label: 'About', href: '/about' },
      { id: 'contact', label: 'Contact', href: '/contact' },
    ],
  },
];
---

<BaseLayout
  title={`${item.name} — 3D3D Print Shop`}
  description={item.seoDescription || item.description}
  schema={schema}
>
  <BrandSidebar slot="sidebar" client:load navGroups={sidebarNav} activePath="/shop" />

  <div class="pt-8 pl-0 lg:pl-4">
    {/* Breadcrumb */}
    <nav class="px-6 lg:px-12 py-4 bg-surface-primary" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 font-body text-xs uppercase tracking-wider text-text-muted">
        <li><a href="/shop" class="hover:text-teal-primary transition-colors">Shop</a></li>
        <li class="text-text-muted">/</li>
        <li class="text-text-secondary">{item.name}</li>
      </ol>
    </nav>

    <section class="px-6 lg:px-12 pb-16 bg-surface-primary">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10">

        {/* Gallery */}
        <div class="space-y-3">
          <div class="aspect-square rounded-2xl overflow-hidden relative product-gallery-main">
            {item.images[0] ? (
              <img
                src={item.images[0]}
                alt={item.name}
                class="w-full h-full object-cover"
                id="main-image"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="font-body text-xs text-text-muted uppercase tracking-widest">No image available</span>
              </div>
            )}
            <div class="absolute top-3 left-3 flex gap-1.5 flex-wrap">
              {sourceInfo && (
                <span class="badge" style={`background: ${sourceInfo.color};`}>
                  {sourceInfo.label}
                </span>
              )}
              {item.isNew && <span class="badge badge-magenta">New</span>}
              {item.isPopular && <span class="badge badge-teal">Popular</span>}
            </div>
          </div>
          {item.images.length > 1 && (
            <div class="grid grid-cols-4 gap-2">
              {item.images.slice(0, 4).map((img, i) => (
                <button
                  class="thumb-btn aspect-square rounded-xl overflow-hidden cursor-pointer transition-all duration-200"
                  data-src={img}
                  data-index={i}
                >
                  <img src={img} alt={`${item.name} view ${i + 1}`} class="w-full h-full object-cover" loading="lazy" decoding="async" />
                </button>
              ))}
            </div>
          )}
        </div>

        {/* Product details */}
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="font-body text-xs uppercase tracking-wider text-text-muted">{categoryLabel}</span>
            <span class="text-text-muted">/</span>
            <span class="font-body text-xs uppercase tracking-wider text-text-muted">{materialSummary}</span>
          </div>

          <h1 class="font-display text-2xl sm:text-3xl font-bold text-text-primary">{item.name}</h1>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">{item.description}</p>

          {item.makerNote && (
            <div class="mt-4 p-4 rounded-xl maker-note">
              <p class="font-body text-xs uppercase tracking-wider text-teal-primary mb-1 font-semibold">Maker Note</p>
              <p class="text-sm text-text-secondary">{item.makerNote}</p>
            </div>
          )}

          {/* Price */}
          <div class="mt-6 flex items-baseline gap-2">
            <span class="font-display text-3xl font-bold text-teal-primary">
              {hasRange ? 'From ' : ''}${startPrice.toFixed(2)}
            </span>
            <span class="font-body text-xs text-text-muted uppercase tracking-wider">CAD</span>
          </div>

          {/* Purchase options */}
          {purchaseOptions.length > 1 && (
            <div class="mt-6">
              <p class="font-body text-xs uppercase tracking-wider text-text-muted mb-2">Options</p>
              <div class="flex flex-wrap gap-2">
                {purchaseOptions.map((opt, i) => (
                  <button
                    class="option-btn px-4 py-2 rounded-lg text-sm font-medium transition-all"
                    data-default={opt.isDefault ? 'true' : 'false'}
                  >
                    {opt.label}
                  </button>
                ))}
              </div>
            </div>
          )}

          {/* Colors */}
          {item.colors.length > 0 && (
            <div class="mt-6">
              <p class="font-body text-xs uppercase tracking-wider text-text-muted mb-2">Colors</p>
              <div class="flex flex-wrap gap-2">
                {item.colors.map((color) => (
                  <span class="color-chip">
                    {color}
                  </span>
                ))}
              </div>
            </div>
          )}

          {/* Size presets */}
          {item.sizePresets && item.sizePresets.length > 0 && (
            <div class="mt-6">
              <p class="font-body text-xs uppercase tracking-wider text-text-muted mb-2">Sizes</p>
              <div class="flex flex-wrap gap-2">
                {item.sizePresets.map((preset) => (
                  <span class="color-chip">
                    {preset.label} ({preset.scale}×)
                  </span>
                ))}
              </div>
            </div>
          )}

          {/* Recommended settings */}
          {item.recommendedSettings && (
            <div class="mt-6">
              <p class="font-body text-xs uppercase tracking-wider text-text-muted mb-2">Recommended Print Settings</p>
              <div class="grid grid-cols-2 gap-2">
                <div class="setting-card">
                  <span class="block font-body text-[10px] uppercase tracking-widest text-text-muted">Layer</span>
                  <span class="text-sm text-text-primary font-medium">{item.recommendedSettings.layerHeight}mm</span>
                </div>
                <div class="setting-card">
                  <span class="block font-body text-[10px] uppercase tracking-widest text-text-muted">Infill</span>
                  <span class="text-sm text-text-primary font-medium">{item.recommendedSettings.infill}% {item.recommendedSettings.infillType}</span>
                </div>
                <div class="setting-card">
                  <span class="block font-body text-[10px] uppercase tracking-widest text-text-muted">Supports</span>
                  <span class="text-sm text-text-primary font-medium">{item.recommendedSettings.supports}</span>
                </div>
                <div class="setting-card">
                  <span class="block font-body text-[10px] uppercase tracking-widest text-text-muted">Walls</span>
                  <span class="text-sm text-text-primary font-medium">{item.recommendedSettings.walls}</span>
                </div>
              </div>
            </div>
          )}

          {/* CTA */}
          <div class="mt-8 flex gap-3">
            <a
              href={`/quote?product=${item.id}`}
              class="btn-primary flex-1 text-center py-3"
            >
              Get Custom Quote
            </a>
            <a
              href="mailto:info@3d3d.ca?subject=Order: {item.name}"
              class="btn-secondary px-5 py-3"
            >
              Contact
            </a>
          </div>

          {/* Specs */}
          <div class="mt-8 grid grid-cols-3 gap-3">
            <div class="spec-card">
              <span class="block font-display text-2xl font-bold text-teal-primary">{item.grams}g</span>
              <span class="font-body text-[10px] uppercase tracking-widest text-text-muted">Weight</span>
            </div>
            <div class="spec-card">
              <span class="block font-display text-2xl font-bold text-teal-primary">{item.hours}h</span>
              <span class="font-body text-[10px] uppercase tracking-widest text-text-muted">Print Time</span>
            </div>
            <div class="spec-card">
              <span class="block font-display text-2xl font-bold text-teal-primary">{item.colors.length}</span>
              <span class="font-body text-[10px] uppercase tracking-widest text-text-muted">Colors</span>
            </div>
          </div>

          {/* Tags */}
          {item.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-1.5">
              {item.tags.map((tag) => (
                <span class="tag-chip">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.thumb-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const main = document.getElementById('main-image') as HTMLImageElement;
      if (main && btn.dataset.src) {
        main.src = btn.dataset.src;
        document.querySelectorAll('.thumb-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
      }
    });
  });
</script>

<style>
  .product-gallery-main {
    background: var(--color-surface-tertiary);
    border: 1px solid var(--color-border-light);
  }
  
  .thumb-btn {
    background: var(--color-surface-tertiary);
    border: 2px solid var(--color-border-light);
    border-radius: 0.75rem;
  }
  
  .thumb-btn:hover,
  .thumb-btn.active {
    border-color: var(--color-teal-primary);
  }
  
  .thumb-btn:first-child {
    border-color: var(--color-teal-primary);
  }
  
  .maker-note {
    background: oklch(from var(--color-teal-primary) l c h / 0.08);
    border: 1px solid oklch(from var(--color-teal-primary) l c h / 0.2);
  }
  
  .option-btn {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-light);
    color: var(--color-text-secondary);
  }
  
  .option-btn:hover {
    border-color: var(--color-teal-light);
  }
  
  .option-btn[data-default='true'] {
    background: oklch(from var(--color-teal-primary) l c h / 0.12);
    border-color: oklch(from var(--color-teal-primary) l c h / 0.3);
    color: var(--color-teal-dark);
  }
  
  .color-chip {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-light);
    color: var(--color-text-primary);
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .setting-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border-light);
    padding: 0.625rem;
    border-radius: 0.5rem;
  }
  
  .spec-card {
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-light);
    text-align: center;
    padding: 0.75rem;
    border-radius: 0.75rem;
  }
  
  .tag-chip {
    background: var(--color-surface-card);
    color: var(--color-text-muted);
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .badge {
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: white;
  }
  
  .badge-magenta {
    background: var(--color-magenta-primary);
  }
  
  .badge-teal {
    background: var(--color-teal-primary);
    color: white;
  }
</style>
