  {
    label: 'WhatsApp',
    href: 'https://wa.me/15069532678',
    color: '#25D366',
    path: 'M17.5 14.4c-.3-.1-1.8-.9-2.1-1-.3-.1-.5-.1-.7.1-.2.2-.8 1-1 1.2-.2.2-.4.2-.7.1-1.9-.9-3.2-1.7-4.4-3.8-.3-.5 0-.5.3-1.5.1-.3 0-.5-.1-.7-.1-.2-.7-1.7-1-2.3-.2-.7-.5-.6-.7-.6h-.6c-.2 0-.5.1-.7.3-.2.3-1 1-1 2.3s1 2.6 1.1 2.8c.1.2 1.9 3 4.7 4.2 2.7 1.1 2.7.7 3.2.7.5-.1 1.7-.7 2-1.4.2-.7.2-1.3.1-1.4ZM12.1 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.6a10 10 0 1 0 5.2-18.4Z',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/3d3dca/',
