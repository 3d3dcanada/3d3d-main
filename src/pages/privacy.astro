---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandSidebar from '../components/BrandSidebar.tsx';

const sidebarTheme = {
  accent: '#00C4CC', accentDark: '#0891B2', bg: '#0D0E1A', bgAlt: '#141525',
  border: 'rgba(255,255,255,0.07)', text: '#E8E8F2', muted: '#7878A0', dimmed: '#4A4A6A', glow: 'rgba(0,196,204,0.3)',
};

const sidebarNav = [{
  label: '3D3D',
  items: [
    { id: 'shop', label: 'Shop', href: '/shop' },
    { id: 'about', label: 'About', href: '/about' },
    { id: 'contact', label: 'Contact', href: '/contact' },
  ],
}];
---

<BaseLayout title="Privacy Policy — 3D3D" description="How 3D3D Atlantic Cooperative collects, uses, and protects your personal information.">
  <BrandSidebar slot="sidebar" client:load navGroups={sidebarNav} theme={sidebarTheme} activePath="/privacy" />

  <div class="pt-16 pl-0 lg:pl-4">
    <section class="px-6 lg:px-12 py-12">
      <div class="max-w-3xl mx-auto">
        <p class="font-tech text-[10px] uppercase tracking-[0.25em] text-[#7878A0] mb-2">Legal</p>
        <h1 class="font-display text-3xl font-bold text-[#E8E8F2] mb-2">Privacy Policy</h1>
        <p class="font-tech text-xs text-[#4A4A6A] mb-8">Last updated: March 2026</p>

        <div class="space-y-6 text-sm leading-relaxed text-[#7878A0]">
          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">Information We Collect</h2>
            <p>When you place an order or submit a form, we collect: name, email address, shipping address, phone number (optional), and payment information. Payment data is processed by Stripe and never stored on our servers.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">How We Use Your Information</h2>
            <p>We use your information to: process and fulfill orders, communicate about your orders, route orders to the nearest qualified maker, improve our products and services, and send marketing communications (with your consent, per CASL).</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">Information Sharing</h2>
            <p>We share necessary order details (name, shipping address) with the maker fulfilling your order. We do not sell, rent, or trade your personal information. Third-party services we use: Formspree (form handling), Cloudflare (DNS and hosting), Vercel (hosting). Payment processors will be added when transactions are enabled.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">Data Retention</h2>
            <p>Order data is retained for 7 years for tax and legal compliance. You may request deletion of your personal data at any time by emailing info@3d3d.ca.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">Cookies</h2>
            <p>We use essential cookies for site functionality and analytics cookies (if consented). No third-party advertising cookies are used.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">Purpose Limitation</h2>
            <p>Your personal information will not be used for purposes other than those described above without your additional consent, except where required by law. This principle is established under PIPEDA (Principle 3 — Limiting Use, Disclosure, and Retention).</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">Your Rights</h2>
            <p>Under PIPEDA and applicable provincial legislation, you have the right to access, correct, and request deletion of your personal information. Access requests will be addressed within 30 days. Contact our Privacy Officer at <a href="mailto:info@3d3d.ca" class="text-[#00C4CC] hover:underline">info@3d3d.ca</a> for any privacy-related requests.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">Complaints</h2>
            <p>If you are not satisfied with our response to a privacy concern, you may file a complaint with the Office of the Privacy Commissioner of Canada at <a href="https://www.priv.gc.ca" class="text-[#00C4CC] hover:underline" target="_blank" rel="noopener noreferrer">priv.gc.ca</a> or by calling 1-800-282-1376.</p>
          </div>

          <div>
            <h2 class="font-display text-base font-semibold text-[#E8E8F2] mb-2">Privacy Officer</h2>
            <p>3D3D Atlantic Cooperative, Moncton, NB, Canada. Privacy Officer: <a href="mailto:info@3d3d.ca" class="text-[#00C4CC] hover:underline">info@3d3d.ca</a> · <a href="tel:+15069532678" class="text-[#00C4CC] hover:underline">506-953-2678</a>.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
