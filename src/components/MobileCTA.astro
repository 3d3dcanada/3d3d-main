  },
  {
    label: 'TikTok',
    href: 'https://www.tiktok.com/@3d3dcanada',
    color: '#F6F7FA',
    path: 'M14.5 2c.5 2 1.7 3.6 3.5 4.6 1.1.7 2.3 1 3.5 1v3.6c-1.8 0-3.7-.5-5.2-1.5v6.2a6 6 0 1 1-6-6c.3 0 .7 0 1 .1v3.7a2.5 2.5 0 1 0 1.5 2.3V2h1.7Z',
  },
  {
    label: 'YouTube',
    href: 'https://www.youtube.com/@3D3Dcanada',
    color: '#FF0000',
    path: 'M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8ZM9.6 15.9V8.1l6.8 3.9Z',
  },
  {
    label: 'Ko-fi',
    href: 'https://ko-fi.com/3d3dca',
    color: '#40C4C4',
    path: 'M20 3H4v10a4 4 0 0 0 4 4h6a4 4 0 0 0 4-4v-3h2a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zm0 5h-2V5h2v3zm-4 13H8v2h8v-2z',
  },
];
---

<nav class="mobile-social" aria-label="Social links">
  {socialLinks.map((link) => (
    <a
      href={link.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={link.label}
      class="mobile-social__link"
      style={`--link-color: ${link.color};`}
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d={link.path} />
      </svg>
      <span class="mobile-social__label">{link.label}</span>
    </a>
  ))}
</nav>

<style>
  .mobile-social {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-social {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 900;
      display: flex;
      align-items: center;
      justify-content: space-around;
      padding: 0.5rem 0.4rem;
      padding-bottom: calc(0.5rem + env(safe-area-inset-bottom, 0px));
      background: rgba(10, 11, 12, 0.95);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-top: 1px solid rgba(64, 196, 196, 0.15);
    }

    .mobile-social__link {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      padding: 0.35rem 0.5rem;
      border-radius: 2px;
      color: rgba(246, 247, 250, 0.7);
      text-decoration: none;
      transition: color 0.2s ease, background 0.2s ease;
      -webkit-tap-highlight-color: transparent;
    }

    .mobile-social__link:active {
      transform: scale(0.93);
      background: rgba(255, 255, 255, 0.06);
    }

    .mobile-social__link svg {
      width: 22px;
      height: 22px;
      color: var(--link-color, rgba(246, 247, 250, 0.7));
      transition: transform 0.2s ease;
    }

    .mobile-social__label {
      font-family: var(--font-tech);
      font-size: 0.52rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(246, 247, 250, 0.78);
    }

    /* Push page content above the bar */
    :global(body) {
      padding-bottom: calc(60px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>
