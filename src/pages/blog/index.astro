---

<BaseLayout title="Blog — 3D3D" description="Updates on 3D printing, materials, the Newport Bermuda campaign, sailing stories, and fabrication from Atlantic Canada." activePath="/blog">

  <div class="blog-index">
    <div class="blog-hero">
      <div class="blog-shell">
        <p class="blog-eyebrow">3D3D Blog</p>
        <h1 class="blog-title">Updates & Stories</h1>
        <p class="blog-intro">Fabrication, sailing, materials, campaign updates, and the things I've learned building 3D3D from nothing.</p>
      </div>
    </div>

    <div class="blog-shell blog-list">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="blog-card">
          <div class="blog-card__meta">
            <span class="blog-card__category">{post.category}</span>
            <span class="blog-card__dot">·</span>
            <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
            <span class="blog-card__dot">·</span>
            <span>{post.readTime}</span>
          </div>
          <h2 class="blog-card__title">{post.title}</h2>
          <p class="blog-card__excerpt">{post.excerpt}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-index {
    --page-accent: #40C4C4;
    --page-bg-dark: #111214;
  }

  .blog-hero {
    background: var(--page-bg-dark);
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3rem, 6vw, 4rem);
    color: #F6F7FA;
  }

  .blog-shell {
    width: min(calc(100% - 3rem), 900px);
    margin: 0 auto;
  }

  .blog-eyebrow {
    margin: 0;
    font-family: var(--font-tech);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--page-accent);
  }

  .blog-title {
    margin: 0.75rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 4vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: #F6F7FA;
  }

  .blog-intro {
    margin: 1rem 0 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(246, 247, 250, 0.72);
    max-width: 36rem;
  }

  .blog-list {
    display: grid;
    gap: 1rem;
    padding: clamp(2rem, 4vw, 3rem) 0 clamp(4rem, 6vw, 6rem);
  }

  .blog-card {
    display: grid;
    gap: 0.6rem;
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    border: 3px solid #1A1A1A;
    border-radius: 1rem;
    background: #FFFFFF;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(26, 26, 26, 0.1);
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-tech);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666666;
  }

  .blog-card__category {
    color: var(--page-accent);
  }

  .blog-card__dot {
    color: #CCC;
  }

  .blog-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 0.9rem + 0.5vw, 1.35rem);
    line-height: 1.15;
    color: #1A1A1A;
  }

  .blog-card__excerpt {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: #555;
  }

  @media (max-width: 640px) {
    .blog-shell {
      width: min(calc(100% - 1.5rem), 900px);
    }
  }
</style>
